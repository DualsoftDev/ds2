{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "DSPilot.Services": "Debug",
      "DSPilot.Repositories": "Debug"
    }
  },
  "AllowedHosts": "*",
  "DsPilot": {
    "AasxFilePath": "../DsCSV_0317.aasx"
  },
  "PlcDatabase": {
    "SourceDbPath": "sample/db/DsDB.sqlite3",
    "ReadIntervalMs": 1000,
    "SimulationMode": true,
    "TagMatchMode": "Address"
  },
  "DspDatabase": {
    "Path": "%APPDATA%/DSPilot/dsp.db",
    "AutoCreate": true,
    "RecreateOnStartup": false
  }
}
