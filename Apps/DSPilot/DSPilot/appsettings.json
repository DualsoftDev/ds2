{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "DSPilot.Services": "Debug",
      "DSPilot.Repositories": "Debug"
    }
  },
  "AllowedHosts": "*",
  "DsPilot": {
    "AasxFilePath": "../DsCSV_0318_C.aasx"
  },
  "ScanInterval": "00:00:00.1000000",
  "TagHistoric": {
    "WALBufferSize": 100,
    "FlushInterval": "00:00:01"
  },
  "IriPrefix": "http://your-company.com/",
  "LibraryPaths": [],
  "AasSettings": {
    "DangerouslyOverwriteAasxFile": false,
    "InjectNameplateSubmodule": false,
    "InjectDocumentationSubmodule": false,
    "PolicyOnMissingCritical": {
      "Case": "Fail"
    }
  },
  "DatabaseWatchdogIntervalSec": 5,
  "UseUtcTime": false,
  "EnableModelValidation": true,
  "LogLevel": "DEBUG",
  "Database": {
    "Type": "Sqlite",
    "ConnectionString": "Data Source=%APPDATA%/DualSoft/DSPilot/plc.db;Version=3;BusyTimeout=20000"
  },
  "DspTables": {
    "Enabled": true
  },
  "RedisSettings": {
    "ConnectionString": "localhost:6379",
    "MaxRetries": 3,
    "RetryDelayMs": 1000
  },
  "PlcDatabase": {
    "ReadIntervalMs": 100,
    "SimulationMode": false,
    "TagMatchMode": "Address"
  },
  "PlcCapture": {
    "Enabled": true,
    "PlcName": "MitsubishiPLC",
    "PlcIpAddress": "192.168.9.120",
    "PlcPort": 5555,
    "ScanIntervalMs": 100,
    "Protocol": "UDP"
  },
  "DspDatabase": {
    "Path": "%APPDATA%/DSPilot/dsp.db",
    "AutoCreate": true,
    "RecreateOnStartup": false
  },
  "PlcConnection": {
    "Enabled": true,
    "PlcName": "MitsubishiPLC",
    "IpAddress": "192.168.9.120",
    "ScanIntervalMs": 100,
    "TagAddresses": []
  },
  "Ui": {
    "ShowPlcDebug": false
  }
}