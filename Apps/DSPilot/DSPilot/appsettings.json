{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "DSPilot.Services": "Debug",
      "DSPilot.Repositories": "Debug"
    }
  },
  "AllowedHosts": "*",
  "DsPilot": {
    "AasxFilePath": "../DsCSV_0318_C.aasx"
  },
  "PlcDatabase": {
    "SourceDbPath": "sample/db/DsDB.sqlite3",
    "ReadIntervalMs": 1000,
    "SimulationMode": false,
    "TagMatchMode": "Address"
  },
  "DspDatabase": {
    "Path": "%APPDATA%/DSPilot/dsp.db",
    "AutoCreate": true,
    "RecreateOnStartup": false
  },
  "PlcConnection": {
    "Enabled": false,
    "PlcName": "PLC_01",
    "IpAddress": "192.168.0.100",
    "ScanIntervalMs": 100,
    "TagAddresses": [
      "Tag1",
      "Tag2",
      "Tag3"
    ]
  }
}
