<svg xmlns="http://www.w3.org/2000/svg"
     style="display: block; @Style"
     viewBox="0 0 @CanvasWidth @CanvasHeight"
     preserveAspectRatio="none"
     @onclick="OnBackgroundClicked" @onclick:stopPropagation>

    @* ── 공용 필터 ── *@
    <defs>
        <filter id="glass-blur" x="-10%" y="-10%" width="120%" height="120%">
            <feGaussianBlur in="SourceGraphic" stdDeviation="10" />
        </filter>
        <filter id="block-shadow" x="-10%" y="-10%" width="130%" height="130%">
            <feGaussianBlur in="SourceAlpha" stdDeviation="4" result="shadow" />
            <feOffset dx="0" dy="3" in="shadow" result="offsetShadow" />
            <feFlood flood-color="rgba(0,0,0,0.3)" result="color" />
            <feComposite in="color" in2="offsetShadow" operator="in" result="colorShadow" />
            <feMerge>
                <feMergeNode in="colorShadow" />
                <feMergeNode in="SourceGraphic" />
            </feMerge>
        </filter>
        <filter id="block-shadow-selected" x="-15%" y="-15%" width="140%" height="140%">
            <feGaussianBlur in="SourceAlpha" stdDeviation="8" result="shadow" />
            <feOffset dx="0" dy="6" in="shadow" result="offsetShadow" />
            <feFlood flood-color="rgba(0,0,0,0.45)" result="color" />
            <feComposite in="color" in2="offsetShadow" operator="in" result="colorShadow" />
            <feMerge>
                <feMergeNode in="colorShadow" />
                <feMergeNode in="SourceGraphic" />
            </feMerge>
        </filter>
        <filter id="selection-glow" x="-35%" y="-35%" width="170%" height="170%">
            <feGaussianBlur stdDeviation="10" />
        </filter>
        <linearGradient id="glass-overlay-grad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="white" stop-opacity="0.10" />
            <stop offset="40%" stop-color="white" stop-opacity="0.03" />
            <stop offset="100%" stop-color="white" stop-opacity="0" />
        </linearGradient>
    </defs>

    @* 도면 배경 *@
    <rect x="0" y="0" width="@CanvasWidth" height="@CanvasHeight" style="fill: var(--mud-palette-background, #f0f0f0)" />
    @if (!string.IsNullOrEmpty(ImagePath))
    {
        <image href="@(ImagePath)?v=@(ImageVersion)"
               x="0" y="0" width="@CanvasWidth" height="@CanvasHeight" opacity="0.3" />
    }

    @foreach (var b in _blockLayouts)
    {
        var sel = b.FlowName == SelectedFlowName;
        var cx  = b.Px + b.Pad + b.InnerW / 2.0;
        var cy  = b.Py + b.Pad + b.InnerH / 2.0;
        var inv = System.Globalization.CultureInfo.InvariantCulture;

        @* ── 선택 시 살짝 확대 + 강한 그림자 래퍼 ── *@
        <g transform="@(sel ? $"translate({cx.ToString("F1", inv)},{cy.ToString("F1", inv)}) scale(1.04) translate({(-cx).ToString("F1", inv)},{(-cy).ToString("F1", inv)})" : "")">

        <defs>
            <clipPath id="@b.ClipId">
                <rect x="@(b.Px + b.Pad)" y="@(b.Py + b.Pad)"
                      width="@b.InnerW" height="@b.InnerH" rx="8" ry="8" />
            </clipPath>
        </defs>

        @* 드롭 쉐도우 (clip 바깥) *@
        <rect x="@(b.Px + b.Pad)" y="@(b.Py + b.Pad)"
              width="@b.InnerW" height="@b.InnerH"
              rx="8" ry="8" fill="transparent"
              filter="@(sel ? "url(#block-shadow-selected)" : "url(#block-shadow)")" />

        @* 선택 글로우 — 상태색 후광 + pulse *@
        @if (sel)
        {
            <rect x="@(b.Px + b.Pad - 4)" y="@(b.Py + b.Pad - 4)"
                  width="@(b.InnerW + 8)" height="@(b.InnerH + 8)"
                  rx="12" ry="12"
                  fill="@b.Color" opacity="0.55"
                  filter="url(#selection-glow)">
                <animate attributeName="opacity"
                         values="0.35;0.65;0.35" dur="2s"
                         repeatCount="indefinite" />
            </rect>
            <rect x="@(b.Px + b.Pad - 1)" y="@(b.Py + b.Pad - 1)"
                  width="@(b.InnerW + 2)" height="@(b.InnerH + 2)"
                  rx="9" ry="9" fill="none"
                  stroke="@b.Color" stroke-width="2.5" stroke-opacity="0.7" />
        }

        <g class="flow-block" clip-path="url(#@b.ClipId)"
           style="cursor:pointer;" @onclick="() => OnBlockClicked(b.FlowName)" @onclick:stopPropagation>
            @* ① 블러된 배경 이미지 (글래스 효과) *@
            @if (!string.IsNullOrEmpty(ImagePath))
            {
                <image href="@(ImagePath)?v=@(ImageVersion)"
                       x="0" y="0" width="@CanvasWidth" height="@CanvasHeight"
                       opacity="0.5" filter="url(#glass-blur)" />
            }
            @* ② 다크 글래스 베이스 *@
            <rect x="@(b.Px + b.Pad)" y="@(b.Py + b.Pad)"
                  width="@b.InnerW" height="@b.InnerH"
                  rx="8" ry="8"
                  fill="#0a1e30" fill-opacity="0.82" />
            @* ②-b 대각선 유리 반사 *@
            <rect x="@(b.Px + b.Pad)" y="@(b.Py + b.Pad)"
                  width="@b.InnerW" height="@b.InnerH"
                  rx="8" ry="8"
                  fill="url(#glass-overlay-grad)" />
            @* ②-c 내부 시안 글로우 *@
            <rect x="@(b.Px + b.Pad)" y="@(b.Py + b.Pad)"
                  width="@b.InnerW" height="@b.InnerH"
                  rx="8" ry="8" fill="none"
                  stroke="#00bfff" stroke-width="18" stroke-opacity="0.12"
                  filter="url(#glass-blur)" />
            @* ③ 시안 글래스 테두리 *@
            <rect x="@(b.Px + b.Pad)" y="@(b.Py + b.Pad)"
                  width="@b.InnerW" height="@b.InnerH"
                  rx="8" ry="8" fill="none"
                  stroke="#00c8ff" stroke-width="1" stroke-opacity="0.30" />
            @* ④ 상단 밝은 하이라이트 *@
            <line x1="@(b.Px + b.Pad + 12)" y1="@(b.Py + b.Pad + 1)"
                  x2="@(b.Px + b.Pad + b.InnerW - 12)" y2="@(b.Py + b.Pad + 1)"
                  stroke="white" stroke-width="1" stroke-opacity="0.50" stroke-linecap="round" />
            @* ⑤ 하단 그림자 *@
            <line x1="@(b.Px + b.Pad + 12)" y1="@(b.Py + b.Pad + b.InnerH - 1)"
                  x2="@(b.Px + b.Pad + b.InnerW - 12)" y2="@(b.Py + b.Pad + b.InnerH - 1)"
                  stroke="black" stroke-width="1" stroke-opacity="0.45" stroke-linecap="round" />
            @* ⑥ 내부 유리 보더 *@
            <line x1="@(b.Px + b.Pad + 10)" y1="@(b.Py + b.Pad + 6)"
                  x2="@(b.Px + b.Pad + b.InnerW - 10)" y2="@(b.Py + b.Pad + 6)"
                  stroke="white" stroke-width="1.5" stroke-opacity="0.50" stroke-linecap="round" />
            <line x1="@(b.Px + b.Pad + 6)" y1="@(b.Py + b.Pad + 10)"
                  x2="@(b.Px + b.Pad + 6)" y2="@(b.Py + b.Pad + b.InnerH - 10)"
                  stroke="white" stroke-width="1.5" stroke-opacity="0.30" stroke-linecap="round" />
            <line x1="@(b.Px + b.Pad + b.InnerW - 6)" y1="@(b.Py + b.Pad + 10)"
                  x2="@(b.Px + b.Pad + b.InnerW - 6)" y2="@(b.Py + b.Pad + b.InnerH - 10)"
                  stroke="#00c8ff" stroke-width="1" stroke-opacity="0.15" stroke-linecap="round" />
            <line x1="@(b.Px + b.Pad + 10)" y1="@(b.Py + b.Pad + b.InnerH - 6)"
                  x2="@(b.Px + b.Pad + b.InnerW - 10)" y2="@(b.Py + b.Pad + b.InnerH - 6)"
                  stroke="#00c8ff" stroke-width="1" stroke-opacity="0.15" stroke-linecap="round" />

            @* ── 카드 내부 콘텐츠 (foreignObject — 최소 카드 기준 중앙 배치) ── *@
            <foreignObject x="@b.ContentX" y="@b.ContentY"
                           width="@b.ContentW" height="@b.ContentH">
                <div xmlns="http://www.w3.org/1999/xhtml" class="fc-cq">
                    <div class="fc-root">
                        @* ── 헤더: 검은 배경 + 큰 제목 + 배지 ── *@
                        <div class="fc-header">
                            <div class="fc-title">@b.FlowName</div>
                            @if (b.Badges.Count > 0)
                            {
                                <div class="fc-badges">
                                    @foreach (var badge in b.Badges)
                                    {
                                        <span class="fc-badge"
                                              style="background: @ColorMix(badge.Color, 0.35); border-color: @ColorMix(badge.Color, 0.60); color: white;">
                                            @badge.Label
                                        </span>
                                    }
                                </div>
                            }
                        </div>

                        @* ── 본문: 도넛(좌) + 통계(우) ── *@
                        @if (b.HasMtWt)
                        {
                            <div class="fc-body" style="max-width:@(b.BodyMaxW)px">
                                <div class="fc-chart @(b.ShowStats ? "" : "fc-chart-full")">
                                    <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                                        <defs>
                                            <linearGradient id="mt-g-@b.ClipId" x1="0%" y1="0%" x2="0%" y2="100%">
                                                <stop offset="0%" stop-color="#4a90e2" />
                                                <stop offset="100%" stop-color="#3a86ff" stop-opacity="0.7" />
                                            </linearGradient>
                                            <linearGradient id="wt-g-@b.ClipId" x1="0%" y1="0%" x2="0%" y2="100%">
                                                <stop offset="0%" stop-color="#ffb347" />
                                                <stop offset="100%" stop-color="#ff9f1c" stop-opacity="0.7" />
                                            </linearGradient>
                                        </defs>
                                        <g transform="rotate(-90 50 50)">
                                            <circle cx="50" cy="50" r="40" fill="none"
                                                    stroke="#ccc" stroke-opacity="0.1" stroke-width="9" />
                                            @if (b.MtFrac > 0)
                                            {
                                                <circle cx="50" cy="50" r="40" fill="none"
                                                        stroke="url(#mt-g-@b.ClipId)" stroke-width="9"
                                                        stroke-dasharray="@b.SMtDash @b.SCirc"
                                                        stroke-linecap="round" />
                                            }
                                            @if (b.WtFrac > 0)
                                            {
                                                <circle cx="50" cy="50" r="40" fill="none"
                                                        stroke="url(#wt-g-@b.ClipId)" stroke-width="9"
                                                        stroke-dasharray="@b.SWtDash @b.SCirc"
                                                        stroke-dashoffset="@b.SNegMt"
                                                        stroke-linecap="round" />
                                            }
                                        </g>
                                    </svg>
                                    <span class="fc-chart-label">@FormatMs(b.Total)</span>
                                </div>

                                @if (b.ShowStats)
                                {
                                    <div class="fc-stats">
                                        <div class="fc-state-label">@b.StateLabel</div>
                                        <div class="fc-stat-row">
                                            <span class="fc-dot fc-dot-mt"></span>
                                            <span class="fc-stat-label">가동</span>
                                            <span class="fc-stat-value">@FormatMs(b.Mt)</span>
                                        </div>
                                        <div class="fc-stat-row">
                                            <span class="fc-dot fc-dot-wt"></span>
                                            <span class="fc-stat-label">대기</span>
                                            <span class="fc-stat-value">@FormatMs(b.Wt)</span>
                                        </div>
                                    </div>
                                }
                            </div>

                            @if (!b.ShowStats)
                            {
                                <div class="fc-footer">@b.StateLabel</div>
                            }
                        }
                        else
                        {
                            <div class="fc-center-state">@b.StateLabel</div>
                        }
                    </div>
                </div>
            </foreignObject>

            @* 선택 오버레이 (clip 안쪽) *@
            @if (sel)
            {
                <rect x="@(b.Px + b.Pad)" y="@(b.Py + b.Pad)"
                      width="@b.InnerW" height="@b.InnerH"
                      rx="8" ry="8"
                      fill="@b.Color" fill-opacity="0.10"
                      stroke="none" />
            }
        </g>
        </g> @* scale 래퍼 닫기 *@
    }
</svg>

@code {
    // ── Parameters ──
    [Parameter] public string Style { get; set; } = "";
    [Parameter] public int CanvasWidth { get; set; }
    [Parameter] public int CanvasHeight { get; set; }
    [Parameter] public string? ImagePath { get; set; }
    [Parameter] public long ImageVersion { get; set; }
    [Parameter] public int OffsetX { get; set; }
    [Parameter] public int OffsetY { get; set; }
    [Parameter] public int CellWidth { get; set; }
    [Parameter] public int CellHeight { get; set; }
    [Parameter] public List<FlowPlacement> Placements { get; set; } = [];
    [Parameter] public Func<FlowPlacement, string>? GetColor { get; set; }
    [Parameter] public Func<FlowPlacement, string>? GetStateLabel { get; set; }
    [Parameter] public Func<FlowPlacement, (int Mt, int Wt)?>? GetMtWt { get; set; }
    [Parameter] public Func<FlowPlacement, IEnumerable<(string Label, string Color)>>? GetBadges { get; set; }
    [Parameter] public string? SelectedFlowName { get; set; }
    [Parameter] public EventCallback<string?> OnFlowClicked { get; set; }

    // ── Pre-computed block layouts ──
    private List<FlowBlockLayout> _blockLayouts = [];

    protected override void OnParametersSet()
    {
        // 최소 카드 크기 산출 (콘텐츠 영역 통일용)
        var pad = 4;
        var minContentW = Placements.Count > 0
            ? Placements.Min(fp => fp.ColSpan * CellWidth - pad * 2) : 0;
        var minContentH = Placements.Count > 0
            ? Placements.Min(fp => fp.RowSpan * CellHeight - pad * 2) : 0;

        _blockLayouts = Placements
            .Select(fp => ComputeSingleBlock(fp, minContentW, minContentH))
            .ToList();
    }

    // ── Simplified layout record ──
    private record FlowBlockLayout
    {
        // 데이터
        public required string FlowName { get; init; }
        public required string Color { get; init; }
        public required string StateLabel { get; init; }
        public required bool HasMtWt { get; init; }
        public required int Mt { get; init; }
        public required int Wt { get; init; }
        public required int Total { get; init; }
        public required List<(string Label, string Color)> Badges { get; init; }

        // 블록 지오메트리
        public required int Px { get; init; }
        public required int Py { get; init; }
        public required int Pad { get; init; }
        public required int InnerW { get; init; }
        public required int InnerH { get; init; }
        public required string ClipId { get; init; }
        public required bool ShowStats { get; init; }

        // foreignObject 영역 (전체 카드 크기, 좌상단 기준)
        public required int ContentX { get; init; }
        public required int ContentY { get; init; }
        public required int ContentW { get; init; }
        public required int ContentH { get; init; }

        // 본문 제약 (최소 카드 기준)
        public required int BodyMaxW { get; init; }
        public required int BodyMaxH { get; init; }

        // 도넛 비율 (viewBox 100x100 기준, r=40, sw=9)
        public required double MtFrac { get; init; }
        public required double WtFrac { get; init; }
        public required string SCirc { get; init; }
        public required string SMtDash { get; init; }
        public required string SWtDash { get; init; }
        public required string SNegMt { get; init; }
    }

    // ── 블록별 레이아웃 계산 (단순화) ──
    private FlowBlockLayout ComputeSingleBlock(FlowPlacement fp, int minContentW, int minContentH)
    {
        var color      = GetColor?.Invoke(fp) ?? "#9E9E9E";
        var stateLabel = GetStateLabel?.Invoke(fp) ?? "";
        var mtWt       = GetMtWt?.Invoke(fp);

        // 블록 지오메트리
        var px     = OffsetX + fp.Col * CellWidth;
        var py     = OffsetY + fp.Row * CellHeight;
        var pw     = fp.ColSpan * CellWidth;
        var ph     = fp.RowSpan * CellHeight;
        var pad    = 4;
        var innerW = pw - pad * 2;
        var innerH = ph - pad * 2;
        var clipId = $"blk{fp.FlowName.GetHashCode() & 0x7FFFFFFF}";

        // foreignObject: 전체 카드 크기, 좌상단 배치
        // 헤더는 전체 너비, 본문은 최소 카드 크기로 제약
        var contentX = px + pad;
        var contentY = py + pad;
        var contentW = innerW;
        var contentH = innerH;
        var bodyMaxW = minContentW;
        var bodyMaxH = minContentH;
        var showStats = minContentW >= 130;

        var hasMtWt = mtWt != null;
        var mt    = mtWt?.Mt ?? 0;
        var wt    = mtWt?.Wt ?? 0;
        var total = mt + wt;

        // 도넛 비율 (고정 viewBox: r=40, circ=2*PI*40)
        var mtFrac = total > 0 ? (double)mt / total : (hasMtWt ? 1.0 : 0.0);
        var wtFrac = 1.0 - mtFrac;
        const double circ = 2 * Math.PI * 40;
        var mtDash = circ * mtFrac;
        var wtDash = circ * wtFrac;

        var inv     = System.Globalization.CultureInfo.InvariantCulture;
        var sCirc   = circ.ToString("F1", inv);
        var sMtDash = mtDash.ToString("F1", inv);
        var sWtDash = wtDash.ToString("F1", inv);
        var sNegMt  = (-mtDash).ToString("F1", inv);

        // 배지
        var badges = GetBadges?.Invoke(fp)?.ToList() ?? new List<(string Label, string Color)>();

        return new FlowBlockLayout
        {
            FlowName = fp.FlowName, Color = color, StateLabel = stateLabel,
            HasMtWt = hasMtWt, Mt = mt, Wt = wt, Total = total,
            Badges = badges,
            Px = px, Py = py, Pad = pad,
            InnerW = innerW, InnerH = innerH, ClipId = clipId,
            ShowStats = showStats,
            ContentX = contentX, ContentY = contentY,
            ContentW = contentW, ContentH = contentH,
            BodyMaxW = bodyMaxW, BodyMaxH = bodyMaxH,
            MtFrac = mtFrac, WtFrac = wtFrac,
            SCirc = sCirc, SMtDash = sMtDash, SWtDash = sWtDash, SNegMt = sNegMt,
        };
    }

    // ── 블록 클릭 ──
    private async Task OnBlockClicked(string flowName)
    {
        var next = flowName == SelectedFlowName ? null : flowName;
        await OnFlowClicked.InvokeAsync(next);
    }

    // ── 배경 클릭 → 선택 해제 ──
    private async Task OnBackgroundClicked()
    {
        if (SelectedFlowName != null)
            await OnFlowClicked.InvokeAsync((string?)null);
    }

    // ── 시간 포맷 ──
    private static string FormatMs(int ms)
    {
        if (ms <= 0) return "0s";
        if (ms < 1000) return $"{ms}ms";
        if (ms < 60_000) return $"{ms / 1000.0:F1}s";
        if (ms < 3_600_000) return $"{ms / 60000}m {ms % 60000 / 1000}s";
        return $"{ms / 3_600_000}h {ms % 3_600_000 / 60000}m";
    }

    // ── 색상 믹스 헬퍼 (배지 배경/테두리용) ──
    private static string ColorMix(string color, double opacity)
    {
        // rgba 형태로 반환
        if (color.StartsWith("#") && color.Length >= 7)
        {
            var r = Convert.ToInt32(color.Substring(1, 2), 16);
            var g = Convert.ToInt32(color.Substring(3, 2), 16);
            var b = Convert.ToInt32(color.Substring(5, 2), 16);
            return $"rgba({r},{g},{b},{opacity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)})";
        }
        return color;
    }
}
