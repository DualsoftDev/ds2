@page "/heatmap"
@using DSPilot.Engine
@using static DSPilot.Engine.Models
@using DSPilot.Services
@inject HeatmapService HeatmapService
@inject ILogger<Heatmap> Logger

<PageTitle>동작편차</PageTitle>

<h5 class="typo-h5 mb-4" style="font-weight: 600; color: #0A1E5A;">
    동작편차
    <span title="각 Call의 실행 시간 통계를 분석하여 성능 이슈를 조기에 발견할 수 있습니다. 평균, 표준편차, 변동계수, 성능점수 등 다양한 메트릭으로 분석 가능합니다."
          style="cursor: help; margin-left: 8px; vertical-align: middle;">
        <span class="material-icons" style="font-size:20px; color:var(--color-primary);">info</span>
    </span>
</h5>
<p class="typo-body1 mb-4" style="color: var(--color-secondary);">
    Call별 실행 통계를 시각적으로 분석합니다. 색상이 진할수록 성능 이슈가 있을 수 있습니다.
    <span title="성능점수: 빠르고 안정적일수록 높음 (최고 100점) / 평균: 낮을수록 빠름 / 표준편차: 낮을수록 안정적 / 변동계수: 낮을수록 일관성 높음"
          style="cursor: help; margin-left: 4px; vertical-align: middle;">
        <span class="material-icons" style="font-size:18px; color:var(--color-secondary);">help_outline</span>
    </span>
</p>

@* 필터 및 컨트롤 패널 *@
<div class="card mb-4" style="padding:16px; box-shadow: var(--shadow-2);">
    <div class="grid" style="gap:8px;">
        <div class="grid-item-4">
            <div class="form-group">
                <label class="form-label">표시 메트릭</label>
                <select class="form-select" @onchange="OnMetricChanged">
                    @foreach (var metric in AvailableMetrics)
                    {
                        <option value="@metric" selected="@(metric.Equals(SelectedMetric))">
                            @HeatmapService.GetMetricDisplayName(metric)
                        </option>
                    }
                </select>
            </div>
        </div>
        <div class="grid-item-4">
            <div class="form-group">
                <label class="form-label">Flow 필터</label>
                <input class="form-field" @bind="FlowFilter" placeholder="Flow 이름 검색..." />
            </div>
        </div>
        <div class="grid-item-4 d-flex" style="align-items:flex-end; gap:8px;">
            <button class="btn btn-filled mr-2" @onclick="LoadDataAsync">
                <span class="material-icons" style="font-size:18px;">refresh</span> 새로고침
            </button>
            <button class="btn btn-outlined" @onclick="ToggleAllGroups">
                <span class="material-icons" style="font-size:18px;">@(AllExpanded ? "unfold_less" : "unfold_more")</span>
                @(AllExpanded ? "모두 접기" : "모두 펼치기")
            </button>
        </div>
    </div>
</div>

@* 로딩 표시 *@
@if (IsLoading)
{
    <div class="progress-bar mb-4" style="height:4px;">
        <div style="width:100%; background:var(--color-primary); height:100%; animation: indeterminate 1.5s infinite;"></div>
    </div>
}

@* 데이터 없음 *@
@if (!IsLoading && FilteredGroups.Count == 0)
{
    <div class="alert alert-info mb-4">
        <span class="material-icons">info</span>
        표시할 데이터가 없습니다. PLC 데이터가 수집되면 자동으로 표시됩니다.
    </div>
}

@* Heatmap 범례 *@
@if (!IsLoading && FilteredGroups.Count > 0)
{
    <div class="card mb-4" style="padding:16px; box-shadow: var(--shadow-1);">
        <span class="typo-subtitle2 mb-2" style="display:block;"
              title="선택한 메트릭에 따라 색상이 자동으로 할당됩니다. 성능점수는 높을수록 좋고, 나머지는 낮을수록 좋습니다.">
            <span style="border-bottom: 1px dotted; cursor: help;">범례</span>
        </span>
        <div class="d-flex" style="flex-wrap:wrap; align-items:center; gap:4px;">
            <div class="heatmap-legend-item" title="성능점수 90점 이상 또는 변동계수 0.1 미만 - 매우 안정적이고 빠른 동작">
                <div class="heatmap-cell heatmap-excellent"></div>
                <span class="typo-caption">우수</span>
            </div>
            <div class="heatmap-legend-item" title="성능점수 70-90점 또는 변동계수 0.1-0.2 - 양호한 성능">
                <div class="heatmap-cell heatmap-good"></div>
                <span class="typo-caption">양호</span>
            </div>
            <div class="heatmap-legend-item" title="성능점수 50-70점 또는 변동계수 0.2-0.3 - 보통 수준의 성능">
                <div class="heatmap-cell heatmap-fair"></div>
                <span class="typo-caption">보통</span>
            </div>
            <div class="heatmap-legend-item" title="성능점수 30-50점 또는 변동계수 0.3-0.5 - 개선이 필요한 수준">
                <div class="heatmap-cell heatmap-poor"></div>
                <span class="typo-caption">개선 필요</span>
            </div>
            <div class="heatmap-legend-item" title="성능점수 30점 미만 또는 변동계수 0.5 이상 - 심각한 성능 문제, 즉시 점검 필요">
                <div class="heatmap-cell heatmap-critical"></div>
                <span class="typo-caption">심각</span>
            </div>
        </div>
    </div>
}

@* Flow 그룹별 Heatmap *@
@foreach (var group in FilteredGroups)
{
    <div class="card mb-4" style="padding:16px; box-shadow: var(--shadow-2);">
        <div class="d-flex" style="align-items:center; justify-content:space-between; margin-bottom:12px;">
            <div class="d-flex" style="align-items:center; gap:4px;">
                <button class="btn-icon" @onclick="@(() => group.IsExpanded = !group.IsExpanded)">
                    <span class="material-icons">@(group.IsExpanded ? "expand_more" : "chevron_right")</span>
                </button>
                <h6 class="typo-h6">@group.FlowName</h6>
                <span class="chip ml-2" style="background:var(--color-info); color:white;">
                    @group.CallCount Calls
                </span>
            </div>
            <span class="typo-body2" style="color:var(--color-text-secondary);">
                평균: @HeatmapService.FormatMetricValue(SelectedMetric, GetFlowAverageValue(group))
            </span>
        </div>

        @if (group.IsExpanded)
        {
            <div class="table-container">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Call</th>
                            <th>Work</th>
                            <th style="text-align:center;">
                                <span title="Call의 평균 실행 시간입니다. Going 상태가 시작되고 종료될 때까지의 평균 소요 시간을 밀리초 단위로 표시합니다."
                                      style="border-bottom:1px dotted; cursor:help;">평균 (ms)</span>
                            </th>
                            <th style="text-align:center;">
                                <span title="실행 시간의 표준편차입니다. 값이 클수록 실행 시간의 변동이 크다는 의미로, 동작이 불안정할 수 있음을 나타냅니다."
                                      style="border-bottom:1px dotted; cursor:help;">표준편차 (ms)</span>
                            </th>
                            <th style="text-align:center;">
                                <span title="변동계수 (CV)는 표준편차를 평균으로 나눈 값입니다. 실행 시간의 상대적 변동성을 나타내며, 0.1 미만은 안정적, 0.3 이상은 불안정한 것으로 판단합니다."
                                      style="border-bottom:1px dotted; cursor:help;">변동계수</span>
                            </th>
                            <th style="text-align:center;">
                                <span title="평균 실행 시간과 변동계수를 종합하여 계산한 성능 점수입니다. 100점 만점이며, 점수가 높을수록 빠르고 안정적입니다."
                                      style="border-bottom:1px dotted; cursor:help;">성능점수</span>
                            </th>
                            <th style="text-align:center;">
                                <span title="Call이 Going 상태로 전환된 총 횟수입니다. 샘플 수가 많을수록 통계의 신뢰도가 높아집니다."
                                      style="border-bottom:1px dotted; cursor:help;">실행횟수</span>
                            </th>
                            <th style="text-align:center;">@HeatmapService.GetMetricDisplayName(SelectedMetric)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var call in group.Calls)
                        {
                            <tr>
                                <td>@call.CallName</td>
                                <td>@call.WorkName</td>
                                <td style="text-align:center;">@($"{call.AverageGoingTime:F0}")</td>
                                <td style="text-align:center;">@($"{call.StdDevGoingTime:F0}")</td>
                                <td style="text-align:center;">@($"{call.CoefficientOfVariation:F2}")</td>
                                <td style="text-align:center;">@($"{call.PerformanceScore:F0}")</td>
                                <td style="text-align:center;">@call.GoingCount</td>
                                <td style="text-align:center;">
                                    <div class="heatmap-cell @call.ColorClass" title="@call.GetTooltipText()">
                                        @HeatmapService.FormatMetricValue(SelectedMetric, call.GetMetricValue(SelectedMetric))
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@code {
    private List<FlowHeatmapGroup> AllGroups { get; set; } = new();
    private List<FlowHeatmapGroup> FilteredGroups => string.IsNullOrWhiteSpace(FlowFilter)
        ? AllGroups
        : AllGroups.Where(g => g.FlowName.Contains(FlowFilter, StringComparison.OrdinalIgnoreCase)).ToList();

    private readonly List<HeatmapMetric> AvailableMetrics = new()
    {
        HeatmapMetric.AverageTime,
        HeatmapMetric.StdDeviation,
        HeatmapMetric.CoefficientOfVariation,
        HeatmapMetric.PerformanceScore
    };

    private HeatmapMetric _selectedMetric = HeatmapMetric.PerformanceScore;
    private HeatmapMetric SelectedMetric
    {
        get => _selectedMetric;
        set
        {
            if (_selectedMetric != value)
            {
                _selectedMetric = value;
                _ = LoadDataAsync();
            }
        }
    }

    private string FlowFilter { get; set; } = string.Empty;
    private bool IsLoading { get; set; } = false;
    private bool AllExpanded { get; set; } = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        IsLoading = true;
        StateHasChanged();

        try
        {
            AllGroups = await HeatmapService.GetHeatmapDataAsync(SelectedMetric);
            Logger.LogInformation("Heatmap data loaded: {Count} flow groups", AllGroups.Count);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load heatmap data");
            AllGroups = new List<FlowHeatmapGroup>();
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private void OnMetricChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        var match = AvailableMetrics.FirstOrDefault(m => m.ToString() == val);
        if (match is not null)
            SelectedMetric = match;
    }

    private void ToggleAllGroups()
    {
        AllExpanded = !AllExpanded;
        foreach (var group in AllGroups)
        {
            group.IsExpanded = AllExpanded;
        }
    }

    private double GetFlowAverageValue(FlowHeatmapGroup group)
    {
        if (SelectedMetric.Equals(HeatmapMetric.AverageTime))
            return group.FlowAverageTime;
        else if (SelectedMetric.Equals(HeatmapMetric.StdDeviation))
            return group.FlowAverageStdDev;
        else if (SelectedMetric.Equals(HeatmapMetric.PerformanceScore))
            return group.FlowAverageScore;
        else if (SelectedMetric.Equals(HeatmapMetric.CoefficientOfVariation))
            return group.Calls.Average(c => c.CoefficientOfVariation);
        else
            return 0;
    }
}
