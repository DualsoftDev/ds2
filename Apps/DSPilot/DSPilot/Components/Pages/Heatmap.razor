@page "/heatmap"
@using DSPilot.Engine
@using static DSPilot.Engine.Models
@using DSPilot.Services
@inject HeatmapService HeatmapService
@inject ILogger<Heatmap> Logger
@inject IJSRuntime JS

<PageTitle>동작편차</PageTitle>

<h5 class="typo-h5 mb-4" style="font-weight: 600; color: var(--color-text-primary);">
    동작편차
    <span title="각 Call의 실행 시간 통계를 매트릭스 히트맵으로 분석합니다. 평균, 표준편차, 변동계수를 기준으로 변동성을 비교합니다."
          style="cursor: help; margin-left: 8px; vertical-align: middle;">
        <span class="material-icons" style="font-size:20px; color:var(--color-primary);">info</span>
    </span>
</h5>
<p class="typo-body1 mb-4" style="color: var(--color-secondary);">
    Call별 실행 통계를 매트릭스 히트맵으로 시각화합니다. 평균 시간과 변동성 이슈를 한눈에 파악할 수 있습니다.
</p>

@* 컨트롤 패널 *@
<div class="card mb-4" style="padding:16px; box-shadow: var(--shadow-2);">
    <div class="d-flex" style="align-items:center; gap:12px; flex-wrap:wrap;">
        <div style="flex:0 0 auto; min-width:160px;">
            <label class="typo-caption" style="display:block; margin-bottom:4px; color:var(--color-text-secondary);">표시 메트릭</label>
            <select class="form-field" value="@AvailableMetrics.IndexOf(SelectedMetric)"
                    @onchange="OnMetricChanged">
                @for (int i = 0; i < AvailableMetrics.Count; i++)
                {
                    <option value="@i">@HeatmapService.GetMetricDisplayName(AvailableMetrics[i])</option>
                }
            </select>
        </div>
        <div style="flex:1; max-width:400px;">
            <label class="typo-caption" style="display:block; margin-bottom:4px; color:var(--color-text-secondary);">Flow 필터</label>
            <input class="form-field" @bind="FlowFilter" placeholder="Flow 이름 검색..." />
        </div>
        <div style="flex:0 0 auto; min-width:80px;">
            <label class="typo-caption" style="display:block; margin-bottom:4px; color:var(--color-text-secondary);">Matrix 열 수</label>
            <input type="number" class="form-field" min="1" max="12"
                   value="@MatrixColumns"
                   @onchange="@(e => OnMatrixColumnsChanged(int.Parse(e.Value?.ToString() ?? "6")))"
                   style="width:80px;" />
        </div>
        <div style="flex:0 0 auto; display:flex; gap:8px; align-items:flex-end; padding-top:18px;">
            <button class="btn btn-filled" @onclick="LoadDataAsync">
                <span class="material-icons" style="font-size:18px;">refresh</span> 새로고침
            </button>
            <button class="btn btn-outlined" @onclick="ToggleFlowGroupMatrix">
                <span class="material-icons" style="font-size:18px;">@(AllExpanded ? "unfold_less" : "unfold_more")</span>
                @(AllExpanded ? "Flow Group Matrix 접기" : "Flow Group Matrix 펼치기")
            </button>
            <button class="btn btn-outlined" @onclick="ExportCsv" disabled="@(FilteredGroups.Count == 0)">
                CSV 내보내기
            </button>
        </div>
    </div>
</div>

@* 로딩 표시 *@
@if (IsLoading)
{
    <div class="mb-4" style="height:4px; background:var(--color-surface-variant, #e0e0e0); border-radius:2px; overflow:hidden;">
        <div style="height:100%; width:25%; background:var(--color-primary); animation: heatmap-indeterminate 1.5s infinite ease-in-out;"></div>
    </div>
}

@* 데이터 없음 *@
@if (!IsLoading && FilteredGroups.Count == 0)
{
    <div class="card mb-4" style="padding:16px; border-left:4px solid var(--color-info, #2196F3);">
        <span class="material-icons" style="font-size:18px; vertical-align:middle; margin-right:8px; color:var(--color-info, #2196F3);">info</span>
        표시할 데이터가 없습니다. PLC 데이터가 수집되면 자동으로 표시됩니다.
    </div>
}

@if (!IsLoading && FilteredGroups.Count > 0)
{
    @* 요약 대시보드 *@
    <div class="grid mb-4" style="gap:12px; grid-template-columns: repeat(4, 1fr);">
        <div class="card" style="padding:16px; text-align:center; box-shadow: var(--shadow-1);">
            <div class="typo-overline" style="color:var(--color-text-secondary);">총 Flow</div>
            <div class="typo-h5" style="color:var(--color-primary);">@FilteredGroups.Count</div>
        </div>
        <div class="card" style="padding:16px; text-align:center; box-shadow: var(--shadow-1);">
            <div class="typo-overline" style="color:var(--color-text-secondary);">총 Call</div>
            <div class="typo-h5" style="color:var(--color-primary);">@TotalCalls</div>
        </div>
        <div class="card" style="padding:16px; text-align:center; box-shadow: var(--shadow-1);">
            <div class="typo-overline" style="color:var(--color-text-secondary);">이슈 Call</div>
            <div class="typo-h5" style="color:@(IssueCalls > 0 ? "var(--color-error)" : "var(--color-success)");">@IssueCalls</div>
        </div>
        <div class="card" style="padding:16px; text-align:center; box-shadow: var(--shadow-1);">
            <div class="typo-overline" style="color:var(--color-text-secondary);">선택 메트릭 평균</div>
            <div class="typo-h5" style="color:var(--color-primary);">
                @HeatmapService.FormatMetricValue(SelectedMetric, SelectedMetricAverage)
            </div>
            <div class="typo-caption" style="color:var(--color-text-secondary);">
                @HeatmapService.GetMetricDisplayName(SelectedMetric)
            </div>
        </div>
    </div>

    @* 범례 *@
    <div class="card mb-4" style="padding:12px 16px; box-shadow: var(--shadow-1);">
        <div class="d-flex" style="flex-wrap:wrap; align-items:center; gap:4px;">
            <span class="typo-caption" style="margin-right:8px; color:var(--color-text-secondary);">범례:</span>
            <div class="heatmap-legend-item" title="현재 선택 메트릭 기준으로 가장 양호한 구간입니다.">
                <div class="heatmap-cell heatmap-excellent"></div>
                <span class="typo-caption">우수</span>
            </div>
            <div class="heatmap-legend-item" title="현재 선택 메트릭 기준으로 양호한 구간입니다.">
                <div class="heatmap-cell heatmap-good"></div>
                <span class="typo-caption">양호</span>
            </div>
            <div class="heatmap-legend-item" title="현재 선택 메트릭 기준으로 중간 수준입니다.">
                <div class="heatmap-cell heatmap-fair"></div>
                <span class="typo-caption">보통</span>
            </div>
            <div class="heatmap-legend-item" title="현재 선택 메트릭 기준으로 개선이 필요한 구간입니다.">
                <div class="heatmap-cell heatmap-poor"></div>
                <span class="typo-caption">개선필요</span>
            </div>
            <div class="heatmap-legend-item" title="현재 선택 메트릭 기준으로 우선 점검이 필요한 구간입니다.">
                <div class="heatmap-cell heatmap-critical"></div>
                <span class="typo-caption">심각</span>
            </div>
        </div>
    </div>

    @if (AllExpanded)
    {
        @* Flow Group Matrix 대시보드 *@
        <div class="card mb-4" style="padding:16px; box-shadow: var(--shadow-2);">
            <div class="d-flex" style="flex-wrap:wrap; align-items:center; justify-content:space-between; margin-bottom:12px; gap:12px;">
                <div>
                    <h6 class="typo-h6">Flow Group Matrix</h6>
                    <span class="typo-body2" style="color:var(--color-text-secondary);">
                        Flow 패널 안에 Work 블록과 Call 셀을 배치해 한눈에 그룹 구조가 보이도록 구성합니다.
                    </span>
                </div>
                <span class="chip" style="background:var(--color-primary); color:white;">
                    @FilteredGroups.Count Flows
                </span>
            </div>

            <div class="flow-dashboard-grid">
                @foreach (var group in FilteredGroups)
                {
                    <section class="flow-dashboard-panel">
                        <div class="flow-dashboard-panel-header">
                            <div>
                                <div class="flow-dashboard-panel-title">@group.FlowName</div>
                                <div class="flow-dashboard-panel-subtitle">
                                    평균 @HeatmapService.FormatMetricValue(SelectedMetric, GetFlowAverageValue(group))
                                </div>
                            </div>
                            <span class="chip" style="background:var(--color-info, #2196F3); color:white; font-size:12px;">
                                @group.CallCount Calls
                            </span>
                        </div>

                        <div class="flow-dashboard-work-grid">
                            @foreach (var workGroup in GetWorkGroups(group))
                            {
                                <div class="flow-dashboard-work-panel">
                                    <div class="flow-dashboard-work-header">
                                        <span>@workGroup.WorkName</span>
                                        <span>@workGroup.Calls.Count</span>
                                    </div>
                                    <div class="flow-dashboard-call-grid" style="@GetWorkMatrixStyle(workGroup.Calls.Count)">
                                        @foreach (var call in workGroup.Calls)
                                        {
                                            <div class="flow-dashboard-call-cell @call.GetColorClass(SelectedMetric)"
                                                 title="@BuildCallTooltip(call)"
                                                 style="cursor:pointer;"
                                                 @onclick="@(() => SelectCall(call))">
                                                <div class="flow-dashboard-call-name">@call.CallName</div>
                                                <div class="flow-dashboard-call-value">
                                                    @HeatmapService.FormatMetricValue(SelectedMetric, call.GetMetricValue(SelectedMetric))
                                                </div>
                                                <div class="flow-dashboard-call-meta">@call.WorkName</div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </section>
                }
            </div>
        </div>
    }

    @* Flow 그룹별 매트릭스 히트맵 *@
    @foreach (var group in FilteredGroups)
    {
        <div class="card mb-4" style="box-shadow: var(--shadow-2); border-radius: 8px;">
            @* Flow 헤더 *@
            <div class="d-flex" style="align-items:center; justify-content:space-between; padding:12px 16px; border-bottom:1px solid var(--color-lines);">
                <div class="d-flex" style="align-items:center; gap:8px;">
                    <button class="btn-icon btn-sm" @onclick="@(() => group.IsExpanded = !group.IsExpanded)">
                        <span class="material-icons">@(group.IsExpanded ? "expand_more" : "chevron_right")</span>
                    </button>
                    <h6 class="typo-h6">@group.FlowName</h6>
                    <span class="chip" style="background:var(--color-info); color:white;">
                        @group.CallCount Calls
                    </span>
                    @if (GetIssueCount(group) > 0)
                    {
                        <span class="chip" style="background:var(--color-error); color:white;">
                            @GetIssueCount(group) 이슈
                        </span>
                    }
                </div>
                @* Flow 수준 미니 집계 셀 *@
                <div class="d-flex" style="align-items:center; gap:4px;">
                    <div class="heatmap-cell-mini @group.FlowColorClassAvg" title="평균: @($"{group.FlowAverageTime:F0}") ms">
                        Avg
                    </div>
                    <div class="heatmap-cell-mini @group.FlowColorClassStdDev" title="표준편차: @($"{group.FlowAverageStdDev:F0}") ms">
                        SD
                    </div>
                    <div class="heatmap-cell-mini @group.FlowColorClassCV" title="변동계수: @($"{group.FlowAverageCV:F2}")">
                        CV
                    </div>
                </div>
            </div>

            @* 매트릭스 테이블 *@
            @if (group.IsExpanded)
            {
                <div class="table-container" style="overflow:auto;">
                    <table class="table heatmap-matrix-table" style="table-layout:fixed; width:100%;">
                        <colgroup>
                            <col style="width:22%;" />
                            <col style="width:14%;" />
                            <col style="width:12%;" />
                            <col style="width:12%;" />
                            <col style="width:12%;" />
                            <col style="width:10%;" />
                        </colgroup>
                        <thead class="table-head-sticky">
                            <tr>
                                <th class="sortable" @onclick="@(() => SortBy(SortField.CallName))">
                                    Call @SortIcon(SortField.CallName)
                                </th>
                                <th class="sortable" @onclick="@(() => SortBy(SortField.WorkName))">
                                    Work @SortIcon(SortField.WorkName)
                                </th>
                                <th class="sortable heatmap-col-header" @onclick="@(() => SortBy(SortField.AvgTime))">
                                    <span title="Call의 평균 실행 시간 (ms). 낮을수록 빠릅니다." style="border-bottom:1px dotted; cursor:help;">
                                        평균 @SortIcon(SortField.AvgTime)
                                    </span>
                                </th>
                                <th class="sortable heatmap-col-header" @onclick="@(() => SortBy(SortField.StdDev))">
                                    <span title="실행 시간의 표준편차 (ms). 낮을수록 안정적입니다." style="border-bottom:1px dotted; cursor:help;">
                                        표준편차 @SortIcon(SortField.StdDev)
                                    </span>
                                </th>
                                <th class="sortable heatmap-col-header" @onclick="@(() => SortBy(SortField.CV))">
                                    <span title="변동계수 (CV) = 표준편차/평균. 0.1 미만: 안정, 0.3 이상: 불안정" style="border-bottom:1px dotted; cursor:help;">
                                        변동계수 @SortIcon(SortField.CV)
                                    </span>
                                </th>
                                <th style="text-align:center;">
                                    <span title="Call이 Going 상태로 전환된 총 횟수" style="border-bottom:1px dotted; cursor:help;">
                                        실행횟수
                                    </span>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var call in GetSortedCalls(group))
                            {
                                <tr class="heatmap-matrix-row @(SelectedCall == call ? "selected" : "")"
                                    @onclick="@(() => SelectCall(call))"
                                    title="@BuildCallTooltip(call)">
                                    <td class="heatmap-matrix-label">@call.CallName</td>
                                    <td class="heatmap-matrix-label">@call.WorkName</td>
                                    <td style="text-align:center; padding:4px;">
                                        <div class="heatmap-cell-compact @call.ColorClassAvg">
                                            @HeatmapService.FormatMetricValueShort(HeatmapMetric.AverageTime, call.AverageGoingTime)
                                        </div>
                                    </td>
                                    <td style="text-align:center; padding:4px;">
                                        <div class="heatmap-cell-compact @call.ColorClassStdDev">
                                            @HeatmapService.FormatMetricValueShort(HeatmapMetric.StdDeviation, call.StdDevGoingTime)
                                        </div>
                                    </td>
                                    <td style="text-align:center; padding:4px;">
                                        <div class="heatmap-cell-compact @call.ColorClassCV">
                                            @HeatmapService.FormatMetricValueShort(HeatmapMetric.CoefficientOfVariation, call.CoefficientOfVariation)
                                        </div>
                                    </td>
                                    <td style="text-align:center;">
                                        <span class="typo-body2">@call.GoingCount</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            }
        </div>
    }
}

@* Call 상세 모달 *@
@if (SelectedCall != null)
{
    <div class="modal-overlay" @onclick="CloseCallModal">
        <div class="modal-content" style="max-width:720px; width:90vw;" @onclick:stopPropagation>
            <div class="d-flex" style="justify-content:space-between; align-items:center; margin-bottom:16px;">
                <div>
                    <h6 class="typo-h6" style="margin:0;">@SelectedCall.CallName</h6>
                    <span class="typo-caption" style="color:var(--color-text-secondary);">
                        Flow: @SelectedCall.FlowName | Work: @SelectedCall.WorkName
                    </span>
                </div>
                <button class="btn-icon btn-sm" @onclick="CloseCallModal">
                    <span class="material-icons">close</span>
                </button>
            </div>

            <div class="grid" style="gap:12px; grid-template-columns: repeat(4, 1fr);">
                <div class="heatmap-detail-card @SelectedCall.ColorClassAvg">
                    <div class="typo-overline" style="color:inherit; opacity:0.85;">평균 시간</div>
                    <div style="font-size:1.25rem; font-weight:700;">@($"{SelectedCall.AverageGoingTime:F0}") ms</div>
                    <div class="typo-caption" style="color:inherit; opacity:0.7;">낮을수록 빠름</div>
                </div>
                <div class="heatmap-detail-card @SelectedCall.ColorClassStdDev">
                    <div class="typo-overline" style="color:inherit; opacity:0.85;">표준편차</div>
                    <div style="font-size:1.25rem; font-weight:700;">@($"{SelectedCall.StdDevGoingTime:F0}") ms</div>
                    <div class="typo-caption" style="color:inherit; opacity:0.7;">낮을수록 안정적</div>
                </div>
                <div class="heatmap-detail-card @SelectedCall.ColorClassCV">
                    <div class="typo-overline" style="color:inherit; opacity:0.85;">변동계수</div>
                    <div style="font-size:1.25rem; font-weight:700;">@($"{SelectedCall.CoefficientOfVariation:F2}")</div>
                    <div class="typo-caption" style="color:inherit; opacity:0.7;">
                        @GetCVStatusText(SelectedCall.CoefficientOfVariation)
                    </div>
                </div>
                <div class="heatmap-detail-card" style="background:linear-gradient(135deg, #475569, #64748b);">
                    <div class="typo-overline" style="color:inherit; opacity:0.85;">실행횟수</div>
                    <div style="font-size:1.25rem; font-weight:700;">@($"{SelectedCall.GoingCount}")회</div>
                    <div class="typo-caption" style="color:inherit; opacity:0.7;">
                        @GetGoingCountStatusText(SelectedCall.GoingCount)
                    </div>
                </div>
            </div>

            @* 실행 이력 차트 *@
            <div style="margin-top:16px; border-top:1px solid var(--color-lines); padding-top:16px;">
                <div class="d-flex" style="align-items:center; gap:8px; margin-bottom:8px;">
                    <span class="material-icons" style="font-size:18px; color:var(--color-primary);">show_chart</span>
                    <span class="typo-subtitle2">실행 시간 추이</span>
                    @if (IsChartLoading)
                    {
                        <span class="typo-caption" style="color:var(--color-text-secondary);">로딩 중...</span>
                    }
                </div>

                @if (CallExecutionHistory.Count > 0)
                {
                    <div style="height:280px; position:relative;">
                        <canvas id="callHistoryChart"></canvas>
                    </div>
                }
                else if (!IsChartLoading)
                {
                    <div class="typo-body2" style="color:var(--color-text-secondary); padding:24px; text-align:center; background:var(--color-surface-variant, #f5f5f5); border-radius:8px;">
                        <span class="material-icons" style="font-size:32px; display:block; margin-bottom:8px; opacity:0.5;">timeline</span>
                        실행 이력이 없습니다.
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "flow")]
    public string? QueryFlow { get; set; }

    private List<FlowHeatmapGroup> AllGroups { get; set; } = new();
    private List<FlowHeatmapGroup> FilteredGroups => string.IsNullOrWhiteSpace(FlowFilter)
        ? AllGroups
        : AllGroups.Where(g => g.FlowName.Contains(FlowFilter, StringComparison.OrdinalIgnoreCase)).ToList();

    // 메트릭 선택
    private readonly List<HeatmapMetric> AvailableMetrics = new()
    {
        HeatmapMetric.AverageTime,
        HeatmapMetric.StdDeviation,
        HeatmapMetric.CoefficientOfVariation
    };

    private HeatmapMetric SelectedMetric { get; set; } = HeatmapMetric.CoefficientOfVariation;

    private string FlowFilter { get; set; } = string.Empty;
    private bool IsLoading { get; set; } = false;
    private bool AllExpanded { get; set; } = true;
    private int MatrixColumns { get; set; } = 6;
    private CallHeatmapItem? SelectedCall { get; set; } = null;

    // 차트
    private List<CallExecutionRecord> CallExecutionHistory { get; set; } = new();
    private bool IsChartLoading { get; set; } = false;

    // 정렬
    private enum SortField { CallName, WorkName, AvgTime, StdDev, CV }
    private SortField _currentSortField = SortField.CV;
    private bool _sortAsc = false;

    // 요약 통계
    private int TotalCalls => FilteredGroups.Sum(g => g.CallCount);
    private int IssueCalls => FilteredGroups.Sum(GetIssueCount);
    private double SelectedMetricAverage => FilteredGroups.Count > 0
        ? FilteredGroups.SelectMany(g => g.Calls).Average(c => c.GetMetricValue(SelectedMetric))
        : 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(QueryFlow))
        {
            FlowFilter = QueryFlow.Trim();
        }
    }

    private void OnMetricChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var idx) && idx >= 0 && idx < AvailableMetrics.Count)
            SelectedMetric = AvailableMetrics[idx];
    }

    private void OnMatrixColumnsChanged(int value)
    {
        MatrixColumns = Math.Clamp(value, 1, 12);
    }

    private string GetWorkMatrixStyle(int count)
    {
        return $"grid-template-columns: repeat(auto-fill, minmax(118px, 1fr));";
    }

    private List<WorkHeatmapGroup> GetWorkGroups(FlowHeatmapGroup group)
    {
        return group.Calls
            .GroupBy(call => string.IsNullOrWhiteSpace(call.WorkName) ? "No Work" : call.WorkName)
            .Select(workGroup => new WorkHeatmapGroup(
                workGroup.Key,
                workGroup.OrderBy(call => call.CallName).ToList()))
            .OrderBy(workGroup => workGroup.WorkName)
            .ToList();
    }

    private double GetFlowAverageValue(FlowHeatmapGroup group)
    {
        if (SelectedMetric.IsAverageTime) return group.FlowAverageTime;
        if (SelectedMetric.IsStdDeviation) return group.FlowAverageStdDev;
        if (SelectedMetric.IsCoefficientOfVariation) return group.FlowAverageCV;
        return 0.0;
    }

    private async Task LoadDataAsync()
    {
        IsLoading = true;
        StateHasChanged();

        try
        {
            AllGroups = await HeatmapService.GetHeatmapDataAsync();
            Logger.LogInformation("Heatmap matrix data loaded: {Count} flow groups", AllGroups.Count);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load heatmap data");
            AllGroups = new List<FlowHeatmapGroup>();
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private void ToggleFlowGroupMatrix()
    {
        AllExpanded = !AllExpanded;
    }

    private async Task SelectCall(CallHeatmapItem call)
    {
        if (SelectedCall == call)
        {
            SelectedCall = null;
            CallExecutionHistory = new();
            await JS.InvokeVoidAsync("destroyCallHistoryChart");
            return;
        }

        SelectedCall = call;
        CallExecutionHistory = new();
        IsChartLoading = true;
        StateHasChanged();

        try
        {
            CallExecutionHistory = await HeatmapService.GetCallExecutionHistoryAsync(call.CallId);

            if (CallExecutionHistory.Count > 0)
            {
                StateHasChanged();
                await Task.Delay(50); // canvas 렌더링 대기

                var chartData = CallExecutionHistory.Select(r => new
                {
                    executionNumber = r.ExecutionNumber,
                    goingTimeMs = r.GoingTimeMs,
                    timestamp = r.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")
                }).ToArray();

                await JS.InvokeVoidAsync("renderCallHistoryChart",
                    "callHistoryChart",
                    chartData,
                    call.AverageGoingTime,
                    call.StdDevGoingTime);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load execution history for Call {CallName}", call.CallName);
        }
        finally
        {
            IsChartLoading = false;
            StateHasChanged();
        }
    }

    private async Task CloseCallModal()
    {
        SelectedCall = null;
        CallExecutionHistory = new();
        await JS.InvokeVoidAsync("destroyCallHistoryChart");
    }

    // 정렬
    private void SortBy(SortField field)
    {
        if (_currentSortField == field)
            _sortAsc = !_sortAsc;
        else
        {
            _currentSortField = field;
            _sortAsc = field is SortField.CallName or SortField.WorkName;
        }
    }

    private IEnumerable<CallHeatmapItem> GetSortedCalls(FlowHeatmapGroup group)
    {
        var calls = group.Calls.AsEnumerable();
        Func<CallHeatmapItem, double> numericKey = _currentSortField switch
        {
            SortField.AvgTime => c => c.AverageGoingTime,
            SortField.StdDev => c => c.StdDevGoingTime,
            SortField.CV => c => c.CoefficientOfVariation,
            _ => null!
        };

        if (_currentSortField == SortField.CallName)
            return _sortAsc ? calls.OrderBy(c => c.CallName) : calls.OrderByDescending(c => c.CallName);
        if (_currentSortField == SortField.WorkName)
            return _sortAsc ? calls.OrderBy(c => c.WorkName) : calls.OrderByDescending(c => c.WorkName);

        return _sortAsc ? calls.OrderBy(numericKey) : calls.OrderByDescending(numericKey);
    }

    private MarkupString SortIcon(SortField field)
    {
        if (_currentSortField != field) return new MarkupString("");
        var icon = _sortAsc ? "arrow_upward" : "arrow_downward";
        return new MarkupString($"<span class=\"material-icons\" style=\"font-size:14px; vertical-align:middle;\">{icon}</span>");
    }

    private static string GetCVStatusText(double cv)
    {
        if (cv < 0.1) return "매우 안정적";
        if (cv < 0.2) return "안정적";
        if (cv < 0.3) return "보통";
        if (cv < 0.5) return "불안정";
        return "매우 불안정";
    }

    private static string GetGoingCountStatusText(int goingCount)
    {
        if (goingCount >= 30) return "샘플 충분";
        if (goingCount >= 10) return "샘플 보통";
        return "샘플 적음";
    }

    private int GetIssueCount(FlowHeatmapGroup group) =>
        group.Calls.Count(IsIssueCall);

    private bool IsIssueCall(CallHeatmapItem call)
    {
        var colorClass = call.GetColorClass(SelectedMetric);
        return colorClass is "heatmap-poor" or "heatmap-critical";
    }

    private string BuildCallTooltip(CallHeatmapItem call)
    {
        var selectedMetricName = HeatmapService.GetMetricDisplayName(SelectedMetric);
        var selectedMetricValue = HeatmapService.FormatMetricValue(SelectedMetric, call.GetMetricValue(SelectedMetric));

        return $"[{call.CallName}]\n" +
               $"Flow: {call.FlowName}\n" +
               $"Work: {call.WorkName}\n" +
               $"평균: {call.AverageGoingTime:F0} ms\n" +
               $"표준편차: {call.StdDevGoingTime:F0} ms\n" +
               $"변동계수: {call.CoefficientOfVariation:F2} ({GetCVStatusText(call.CoefficientOfVariation)})\n" +
               $"실행횟수: {call.GoingCount}회\n" +
               $"{selectedMetricName}: {selectedMetricValue}";
    }

    private async Task ExportCsv()
    {
        var groups = FilteredGroups;
        if (groups.Count == 0) return;

        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Flow,Call,Work,평균(ms),표준편차(ms),변동계수,실행횟수");

        foreach (var group in groups)
        {
            foreach (var call in GetSortedCalls(group))
            {
                sb.AppendLine(string.Join(",",
                    CsvEscape(call.FlowName),
                    CsvEscape(call.CallName),
                    CsvEscape(call.WorkName),
                    $"{call.AverageGoingTime:F0}",
                    $"{call.StdDevGoingTime:F0}",
                    $"{call.CoefficientOfVariation:F2}",
                    call.GoingCount));
            }
        }

        var fileName = $"Heatmap_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        var bytes = System.Text.Encoding.UTF8.GetPreamble().Concat(System.Text.Encoding.UTF8.GetBytes(sb.ToString())).ToArray();
        var base64 = Convert.ToBase64String(bytes);

        await JS.InvokeVoidAsync("eval", $@"
            (function() {{
                var byteChars = atob('{base64}');
                var bytes = new Uint8Array(byteChars.length);
                for (var i = 0; i < byteChars.length; i++) bytes[i] = byteChars.charCodeAt(i);
                var blob = new Blob([bytes], {{ type: 'text/csv;charset=utf-8' }});
                var a = document.createElement('a');
                a.href = URL.createObjectURL(blob);
                a.download = '{fileName}';
                a.click();
                URL.revokeObjectURL(a.href);
            }})();
        ");
    }

    private static string CsvEscape(string value)
    {
        if (string.IsNullOrEmpty(value)) return "";
        if (value.Contains(',') || value.Contains('"') || value.Contains('\n'))
            return "\"" + value.Replace("\"", "\"\"") + "\"";
        return value;
    }

    private sealed record WorkHeatmapGroup(string WorkName, List<CallHeatmapItem> Calls);
