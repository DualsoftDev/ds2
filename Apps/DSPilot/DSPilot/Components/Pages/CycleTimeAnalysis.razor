@page "/cycle-time-analysis"
@rendermode InteractiveServer
@using DSPilot.Services
@using DSPilot.Models.Analysis
@using DSPilot.Repositories
@using Microsoft.AspNetCore.Components.Rendering
@inject PlcToCallMapperService CallMapper
@inject IPlcRepository PlcRepository
@inject CycleAnalysisService CycleAnalysis
@inject IJSRuntime JS

<PageTitle>Cycle Time Analysis - DSPilot</PageTitle>

<div class="cycle-time-analysis">
    <div class="page-header">
        <h3>사이클 분석</h3>
        <div class="header-actions">
            <select class="form-field" @bind="_selectedFlowName" @bind:after="OnFlowChanged">
                <option value="">-- Flow 선택 --</option>
                @foreach (var flow in _flows)
                {
                    <option value="@flow">@flow</option>
                }
            </select>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_selectedFlowName))
    {
        <div class="chart-filter-panel">
            <h4>시간 범위 설정</h4>
            <div class="filter-row">
                <div class="filter-group">
                    <label>시작 시간</label>
                    <input type="datetime-local" class="form-field" @bind="_chartStartTime" />
                </div>
                <div class="filter-group">
                    <label>종료 시간</label>
                    <input type="datetime-local" class="form-field" @bind="_chartEndTime" />
                </div>
                <div class="filter-group">
                    <label>&nbsp;</label>
                    <button class="btn btn-primary" @onclick="LoadGanttData">
                        GAP 분석 시작
                    </button>
                </div>
            </div>
            <div class="filter-row">
                <button class="btn btn-sm" @onclick="() => SetTimeRangeMinutes(1)">최근 1분</button>
                <button class="btn btn-sm" @onclick="() => SetTimeRangeMinutes(2)">최근 2분</button>
                <button class="btn btn-sm" @onclick="() => SetTimeRangeMinutes(5)">최근 5분</button>
                <button class="btn btn-sm" @onclick="() => SetTimeRangeMinutes(10)">최근 10분</button>
                <button class="btn btn-sm" @onclick="() => SetTimeRangeMinutes(30)">최근 30분</button>
                <button class="btn btn-sm" @onclick="() => SetTimeRange(1)">최근 1시간</button>
            </div>

            @if (_ganttData != null)
            {
                <div class="filter-row">
                    <div class="filter-group">
                        <label>정렬 방식</label>
                        <select class="form-field" value="@_chartSort" @onchange="OnChartSortChanged">
                            <option value="@ChartSortMode.ByLane">Lane별</option>
                            <option value="@ChartSortMode.ByTime">시간순</option>
                            <option value="@ChartSortMode.ByCallName">Call 이름순</option>
                            <option value="@ChartSortMode.ByGapSize">GAP 크기순</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>Zoom</label>
                        <input type="range" min="0.5" max="3.0" step="0.1" @bind="_zoomLevel" @bind:after="StateHasChanged" />
                        <span>@_zoomLevel.ToString("F1")x</span>
                    </div>
                </div>
            }
        </div>
    }

    @if (_isLoading)
    {
        <div class="loading-container">
            <div class="spinner"></div>
            <p>데이터 로딩 중...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-error">
            <span class="material-icons">error</span>
            @_errorMessage
        </div>
    }
    else if (_ganttData != null && _ganttData.Items.Any())
    {
        <!-- Gantt Chart Info Bar -->
        <div class="gantt-info-bar">
            <div class="info-item">
                <span class="label">Flow:</span>
                <span class="value">@_ganttData.FlowName</span>
            </div>
            <div class="info-item">
                <span class="label">시간 범위:</span>
                <span class="value">@_ganttData.StartTime.ToString("HH:mm:ss") ~ @(_ganttData.EndTime?.ToString("HH:mm:ss") ?? "N/A")</span>
            </div>
            <div class="info-item">
                <span class="label">총 이벤트:</span>
                <span class="value">@_ganttData.TotalEventCount (@_ganttData.RenderedEventCount 렌더링)</span>
            </div>
            <div class="info-item">
                <span class="label">Lane 수:</span>
                <span class="value">@_ganttData.TotalLanes</span>
            </div>
            @if (_topGaps.Any())
            {
                <div class="info-item highlight gap-picker">
                    <span class="label">최대 GAP (Top 5):</span>
                    <select class="form-field gap-picker-select" value="@_selectedGapIndex" @onchange="OnGapSelectedChanged">
                        @for (int i = 0; i < _topGaps.Count; i++)
                        {
                            var gap = _topGaps[i];
                            var label = $"#{i + 1}: {(gap.Duration / 1000.0):F2}s | {gap.Start:HH:mm:ss} ~ {gap.End:HH:mm:ss}";
                            <option value="@i">@label</option>
                        }
                    </select>
                </div>
            }
        </div>

        <!-- Full-Screen Gantt Chart -->
        <div class="gantt-chart-container">
            <div class="gantt-chart-wrapper" style="transform: scale(@_zoomLevel); transform-origin: top left;">
                @RenderGanttChart(_ganttData)
            </div>
        </div>

        <!-- Selected Item Detail Panel -->
        @if (_selectedItem != null)
        {
            <div class="item-detail-panel">
                <div class="detail-header">
                    <h4>@_selectedItem.CallName</h4>
                    <button class="btn btn-sm" @onclick="ClearSelection">
                        <span class="material-icons">close</span>
                    </button>
                </div>
                <div class="detail-content">
                    <div class="detail-row">
                        <span class="detail-label">Work:</span>
                        <span class="detail-value">@_selectedItem.WorkName</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Tag:</span>
                        <span class="detail-value">@_selectedItem.TagName (@_selectedItem.TagAddress)</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Event Type:</span>
                        <span class="detail-value">@_selectedItem.EventType</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">시작 시간:</span>
                        <span class="detail-value">@_selectedItem.GoingStartTime.ToString("HH:mm:ss.fff")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">종료 시간:</span>
                        <span class="detail-value">@(_selectedItem.FinishTime?.ToString("HH:mm:ss.fff") ?? "진행중")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Duration:</span>
                        <span class="detail-value">@FormatDurationTooltip(GetItemDurationMs(_selectedItem))</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Lane:</span>
                        <span class="detail-value">@_selectedItem.Lane - @_ganttData.LaneLabels[_selectedItem.Lane]</span>
                    </div>

                    @if (_previousGap.HasValue)
                    {
                        <div class="detail-row gap-info">
                            <span class="detail-label">이전 GAP:</span>
                            <span class="detail-value">@FormatDurationTooltip(_previousGap.Value)</span>
                        </div>
                    }
                    @if (_nextGap.HasValue)
                    {
                        <div class="detail-row gap-info">
                            <span class="detail-label">다음 GAP:</span>
                            <span class="detail-value">@FormatDurationTooltip(_nextGap.Value)</span>
                        </div>
                    }
                </div>
            </div>
        }
    }
    else if (!string.IsNullOrEmpty(_selectedFlowName))
    {
        <div class="empty-state">
            <span class="material-icons">bar_chart</span>
            <p>시간 범위를 설정하고 'GAP 분석 시작' 버튼을 클릭하세요</p>
        </div>
    }
    else
    {
        <div class="empty-state">
            <span class="material-icons">bar_chart</span>
            <p>Flow를 선택하세요</p>
        </div>
    }
</div>

@code {
    private List<string> _flows = new();
    private string _selectedFlowName = "";
    private bool _isLoading = false;
    private string? _errorMessage;

    private DateTime _chartStartTime = DateTime.Now.AddHours(-1);
    private DateTime _chartEndTime = DateTime.Now;

    private GanttChartData? _ganttData;
    private GanttChartItem? _selectedItem;
    private (DateTime Start, DateTime End, double Duration)? _longestGap;
    private List<(DateTime Start, DateTime End, double Duration)> _topGaps = new();
    private int _selectedGapIndex = 0;
    private double? _previousGap;
    private double? _nextGap;

    private ChartSortMode _chartSort = ChartSortMode.ByLane;
    private double _zoomLevel = 1.0;

    private enum ChartSortMode
    {
        ByLane,      // Lane별 정렬 (기본)
        ByTime,      // 시작 시간순 정렬
        ByCallName,  // Call 이름순 정렬
        ByGapSize    // GAP 크기순 정렬
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadFlows();

        // 첫 번째 Flow가 선택되었으면 자동으로 GAP 분석 시작
        if (!string.IsNullOrEmpty(_selectedFlowName))
        {
            await LoadGanttData();
        }
    }

    private Task LoadFlows()
    {
        try
        {
            var mappings = CallMapper.GetAllMappings();
            _flows = mappings
                .Select(m => m.FlowName)
                .Where(f => !string.IsNullOrEmpty(f))
                .Distinct()
                .OrderBy(f => f)
                .ToList();

            // 첫 번째 Flow 자동 선택
            if (_flows.Any() && string.IsNullOrEmpty(_selectedFlowName))
            {
                _selectedFlowName = _flows.First();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Flow 로딩 실패: {ex.Message}";
        }
        return Task.CompletedTask;
    }

    private async Task OnFlowChanged()
    {
        _ganttData = null;
        _selectedItem = null;
        _longestGap = null;
        _topGaps.Clear();
        StateHasChanged();

        // Flow 변경 시 자동으로 GAP 분석 시작
        if (!string.IsNullOrEmpty(_selectedFlowName))
        {
            await LoadGanttData();
        }
    }

    private void SetTimeRange(int hours)
    {
        _chartEndTime = DateTime.Now;
        _chartStartTime = _chartEndTime.AddHours(-hours);
        StateHasChanged();
    }

    private void SetTimeRangeMinutes(int minutes)
    {
        _chartEndTime = DateTime.Now;
        _chartStartTime = _chartEndTime.AddMinutes(-minutes);
        StateHasChanged();
    }

    private async Task LoadGanttData()
    {
        _isLoading = true;
        _errorMessage = null;
        _ganttData = null;
        _selectedItem = null;
        _longestGap = null;
        StateHasChanged();

        try
        {
            _ganttData = await CycleAnalysis.GetActualIoSignalSegmentsInTimeRangeAsync(
                _selectedFlowName,
                _chartStartTime,
                _chartEndTime);

            if (_ganttData.Items.Any())
            {
                // 실제 데이터 범위로 시간 범위 자동 조정
                if (_ganttData.ActualEventStartTime.HasValue && _ganttData.ActualEventEndTime.HasValue)
                {
                    _chartStartTime = _ganttData.ActualEventStartTime.Value;
                    _chartEndTime = _ganttData.ActualEventEndTime.Value;
                }

                CalculateLongestGap();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"데이터 로딩 실패: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void CalculateLongestGap()
    {
        _longestGap = null;
        _topGaps.Clear();
        _selectedGapIndex = 0;

        if (_ganttData == null || _ganttData.Items.Count < 2)
            return;

        var sortedItems = GetSortedItemsForGapAnalysis();
        var allGaps = new List<(DateTime Start, DateTime End, double Duration)>();

        for (int i = 0; i < sortedItems.Count - 1; i++)
        {
            var current = sortedItems[i];
            var next = sortedItems[i + 1];

            var currentEnd = current.FinishTime ?? current.GoingStartTime;
            var nextStart = next.GoingStartTime;

            var gapDuration = (nextStart - currentEnd).TotalMilliseconds;

            if (gapDuration > 0)
            {
                allGaps.Add((currentEnd, nextStart, gapDuration));
            }
        }

        // 상위 5개 GAP 선택
        _topGaps = allGaps
            .OrderByDescending(g => g.Duration)
            .Take(5)
            .ToList();

        if (_topGaps.Any())
        {
            _longestGap = _topGaps[0];
        }
    }

    private Task OnGapSelected()
    {
        if (_selectedGapIndex >= 0 && _selectedGapIndex < _topGaps.Count)
        {
            _longestGap = _topGaps[_selectedGapIndex];
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    private Task OnGapSelectedChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var index))
        {
            _selectedGapIndex = index;
        }

        return OnGapSelected();
    }

    private Task OnChartSortChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<ChartSortMode>(e.Value?.ToString(), out var mode))
        {
            _chartSort = mode;
        }

        StateHasChanged();
        return Task.CompletedTask;
    }

    private List<GanttChartItem> GetSortedItemsForGapAnalysis()
    {
        if (_ganttData == null) return new List<GanttChartItem>();

        return _ganttData.Items
            .OrderBy(item => item.GoingStartTime)
            .ThenBy(item => item.FinishTime ?? item.GoingStartTime)
            .ToList();
    }

    private List<GanttChartItem> GetSortedItemsForDisplay()
    {
        if (_ganttData == null) return new List<GanttChartItem>();

        var laneOrder = GetDisplayLaneOrder();
        var laneIndexByLane = laneOrder
            .Select((lane, index) => new { lane, index })
            .ToDictionary(x => x.lane, x => x.index);

        return _chartSort switch
        {
            ChartSortMode.ByLane => _ganttData.Items.OrderBy(i => i.Lane).ThenBy(i => i.GoingStartTime).ToList(),
            ChartSortMode.ByTime => _ganttData.Items.OrderBy(i => i.GoingStartTime).ToList(),
            ChartSortMode.ByCallName => _ganttData.Items
                .OrderBy(i => laneIndexByLane.GetValueOrDefault(i.Lane, i.Lane))
                .ThenBy(i => i.GoingStartTime)
                .ToList(),
            ChartSortMode.ByGapSize => _ganttData.Items
                .OrderBy(i => laneIndexByLane.GetValueOrDefault(i.Lane, i.Lane))
                .ThenBy(i => i.GoingStartTime)
                .ToList(),
            _ => _ganttData.Items.OrderBy(i => i.Lane).ThenBy(i => i.GoingStartTime).ToList()
        };
    }

    private List<int> GetDisplayLaneOrder()
    {
        if (_ganttData == null)
        {
            return new List<int>();
        }

        var laneStats = _ganttData.Items
            .GroupBy(item => item.Lane)
            .Select(group =>
            {
                var ordered = group.OrderBy(item => item.GoingStartTime).ToList();
                var label = group.Key >= 0 && group.Key < _ganttData.LaneLabels.Count
                    ? _ganttData.LaneLabels[group.Key]
                    : $"Lane {group.Key}";

                return new
                {
                    Lane = group.Key,
                    Label = label,
                    FirstStart = ordered.FirstOrDefault()?.GoingStartTime ?? DateTime.MaxValue,
                    MaxGap = CalculateMaxGap(ordered)
                };
            })
            .ToList();

        return _chartSort switch
        {
            ChartSortMode.ByTime => laneStats
                .OrderBy(stat => stat.FirstStart)
                .ThenBy(stat => stat.Lane)
                .Select(stat => stat.Lane)
                .ToList(),
            ChartSortMode.ByCallName => laneStats
                .OrderBy(stat => stat.Label, StringComparer.OrdinalIgnoreCase)
                .ThenBy(stat => stat.Lane)
                .Select(stat => stat.Lane)
                .ToList(),
            ChartSortMode.ByGapSize => laneStats
                .OrderByDescending(stat => stat.MaxGap)
                .ThenBy(stat => stat.FirstStart)
                .ThenBy(stat => stat.Lane)
                .Select(stat => stat.Lane)
                .ToList(),
            _ => laneStats
                .OrderBy(stat => stat.Lane)
                .Select(stat => stat.Lane)
                .ToList()
        };
    }

    private static double CalculateMaxGap(List<GanttChartItem> orderedItems)
    {
        if (orderedItems.Count < 2)
        {
            return 0;
        }

        double maxGap = 0;
        for (int i = 0; i < orderedItems.Count - 1; i++)
        {
            var currentEnd = orderedItems[i].FinishTime ?? orderedItems[i].GoingStartTime;
            var nextStart = orderedItems[i + 1].GoingStartTime;
            maxGap = Math.Max(maxGap, (nextStart - currentEnd).TotalMilliseconds);
        }

        return maxGap;
    }

    private Dictionary<GanttChartItem, double> CalculateItemGaps()
    {
        var gapMap = new Dictionary<GanttChartItem, double>();
        if (_ganttData == null) return gapMap;

        var sortedItems = GetSortedItemsForGapAnalysis();

        for (int i = 0; i < sortedItems.Count; i++)
        {
            var current = sortedItems[i];
            double maxGap = 0;

            if (i > 0)
            {
                var prev = sortedItems[i - 1];
                var prevEnd = prev.FinishTime ?? prev.GoingStartTime;
                maxGap = Math.Max(maxGap, (current.GoingStartTime - prevEnd).TotalMilliseconds);
            }

            if (i < sortedItems.Count - 1)
            {
                var next = sortedItems[i + 1];
                var currentEnd = current.FinishTime ?? current.GoingStartTime;
                maxGap = Math.Max(maxGap, (next.GoingStartTime - currentEnd).TotalMilliseconds);
            }

            gapMap[current] = maxGap;
        }

        return gapMap;
    }

    private void SelectItem(GanttChartItem item)
    {
        _selectedItem = item;
        CalculateItemGaps(item);
        StateHasChanged();
    }

    private void CalculateItemGaps(GanttChartItem item)
    {
        _previousGap = null;
        _nextGap = null;

        if (_ganttData == null) return;

        var sortedItems = GetSortedItemsForGapAnalysis();
        var index = sortedItems.FindIndex(i => i == item);

        if (index == -1) return;

        if (index > 0)
        {
            var prev = sortedItems[index - 1];
            var prevEnd = prev.FinishTime ?? prev.GoingStartTime;
            _previousGap = (item.GoingStartTime - prevEnd).TotalMilliseconds;
        }

        if (index < sortedItems.Count - 1)
        {
            var next = sortedItems[index + 1];
            var currentEnd = item.FinishTime ?? item.GoingStartTime;
            _nextGap = (next.GoingStartTime - currentEnd).TotalMilliseconds;
        }
    }

    private void ClearSelection()
    {
        _selectedItem = null;
        _previousGap = null;
        _nextGap = null;
        StateHasChanged();
    }

    // SVG Gantt Chart Rendering
    private RenderFragment RenderGanttChart(GanttChartData data) => builder =>
    {
        const int leftMargin = 220;
        const int topMargin = 60;
        const int laneHeight = 52;
        const int barHeight = 14;
        const int plotWidth = 2000;

        var chartStartTime = data.ActualEventStartTime ?? data.StartTime;
        var chartEndTime = data.ActualEventEndTime ?? (data.EndTime ?? data.StartTime.AddSeconds(1));
        var cycleTime = Math.Max((int)(chartEndTime - chartStartTime).TotalMilliseconds, 1);
        var xScale = plotWidth / (double)cycleTime;

        var sortedItems = GetSortedItemsForDisplay();
        var displayLaneOrder = GetDisplayLaneOrder();
        var displayLaneIndexByLane = displayLaneOrder
            .Select((lane, index) => new { lane, index })
            .ToDictionary(x => x.lane, x => x.index);
        var totalHeight = topMargin + (data.TotalLanes * laneHeight) + 100;

        builder.OpenElement(0, "svg");
        builder.AddAttribute(1, "class", "gantt-chart");
        builder.AddAttribute(2, "width", leftMargin + plotWidth + 100);
        builder.AddAttribute(3, "height", totalHeight);
        builder.AddAttribute(4, "xmlns", "http://www.w3.org/2000/svg");

        // Background
        builder.OpenElement(5, "rect");
        builder.AddAttribute(6, "width", "100%");
        builder.AddAttribute(7, "height", "100%");
        builder.AddAttribute(8, "fill", "#fafafa");
        builder.CloseElement();

        // Time axis
        RenderTimeAxis(builder, 10, leftMargin, topMargin, plotWidth, chartStartTime, chartEndTime, xScale);

        // Lanes
        for (int displayLane = 0; displayLane < displayLaneOrder.Count; displayLane++)
        {
            var lane = displayLaneOrder[displayLane];
            var y = topMargin + (displayLane * laneHeight);

            // Lane background
            builder.OpenElement(20, "rect");
            builder.AddAttribute(21, "x", leftMargin);
            builder.AddAttribute(22, "y", y);
            builder.AddAttribute(23, "width", plotWidth);
            builder.AddAttribute(24, "height", laneHeight);
            builder.AddAttribute(25, "fill", displayLane % 2 == 0 ? "#ffffff" : "#f5f5f5");
            builder.AddAttribute(26, "stroke", "#e0e0e0");
            builder.AddAttribute(27, "stroke-width", "1");
            builder.CloseElement();

            builder.OpenElement(27, "line");
            builder.AddAttribute(28, "x1", leftMargin);
            builder.AddAttribute(29, "y1", y + (laneHeight / 2));
            builder.AddAttribute(30, "x2", leftMargin + plotWidth);
            builder.AddAttribute(31, "y2", y + (laneHeight / 2));
            builder.AddAttribute(32, "stroke", "#eceff1");
            builder.AddAttribute(33, "stroke-width", "1");
            builder.CloseElement();

            // Lane label
            builder.OpenElement(34, "text");
            builder.AddAttribute(35, "x", leftMargin - 10);
            builder.AddAttribute(36, "y", y + (laneHeight / 2) - 6);
            builder.AddAttribute(37, "text-anchor", "end");
            builder.AddAttribute(38, "dominant-baseline", "middle");
            builder.AddAttribute(39, "font-size", "12");
            builder.AddAttribute(40, "font-weight", "600");
            builder.AddAttribute(41, "fill", "#333");
            builder.AddContent(42, lane >= 0 && lane < data.LaneLabels.Count ? data.LaneLabels[lane] : $"Lane {lane}");
            builder.CloseElement();

            builder.OpenElement(43, "text");
            builder.AddAttribute(44, "x", leftMargin - 10);
            builder.AddAttribute(45, "y", y + (laneHeight / 2) + 10);
            builder.AddAttribute(46, "text-anchor", "end");
            builder.AddAttribute(47, "dominant-baseline", "middle");
            builder.AddAttribute(48, "font-size", "10");
            builder.AddAttribute(49, "fill", "#78909c");
            builder.AddContent(50, "IN / OUT");
            builder.CloseElement();
        }

        // Longest GAP visualization
        if (_longestGap.HasValue)
        {
            var gapStart = _longestGap.Value.Start;
            var gapEnd = _longestGap.Value.End;
            var gapX = leftMargin + ((gapStart - chartStartTime).TotalMilliseconds * xScale);
            var gapWidth = (gapEnd - gapStart).TotalMilliseconds * xScale;

            builder.OpenElement(40, "rect");
            builder.AddAttribute(41, "x", gapX);
            builder.AddAttribute(42, "y", topMargin);
            builder.AddAttribute(43, "width", gapWidth);
            builder.AddAttribute(44, "height", data.TotalLanes * laneHeight);
            builder.AddAttribute(45, "fill", "rgba(255, 0, 0, 0.1)");
            builder.AddAttribute(46, "stroke", "rgba(255, 0, 0, 0.5)");
            builder.AddAttribute(47, "stroke-width", "2");
            builder.AddAttribute(48, "stroke-dasharray", "5,5");
            builder.CloseElement();

            // GAP label
            builder.OpenElement(49, "text");
            builder.AddAttribute(50, "x", gapX + (gapWidth / 2));
            builder.AddAttribute(51, "y", topMargin - 10);
            builder.AddAttribute(52, "text-anchor", "middle");
            builder.AddAttribute(53, "font-size", "11");
            builder.AddAttribute(54, "font-weight", "bold");
            builder.AddAttribute(55, "fill", "#d32f2f");
            builder.AddContent(56, $"최대 GAP: {(_longestGap.Value.Duration / 1000.0):F2}s");
            builder.CloseElement();
        }

        // Gantt bars
        foreach (var item in sortedItems)
        {
            var displayLane = displayLaneIndexByLane.GetValueOrDefault(item.Lane, item.Lane);
            var laneTop = topMargin + (displayLane * laneHeight);
            var y = item.EventType == IOEventType.InTag
                ? laneTop + 7
                : laneTop + 29;
            var x = leftMargin + (item.RelativeStart * xScale);
            var durationMs = GetItemDurationMs(item);
            var width = Math.Max(2, Math.Max(durationMs, 1) * xScale);

            var isSelected = _selectedItem == item;
            var fillColor = item.EventType == IOEventType.InTag ? "#42a5f5" : "#f8a8c8";
            var strokeColor = isSelected ? "#ff9800" : (item.EventType == IOEventType.InTag ? "#1e88e5" : "#e58ab0");
            var eventLabel = item.EventType == IOEventType.InTag ? "InTag" : "OutTag";
            var endLabel = item.FinishTime?.ToString("HH:mm:ss.fff") ?? "진행중";
            var tooltipText = string.Join("\n", new[]
            {
                $"Call: {item.CallName}",
                $"Work: {item.WorkName}",
                $"Tag: {item.TagName} ({item.TagAddress})",
                $"Event: {eventLabel}",
                $"Start: {item.GoingStartTime:HH:mm:ss.fff}",
                $"End: {endLabel}",
                $"Duration: {FormatDurationTooltip(durationMs)}"
            });

            builder.OpenElement(60, "g");
            builder.AddAttribute(61, "style", "cursor: pointer;");
            builder.AddAttribute(62, "onclick", EventCallback.Factory.Create(this, () => SelectItem(item)));

            builder.OpenElement(63, "title");
            builder.AddContent(64, tooltipText);
            builder.CloseElement();

            builder.OpenElement(65, "rect");
            builder.AddAttribute(66, "x", x);
            builder.AddAttribute(67, "y", y);
            builder.AddAttribute(68, "width", width);
            builder.AddAttribute(69, "height", barHeight);
            builder.AddAttribute(70, "fill", fillColor);
            builder.AddAttribute(71, "stroke", strokeColor);
            builder.AddAttribute(72, "stroke-width", isSelected ? "3" : "1");
            builder.AddAttribute(73, "rx", "4");
            builder.CloseElement();

            // Bar label (if wide enough)
            if (width > 30)
            {
                builder.OpenElement(74, "text");
                builder.AddAttribute(75, "x", x + (width / 2));
                builder.AddAttribute(76, "y", y + (barHeight / 2));
                builder.AddAttribute(77, "text-anchor", "middle");
                builder.AddAttribute(78, "dominant-baseline", "middle");
                builder.AddAttribute(79, "font-size", "10");
                builder.AddAttribute(80, "fill", "white");
                builder.AddAttribute(81, "style", "pointer-events: none;");
                builder.AddContent(82, item.EventType == IOEventType.InTag ? "In" : "Out");
                builder.CloseElement();
            }

            builder.CloseElement();
        }

        builder.CloseElement(); // svg
    };

    private void RenderTimeAxis(RenderTreeBuilder builder, int sequence, int leftMargin, int topMargin, int plotWidth, DateTime startTime, DateTime endTime, double xScale)
    {
        var duration = (endTime - startTime).TotalMilliseconds;
        var tickCount = 20;
        var tickInterval = duration / tickCount;

        // Axis line
        builder.OpenElement(sequence++, "line");
        builder.AddAttribute(sequence++, "x1", leftMargin);
        builder.AddAttribute(sequence++, "y1", topMargin - 5);
        builder.AddAttribute(sequence++, "x2", leftMargin + plotWidth);
        builder.AddAttribute(sequence++, "y2", topMargin - 5);
        builder.AddAttribute(sequence++, "stroke", "#333");
        builder.AddAttribute(sequence++, "stroke-width", "2");
        builder.CloseElement();

        // Ticks and labels
        for (int i = 0; i <= tickCount; i++)
        {
            var x = leftMargin + (i * plotWidth / tickCount);
            var tickTime = startTime.AddMilliseconds(i * tickInterval);

            // Tick mark
            builder.OpenElement(sequence++, "line");
            builder.AddAttribute(sequence++, "x1", x);
            builder.AddAttribute(sequence++, "y1", topMargin - 5);
            builder.AddAttribute(sequence++, "x2", x);
            builder.AddAttribute(sequence++, "y2", topMargin - 10);
            builder.AddAttribute(sequence++, "stroke", "#333");
            builder.AddAttribute(sequence++, "stroke-width", "1");
            builder.CloseElement();

            // Tick label
            builder.OpenElement(sequence++, "text");
            builder.AddAttribute(sequence++, "x", x);
            builder.AddAttribute(sequence++, "y", topMargin - 15);
            builder.AddAttribute(sequence++, "text-anchor", "middle");
            builder.AddAttribute(sequence++, "font-size", "10");
            builder.AddAttribute(sequence++, "fill", "#666");
            builder.AddContent(sequence++, tickTime.ToString("HH:mm:ss"));
            builder.CloseElement();
        }
    }

    private static int GetItemDurationMs(GanttChartItem item)
    {
        if (item.Duration.HasValue && item.Duration.Value > 0)
        {
            return item.Duration.Value;
        }

        if (item.RelativeEnd.HasValue)
        {
            return Math.Max(0, item.RelativeEnd.Value - item.RelativeStart);
        }

        if (item.FinishTime.HasValue)
        {
            return Math.Max(0, (int)(item.FinishTime.Value - item.GoingStartTime).TotalMilliseconds);
        }

        return 0;
    }

    private static string FormatDurationTooltip(double durationMs)
    {
        return $"{durationMs / 1000.0:F1} (sec)";
    }
}
