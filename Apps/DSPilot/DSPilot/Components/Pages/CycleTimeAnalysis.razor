@page "/cycle-time-analysis"
@using DSPilot.Services
@using DSPilot.Models.Analysis
@using DSPilot.Repositories
@using Microsoft.AspNetCore.Components.Rendering
@inject PlcToCallMapperService CallMapper
@inject IPlcRepository PlcRepository
@inject CycleAnalysisService CycleAnalysis
@inject IFlowMetricsService FlowMetrics
@inject AppSettingsService SettingsService
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Cycle Time Analysis - DSPilot</PageTitle>

<div class="cycle-time-analysis">
    <div class="chart-filter-panel">
        <div class="filter-row">
            <div class="filter-group">
                <label>Flow 선택</label>
                <select class="form-field" @bind="_selectedFlowName" @bind:after="OnFlowChanged">
                    <option value="">-- Flow 선택 --</option>
                    @foreach (var flow in _flows)
                    {
                        <option value="@flow">@flow</option>
                    }
                </select>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_selectedFlowName))
    {
        <div class="chart-filter-panel">
            <h4>시간 범위 설정</h4>
            <div class="filter-row">
                <div class="filter-group">
                    <label>시작 시간</label>
                    <input type="datetime-local" class="form-field" @bind="_chartStartTime" @bind:after="OnTimeRangeChanged" />
                    <div class="time-preset-buttons">
                        <button class="btn btn-sm" @onclick="() => SetDurationMinutes(1)">시작 1분</button>
                        <button class="btn btn-sm" @onclick="() => SetDurationMinutes(2)">시작 2분</button>
                        <button class="btn btn-sm" @onclick="() => SetDurationMinutes(5)">시작 5분</button>
                        <button class="btn btn-sm" @onclick="() => SetDurationMinutes(10)">시작 10분</button>
                        <button class="btn btn-sm" @onclick="() => SetDurationMinutes(30)">시작 30분</button>
                        <button class="btn btn-sm" @onclick="() => SetDurationHours(1)">시작 1시간</button>
                    </div>
                </div>
                <div class="filter-group">
                    <label>종료 시간</label>
                    <input type="datetime-local" class="form-field" @bind="_chartEndTime" @bind:after="OnTimeRangeChanged" />
                    <div class="time-preset-buttons">
                        <button class="btn btn-sm" @onclick="() => SetRecentMinutes(1)">최근 1분</button>
                        <button class="btn btn-sm" @onclick="() => SetRecentMinutes(2)">최근 2분</button>
                        <button class="btn btn-sm" @onclick="() => SetRecentMinutes(5)">최근 5분</button>
                        <button class="btn btn-sm" @onclick="() => SetRecentMinutes(10)">최근 10분</button>
                        <button class="btn btn-sm" @onclick="() => SetRecentMinutes(30)">최근 30분</button>
                        <button class="btn btn-sm" @onclick="() => SetRecentHours(1)">최근 1시간</button>
                    </div>
                </div>
            </div>

            @if (_ganttData != null)
            {
                <div class="filter-row">
                    <div class="filter-group">
                        <label>정렬 방식</label>
                        <select class="form-field" value="@_chartSort" @onchange="OnChartSortChanged">
                            <option value="@ChartSortMode.ByLane">Lane별</option>
                            <option value="@ChartSortMode.ByTime">시간순</option>
                            <option value="@ChartSortMode.ByCallName">Call 이름순</option>
                            <option value="@ChartSortMode.ByGapSize">GAP 크기순</option>
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>Zoom</label>
                        <input type="range" min="0.5" max="3.0" step="0.1" @bind="_zoomLevel"
                               oninput="(function(el){var w=document.querySelector('.gantt-chart-wrapper');if(w)w.style.transform='scale('+el.value+')';var d=document.querySelector('.zoom-display');if(d)d.textContent=parseFloat(el.value).toFixed(1)+'x';})(this)" />
                        <span class="zoom-display">@_zoomLevel.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)x</span>
                    </div>
                </div>
            }
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-error">
            <span class="material-icons">error</span>
            @_errorMessage
        </div>
    }
    @* 로딩 중에도 기존 차트 유지 — 깜빡임 방지. _ganttData 가 비어있을 때만 전체 로딩 화면. *@
    @if (_isLoading && (_ganttData == null || !_ganttData.Items.Any()))
    {
        <div class="loading-container">
            <div class="spinner"></div>
            <p>데이터 로딩 중...</p>
        </div>
    }
    else if (_ganttData != null && _ganttData.Items.Any())
    {
        <!-- Gantt Chart Info Bar -->
        <div class="gantt-info-bar">
            <div class="info-item">
                <span class="label">Flow:</span>
                <span class="value">@_ganttData.FlowName</span>
            </div>
            <div class="info-item">
                <span class="label">시간 범위:</span>
                <span class="value">@_ganttData.StartTime.ToString("HH:mm:ss") ~ @(_ganttData.EndTime?.ToString("HH:mm:ss") ?? "N/A")</span>
            </div>
            <div class="info-item">
                <span class="label">총 이벤트:</span>
                <span class="value">@_ganttData.TotalEventCount (@_ganttData.RenderedEventCount 렌더링)</span>
            </div>
            <div class="info-item">
                <span class="label">Lane 수:</span>
                <span class="value">@_ganttData.TotalLanes</span>
            </div>
            <div class="gantt-info-controls">
                <label class="gantt-info-label">
                    <input type="checkbox" @bind="_showGapOverlay" disabled="@(!_topGaps.Any())" /> GAP
                </label>
                <select class="form-field gap-picker-select" value="@_selectedGapIndex" @onchange="OnGapSelectedChanged"
                        disabled="@(!_showGapOverlay || !_topGaps.Any())" style="opacity:@(_showGapOverlay && _topGaps.Any() ? "1" : "0.4");">
                    @if (!_topGaps.Any())
                    {
                        <option value="-1">GAP 없음</option>
                    }
                    else
                    {
                        @for (int i = 0; i < _topGaps.Count; i++)
                        {
                            var gap = _topGaps[i];
                            var label = $"#{i + 1}: {(gap.Duration / 1000.0):F2}s | {gap.LaneName} | {gap.Start:HH:mm:ss} ~ {gap.End:HH:mm:ss}";
                            <option value="@i">@label</option>
                        }
                    }
                </select>
                <span class="gantt-info-separator">|</span>
                <label class="gantt-info-label">
                    <input type="checkbox" @bind="_showCycleTimeOverlay" /> Cycle Time
                </label>
                <span class="gantt-info-hint">신호 클릭 시 동일 신호의 다음 발생까지 표시</span>
                @if (_idleRegions.Any())
                {
                    <span class="gantt-info-separator">|</span>
                    <span class="gantt-idle-legend">
                        <span class="gantt-idle-swatch"></span>
                        비가동 구간
                    </span>
                }
            </div>
            <div style="display:flex; gap:4px;">
                <button class="btn btn-sm gantt-info-export" @onclick="LoadGanttData" disabled="@_isLoading" title="현재 시간 범위로 다시 조회">
                    <span class="material-icons" style="font-size:14px;vertical-align:middle;margin-right:2px;">refresh</span>새로고침
                </button>
                <button class="btn btn-sm gantt-info-export" @onclick="ExportCsv">
                    CSV 내보내기
                </button>
                <button class="btn btn-sm gantt-info-export" @onclick="ExportGanttExcel">
                    차트 내보내기
                </button>
            </div>
        </div>

        @if (_selectedItem != null)
        {
            <div class="sel-panel">
                <!-- 선택 신호 헤더 -->
                <div class="sel-header">
                    <div class="sel-selected-signal">
                        <span class="sel-badge sel-badge-selected">선택</span>
                        <strong>@_selectedItem.CallName</strong>
                        <span class="sel-event-type">@GetEventTypeLabel(_selectedItem.EventType)</span>
                        <span class="sel-time">@_selectedItem.GoingStartTime.ToString("HH:mm:ss.fff")</span>
                    </div>
                    <button class="btn btn-sm btn-outlined" @onclick="ClearSelection" style="white-space:nowrap;">선택 해제</button>
                </div>

                <!-- GAP + Cycle Time 정보 -->
                <div class="sel-info-row">
                    <!-- 이전 GAP -->
                    <div class="sel-gap-card">
                        <div class="sel-gap-direction">
                            <span class="sel-arrow sel-arrow-left"></span> 이전 GAP
                        </div>
                        <div class="sel-gap-value">@(_previousGap.HasValue ? FormatDurationTooltip(_previousGap.Value) : "-")</div>
                        @if (_previousItem != null)
                        {
                            <div class="sel-gap-signal">@_previousItem.CallName <span>@GetEventTypeLabel(_previousItem.EventType)</span></div>
                        }
                    </div>

                    @if (_comparisonItem != null)
                    {
                        <!-- Cycle Time -->
                        <div class="sel-cycle-card">
                            <div class="sel-cycle-label">Cycle Time</div>
                            <div class="sel-cycle-value">@(_comparisonGap.HasValue ? FormatDurationTooltip(_comparisonGap.Value) : "-")</div>
                            <div class="sel-cycle-signal">
                                <span class="sel-badge sel-badge-next">다음</span>
                                @_comparisonItem.CallName
                                <span class="sel-time">@_comparisonItem.GoingStartTime.ToString("HH:mm:ss.fff")</span>
                            </div>
                        </div>
                    }

                    <!-- 다음 GAP -->
                    <div class="sel-gap-card">
                        <div class="sel-gap-direction">
                            다음 GAP <span class="sel-arrow sel-arrow-right"></span>
                        </div>
                        <div class="sel-gap-value">@(_nextGap.HasValue ? FormatDurationTooltip(_nextGap.Value) : "-")</div>
                        @if (_nextItem != null)
                        {
                            <div class="sel-gap-signal">@_nextItem.CallName <span>@GetEventTypeLabel(_nextItem.EventType)</span></div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Full-Screen Gantt Chart -->
        <div class="gantt-chart-container" @ref="_ganttChartContainerRef" style="position: relative;">
            <div class="gantt-chart-wrapper" style="transform: scale(@_zoomLevel.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)); transform-origin: top left; position: relative;">
                @* base SVG (bars+axis+lanes+idle): 통째로 MarkupString 으로 갈아끼워 SVG inner 의 namespace diff 문제 회피 *@
                @_baseSvgFullMarkup
                @* 선택/오버레이 dynamic 레이어: 같은 좌표계 위에 별도 SVG 로 겹쳐 렌더링 *@
                <svg class="gantt-chart-overlay-layer" width="@_chartWidth" height="@_chartHeight" xmlns="http://www.w3.org/2000/svg"
                     style="position:absolute; top:0; left:0; pointer-events:none;">
                    @RenderDynamicOverlay()
                </svg>
            </div>
            @if (_isLoading)
            {
                <div class="chart-loading-overlay">
                    <div class="spinner"></div>
                    <span>데이터 로딩 중...</span>
                </div>
            }
        </div>
    }
    else if (!string.IsNullOrEmpty(_selectedFlowName))
    {
        <div class="empty-state">
            <span class="material-icons">search_off</span>
            <p>선택한 시간 범위에 분석할 데이터가 없습니다</p>
            <p class="empty-state-hint">시간 범위를 변경하거나 프리셋 버튼을 사용해 보세요</p>
        </div>
    }
    else
    {
        <div class="empty-state">
            <span class="material-icons">bar_chart</span>
            <p>Flow를 선택하세요</p>
        </div>
    }
</div>

@code {
    private List<string> _flows = new();
    private string _selectedFlowName = "";
    private bool _isLoading = false;
    private string? _errorMessage;

    // Crosshair
    private ElementReference _ganttChartContainerRef;
    private bool _isCrosshairInitialized = false;
    private bool _needsCrosshairInit = false;

    private DateTime _chartStartTime = DateTime.Now.AddHours(-1);
    private DateTime _chartEndTime = DateTime.Now;
    private CancellationTokenSource? _debounceCts;

    private GanttChartData? _ganttData;
    private List<(DateTime Start, DateTime End)> _idleRegions = new();
    private GanttChartItem? _selectedItem;
    private GanttChartItem? _comparisonItem;
    private GanttChartItem? _previousItem;
    private GanttChartItem? _nextItem;
    private (DateTime Start, DateTime End, double Duration, int Lane, string LaneName)? _longestGap;
    private List<(DateTime Start, DateTime End, double Duration, int Lane, string LaneName)> _topGaps = new();
    private int _selectedGapIndex = 0;
    private double? _comparisonGap;
    private double? _previousGap;
    private double? _nextGap;

    private bool _showGapOverlay = true;
    private bool _showCycleTimeOverlay = true;
    private ChartSortMode _chartSort = ChartSortMode.ByLane;
    private double _zoomLevel = 1.0;

    private enum ChartSortMode
    {
        ByLane,      // Lane별 정렬 (기본)
        ByTime,      // 시작 시간순 정렬
        ByCallName,  // Call 이름순 정렬
        ByGapSize    // GAP 크기순 정렬
    }

    // 차트 표시용 정렬/lane 캐시 — 데이터 로드 또는 정렬 변경 시 무효화
    private List<int>? _displayLaneOrderCache;
    private List<GanttChartItem>? _sortedItemsForDisplayCache;

    // 차트 base SVG (bars + axis + lanes + idle regions). 데이터/정렬 변경 시에만 재구성.
    // 외부 <svg> 태그까지 포함해 통째로 MarkupString 으로 갈아끼움 — SVG inner content 의
    // namespace diff 문제(동일 SVG 안에 MarkupString 만 바뀌어도 시각적으로 갱신이 안 되는 케이스) 회피.
    private MarkupString _baseSvgFullMarkup;
    private int _chartWidth;
    private int _chartHeight;
    private DateTime _renderedChartStartTime;
    private double _renderedXScale;
    private Dictionary<int, int> _renderedDisplayLaneIndex = new();

    // JS click delegation (per-bar EventCallback 할당 회피)
    private DotNetObjectReference<CycleTimeAnalysis>? _dotNetRef;
    private bool _clickDelegationInitialized;
    private bool _needsClickDelegationInit;

    // 차트 geometry 상수 — CycleTimeChartRenderer 의 정의를 razor 안에서도 그대로 쓰도록 forward.
    // dynamic overlay 가 base SVG 와 동일 좌표계를 사용해야 해서 수치 단일 소스 유지.
    private const int ChartLeftMargin = CycleTimeChartRenderer.LeftMargin;
    private const int ChartTopMargin = CycleTimeChartRenderer.TopMargin;
    private const int ChartLaneHeight = CycleTimeChartRenderer.LaneHeight;
    private const int ChartBarHeight = CycleTimeChartRenderer.BarHeight;
    private const int ChartPlotWidth = CycleTimeChartRenderer.PlotWidth;

    private void InvalidateDisplayCache()
    {
        _displayLaneOrderCache = null;
        _sortedItemsForDisplayCache = null;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadFlows();

        // 첫 번째 Flow가 자동 선택된 경우 1회만 로딩 (이후 자동 갱신 없음 — 사용자 선택 시에만 새로고침)
        if (!string.IsNullOrEmpty(_selectedFlowName))
        {
            await LoadGanttData();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needsCrosshairInit && _ganttData != null && _ganttData.Items.Any())
        {
            _needsCrosshairInit = false;
            try
            {
                await InitCrosshairAsync();
            }
            catch (Exception) { }
        }

        if (_needsClickDelegationInit && _ganttData != null && _ganttData.Items.Any())
        {
            _needsClickDelegationInit = false;
            try
            {
                _dotNetRef ??= DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("cycleTimeChart.init", _ganttChartContainerRef, _dotNetRef);
                _clickDelegationInitialized = true;
            }
            catch (JSDisconnectedException) { }
            catch (ObjectDisposedException) { }
            catch (Exception) { }
        }
    }

    private async Task InitCrosshairAsync()
    {
        if (_ganttData == null || !_ganttData.Items.Any()) return;

        try
        {
            if (_isCrosshairInitialized)
            {
                await JS.InvokeVoidAsync("ganttCrosshair.dispose", _ganttChartContainerRef);
                _isCrosshairInitialized = false;
            }

            const int leftMargin = 220;
            const int topMargin = 60;
            const int laneHeight = 52;
            const int plotWidth = 2000;

            var chartStartTime = _ganttData.ActualEventStartTime ?? _ganttData.StartTime;
            var chartEndTime = _ganttData.ActualEventEndTime ?? (_ganttData.EndTime ?? _ganttData.StartTime.AddSeconds(1));
            var cycleTime = Math.Max((int)(chartEndTime - chartStartTime).TotalMilliseconds, 1);
            var xScale = plotWidth / (double)cycleTime;
            var plotHeight = _ganttData.TotalLanes * laneHeight;

            var chartStartEpochMs = new DateTimeOffset(chartStartTime).ToUnixTimeMilliseconds();

            // Build snap edges
            var snapEdges = new List<object>();
            foreach (var item in _ganttData.Items)
            {
                var x = leftMargin + ((item.GoingStartTime - chartStartTime).TotalMilliseconds * xScale);
                var edgeTimeMs = new DateTimeOffset(item.GoingStartTime).ToUnixTimeMilliseconds();
                snapEdges.Add(new { x = (int)x, timeMs = edgeTimeMs });

                var durationMs = GetItemDurationMs(item);
                if (durationMs > 0)
                {
                    var endX = (int)(x + Math.Max(2, durationMs * xScale));
                    var endTime = item.GoingStartTime.AddMilliseconds(durationMs);
                    var endTimeMs = new DateTimeOffset(endTime).ToUnixTimeMilliseconds();
                    snapEdges.Add(new { x = endX, timeMs = endTimeMs });
                }
            }

            var crosshairParams = new
            {
                leftMargin,
                topMargin,
                plotWidth,
                plotHeight,
                xScale,
                chartStartTimeMs = chartStartEpochMs,
                snapEdges
            };

            await JS.InvokeVoidAsync("ganttCrosshair.init", _ganttChartContainerRef, crosshairParams);
            _isCrosshairInitialized = true;
        }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
    }

    public async ValueTask DisposeAsync()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();

        if (_isCrosshairInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("ganttCrosshair.dispose", _ganttChartContainerRef);
            }
            catch { }
        }

        if (_clickDelegationInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("cycleTimeChart.dispose", _ganttChartContainerRef);
            }
            catch { }
        }

        _dotNetRef?.Dispose();
        _dotNetRef = null;
    }

    private Task LoadFlows()
    {
        try
        {
            var mappings = CallMapper.GetAllMappings();
            _flows = mappings
                .Select(m => m.FlowName)
                .Where(f => !string.IsNullOrEmpty(f))
                .Distinct()
                .OrderBy(f => f)
                .ToList();

            // 첫 번째 Flow 자동 선택
            if (_flows.Any() && string.IsNullOrEmpty(_selectedFlowName))
            {
                _selectedFlowName = _flows.First();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Flow 로딩 실패: {ex.Message}";
        }
        return Task.CompletedTask;
    }

    private async Task OnFlowChanged()
    {
        _ganttData = null;
        _selectedItem = null;
        _comparisonItem = null;
        _previousItem = null;
        _nextItem = null;
        _longestGap = null;
        _topGaps.Clear();
        InvalidateDisplayCache();
        _baseSvgFullMarkup = default;
        StateHasChanged();

        // Flow 변경 시 자동으로 GAP 분석 시작
        if (!string.IsNullOrEmpty(_selectedFlowName))
        {
            await LoadGanttData();
        }
    }

    private async Task OnTimeRangeChanged()
    {
        _debounceCts?.Cancel();
        _debounceCts = new CancellationTokenSource();
        var token = _debounceCts.Token;
        try
        {
            await Task.Delay(500, token);
            if (!string.IsNullOrEmpty(_selectedFlowName))
                await LoadGanttData();
        }
        catch (TaskCanceledException) { }
    }

    private async Task SetDurationHours(int hours)
    {
        _chartEndTime = _chartStartTime.AddHours(hours);
        if (!string.IsNullOrEmpty(_selectedFlowName))
            await LoadGanttData();
    }

    private async Task SetDurationMinutes(int minutes)
    {
        _chartEndTime = _chartStartTime.AddMinutes(minutes);
        if (!string.IsNullOrEmpty(_selectedFlowName))
            await LoadGanttData();
    }

    private async Task SetRecentHours(int hours)
    {
        _chartEndTime = await GetEffectiveLatestTimeAsync();
        _chartStartTime = _chartEndTime.AddHours(-hours);
        if (!string.IsNullOrEmpty(_selectedFlowName))
            await LoadGanttData();
    }

    private async Task SetRecentMinutes(int minutes)
    {
        _chartEndTime = await GetEffectiveLatestTimeAsync();
        _chartStartTime = _chartEndTime.AddMinutes(-minutes);
        if (!string.IsNullOrEmpty(_selectedFlowName))
            await LoadGanttData();
    }

    /// <summary>
    /// "최근 X분" 의 기준 시각. DB 의 최신 로그 시각을 우선 사용 (실시간 + 이력 데이터 양쪽 케이스에서 의미 있음).
    /// 로그가 비었거나 조회 실패 시 DateTime.Now 로 폴백.
    /// </summary>
    private async Task<DateTime> GetEffectiveLatestTimeAsync()
    {
        try
        {
            var latest = await PlcRepository.GetLatestLogDateTimeAsync();
            if (latest.HasValue) return latest.Value;
        }
        catch { }
        return DateTime.Now;
    }

    private async Task LoadGanttData()
    {
        // 로딩 중 차트를 비우지 않고 기존 화면 유지 — 로딩 오버레이만 표시.
        // (예전 동작: _ganttData=null 로 즉시 비웠다가 결과 도착 후 다시 그림 → 깜빡임)
        _isLoading = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            var newData = await CycleAnalysis.GetActualIoSignalSegmentsInTimeRangeAsync(
                _selectedFlowName,
                _chartStartTime,
                _chartEndTime);

            // 결과 도착 후에야 기존 데이터 교체
            _ganttData = newData;
            _idleRegions.Clear();
            _selectedItem = null;
            _comparisonItem = null;
            _previousItem = null;
            _nextItem = null;
            _longestGap = null;
            _topGaps.Clear();

            if (_ganttData.Items.Any())
            {
                // 실제 데이터 범위로 시간 범위 자동 조정
                if (_ganttData.ActualEventStartTime.HasValue && _ganttData.ActualEventEndTime.HasValue)
                {
                    _chartStartTime = _ganttData.ActualEventStartTime.Value;
                    _chartEndTime = _ganttData.ActualEventEndTime.Value;
                }

                CalculateLongestGap();
                _needsCrosshairInit = true;

                // 비가동 사이클 구간 감지
                await DetectIdleRegionsAsync();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"데이터 로딩 실패: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
            InvalidateDisplayCache();
            RebuildBaseSvgMarkup();
            _needsClickDelegationInit = true;
            StateHasChanged();
        }
    }

    private void CalculateLongestGap()
    {
        _longestGap = null;
        _topGaps.Clear();
        _selectedGapIndex = 0;

        if (_ganttData == null || _ganttData.Items.Count < 2)
            return;

        var sortedItems = GetSortedItemsForGapAnalysis();
        var allGaps = new List<(DateTime Start, DateTime End, double Duration, int Lane, string LaneName)>();

        // Lane별로 그룹화하여 같은 Lane 내에서만 gap 계산 (병렬 실행 Lane 간 overlap 제외)
        var laneGroups = sortedItems.GroupBy(i => i.Lane);

        foreach (var group in laneGroups)
        {
            var lane = group.Key;
            var laneName = lane >= 0 && lane < _ganttData.LaneLabels.Count
                ? _ganttData.LaneLabels[lane]
                : $"Lane {lane}";
            var laneItems = group.OrderBy(i => i.GoingStartTime).ToList();

            for (int i = 0; i < laneItems.Count - 1; i++)
            {
                var current = laneItems[i];
                var next = laneItems[i + 1];

                var currentEnd = current.FinishTime ?? current.GoingStartTime;
                var nextStart = next.GoingStartTime;

                var gapDuration = (nextStart - currentEnd).TotalMilliseconds;

                if (gapDuration > 0 && !OverlapsIdleRegion(currentEnd, nextStart))
                {
                    allGaps.Add((currentEnd, nextStart, gapDuration, lane, laneName));
                }
            }
        }

        // 상위 5개 GAP 선택
        _topGaps = allGaps
            .OrderByDescending(g => g.Duration)
            .Take(5)
            .ToList();

        if (_topGaps.Any())
        {
            _longestGap = _topGaps[0];
        }
    }

    private bool OverlapsIdleRegion(DateTime gapStart, DateTime gapEnd)
    {
        foreach (var (idleStart, idleEnd) in _idleRegions)
        {
            if (gapStart < idleEnd && gapEnd > idleStart)
                return true;
        }
        return false;
    }

    private Task OnGapSelected()
    {
        if (_selectedGapIndex >= 0 && _selectedGapIndex < _topGaps.Count)
        {
            _longestGap = _topGaps[_selectedGapIndex];
            StateHasChanged();
        }
        return Task.CompletedTask;
    }

    private Task OnGapSelectedChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var index))
        {
            _selectedGapIndex = index;
        }

        return OnGapSelected();
    }

    private Task OnChartSortChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<ChartSortMode>(e.Value?.ToString(), out var mode))
        {
            _chartSort = mode;
            InvalidateDisplayCache();
            RebuildBaseSvgMarkup();
        }

        StateHasChanged();
        return Task.CompletedTask;
    }

    private List<GanttChartItem> GetSortedItemsForGapAnalysis()
    {
        if (_ganttData == null) return new List<GanttChartItem>();

        return _ganttData.Items
            .OrderBy(item => item.GoingStartTime)
            .ThenBy(item => item.FinishTime ?? item.GoingStartTime)
            .ToList();
    }

    private List<GanttChartItem> GetSortedItemsForDisplay()
    {
        if (_ganttData == null) return new List<GanttChartItem>();
        if (_sortedItemsForDisplayCache != null) return _sortedItemsForDisplayCache;

        var laneOrder = GetDisplayLaneOrder();
        var laneIndexByLane = laneOrder
            .Select((lane, index) => new { lane, index })
            .ToDictionary(x => x.lane, x => x.index);

        _sortedItemsForDisplayCache = _chartSort switch
        {
            ChartSortMode.ByLane => _ganttData.Items.OrderBy(i => i.Lane).ThenBy(i => i.GoingStartTime).ToList(),
            ChartSortMode.ByTime => _ganttData.Items.OrderBy(i => i.GoingStartTime).ToList(),
            ChartSortMode.ByCallName => _ganttData.Items
                .OrderBy(i => laneIndexByLane.GetValueOrDefault(i.Lane, i.Lane))
                .ThenBy(i => i.GoingStartTime)
                .ToList(),
            ChartSortMode.ByGapSize => _ganttData.Items
                .OrderBy(i => laneIndexByLane.GetValueOrDefault(i.Lane, i.Lane))
                .ThenBy(i => i.GoingStartTime)
                .ToList(),
            _ => _ganttData.Items.OrderBy(i => i.Lane).ThenBy(i => i.GoingStartTime).ToList()
        };

        return _sortedItemsForDisplayCache;
    }

    private List<int> GetDisplayLaneOrder()
    {
        if (_ganttData == null)
        {
            return new List<int>();
        }
        if (_displayLaneOrderCache != null) return _displayLaneOrderCache;

        var laneStats = _ganttData.Items
            .GroupBy(item => item.Lane)
            .Select(group =>
            {
                var ordered = group.OrderBy(item => item.GoingStartTime).ToList();
                var label = group.Key >= 0 && group.Key < _ganttData.LaneLabels.Count
                    ? _ganttData.LaneLabels[group.Key]
                    : $"Lane {group.Key}";

                return new
                {
                    Lane = group.Key,
                    Label = label,
                    FirstStart = ordered.FirstOrDefault()?.GoingStartTime ?? DateTime.MaxValue,
                    MaxGap = CalculateMaxGap(ordered)
                };
            })
            .ToList();

        _displayLaneOrderCache = _chartSort switch
        {
            ChartSortMode.ByTime => laneStats
                .OrderBy(stat => stat.FirstStart)
                .ThenBy(stat => stat.Lane)
                .Select(stat => stat.Lane)
                .ToList(),
            ChartSortMode.ByCallName => laneStats
                .OrderBy(stat => stat.Label, StringComparer.OrdinalIgnoreCase)
                .ThenBy(stat => stat.Lane)
                .Select(stat => stat.Lane)
                .ToList(),
            ChartSortMode.ByGapSize => laneStats
                .OrderByDescending(stat => stat.MaxGap)
                .ThenBy(stat => stat.FirstStart)
                .ThenBy(stat => stat.Lane)
                .Select(stat => stat.Lane)
                .ToList(),
            _ => laneStats
                .OrderBy(stat => stat.Lane)
                .Select(stat => stat.Lane)
                .ToList()
        };

        return _displayLaneOrderCache;
    }

    private static double CalculateMaxGap(List<GanttChartItem> orderedItems)
    {
        if (orderedItems.Count < 2)
        {
            return 0;
        }

        double maxGap = 0;
        for (int i = 0; i < orderedItems.Count - 1; i++)
        {
            var currentEnd = orderedItems[i].FinishTime ?? orderedItems[i].GoingStartTime;
            var nextStart = orderedItems[i + 1].GoingStartTime;
            maxGap = Math.Max(maxGap, (nextStart - currentEnd).TotalMilliseconds);
        }

        return maxGap;
    }

    private Dictionary<GanttChartItem, double> CalculateItemGaps()
    {
        var gapMap = new Dictionary<GanttChartItem, double>();
        if (_ganttData == null) return gapMap;

        var sortedItems = GetSortedItemsForGapAnalysis();

        for (int i = 0; i < sortedItems.Count; i++)
        {
            var current = sortedItems[i];
            double maxGap = 0;

            if (i > 0)
            {
                var prev = sortedItems[i - 1];
                var prevEnd = prev.FinishTime ?? prev.GoingStartTime;
                maxGap = Math.Max(maxGap, (current.GoingStartTime - prevEnd).TotalMilliseconds);
            }

            if (i < sortedItems.Count - 1)
            {
                var next = sortedItems[i + 1];
                var currentEnd = current.FinishTime ?? current.GoingStartTime;
                maxGap = Math.Max(maxGap, (next.GoingStartTime - currentEnd).TotalMilliseconds);
            }

            gapMap[current] = maxGap;
        }

        return gapMap;
    }

    private void SelectItem(GanttChartItem item)
    {
        if (_selectedItem != null && ReferenceEquals(_selectedItem, item))
        {
            ClearSelection();
        }
        else
        {
            SetPrimarySelection(item);
        }

        StateHasChanged();
    }

    private void SetPrimarySelection(GanttChartItem item)
    {
        _selectedItem = item;
        _comparisonItem = null;
        _comparisonGap = null;
        CalculateItemGaps(item);
        AutoMatchCycleTime(item);
    }

    private void AutoMatchCycleTime(GanttChartItem item)
    {
        if (_ganttData == null) return;

        var nextOccurrence = _ganttData.Items
            .Where(i => i.TagAddress == item.TagAddress
                      && i.EventType == item.EventType
                      && i.GoingStartTime > item.GoingStartTime)
            .OrderBy(i => i.GoingStartTime)
            .FirstOrDefault();

        if (nextOccurrence != null)
        {
            _comparisonItem = nextOccurrence;
            _comparisonGap = (nextOccurrence.GoingStartTime - item.GoingStartTime).TotalMilliseconds;
        }
    }

    private void CalculateItemGaps(GanttChartItem item)
    {
        _previousGap = null;
        _nextGap = null;
        _previousItem = null;
        _nextItem = null;

        if (_ganttData == null) return;

        // 같은 Lane 내에서만 이전/다음 아이템을 찾아 gap 계산 (병렬 Lane 간 무의미한 gap 제외)
        var sameLaneItems = _ganttData.Items
            .Where(i => i.Lane == item.Lane)
            .OrderBy(i => i.GoingStartTime)
            .ToList();

        var index = sameLaneItems.FindIndex(i => i == item);
        if (index == -1) return;

        if (index > 0)
        {
            _previousItem = sameLaneItems[index - 1];
            var prevEnd = _previousItem.FinishTime ?? _previousItem.GoingStartTime;
            _previousGap = (item.GoingStartTime - prevEnd).TotalMilliseconds;
        }

        if (index < sameLaneItems.Count - 1)
        {
            _nextItem = sameLaneItems[index + 1];
            var currentEnd = item.FinishTime ?? item.GoingStartTime;
            _nextGap = (_nextItem.GoingStartTime - currentEnd).TotalMilliseconds;
        }
    }

    private void ClearSelection()
    {
        _selectedItem = null;
        _comparisonItem = null;
        _previousItem = null;
        _nextItem = null;
        _comparisonGap = null;
        _previousGap = null;
        _nextGap = null;
        StateHasChanged();
    }

    private async Task DetectIdleRegionsAsync()
    {
        _idleRegions.Clear();
        var settings = SettingsService.LoadSettings();
        var maxCT = settings.HistoryView.MaxCycleTimeMs;
        if (maxCT <= 0 || string.IsNullOrEmpty(_selectedFlowName)) return;

        // FlowMetricsService가 실제 사용하는 HeadCall의 InTag로 사이클 경계 감지
        var (headCallName, _) = FlowMetrics.GetCycleBoundaryCallNames(_selectedFlowName);
        string? inTagAddress = null;

        if (!string.IsNullOrEmpty(headCallName))
        {
            // HeadCallName으로 InTag 주소 찾기
            var allPairs = CallMapper.GetAllCallTagPairs();
            var match = allPairs.FirstOrDefault(p =>
                p.FlowName == _selectedFlowName && p.CallName == headCallName);
            if (match != default)
                inTagAddress = match.InTag;
        }

        // FlowMetrics에서 못 찾으면 CycleAnalysisService 폴백
        List<DateTime> edges;
        if (!string.IsNullOrEmpty(inTagAddress))
        {
            edges = await PlcRepository.FindRisingEdgesAsync(inTagAddress, _chartStartTime, _chartEndTime);
        }
        else
        {
            edges = await CycleAnalysis.GetCycleBoundaryTimesAsync(
                _selectedFlowName, _chartStartTime, _chartEndTime);
        }

        if (edges.Count == 0) return;

        var sorted = edges.OrderBy(t => t).ToList();

        // 인접 edge 사이 비가동 구간
        for (int i = 0; i < sorted.Count - 1; i++)
        {
            var cycleStart = sorted[i];
            var cycleEnd = sorted[i + 1];
            if ((cycleEnd - cycleStart).TotalMilliseconds > maxCT)
            {
                _idleRegions.Add((cycleStart, cycleEnd));
            }
        }

        // 마지막 edge ~ 차트 끝: 사이클 시작 후 다음 사이클이 없는 경우
        var lastEdge = sorted[^1];
        if ((_chartEndTime - lastEdge).TotalMilliseconds > maxCT)
        {
            _idleRegions.Add((lastEdge, _chartEndTime));
        }

        // 차트 시작 ~ 첫 edge: 이전 사이클이 오래 전에 시작된 경우
        var firstEdge = sorted[0];
        if ((firstEdge - _chartStartTime).TotalMilliseconds > maxCT)
        {
            _idleRegions.Add((_chartStartTime, firstEdge));
        }
    }

    private async Task ExportCsv()
    {
        if (_ganttData == null || !_ganttData.Items.Any()) return;
        var bytes = CycleTimeChartExporter.BuildCsvBytes(_ganttData);
        await DownloadFileAsync(
            CycleTimeChartExporter.CsvFileName(_ganttData.FlowName),
            bytes,
            CycleTimeChartExporter.CsvMimeType);
    }

    private async Task ExportGanttExcel()
    {
        if (_ganttData == null || !_ganttData.Items.Any()) return;
        var bytes = CycleTimeChartExporter.BuildExcelBytes(
            _ganttData,
            GetDisplayLaneOrder(),
            _idleRegions);
        await DownloadFileAsync(
            CycleTimeChartExporter.ExcelFileName(_ganttData.FlowName),
            bytes,
            CycleTimeChartExporter.XlsxMimeType);
    }

    /// <summary>JS interop 으로 base64 바이트를 브라우저 다운로드. cycle-time-chart.js 의 downloadFile 호출.</summary>
    private async Task DownloadFileAsync(string fileName, byte[] bytes, string mimeType)
    {
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("cycleTimeChart.downloadFile", fileName, base64, mimeType);
    }

    /// <summary>
    /// Base SVG (bars + axis + lanes + idle regions + defs) 를 <see cref="CycleTimeChartRenderer"/> 로 빌드.
    /// 데이터/정렬 변경 시에만 호출되며, 선택/오버레이 변경에는 영향 없음 (별도 dynamic 레이어).
    /// </summary>
    private void RebuildBaseSvgMarkup()
    {
        if (_ganttData == null || !_ganttData.Items.Any())
        {
            _baseSvgFullMarkup = default;
            _renderedDisplayLaneIndex = new();
            return;
        }

        var result = CycleTimeChartRenderer.BuildBaseSvg(
            _ganttData,
            GetSortedItemsForDisplay(),
            GetDisplayLaneOrder(),
            _idleRegions);

        _baseSvgFullMarkup = new MarkupString(result.Svg);
        _renderedChartStartTime = result.ChartStartTime;
        _renderedXScale = result.XScale;
        _renderedDisplayLaneIndex = result.DisplayLaneIndex;
        _chartWidth = result.ChartWidth;
        _chartHeight = result.ChartHeight;
    }

    // ===========================================================================================
    // Dynamic Overlay — 선택/Cycle Time/GAP 오버레이만 처리. 매 click 마다 작은 RenderFragment 만 재렌더.
    // ===========================================================================================
    private RenderFragment RenderDynamicOverlay() => builder =>
    {
        if (_ganttData == null || !_ganttData.Items.Any()) return;

        var data = _ganttData;
        var chartStartTime = _renderedChartStartTime;
        var xScale = _renderedXScale;
        var displayLaneIndex = _renderedDisplayLaneIndex;
        var inv = System.Globalization.CultureInfo.InvariantCulture;
        int seq = 0;

        // GAP 배경 오버레이
        if (_showGapOverlay && _longestGap.HasValue)
        {
            var gapStart = _longestGap.Value.Start;
            var gapEnd = _longestGap.Value.End;
            var gapLane = _longestGap.Value.Lane;
            var gapX = ChartLeftMargin + ((gapStart - chartStartTime).TotalMilliseconds * xScale);
            var gapWidth = (gapEnd - gapStart).TotalMilliseconds * xScale;
            var gapY = ChartTopMargin + (gapLane * ChartLaneHeight);

            builder.OpenElement(seq++, "rect");
            builder.AddAttribute(seq++, "class", "gantt-gap-overlay");
            builder.AddAttribute(seq++, "x", gapX.ToString("F2", inv));
            builder.AddAttribute(seq++, "y", gapY);
            builder.AddAttribute(seq++, "width", gapWidth.ToString("F2", inv));
            builder.AddAttribute(seq++, "height", ChartLaneHeight);
            builder.AddAttribute(seq++, "stroke-dasharray", "5,5");
            builder.CloseElement();
        }

        // Cycle Time 배경 오버레이 + 시작/끝 세로선
        if (_showCycleTimeOverlay && _selectedItem != null && _comparisonItem != null)
        {
            var itemA = _selectedItem;
            var itemB = _comparisonItem;
            if (itemA.GoingStartTime > itemB.GoingStartTime)
            {
                (itemA, itemB) = (itemB, itemA);
            }

            var ctX = ChartLeftMargin + ((itemA.GoingStartTime - chartStartTime).TotalMilliseconds * xScale);
            var ctWidth = Math.Max(2, (itemB.GoingStartTime - itemA.GoingStartTime).TotalMilliseconds * xScale);
            var totalLaneHeight = data.TotalLanes * ChartLaneHeight;

            builder.OpenElement(seq++, "rect");
            builder.AddAttribute(seq++, "class", "gantt-cycletime-overlay");
            builder.AddAttribute(seq++, "x", ctX.ToString("F2", inv));
            builder.AddAttribute(seq++, "y", ChartTopMargin);
            builder.AddAttribute(seq++, "width", ctWidth.ToString("F2", inv));
            builder.AddAttribute(seq++, "height", totalLaneHeight);
            builder.AddAttribute(seq++, "stroke-dasharray", "6,3");
            builder.CloseElement();

            builder.OpenElement(seq++, "line");
            builder.AddAttribute(seq++, "class", "gantt-cycletime-start");
            builder.AddAttribute(seq++, "x1", ctX.ToString("F2", inv));
            builder.AddAttribute(seq++, "y1", ChartTopMargin);
            builder.AddAttribute(seq++, "x2", ctX.ToString("F2", inv));
            builder.AddAttribute(seq++, "y2", ChartTopMargin + totalLaneHeight);
            builder.CloseElement();

            var ctEndX = ctX + ctWidth;
            builder.OpenElement(seq++, "line");
            builder.AddAttribute(seq++, "class", "gantt-cycletime-end");
            builder.AddAttribute(seq++, "x1", ctEndX.ToString("F2", inv));
            builder.AddAttribute(seq++, "y1", ChartTopMargin);
            builder.AddAttribute(seq++, "x2", ctEndX.ToString("F2", inv));
            builder.AddAttribute(seq++, "y2", ChartTopMargin + totalLaneHeight);
            builder.CloseElement();
        }

        // 선택/비교/이전/다음 bar 하이라이트 — base 의 bar 위에 stroke-only rect 를 덮어 그림
        void DrawHighlight(GanttChartItem? item, string color, int strokeWidth)
        {
            if (item == null) return;
            var displayLane = displayLaneIndex.GetValueOrDefault(item.Lane, item.Lane);
            var laneTop = ChartTopMargin + (displayLane * ChartLaneHeight);
            var hy = item.EventType == IOEventType.InTag ? laneTop + 7 : laneTop + 29;
            var hx = ChartLeftMargin + ((item.GoingStartTime - chartStartTime).TotalMilliseconds * xScale);
            var hDuration = GetItemDurationMs(item);
            var hWidth = Math.Max(2, Math.Max(hDuration, 1) * xScale);

            builder.OpenElement(seq++, "rect");
            builder.AddAttribute(seq++, "x", hx.ToString("F2", inv));
            builder.AddAttribute(seq++, "y", hy);
            builder.AddAttribute(seq++, "width", hWidth.ToString("F2", inv));
            builder.AddAttribute(seq++, "height", ChartBarHeight);
            builder.AddAttribute(seq++, "rx", "4");
            builder.AddAttribute(seq++, "fill", "none");
            builder.AddAttribute(seq++, "stroke", color);
            builder.AddAttribute(seq++, "stroke-width", strokeWidth);
            builder.AddAttribute(seq++, "pointer-events", "none");
            builder.CloseElement();
        }

        DrawHighlight(_selectedItem, "#ff9800", 3);
        DrawHighlight(_comparisonItem, "#8b5cf6", 3);
        DrawHighlight(_previousItem, "#ff9800", 2);
        DrawHighlight(_nextItem, "#26a69a", 2);

        // GAP 텍스트 라벨
        if (_showGapOverlay && _longestGap.HasValue)
        {
            var gapStart = _longestGap.Value.Start;
            var gapEnd = _longestGap.Value.End;
            var gapLane = _longestGap.Value.Lane;
            var gapX = ChartLeftMargin + ((gapStart - chartStartTime).TotalMilliseconds * xScale);
            var gapWidth = (gapEnd - gapStart).TotalMilliseconds * xScale;
            var gapY = ChartTopMargin + (gapLane * ChartLaneHeight);
            var gapLabel = $"{_longestGap.Value.LaneName} GAP: {(_longestGap.Value.Duration / 1000.0):F2}s";

            const int gapFontSize = 13;
            var gapTextWidth = gapLabel.Length * (gapFontSize * 0.62);
            const double gapPadX = 6.0;
            const double gapPadY = 4.0;
            var gapBgW = gapTextWidth + (gapPadX * 2);
            var gapBgH = gapFontSize + (gapPadY * 2);
            var gapCenterX = gapX + (gapWidth / 2);
            var gapCenterY = gapY + (ChartLaneHeight / 2);

            builder.OpenElement(seq++, "rect");
            builder.AddAttribute(seq++, "class", "gantt-gap-label-bg");
            builder.AddAttribute(seq++, "x", (gapCenterX - (gapBgW / 2)).ToString("F2", inv));
            builder.AddAttribute(seq++, "y", (gapCenterY - (gapBgH / 2)).ToString("F2", inv));
            builder.AddAttribute(seq++, "width", gapBgW.ToString("F2", inv));
            builder.AddAttribute(seq++, "height", gapBgH.ToString("F2", inv));
            builder.AddAttribute(seq++, "rx", 4);
            builder.CloseElement();

            builder.OpenElement(seq++, "text");
            builder.AddAttribute(seq++, "class", "gantt-gap-text");
            builder.AddAttribute(seq++, "x", gapCenterX.ToString("F2", inv));
            builder.AddAttribute(seq++, "y", gapCenterY.ToString("F2", inv));
            builder.AddAttribute(seq++, "text-anchor", "middle");
            builder.AddAttribute(seq++, "dominant-baseline", "central");
            builder.AddAttribute(seq++, "font-size", gapFontSize);
            builder.AddAttribute(seq++, "font-weight", "bold");
            builder.AddContent(seq++, gapLabel);
            builder.CloseElement();
        }

        // CT 텍스트 라벨
        if (_showCycleTimeOverlay && _selectedItem != null && _comparisonItem != null)
        {
            var itemA = _selectedItem;
            var itemB = _comparisonItem;
            if (itemA.GoingStartTime > itemB.GoingStartTime)
            {
                (itemA, itemB) = (itemB, itemA);
            }

            var ctX = ChartLeftMargin + ((itemA.GoingStartTime - chartStartTime).TotalMilliseconds * xScale);
            var ctWidth = Math.Max(2, (itemB.GoingStartTime - itemA.GoingStartTime).TotalMilliseconds * xScale);
            var ctDuration = (itemB.GoingStartTime - itemA.GoingStartTime).TotalMilliseconds;
            var ctLabel = $"Δ {(ctDuration / 1000.0):F2}s";

            const int ctFontSize = 13;
            var ctTextWidth = ctLabel.Length * (ctFontSize * 0.65);
            const double ctPadX = 6.0;
            const double ctPadY = 4.0;
            var ctBgW = ctTextWidth + (ctPadX * 2);
            var ctBgH = ctFontSize + (ctPadY * 2);
            var ctCenterX = ctX + (ctWidth / 2);
            const double ctCenterY = ChartTopMargin - 20.0;

            builder.OpenElement(seq++, "rect");
            builder.AddAttribute(seq++, "class", "gantt-ct-label-bg");
            builder.AddAttribute(seq++, "x", (ctCenterX - (ctBgW / 2)).ToString("F2", inv));
            builder.AddAttribute(seq++, "y", (ctCenterY - (ctBgH / 2)).ToString("F2", inv));
            builder.AddAttribute(seq++, "width", ctBgW.ToString("F2", inv));
            builder.AddAttribute(seq++, "height", ctBgH.ToString("F2", inv));
            builder.AddAttribute(seq++, "rx", 4);
            builder.CloseElement();

            builder.OpenElement(seq++, "text");
            builder.AddAttribute(seq++, "class", "gantt-cycletime-text");
            builder.AddAttribute(seq++, "x", ctCenterX.ToString("F2", inv));
            builder.AddAttribute(seq++, "y", ctCenterY.ToString("F2", inv));
            builder.AddAttribute(seq++, "text-anchor", "middle");
            builder.AddAttribute(seq++, "dominant-baseline", "central");
            builder.AddAttribute(seq++, "font-size", ctFontSize);
            builder.AddAttribute(seq++, "font-weight", "bold");
            builder.AddContent(seq++, ctLabel);
            builder.CloseElement();
        }
    };

    [JSInvokable]
    public Task OnBarClicked(int idx)
    {
        var sortedItems = GetSortedItemsForDisplay();
        if (idx >= 0 && idx < sortedItems.Count)
        {
            SelectItem(sortedItems[idx]);
        }
        return Task.CompletedTask;
    }

    // GetItemDurationMs / FormatDurationTooltip 은 CycleTimeChartRenderer 로 이관.
    // razor 안에서 짧게 쓰기 위해 한 줄짜리 forwarder 만 유지.
    private static int GetItemDurationMs(GanttChartItem item) => CycleTimeChartRenderer.GetItemDurationMs(item);
    private static string FormatDurationTooltip(double durationMs) => CycleTimeChartRenderer.FormatDurationTooltip(durationMs);

    private static string GetEventTypeLabel(IOEventType eventType)
        => eventType == IOEventType.InTag ? "IN" : "OUT";
}
