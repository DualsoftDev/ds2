@page "/cycle"
@using DSPilot.Models.Analysis
@using DSPilot.Services
@inject CycleAnalysisService AnalysisService
@inject DsProjectService ProjectService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>사이클 분석 - DSPilot</PageTitle>

<div class="cycle-analysis-page">
    <h5 class="typo-h5 mb-4" style="font-weight: 600; color: #0A1E5A;">사이클 분석</h5>

    @* 사이클 선택 및 분석 실행 *@
    <section class="card mb-3">
        <div class="card-content">
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Flow 선택</label>
                    <select class="form-field" @bind="_selectedFlowName">
                        <option value="">-- Flow 선택 --</option>
                        @foreach (var flow in _flows)
                        {
                            <option value="@flow.Name">@flow.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">시작 시간</label>
                    <input type="datetime-local" class="form-field" step="1" @bind="_cycleStartTime" />
                </div>
                <div class="form-group">
                    <label class="form-label">종료 시간</label>
                    <input type="datetime-local" class="form-field" step="1" @bind="_cycleEndTime" />
                </div>
                <div class="form-group" style="display:flex; align-items:end;">
                    <button class="btn btn-filled" @onclick="AnalyzeCycle" disabled="@_analyzing">
                        <span class="material-icons" style="font-size:18px;">@(_analyzing ? "hourglass_empty" : "analytics")</span>
                        @(_analyzing ? "분석 중..." : "분석 실행")
                    </button>
                </div>
            </div>
        </div>
    </section>

    @if (_analysisData != null)
    {
        @* 사이클 요약 *@
        <section class="card mb-3">
            <div class="card-header">
                <span class="material-icons mr-2">summarize</span>
                <h6 class="typo-h6">사이클 요약</h6>
            </div>
            <div class="card-content">
                <div class="stats-grid">
                    <div class="stat-card">
                        <span class="stat-label">총 시간</span>
                        <strong class="stat-value">@_analysisData.TotalDuration.TotalSeconds.ToString("F1")s</strong>
                    </div>
                    <div class="stat-card">
                        <span class="stat-label">Call 수</span>
                        <strong class="stat-value">@_analysisData.CallCount</strong>
                    </div>
                    <div class="stat-card">
                        <span class="stat-label">평균 시간</span>
                        <strong class="stat-value">@GetAverageCallTime().ToString("F2")s</strong>
                    </div>
                    <div class="stat-card">
                        <span class="stat-label">Gap 총합</span>
                        <strong class="stat-value">@_analysisData.TotalGapDuration.TotalSeconds.ToString("F1")s</strong>
                    </div>
                </div>
            </div>
        </section>

        @* Top 3 긴 대기 시간 *@
        @if (_analysisData.TopLongGaps.Count > 0)
        {
            <section class="card mb-3">
                <div class="card-header">
                    <span class="material-icons mr-2" style="color: var(--color-error);">warning</span>
                    <h6 class="typo-h6">Top 3 긴 대기 시간 (Gap)</h6>
                </div>
                <div class="card-content">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>순위</th>
                                <th>구간</th>
                                <th>시간</th>
                                <th>병목</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var gap in _analysisData.TopLongGaps)
                            {
                                <tr>
                                    <td>
                                        <span class="rank-badge rank-@gap.Rank">@gap.Rank</span>
                                    </td>
                                    <td>@gap.PreviousCall → @gap.NextCall</td>
                                    <td><strong>@gap.GapDuration.TotalSeconds.ToString("F2")s</strong></td>
                                    <td>
                                        @if (gap.IsBottleneck)
                                        {
                                            <span class="badge badge-error">병목</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }

        @* 동작 순서 타임라인 (Gantt Chart) *@
        <section class="card mb-3">
            <div class="card-header">
                <span class="material-icons mr-2">timeline</span>
                <h6 class="typo-h6">동작 순서 타임라인</h6>
            </div>
            <div class="card-content">
                <div class="gantt-container" style="height: 600px;">
                    <canvas id="cycleGanttChart"></canvas>
                </div>
            </div>
        </section>

        @* 장치별 시간 분포 *@
        @if (_analysisData.DeviceStats.Count > 0)
        {
            <section class="card mb-3">
                <div class="card-header">
                    <span class="material-icons mr-2">devices</span>
                    <h6 class="typo-h6">장치별 시간 분포</h6>
                </div>
                <div class="card-content">
                    <div class="device-stats">
                        @foreach (var (deviceName, stats) in _analysisData.DeviceStats)
                        {
                            <div class="device-bar">
                                <div class="device-info">
                                    <span class="device-name">@deviceName</span>
                                    <span class="device-percentage">@stats.PercentageOfCycle.ToString("F1")%</span>
                                </div>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: @stats.PercentageOfCycle%"></div>
                                </div>
                                <div class="device-details">
                                    총 @stats.TotalTime.TotalSeconds.ToString("F1")s |
                                    평균 @stats.AverageTime.TotalSeconds.ToString("F2")s |
                                    @($"{stats.CallCount}회")
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </section>
        }

        @* 상세 Call 목록 *@
        <section class="card mb-3">
            <div class="card-header">
                <span class="material-icons mr-2">list</span>
                <h6 class="typo-h6">상세 Call 목록 (시간순 정렬)</h6>
            </div>
            <div class="card-content">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>순서</th>
                            <th>Call 이름</th>
                            <th>Flow</th>
                            <th>장치</th>
                            <th>시작 시간</th>
                            <th>소요 시간</th>
                            <th>Gap</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var call in _analysisData.CallSequence)
                        {
                            <tr>
                                <td>@call.SequenceNumber</td>
                                <td><strong>@call.CallName</strong></td>
                                <td>@call.FlowName</td>
                                <td>@call.DeviceName</td>
                                <td>@call.RelativeStartTime.TotalSeconds.ToString("F2")s</td>
                                <td>@call.Duration.TotalSeconds.ToString("F2")s</td>
                                <td>
                                    @if (call.GapFromPrevious.TotalSeconds > 0.5)
                                    {
                                        <span class="text-warning">@call.GapFromPrevious.TotalSeconds.ToString("F2")s ⚠</span>
                                    }
                                    else if (call.GapFromPrevious.TotalSeconds > 0)
                                    {
                                        <span>@call.GapFromPrevious.TotalSeconds.ToString("F2")s</span>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        @* 병목 구간 *@
        @if (_analysisData.Bottlenecks.Count > 0)
        {
            <section class="card mb-3">
                <div class="card-header">
                    <span class="material-icons mr-2" style="color: var(--color-error);">report_problem</span>
                    <h6 class="typo-h6">병목 구간</h6>
                </div>
                <div class="card-content">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Call</th>
                                <th>원인</th>
                                <th>소요 시간</th>
                                <th>예상 시간</th>
                                <th>지연 배율</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var bottleneck in _analysisData.Bottlenecks)
                            {
                                <tr>
                                    <td><strong>@bottleneck.CallName</strong></td>
                                    <td>@bottleneck.Reason</td>
                                    <td>@bottleneck.Duration.TotalSeconds.ToString("F2")s</td>
                                    <td>@bottleneck.ExpectedDuration.TotalSeconds.ToString("F2")s</td>
                                    <td><span class="badge badge-error">@bottleneck.DelayRatio.ToString("F1")x</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
    }
    else if (!_analyzing)
    {
        <section class="card empty-state">
            <span class="material-icons">analytics</span>
            <div class="typo-h6 mt-3">사이클 시간 범위를 설정하고 분석을 실행하세요</div>
        </section>
    }
</div>

<style>
    .cycle-analysis-page {
        padding: 16px;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr auto;
        gap: 12px;
        align-items: end;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
    }

    .stat-card {
        padding: 16px;
        border-radius: 10px;
        border: 1px solid var(--color-lines);
        background: #fbfcff;
        text-align: center;
    }

    .stat-label {
        display: block;
        font-size: 0.85rem;
        color: var(--color-text-secondary);
        margin-bottom: 8px;
    }

    .stat-value {
        display: block;
        font-size: 1.5rem;
        color: var(--color-primary);
    }

    .rank-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        font-weight: 700;
        color: white;
    }

    .rank-1 { background: #d32f2f; }
    .rank-2 { background: #f57c00; }
    .rank-3 { background: #fbc02d; }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

    .data-table th {
        text-align: left;
        padding: 12px;
        background: #f5f5f5;
        border-bottom: 2px solid var(--color-lines);
        font-weight: 600;
    }

    .data-table td {
        padding: 10px 12px;
        border-bottom: 1px solid var(--color-lines);
    }

    .device-stats {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .device-bar {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .device-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .device-name {
        font-weight: 600;
        color: var(--color-text-primary);
    }

    .device-percentage {
        font-weight: 700;
        color: var(--color-primary);
    }

    .progress-bar {
        height: 24px;
        background: #e0e0e0;
        border-radius: 12px;
        overflow: hidden;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--color-primary), var(--color-secondary));
        transition: width 0.3s ease;
    }

    .device-details {
        font-size: 0.85rem;
        color: var(--color-text-secondary);
    }

    .badge {
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .badge-error {
        background: #ffebee;
        color: #c62828;
    }

    .text-warning {
        color: var(--color-warning);
        font-weight: 600;
    }

    .empty-state {
        min-height: 400px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: var(--color-text-secondary);
        text-align: center;
    }

    .empty-state .material-icons {
        font-size: 64px;
        opacity: 0.3;
    }

    .gantt-container {
        position: relative;
        width: 100%;
    }

    @@media (max-width: 1024px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .form-row {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private List<Ds2.Core.Flow> _flows = new();
    private string _selectedFlowName = "";
    private DateTime? _cycleStartTime = DateTime.Now.AddMinutes(-5);
    private DateTime? _cycleEndTime = DateTime.Now;
    private bool _analyzing;
    private CycleAnalysisData? _analysisData;

    protected override void OnInitialized()
    {
        if (ProjectService.IsLoaded)
        {
            var systems = ProjectService.GetActiveSystems();
            foreach (var system in systems)
            {
                _flows.AddRange(ProjectService.GetFlows(system.Id));
            }
        }
    }

    private async Task AnalyzeCycle()
    {
        if (string.IsNullOrEmpty(_selectedFlowName))
        {
            await JS.InvokeVoidAsync("uiUtils.showSnackbar", "Flow를 선택하세요", "warning");
            return;
        }

        if (!_cycleStartTime.HasValue || !_cycleEndTime.HasValue)
        {
            await JS.InvokeVoidAsync("uiUtils.showSnackbar", "시작 시간과 종료 시간을 입력하세요", "warning");
            return;
        }

        if (_cycleEndTime <= _cycleStartTime)
        {
            await JS.InvokeVoidAsync("uiUtils.showSnackbar", "종료 시간은 시작 시간보다 커야 합니다", "warning");
            return;
        }

        _analyzing = true;
        StateHasChanged();

        try
        {
            _analysisData = await AnalysisService.AnalyzeCycleAsync(
                _selectedFlowName,
                _cycleStartTime.Value,
                _cycleEndTime.Value);

            await RenderGanttChart();
            await JS.InvokeVoidAsync("uiUtils.showSnackbar", "사이클 분석 완료", "success");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("uiUtils.showSnackbar", $"분석 실패: {ex.Message}", "error");
        }
        finally
        {
            _analyzing = false;
            StateHasChanged();
        }
    }

    private async Task RenderGanttChart()
    {
        if (_analysisData == null || _analysisData.CallSequence.Count == 0)
            return;

        // DateTime을 Local로 명시적 변환 후 Unix timestamp 계산
        var cycleStartLocal = DateTime.SpecifyKind(_analysisData.CycleStartTime, DateTimeKind.Local);
        var cycleStartTimeMs = new DateTimeOffset(cycleStartLocal).ToUnixTimeMilliseconds();

        var datasets = _analysisData.CallSequence.Select((call, index) =>
        {
            var startTimeMs = cycleStartTimeMs + (long)call.RelativeStartTime.TotalMilliseconds;
            var endTimeMs = startTimeMs + (long)call.Duration.TotalMilliseconds;

            return new
            {
                label = call.CallName,
                deviceName = call.DeviceName,
                startOffsetMs = call.RelativeStartTime.TotalMilliseconds,
                endOffsetMs = call.RelativeStartTime.Add(call.Duration).TotalMilliseconds,
                gapFromPreviousMs = call.GapFromPrevious.TotalMilliseconds,
                data = new[]
                {
                    new
                    {
                        x = new long[] { startTimeMs, endTimeMs },
                        y = index
                    }
                },
                backgroundColor = GetDeviceColor(call.DeviceName)
            };
        }).ToList();

        await JS.InvokeVoidAsync("cycleAnalysis.renderGanttChart", "cycleGanttChart", datasets, cycleStartLocal.ToString("O"));
    }

    private string GetDeviceColor(string deviceName)
    {
        var hash = Math.Abs(deviceName.GetHashCode());
        var hue = hash % 360;
        return $"hsl({hue}, 70%, 50%)";
    }

    private double GetAverageCallTime()
    {
        if (_analysisData == null || _analysisData.CallCount == 0)
            return 0;

        return _analysisData.TotalDuration.TotalSeconds / _analysisData.CallCount;
    }
}
