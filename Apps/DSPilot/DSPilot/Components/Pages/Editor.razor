@page "/editor"
@inject DsProjectService ProjectService
@inject BlueprintService BlueprintService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IAsyncDisposable

<PageTitle>Editor - DSPilot</PageTitle>

<style>
    .ed-page    { flex: 1; min-height: 0; display: flex; flex-direction: column; gap: 14px; }
    .ed-header  { display: flex; align-items: center; flex-shrink: 0; gap: 6px; }
    .ed-main    { flex: 1; min-height: 0; display: flex; gap: 14px; }
    .ed-sidebar { width: 300px; flex-shrink: 0; display: flex; flex-direction: column; gap: 10px; overflow-y: auto; }
    .ed-canvas  { flex: 1; min-width: 0; min-height: 0; display: flex; flex-direction: column; }
    .ed-card    { background: var(--mud-palette-surface, #fff); border: 1px solid var(--mud-palette-lines-default, rgba(0,0,0,0.12)); border-radius: 8px; overflow: hidden; flex-shrink: 0; }
    .ed-card-header { background: var(--mud-palette-background, #f5f5f5); border-bottom: 1px solid var(--mud-palette-lines-default, rgba(0,0,0,0.12)); padding: 10px 14px;
                      font-weight: 600; color: var(--mud-palette-primary, #0A1E5A); font-size: 0.875rem;
                      display: flex; align-items: center; justify-content: space-between; }
    .ed-flow-item { padding: 6px 10px; margin: 2px 0; border-radius: 4px; font-size: 0.85rem; font-weight: 500; }
    .ed-flow-item.active { background: var(--mud-palette-background, #e8ecf4); color: var(--mud-palette-primary, #0A1E5A);
                           cursor: grab; border-left: 3px solid var(--mud-palette-primary, #0A1E5A); }
    .ed-flow-item.placed { background: var(--mud-palette-background, #f0f0f0); color: var(--mud-palette-text-disabled, #bbb);
                           cursor: default; border-left: 3px solid var(--mud-palette-lines-default, #ddd); }
    .ed-flow-item.placed .placed-label { color: var(--mud-palette-text-disabled, #aaa); }
    .ed-offset-label { font-size: 10px; color: var(--mud-palette-text-secondary, #888); }
    .ed-offset-input { width: 52px; padding: 2px 4px; border: 1px solid var(--mud-palette-lines-default, #ccc); border-radius: 4px;
                       text-align: center; font-size: 0.8rem; background: var(--mud-palette-surface, #fff); color: var(--mud-palette-text-primary, #333); }
    .ed-cell-input  { width: 40px; border: 1px solid var(--mud-palette-lines-default, #ddd); border-radius: 3px; padding: 2px;
                      background: var(--mud-palette-surface, #fff); color: var(--mud-palette-text-primary, #333); }
    .ed-card-body   { padding: 14px; }
    .ed-flows-card  { flex: 1; min-height: 0; display: flex; flex-direction: column; overflow: hidden; }
    .ed-flows-body  { flex: 1; min-height: 0; overflow-y: auto; padding: 6px 10px; }
    .ed-placed-body { max-height: 180px; overflow-y: auto; }
</style>

<div class="ed-page">

    @* ── 헤더 ── *@
    <div class="ed-header">
        <MudText Typo="Typo.h5" Style="font-weight: 600;" Color="Color.Primary">Editor</MudText>
        <MudSpacer />
        <MudFileUpload T="IBrowserFile" Accept=".png,.jpg,.jpeg"
                       FilesChanged="OnBlueprintFileSelected"
                       MaximumFileCount="1" Class="mr-2">
            <ActivatorContent>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Image">
                    Upload Image
                    @if (!string.IsNullOrEmpty(BlueprintService.Layout.BlueprintImagePath))
                    {
                        <span style="font-size:10px; color:var(--mud-palette-text-secondary, #7D8282); margin-left:4px;">
                            @(BlueprintService.Layout.CanvasWidth)x@(BlueprintService.Layout.CanvasHeight)
                        </span>
                    }
                </MudButton>
            </ActivatorContent>
        </MudFileUpload>
        <MudButton Variant="@(_isDirty ? Variant.Filled : Variant.Outlined)"
                   Color="Color.Primary" Class="mr-2"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="ApplyChanges">
            적용@(_isDirty ? " *" : "")
        </MudButton>
        <MudFileUpload T="IBrowserFile" Accept=".json" FilesChanged="ImportJson" MaximumFileCount="1" Class="mr-2">
            <ActivatorContent>
                <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                           StartIcon="@Icons.Material.Filled.FileUpload">
                    Import JSON
                </MudButton>
            </ActivatorContent>
        </MudFileUpload>
        <MudButton Variant="Variant.Outlined" Color="Color.Success" Class="mr-2"
                   StartIcon="@Icons.Material.Filled.FileDownload"
                   OnClick="ExportJson">
            Export JSON
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Dashboard"
                   OnClick="@(() => Nav.NavigateTo("/"))">
            대시보드
        </MudButton>
    </div>

    @if (!ProjectService.IsLoaded)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No project loaded.
        </MudAlert>
    }
    else
    {
        @* ── 메인: 사이드바(좌) + 캔버스(우) ── *@
        <div class="ed-main">

            @* 왼쪽 사이드바 *@
            <div class="ed-sidebar">

                @* Grid *@
                <div class="ed-card">
                    <div class="ed-card-header">Grid</div>
                    <div class="ed-card-body">
                        <div class="d-flex gap-2">
                            <MudNumericField T="int" Value="_gridColumns"
                                             ValueChanged="v => OnGridChanged(() => _gridColumns = v)"
                                             Label="Columns" Variant="Variant.Outlined" Margin="Margin.Dense"
                                             Min="2" Max="20" Immediate="true" />
                            <MudNumericField T="int" Value="_gridRows"
                                             ValueChanged="v => OnGridChanged(() => _gridRows = v)"
                                             Label="Rows" Variant="Variant.Outlined" Margin="Margin.Dense"
                                             Min="2" Max="20" Immediate="true" />
                        </div>
                        @* Offset 방향 배치 *@
                        <div style="display:flex; flex-direction:column; align-items:center; gap:4px; margin-top:10px;">
                            @* Top *@
                            <div style="display:flex; flex-direction:column; align-items:center; gap:2px;">
                                <span class="ed-offset-label">Top</span>
                                <input type="number" value="@_offsetY" class="ed-offset-input"
                                       @onchange="@(async e => { if (int.TryParse(e.Value?.ToString(), out var v)) await OnGridChanged(() => _offsetY = v); })" />
                            </div>
                            @* Middle: Left + Rect + Right *@
                            <div style="display:flex; align-items:center; gap:8px;">
                                <div style="display:flex; flex-direction:column; align-items:center; gap:2px;">
                                    <span class="ed-offset-label">Left</span>
                                    <input type="number" value="@_offsetX" class="ed-offset-input"
                                           @onchange="@(async e => { if (int.TryParse(e.Value?.ToString(), out var v)) await OnGridChanged(() => _offsetX = v); })" />
                                </div>
                                <div style="width:52px; height:24px; border:2px solid var(--mud-palette-primary, #0A1E5A); border-radius:4px; background:color-mix(in srgb, var(--mud-palette-primary) 5%, transparent); flex-shrink:0;"></div>
                                <div style="display:flex; flex-direction:column; align-items:center; gap:2px;">
                                    <span class="ed-offset-label">Right</span>
                                    <input type="number" value="@_offsetRight" class="ed-offset-input"
                                           @onchange="@(async e => { if (int.TryParse(e.Value?.ToString(), out var v)) await OnGridChanged(() => _offsetRight = v); })" />
                                </div>
                            </div>
                            @* Bottom *@
                            <div style="display:flex; flex-direction:column; align-items:center; gap:2px;">
                                <input type="number" value="@_offsetBottom" class="ed-offset-input"
                                       @onchange="@(async e => { if (int.TryParse(e.Value?.ToString(), out var v)) await OnGridChanged(() => _offsetBottom = v); })" />
                                <span class="ed-offset-label">Bottom</span>
                            </div>
                        </div>
                        <MudText Typo="Typo.caption" Class="mt-1" Color="Color.Secondary">
                            Cell: @(BlueprintService.Layout.CellWidth) x @(BlueprintService.Layout.CellHeight) px
                        </MudText>
                    </div>
                </div>

                @* Flows — 남은 높이 채움 *@
                <div class="ed-card ed-flows-card">
                    <div class="ed-card-header">Flows</div>
                    <div class="ed-flows-body">
                        @foreach (var sys in _systems)
                        {
                            <MudText Typo="Typo.overline" Class="px-2 mt-1" Color="Color.Secondary">
                                @sys.Name
                            </MudText>
                            @foreach (var flow in _systemFlows.GetValueOrDefault(sys.Id, []))
                            {
                                var placed = BlueprintService.Layout.FlowPlacements.Any(p => p.FlowId == flow.Id);
                                <div draggable="@(!placed ? "true" : "false")"
                                     @ondragstart="() => OnDragStart(flow.Id)"
                                     class="ed-flow-item @(placed ? "placed" : "active")">
                                    @flow.Name
                                    @if (placed)
                                    {
                                        <span class="placed-label" style="float: right; font-size: 0.7rem;">placed</span>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>

            </div>

            @* SVG 캔버스 *@
            <div class="ed-canvas"
                 @ondragover:preventDefault="true"
                 @ondrop="OnDrop"
                 @ondrop:preventDefault="true">
                <svg id="editor-svg" xmlns="http://www.w3.org/2000/svg"
                     style="display: block; width: 100%; height: 100%;"
                     viewBox="0 0 @BlueprintService.Layout.CanvasWidth @BlueprintService.Layout.CanvasHeight"
                     preserveAspectRatio="none">

                    @if (!string.IsNullOrEmpty(BlueprintService.Layout.BlueprintImagePath))
                    {
                        <image href="@(BlueprintService.Layout.BlueprintImagePath)?v=@(BlueprintService.ImageVersion)"
                               x="0" y="0"
                               width="@BlueprintService.Layout.CanvasWidth"
                               height="@BlueprintService.Layout.CanvasHeight"
                               opacity="0.3" />
                    }
                    else
                    {
                        <rect x="0" y="0"
                              width="@BlueprintService.Layout.CanvasWidth"
                              height="@BlueprintService.Layout.CanvasHeight"
                              style="fill: var(--mud-palette-background, #f5f5f5)" />
                    }

                    @{
                        var cellW = BlueprintService.Layout.CellWidth;
                        var cellH = BlueprintService.Layout.CellHeight;
                        var ox    = BlueprintService.Layout.OffsetX;
                        var oy    = BlueprintService.Layout.OffsetY;
                    }

                    @* Grid lines *@
                    @for (int c = 0; c <= _gridColumns; c++)
                    {
                        var x = ox + c * cellW;
                        <line x1="@x" y1="@oy" x2="@x"
                              y2="@(oy + _gridRows * cellH)"
                              style="stroke: var(--mud-palette-lines-default, #bbb)" stroke-width="@(c == 0 || c == _gridColumns ? 1 : 0.5)"
                              stroke-dasharray="@(c == 0 || c == _gridColumns ? "0" : "4,4")" />
                    }
                    @for (int r = 0; r <= _gridRows; r++)
                    {
                        var y = oy + r * cellH;
                        <line x1="@ox" y1="@y"
                              x2="@(ox + _gridColumns * cellW)" y2="@y"
                              style="stroke: var(--mud-palette-lines-default, #bbb)" stroke-width="@(r == 0 || r == _gridRows ? 1 : 0.5)"
                              stroke-dasharray="@(r == 0 || r == _gridRows ? "0" : "4,4")" />
                    }

                    @* Flow nodes *@
                    @foreach (var fp in BlueprintService.Layout.FlowPlacements)
                    {
                        var color      = GetSystemColor(fp.SystemId);
                        var px         = ox + fp.Col * cellW;
                        var py         = oy + fp.Row * cellH;
                        var pw         = fp.ColSpan * cellW;
                        var ph         = fp.RowSpan * cellH;
                        var pad        = 4;
                        var hasOverlap = IsOccupied(fp.Col, fp.Row, fp.ColSpan, fp.RowSpan, fp.FlowId);
                        var strokeColor  = hasOverlap ? "#e53935" : color;
                        var strokeWidth  = hasOverlap ? 3 : 2;
                        var fillOpacity  = hasOverlap ? "0.6" : "0.9";

                        <g data-flow-id="@fp.FlowId"
                           data-col="@fp.Col" data-row="@fp.Row"
                           data-colspan="@fp.ColSpan" data-rowspan="@fp.RowSpan"
                           style="cursor: grab;">
                            <rect x="@(px + pad)" y="@(py + pad)"
                                  width="@(pw - pad * 2)" height="@(ph - pad * 2)"
                                  rx="6" ry="6"
                                  fill="@color" fill-opacity="@fillOpacity"
                                  stroke="@strokeColor" stroke-width="@strokeWidth" />
                            @if (hasOverlap)
                            {
                                <circle cx="@(px + pw - pad - 8)" cy="@(py + pad + 8)"
                                        r="7" fill="#e53935" style="pointer-events: none;" />
                            }
                            <text x="@(px + pw / 2)" y="@(py + ph / 2 - 4)"
                                  text-anchor="middle" fill="white"
                                  font-size="13" font-weight="600"
                                  style="pointer-events: none;">
                                @fp.FlowName
                            </text>
                            <text x="@(px + pw / 2)" y="@(py + ph / 2 + 14)"
                                  text-anchor="middle" fill="rgba(255,255,255,0.7)"
                                  font-size="10"
                                  style="pointer-events: none;">
                                @fp.SystemName
                            </text>
                            @* 리사이즈 핸들 (우하단) *@
                            <g data-resize-for="@fp.FlowId.ToString()" style="cursor: se-resize;">
                                <rect x="@(px + pw - pad - 14)" y="@(py + ph - pad - 14)"
                                      width="14" height="14" rx="3" ry="3"
                                      fill="rgba(255,255,255,0.85)"
                                      stroke="@color" stroke-width="1.5" />
                                <text x="@(px + pw - pad - 7)" y="@(py + ph - pad - 2)"
                                      text-anchor="middle" fill="@color"
                                      font-size="11" font-weight="700"
                                      style="pointer-events: none; user-select: none;">⤡</text>
                            </g>
                        </g>
                    }
                </svg>
            </div>
        </div>

        @* ── Placed: 전체 너비, 하단 ── *@
        <div class="ed-card" style="flex-shrink: 0;">
            <div class="ed-card-header">
                Placed (@BlueprintService.Layout.FlowPlacements.Count)
            </div>
            <div class="ed-placed-body">
                @if (BlueprintService.Layout.FlowPlacements.Count == 0)
                {
                    <MudText Typo="Typo.body2" Class="pa-4" Color="Color.Secondary">
                        Drag flows onto the grid.
                    </MudText>
                }
                else
                {
                    <MudSimpleTable Dense="true" Hover="true">
                        <thead>
                            <tr>
                                <th>Flow</th>
                                <th>Col</th>
                                <th>Row</th>
                                <th>W</th>
                                <th>H</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var fp in BlueprintService.Layout.FlowPlacements)
                            {
                                <tr>
                                    <td style="font-size: 0.8rem;">@fp.FlowName</td>
                                    <td>
                                        <input type="number" value="@fp.Col" min="0" max="@(_gridColumns - 1)"
                                               class="ed-cell-input"
                                               @onchange="e => OnCellChanged(fp, nameof(fp.Col), e)" />
                                    </td>
                                    <td>
                                        <input type="number" value="@fp.Row" min="0" max="@(_gridRows - 1)"
                                               class="ed-cell-input"
                                               @onchange="e => OnCellChanged(fp, nameof(fp.Row), e)" />
                                    </td>
                                    <td>
                                        <input type="number" value="@fp.ColSpan" min="1" max="@(_gridColumns)"
                                               class="ed-cell-input"
                                               @onchange="e => OnCellChanged(fp, nameof(fp.ColSpan), e)" />
                                    </td>
                                    <td>
                                        <input type="number" value="@fp.RowSpan" min="1" max="@(_gridRows)"
                                               class="ed-cell-input"
                                               @onchange="e => OnCellChanged(fp, nameof(fp.RowSpan), e)" />
                                    </td>
                                    <td>
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                       Size="Size.Small" Color="Color.Error"
                                                       OnClick="@(() => RemovePlacement(fp.FlowId))" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
            </div>
        </div>
    }
</div>

@code {
    private List<Ds2.Core.DsSystem> _systems = [];
    private Dictionary<Guid, List<Ds2.Core.Flow>> _systemFlows = [];
    private Dictionary<Guid, (string SystemName, string FlowName, Guid SystemId)> _flowInfo = [];
    private DotNetObjectReference<Editor>? _dotNetRef;
    private Guid? _dragFlowId;
    private bool _isDirty;

    private int _gridColumns;
    private int _gridRows;
    private int _offsetX;
    private int _offsetY;
    private int _offsetRight;
    private int _offsetBottom;

    private static readonly string[] SystemColors =
        ["#0A1E5A", "#1A3A7A", "#2D5499", "#4070B8", "#5A8CD7"];
    private readonly Dictionary<Guid, int> _systemColorIndex = [];

    protected override void OnInitialized()
    {
        if (!ProjectService.IsLoaded) return;
        _systems = ProjectService.GetActiveSystems();
        foreach (var sys in _systems)
        {
            var flows = ProjectService.GetFlows(sys.Id);
            _systemFlows[sys.Id] = flows;
            foreach (var flow in flows)
            {
                _flowInfo[flow.Id] = (sys.Name, flow.Name, sys.Id);
            }
        }
        _gridColumns = BlueprintService.Layout.GridColumns;
        _gridRows = BlueprintService.Layout.GridRows;
        _offsetX = BlueprintService.Layout.OffsetX;
        _offsetY = BlueprintService.Layout.OffsetY;
        _offsetRight = BlueprintService.Layout.OffsetRight;
        _offsetBottom = BlueprintService.Layout.OffsetBottom;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && ProjectService.IsLoaded)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            var layout = BlueprintService.Layout;
            await JS.InvokeVoidAsync("canvasInterop.init",
                _dotNetRef, "editor-svg", layout.CellWidth, layout.CellHeight,
                layout.GridColumns, layout.GridRows, layout.OffsetX, layout.OffsetY);
        }
    }

    private async Task OnGridChanged(Action assign)
    {
        assign();
        BlueprintService.Layout.GridColumns = _gridColumns;
        BlueprintService.Layout.GridRows = _gridRows;
        BlueprintService.Layout.OffsetX = _offsetX;
        BlueprintService.Layout.OffsetY = _offsetY;
        BlueprintService.Layout.OffsetRight = _offsetRight;
        BlueprintService.Layout.OffsetBottom = _offsetBottom;
        _isDirty = true;
        var layout = BlueprintService.Layout;
        await JS.InvokeVoidAsync("canvasInterop.updateGrid",
            layout.CellWidth, layout.CellHeight, layout.GridColumns, layout.GridRows,
            layout.OffsetX, layout.OffsetY);
    }

    private async Task OnBlueprintFileSelected(IBrowserFile file)
    {
        if (file == null) return;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            var (w, h) = await BlueprintService.SaveBlueprintImageAsync(stream, file.Name);

            if (w > 0 && h > 0)
            {
                Snackbar.Add($"Blueprint uploaded. Canvas: {w} x {h}", Severity.Success);
                var layout = BlueprintService.Layout;
                await JS.InvokeVoidAsync("canvasInterop.updateGrid",
                    layout.CellWidth, layout.CellHeight, layout.GridColumns, layout.GridRows,
                    layout.OffsetX, layout.OffsetY);
            }
            else
            {
                Snackbar.Add("Blueprint uploaded.", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Upload failed: {ex.Message}", Severity.Error);
        }
    }

    private void OnDragStart(Guid flowId) => _dragFlowId = flowId;

    private void OnDrop(DragEventArgs e)
    {
        if (_dragFlowId == null) return;
        var flowId = _dragFlowId.Value;
        _dragFlowId = null;

        if (!_flowInfo.TryGetValue(flowId, out var info)) return;
        if (BlueprintService.Layout.FlowPlacements.Any(p => p.FlowId == flowId)) return;

        var layout = BlueprintService.Layout;
        var cellW = layout.CellWidth;
        var cellH = layout.CellHeight;
        var col = Math.Clamp((int)((e.OffsetX - layout.OffsetX) / cellW), 0, _gridColumns - 1);
        var row = Math.Clamp((int)((e.OffsetY - layout.OffsetY) / cellH), 0, _gridRows - 1);
        var cs = 1;
        var rs = 1;

        if (IsOccupied(col, row, cs, rs))
        {
            Snackbar.Add($"해당 위치가 이미 점유되어 있습니다. [{col},{row}]", Severity.Warning);
            return;
        }

        var placement = new FlowPlacement
        {
            FlowId = flowId,
            SystemId = info.SystemId,
            FlowName = info.FlowName,
            SystemName = info.SystemName,
            Col = col,
            Row = row,
            ColSpan = cs,
            RowSpan = rs
        };

        BlueprintService.UpdatePlacementLocal(placement);
        _isDirty = true;
        Snackbar.Add($"배치됨: {info.FlowName} [{col},{row}] {cs}x{rs}", Severity.Success);
        StateHasChanged();
    }

    [JSInvokable]
    public void OnNodeDropped(string flowIdStr, int col, int row)
    {
        if (!Guid.TryParse(flowIdStr, out var flowId)) return;
        var existing = BlueprintService.Layout.FlowPlacements.FirstOrDefault(p => p.FlowId == flowId);
        if (existing == null) return;

        if (IsOccupied(col, row, existing.ColSpan, existing.RowSpan, flowId))
        {
            Snackbar.Add("해당 위치가 다른 블럭과 겹칩니다.", Severity.Warning);
            InvokeAsync(StateHasChanged);
            return;
        }

        existing.Col = col;
        existing.Row = row;
        BlueprintService.UpdatePlacementLocal(existing);
        _isDirty = true;
        InvokeAsync(StateHasChanged);
    }

    private void OnCellChanged(FlowPlacement fp, string field, ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var val)) return;
        var prev = (fp.Col, fp.Row, fp.ColSpan, fp.RowSpan);
        switch (field)
        {
            case nameof(FlowPlacement.Col): fp.Col = Math.Clamp(val, 0, _gridColumns - 1); break;
            case nameof(FlowPlacement.Row): fp.Row = Math.Clamp(val, 0, _gridRows - 1); break;
            case nameof(FlowPlacement.ColSpan): fp.ColSpan = Math.Clamp(val, 1, _gridColumns - fp.Col); break;
            case nameof(FlowPlacement.RowSpan): fp.RowSpan = Math.Clamp(val, 1, _gridRows - fp.Row); break;
        }
        if (IsOccupied(fp.Col, fp.Row, fp.ColSpan, fp.RowSpan, fp.FlowId))
        {
            (fp.Col, fp.Row, fp.ColSpan, fp.RowSpan) = prev;
            Snackbar.Add("해당 위치/크기가 다른 블럭과 겹칩니다.", Severity.Warning);
        }
        else
        {
            BlueprintService.UpdatePlacementLocal(fp);
            _isDirty = true;
        }
        StateHasChanged();
    }

    private bool IsOccupied(int col, int row, int colSpan, int rowSpan, Guid? excludeId = null)
    {
        foreach (var fp in BlueprintService.Layout.FlowPlacements)
        {
            if (excludeId.HasValue && fp.FlowId == excludeId.Value) continue;
            bool colOverlap = col < fp.Col + fp.ColSpan && col + colSpan > fp.Col;
            bool rowOverlap = row < fp.Row + fp.RowSpan && row + rowSpan > fp.Row;
            if (colOverlap && rowOverlap) return true;
        }
        return false;
    }

    private void RemovePlacement(Guid flowId)
    {
        BlueprintService.RemovePlacementLocal(flowId);
        _isDirty = true;
        Snackbar.Add("Removed.", Severity.Info);
        StateHasChanged();
    }

    private void ApplyChanges()
    {
        BlueprintService.SaveLayout();
        _isDirty = false;
        Snackbar.Add("저장되었습니다.", Severity.Success);
    }

    [JSInvokable]
    public void OnNodeResized(string flowIdStr, int colSpan, int rowSpan)
    {
        if (!Guid.TryParse(flowIdStr, out var flowId)) return;
        var existing = BlueprintService.Layout.FlowPlacements.FirstOrDefault(p => p.FlowId == flowId);
        if (existing == null) return;

        var newCS = Math.Clamp(colSpan, 1, _gridColumns - existing.Col);
        var newRS = Math.Clamp(rowSpan, 1, _gridRows - existing.Row);
        if (newCS == existing.ColSpan && newRS == existing.RowSpan) return;

        var prev = (existing.ColSpan, existing.RowSpan);
        existing.ColSpan = newCS;
        existing.RowSpan = newRS;

        if (IsOccupied(existing.Col, existing.Row, newCS, newRS, flowId))
        {
            (existing.ColSpan, existing.RowSpan) = prev;
            Snackbar.Add("해당 크기가 다른 블럭과 겹칩니다.", Severity.Warning);
        }
        else
        {
            BlueprintService.UpdatePlacementLocal(existing);
            _isDirty = true;
        }
        InvokeAsync(StateHasChanged);
    }

    private async Task ImportJson(IBrowserFile file)
    {
        if (file == null) return;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var reader = new System.IO.StreamReader(stream);
            var json = await reader.ReadToEndAsync();
            BlueprintService.LoadLayoutJson(json);

            _gridColumns = BlueprintService.Layout.GridColumns;
            _gridRows = BlueprintService.Layout.GridRows;
            _offsetX = BlueprintService.Layout.OffsetX;
            _offsetY = BlueprintService.Layout.OffsetY;
            _offsetRight = BlueprintService.Layout.OffsetRight;
            _offsetBottom = BlueprintService.Layout.OffsetBottom;

            var layout = BlueprintService.Layout;
            await JS.InvokeVoidAsync("canvasInterop.updateGrid",
                layout.CellWidth, layout.CellHeight, layout.GridColumns, layout.GridRows,
                layout.OffsetX, layout.OffsetY);

            _isDirty = false;
            Snackbar.Add("JSON imported.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task ExportJson()
    {
        var json = BlueprintService.GetLayoutJson();
        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("canvasInterop.downloadFile",
            "layout-data.json", "application/json", base64);
        Snackbar.Add("JSON exported.", Severity.Success);
    }

    private string GetSystemColor(Guid systemId)
    {
        if (!_systemColorIndex.ContainsKey(systemId))
            _systemColorIndex[systemId] = _systemColorIndex.Count % SystemColors.Length;
        return SystemColors[_systemColorIndex[systemId]];
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("canvasInterop.dispose"); } catch { }
        _dotNetRef?.Dispose();
    }
}
