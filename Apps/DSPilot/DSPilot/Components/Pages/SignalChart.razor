@page "/signal-chart"
@using DSPilot.Services
@inject DsProjectService ProjectService
@inject DspDbService DspDbService
@inject PlcToCallMapperService MapperService
@inject SignalTimelineBufferService TimelineBuffer
@inject ILogger<SignalChart> Logger
@implements IDisposable

<PageTitle>신호 타임라인 - DSPilot</PageTitle>

<h5 class="typo-h5 mb-3" style="font-weight: 600; color: #0A1E5A;">실시간 신호 타임라인</h5>

@if (!ProjectService.IsLoaded)
{
    <div class="card" style="padding:16px; border-left:4px solid var(--color-info, #2196F3);">
        <span class="material-icons" style="font-size:18px; vertical-align:middle; margin-right:8px; color:var(--color-info, #2196F3);">info</span>
        No project loaded.
    </div>
}
else
{
    <div class="signal-timeline-page">
        <div class="card mb-2" style="padding:8px 16px; box-shadow: var(--shadow-1);">
            <div class="d-flex" style="gap:12px; flex-wrap:wrap; align-items:flex-end;">
                <div style="flex:0 0 auto; min-width:120px;">
                    <label class="typo-caption" style="display:block; margin-bottom:4px; color:var(--color-text-secondary);">Flow</label>
                    <select class="form-field form-field-dense"
                            value="@(_selectedFlow ?? "")"
                            @onchange="@(e => OnFlowChanged(e.Value?.ToString()))">
                        <option value="">전체</option>
                        @foreach (var flow in _flowNames)
                        {
                            <option value="@flow">@flow</option>
                        }
                    </select>
                </div>
                <div style="flex:1; min-width:120px; max-width:240px;">
                    <label class="typo-caption" style="display:block; margin-bottom:4px; color:var(--color-text-secondary);">검색</label>
                    <input class="form-field form-field-dense"
                           value="@_searchText"
                           @oninput="@(e => OnSearchChanged(e.Value?.ToString()))"
                           placeholder="신호 검색..." />
                </div>
                <div style="flex:0 0 auto; min-width:100px;">
                    <label class="typo-caption" style="display:block; margin-bottom:4px; color:var(--color-text-secondary);">조회 범위</label>
                    <select class="form-field form-field-dense"
                            value="@_timeRangeSeconds"
                            @onchange="@(e => OnTimeRangeChanged(int.Parse(e.Value?.ToString() ?? "60")))">
                        <option value="30">30초</option>
                        <option value="60">1분</option>
                        <option value="120">2분</option>
                        <option value="300">5분</option>
                    </select>
                </div>
                <div style="flex:0 0 auto; min-width:80px;">
                    <label class="typo-caption" style="display:block; margin-bottom:4px; color:var(--color-text-secondary);">축 배율</label>
                    <select class="form-field form-field-dense"
                            value="@_zoomScale"
                            @onchange="@(e => OnZoomChanged(int.Parse(e.Value?.ToString() ?? "2")))">
                        <option value="1">1x</option>
                        <option value="2">2x</option>
                        <option value="4">4x</option>
                    </select>
                </div>
                <div style="flex:1; min-width:200px;">
                    <div class="signal-chart-meta">
                        <span class="typo-body2">
                            <strong>@_filteredSignals.Count</strong> / @_signalData.Count 신호 |
                            최신 이벤트: <strong>@_lastUpdateTime.ToString("HH:mm:ss.fff")</strong>
                        </span>
                        <div class="signal-chart-legend">
                            <span class="signal-chart-legend-item">
                                <span class="signal-chart-legend-swatch in-tag"></span>
                                In Tag
                            </span>
                            <span class="signal-chart-legend-item">
                                <span class="signal-chart-legend-swatch out-tag"></span>
                                Out Tag
                            </span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="signal-chart-tip">
                X축은 가로 스크롤로 이동합니다. bar 위치와 길이는 구간 칸이 아니라 실제 이벤트 timestamp(ms) 기준으로 계산합니다.
            </div>
            <div class="signal-chart-tip">
                범위: @_windowStart.ToString("HH:mm:ss.fff") ~ @_windowEnd.ToString("HH:mm:ss.fff")
            </div>
        </div>

        @if (_signalData.Count == 0)
        {
            <div class="card" style="padding:16px; border-left:4px solid var(--color-warning, #ff9800);">
                <span class="material-icons" style="font-size:18px; vertical-align:middle; margin-right:8px; color:var(--color-warning, #ff9800);">warning</span>
                표시할 신호가 없습니다. 프로젝트 Call/Tag 매핑을 확인하세요.
            </div>
        }
        else
        {
            <div class="signal-timeline-stage">
                <div class="signal-timeline-header" style="@GetGridStyle()">
                    <div class="signal-timeline-header-label">Signal / Address</div>
                    <div class="signal-timeline-header-scale" style="@GetHeaderScaleStyle()">
                        @foreach (var tick in _timelineTicks)
                        {
                            <div class="signal-timeline-tick-line" style="@GetTickLineStyle(tick)"></div>
                            <div class="signal-timeline-tick" style="@GetTickLabelStyle(tick)">@tick.Label</div>
                        }
                    </div>
                </div>

                @if (_filteredSignals.Count == 0)
                {
                    <div class="signal-chart-empty">필터 조건에 맞는 신호가 없습니다.</div>
                }
                else
                {
                    <Virtualize TItem="SignalData"
                                Items="@_filteredSignals"
                                Context="signal"
                                ItemSize="@ChartRowHeight"
                                OverscanCount="8">
                        <div class="signal-timeline-row" style="@GetGridStyle()" @key="signal.Key">
                            <div class="signal-timeline-row-label" title="@signal.DisplayName">
                                <div class="signal-timeline-name">@signal.DisplayName</div>
                                <div class="signal-timeline-meta">@signal.Address.ToUpperInvariant() [@(signal.TagType == "out-tag" ? "OUT" : "IN")]</div>
                            </div>
                            <div class="signal-timeline-row-track" style="@GetTrackStyle()">
                                @foreach (var run in signal.Runs)
                                {
                                    <div class="signal-timeline-run @signal.TagType"
                                         style="@GetRunStyle(run)"
                                         title="@GetRunTitle(run)"></div>
                                }
                            </div>
                        </div>
                    </Virtualize>
                }
            </div>
        }
    </div>
}

@code {
    private const int ChartRowHeight = 64;
    private const double LabelWidthPx = 360d;
    private const double BasePixelsPerSecond = 40d;
    private const double MinTimelineWidthPx = 1200d;
    private const double DesiredTickSpacingPx = 140d;
    private static readonly int[] TickIntervalsMs = [10, 25, 50, 100, 250, 500, 1000, 2000, 5000, 10000, 30000, 60000];

    private DateTime _lastUpdateTime = DateTime.Now;
    private DateTime _windowStart = DateTime.Now.AddSeconds(-60);
    private DateTime _windowEnd = DateTime.Now;
    private string? _selectedFlow;
    private string _searchText = "";
    private int _timeRangeSeconds = 60;
    private int _zoomScale = 2;
    private double _timelineWidthPx = MinTimelineWidthPx;
    private double _tickSpacingPx = 160d;
    private double _tickOffsetPx;
    private List<string> _flowNames = new();
    private List<SignalData> _signalData = new();
    private List<SignalData> _filteredSignals = new();
    private List<TimelineTick> _timelineTicks = [];
    private int _lastSnapshotFlowCount = -1;
    private int _lastSnapshotCallCount = -1;
    private int _timelineRefreshQueued;
    private bool _disposed;

    protected override Task OnInitializedAsync()
    {
        if (!ProjectService.IsLoaded)
            return Task.CompletedTask;

        DspDbService.OnDataChanged += HandleDspDbChanged;
        TimelineBuffer.OnUpdated += HandleTimelineUpdated;

        LoadSignalMetadata();
        RefreshFilteredSignals();
        RefreshTimeline();
        return Task.CompletedTask;
    }

    private void OnFlowChanged(string? value)
    {
        _selectedFlow = string.IsNullOrEmpty(value) ? null : value;
        RefreshFilteredSignals();
        RefreshTimeline();
        StateHasChanged();
    }

    private void OnSearchChanged(string? value)
    {
        _searchText = value?.Trim() ?? "";
        RefreshFilteredSignals();
        RefreshTimeline();
        StateHasChanged();
    }

    private async Task OnTimeRangeChanged(int value)
    {
        if (_timeRangeSeconds == value)
            return;

        _timeRangeSeconds = value;
        RefreshTimeline();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnZoomChanged(int value)
    {
        if (_zoomScale == value)
            return;

        _zoomScale = value;
        RefreshTimeline();
        await InvokeAsync(StateHasChanged);
    }

    private void LoadSignalMetadata()
    {
        try
        {
            _lastSnapshotFlowCount = DspDbService.Snapshot.Flows.Count;
            _lastSnapshotCallCount = DspDbService.Snapshot.Calls.Count;

            _flowNames = DspDbService.Snapshot.Flows
                .Select(flow => flow.FlowName)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(name => name)
                .ToList();

            var signals = new List<SignalData>();
            var signalKeys = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

            foreach (var call in DspDbService.Snapshot.Calls)
            {
                var tagKeys = MapperService.GetCallTagsByCallId(call.CallId);
                if (tagKeys is null)
                {
                    Logger.LogDebug("Call '{CallName}' (ID: {CallId}) tag mapping not found, skipping", call.CallName, call.CallId);
                    continue;
                }

                TryAddSignal(signals, signalKeys, call, tagKeys.Value.InTag, "in-tag");
                TryAddSignal(signals, signalKeys, call, tagKeys.Value.OutTag, "out-tag");
            }

            _signalData = signals;
            Logger.LogInformation("Loaded {Count} signals from ApiCalls", _signalData.Count);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load signal metadata");
        }
    }

    private void TryAddSignal(
        List<SignalData> signals,
        HashSet<string> signalKeys,
        DSPilot.Models.CallState call,
        string? tagAddress,
        string tagType)
    {
        if (string.IsNullOrWhiteSpace(tagAddress))
            return;

        var signalKey = $"{call.FlowName}|{call.WorkName}|{call.CallName}|{tagType}";
        if (!signalKeys.Add(signalKey))
            return;

        signals.Add(new SignalData
        {
            Key = $"{signalKey}|{tagAddress}",
            CallName = call.CallName,
            FlowName = call.FlowName,
            DisplayName = string.IsNullOrWhiteSpace(call.FlowName)
                ? call.CallName
                : $"{call.FlowName}_{call.CallName}",
            Address = tagAddress,
            TagType = tagType
        });
    }

    private void HandleDspDbChanged()
    {
        if (_disposed)
            return;

        var flowCount = DspDbService.Snapshot.Flows.Count;
        var callCount = DspDbService.Snapshot.Calls.Count;
        if (flowCount == _lastSnapshotFlowCount && callCount == _lastSnapshotCallCount)
            return;

        _ = InvokeAsync(() =>
        {
            LoadSignalMetadata();
            RefreshFilteredSignals();
            RefreshTimeline();
            StateHasChanged();
            return Task.CompletedTask;
        });
    }

    private void HandleTimelineUpdated()
    {
        if (_disposed)
            return;

        if (Interlocked.Exchange(ref _timelineRefreshQueued, 1) == 1)
            return;

        _ = InvokeAsync(() =>
        {
            _timelineRefreshQueued = 0;
            RefreshTimeline();
            StateHasChanged();
            return Task.CompletedTask;
        });
    }

    private void RefreshFilteredSignals()
    {
        IEnumerable<SignalData> query = _signalData;

        if (!string.IsNullOrWhiteSpace(_selectedFlow))
        {
            query = query.Where(signal => signal.FlowName.Equals(_selectedFlow, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            query = query.Where(signal =>
                signal.DisplayName.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                signal.CallName.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                signal.FlowName.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                signal.Address.Contains(_searchText, StringComparison.OrdinalIgnoreCase));
        }

        _filteredSignals = query
            .OrderBy(signal => signal.FlowName)
            .ThenBy(signal => signal.CallName)
            .ThenBy(signal => signal.TagType)
            .ToList();
    }

    private void RefreshTimeline()
    {
        var addresses = _filteredSignals
            .Select(signal => signal.Address)
            .Where(address => !string.IsNullOrWhiteSpace(address))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        var window = TimelineBuffer.BuildTimelineWindow(addresses, _timeRangeSeconds);
        _windowStart = window.WindowStart;
        _windowEnd = window.WindowEnd;
        _lastUpdateTime = window.WindowEnd;

        var durationMs = Math.Max(1d, (_windowEnd - _windowStart).TotalMilliseconds);
        var pixelsPerSecond = BasePixelsPerSecond * _zoomScale;
        var pixelsPerMillisecond = pixelsPerSecond / 1000d;

        _timelineWidthPx = Math.Max(MinTimelineWidthPx, Math.Ceiling(durationMs * pixelsPerMillisecond));

        var tickIntervalMs = ChooseTickIntervalMs(pixelsPerMillisecond);
        _tickSpacingPx = Math.Max(1d, tickIntervalMs * pixelsPerMillisecond);
        _timelineTicks = BuildTimelineTicks(tickIntervalMs);
        _tickOffsetPx = _timelineTicks.Count > 0 ? _timelineTicks[0].LeftPx : 0d;

        foreach (var signal in _signalData)
        {
            if (window.RangesByAddress.TryGetValue(signal.Address, out var activeRanges))
            {
                signal.Runs = BuildRuns(activeRanges, durationMs);
            }
            else
            {
                signal.Runs = [];
            }
        }
    }

    private List<SignalRunVisual> BuildRuns(
        List<SignalActiveRange> activeRanges,
        double durationMs)
    {
        var runs = new List<SignalRunVisual>(activeRanges.Count);
        var pixelsPerMillisecond = _timelineWidthPx / durationMs;

        foreach (var activeRange in activeRanges)
        {
            var clippedStart = activeRange.StartTime < _windowStart ? _windowStart : activeRange.StartTime;
            var clippedEnd = activeRange.EndTime > _windowEnd ? _windowEnd : activeRange.EndTime;
            if (clippedEnd <= clippedStart)
                continue;

            var leftPx = (clippedStart - _windowStart).TotalMilliseconds * pixelsPerMillisecond;
            var widthPx = Math.Max(2d, (clippedEnd - clippedStart).TotalMilliseconds * pixelsPerMillisecond);

            runs.Add(new SignalRunVisual(clippedStart, clippedEnd, leftPx, widthPx));
        }

        return runs;
    }

    private List<TimelineTick> BuildTimelineTicks(int tickIntervalMs)
    {
        var ticks = new List<TimelineTick>();
        if (_windowEnd <= _windowStart)
            return ticks;

        var durationMs = (_windowEnd - _windowStart).TotalMilliseconds;
        var pixelsPerMillisecond = _timelineWidthPx / Math.Max(1d, durationMs);
        var firstTick = AlignForward(_windowStart, tickIntervalMs);

        for (var tickTime = firstTick; tickTime <= _windowEnd; tickTime = tickTime.AddMilliseconds(tickIntervalMs))
        {
            var leftPx = (tickTime - _windowStart).TotalMilliseconds * pixelsPerMillisecond;
            ticks.Add(new TimelineTick(leftPx, FormatTickLabel(tickTime, tickIntervalMs)));
        }

        return ticks;
    }

    private static int ChooseTickIntervalMs(double pixelsPerMillisecond)
    {
        foreach (var candidate in TickIntervalsMs)
        {
            if (candidate * pixelsPerMillisecond >= DesiredTickSpacingPx)
                return candidate;
        }

        return TickIntervalsMs[^1];
    }

    private static DateTime AlignForward(DateTime value, int intervalMs)
    {
        var intervalTicks = TimeSpan.FromMilliseconds(intervalMs).Ticks;
        var remainder = value.Ticks % intervalTicks;
        if (remainder == 0)
            return value;

        return new DateTime(value.Ticks + (intervalTicks - remainder), value.Kind);
    }

    private static string FormatTickLabel(DateTime tickTime, int tickIntervalMs)
    {
        if (tickIntervalMs < 1000)
            return tickTime.ToString("mm:ss.fff");

        if (tickIntervalMs < 60000)
            return tickTime.ToString("HH:mm:ss");

        return tickTime.ToString("HH:mm");
    }

    private string GetGridStyle()
    {
        var totalWidthPx = LabelWidthPx + _timelineWidthPx;
        return FormattableString.Invariant(
            $"grid-template-columns:{LabelWidthPx:F0}px {_timelineWidthPx:F2}px;min-width:{totalWidthPx:F2}px;");
    }

    private string GetHeaderScaleStyle()
    {
        return FormattableString.Invariant($"width:{_timelineWidthPx:F2}px;");
    }

    private string GetTrackStyle()
    {
        return FormattableString.Invariant(
            $"width:{_timelineWidthPx:F2}px;--grid-spacing:{_tickSpacingPx:F2}px;--grid-offset:{_tickOffsetPx:F2}px;");
    }

    private static string GetTickLineStyle(TimelineTick tick)
    {
        return FormattableString.Invariant($"left:{tick.LeftPx:F2}px;");
    }

    private static string GetTickLabelStyle(TimelineTick tick)
    {
        return FormattableString.Invariant($"left:{tick.LeftPx:F2}px;");
    }

    private static string GetRunStyle(SignalRunVisual run)
    {
        return FormattableString.Invariant($"left:{run.LeftPx:F2}px;width:{run.WidthPx:F2}px;");
    }

    private static string GetRunTitle(SignalRunVisual run)
    {
        var duration = run.EndTime - run.StartTime;
        return $"{run.StartTime:HH:mm:ss.fff} ~ {run.EndTime:HH:mm:ss.fff} ({FormatDurationSeconds(duration)} sec)";
    }

    private static string FormatDurationSeconds(TimeSpan duration)
    {
        var totalSeconds = Math.Max(0d, duration.TotalSeconds);
        return FormattableString.Invariant($"{totalSeconds:00.00}");
    }

    public void Dispose()
    {
        _disposed = true;
        DspDbService.OnDataChanged -= HandleDspDbChanged;
        TimelineBuffer.OnUpdated -= HandleTimelineUpdated;
    }

    private sealed class SignalData
    {
        public string Key { get; set; } = "";
        public string CallName { get; set; } = "";
        public string FlowName { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public string Address { get; set; } = "";
        public string TagType { get; set; } = "";
        public List<SignalRunVisual> Runs { get; set; } = [];
    }

    private readonly record struct SignalRunVisual(
        DateTime StartTime,
        DateTime EndTime,
        double LeftPx,
        double WidthPx);

    private readonly record struct TimelineTick(double LeftPx, string Label);
}
