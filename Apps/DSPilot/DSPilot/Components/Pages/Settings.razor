@page "/settings"
@implements IDisposable
@inject AppSettingsService SettingsService
@inject IDatabasePathResolver DatabasePathResolver
@inject IFlowMetricsService FlowMetricsService
@inject DsProjectService ProjectService
@inject DatabaseLifecycleService DbLifecycle
@inject IJSRuntime JS

<PageTitle>설정 - DSPilot</PageTitle>

@if (_settings is not null)
{
    <div class="d-flex mb-4" style="justify-content:flex-end; gap:12px;">
        <button class="btn btn-outlined" @onclick="ReloadSettings">
            <span class="material-icons" style="font-size:18px;">refresh</span> 되돌리기
        </button>
        <button class="btn btn-filled" @onclick="SaveSettings">
            <span class="material-icons" style="font-size:18px;">save</span> 저장
        </button>
    </div>

    <div class="grid" style="gap: 16px;">
        @* 왼쪽 열 *@
        <div class="grid-item-6" style="display:flex; flex-direction:column; gap:16px;">

            @* AASX 모델 *@
            <div class="card" style="box-shadow: var(--shadow-2);">
                <div class="card-header">
                    <span class="material-icons mr-2">schema</span>
                    <h6 class="typo-h6">AASX 모델</h6>
                </div>
                <div class="card-content">
                    <div style="padding:8px 12px; margin-bottom:12px; background:var(--color-surface-variant, #f5f5f5); border-radius:6px; border-left:3px solid var(--color-primary);">
                        <small style="color: var(--color-text-secondary); line-height:1.5;">
                            Promaker 와 공유하는 AASX 모델 파일. 경로는 두 앱 공통 고정값으로 운영됩니다.<br/>
                            <strong>Promaker 에서 같은 경로에 저장</strong>한 뒤 아래 "모델 다시 불러오기" 를 누르면 dspilot 에 반영됩니다.
                        </small>
                    </div>

                    <div class="form-group mb-2">
                        <label class="form-label">파일 경로 (고정)</label>
                        <input class="form-field" value="@ProjectService.AasxFilePath" readonly
                               style="background:var(--color-surface-variant, #f7f7f7); font-family:monospace; font-size:12px;" />
                    </div>

                    <div style="display:grid; grid-template-columns:auto 1fr; gap:6px 12px; font-size:13px; margin:8px 0 12px;">
                        <span style="color:var(--color-text-secondary);">파일 상태</span>
                        @if (_aasxExists)
                        {
                            <span style="color:#27ae60;">존재함 (@FormatBytes(_aasxSize))</span>
                        }
                        else
                        {
                            <span style="color:#c0392b;">파일 없음 — Promaker 에서 먼저 저장하세요</span>
                        }

                        <span style="color:var(--color-text-secondary);">파일 수정</span>
                        <span>@FormatTime(_aasxWriteUtc)</span>

                        <span style="color:var(--color-text-secondary);">마지막 로드</span>
                        <span>@FormatTime(ProjectService.LastLoadedUtc)</span>

                        <span style="color:var(--color-text-secondary);">동기화</span>
                        <span style="color:@SyncBadgeColor;">@SyncBadgeText</span>
                    </div>

                    <button class="btn btn-outlined" style="width:100%;" @onclick="ReloadAasxModel" disabled="@(!_aasxExists)">
                        <span class="material-icons" style="font-size:18px;">refresh</span>
                        AASX 모델 다시 불러오기 (DB 재구축)
                    </button>
                    <small style="color: var(--color-text-secondary); margin-top: 6px; display: block;">
                        디스크의 AASX 파일을 다시 읽고 dspFlow / dspCall 을 재생성합니다.
                        통계/히스토리는 모두 초기화됩니다. 서비스 재시작 불필요.
                    </small>
                </div>
            </div>

            @* 데이터베이스 *@
            <div class="card" style="box-shadow: var(--shadow-2);">
                <div class="card-header">
                    <span class="material-icons mr-2">storage</span>
                    <h6 class="typo-h6">데이터베이스</h6>
                </div>
                <div class="card-content">
                    <div class="form-group mb-3">
                        <label class="form-label">DB 저장 폴더</label>
                        <input class="form-field" @bind="_dbDir"
                               placeholder="%ProgramData%/DualSoft/DSPilot" />
                        <small style="color: var(--color-text-secondary); margin-top: 4px; display: block;">
                            plc.db 파일이 저장될 폴더. 서비스 모드에서 <code>%APPDATA%</code> 는 SYSTEM 계정 경로로 해석되므로 사용 금지.
                        </small>
                    </div>
                    <hr class="divider my-3" />
                    <button class="btn btn-outlined" style="width:100%; color:#e67e22; border-color:#e67e22;" @onclick="ClearFlowHistory">
                        <span class="material-icons" style="font-size:18px;">delete_sweep</span> Flow 히스토리 삭제
                    </button>
                    <small style="color: var(--color-text-secondary); margin-top: 6px; display: block;">
                        dspFlowHistory 와 Call 통계만 초기화. Flow/Call 정의와 AASX 는 유지.
                    </small>
                    <small style="color: var(--color-text-secondary); margin-top: 8px; display: block;">
                        현재 DB: @GetDatabasePath()
                    </small>
                </div>
            </div>

            @* 로깅 *@
            <div class="card" style="box-shadow: var(--shadow-2);">
                <div class="card-header">
                    <span class="material-icons mr-2">bug_report</span>
                    <h6 class="typo-h6">로깅</h6>
                </div>
                <div class="card-content">
                    <div class="form-group">
                        <label class="form-label">로그 수준</label>
                        <select class="form-select" @bind="_settings.Logging.LogLevel.Default">
                            @foreach (var level in _logLevels)
                            {
                                <option value="@level">@level</option>
                            }
                        </select>
                        <small style="color: var(--color-text-secondary); margin-top: 4px; display: block;">
                            세부 카테고리별 로그 수준은 <code>appsettings.json</code> 에서 직접 편집.
                        </small>
                    </div>
                </div>
            </div>

            @* UI *@
            <div class="card" style="box-shadow: var(--shadow-2);">
                <div class="card-header">
                    <span class="material-icons mr-2">settings</span>
                    <h6 class="typo-h6">사용자 인터페이스</h6>
                </div>
                <div class="card-content">
                    <label class="switch mb-2">
                        <input type="checkbox" @bind="_settings.Ui.ShowPlcDebug" />
                        PLC 디버그 페이지 표시
                    </label>
                    <small style="color: var(--color-text-secondary); margin-top: 4px; display: block;">
                        왼쪽 메뉴에 PLC 디버그 항목을 노출합니다.
                    </small>
                </div>
            </div>
        </div>

        @* 오른쪽 열 *@
        <div class="grid-item-6" style="display:flex; flex-direction:column; gap:16px;">

            @* 이상치 필터 *@
            <div class="card" style="box-shadow: var(--shadow-2);">
                <div class="card-header">
                    <span class="material-icons mr-2">filter_list</span>
                    <h6 class="typo-h6">이상치 필터</h6>
                </div>
                <div class="card-content">
                    <div style="padding:8px 12px; margin-bottom:12px; background:var(--color-surface-variant, #f5f5f5); border-radius:6px; border-left:3px solid var(--color-primary);">
                        <small style="color: var(--color-text-secondary); line-height:1.5;">
                            저장하면 서버 재시작 없이 즉시 적용됩니다.
                        </small>
                    </div>

                    <h6 class="typo-subtitle2" style="margin-bottom:8px;">
                        <span class="material-icons" style="font-size:16px; vertical-align:middle; margin-right:4px;">timer_off</span>
                        비가동 사이클 판정
                    </h6>
                    <small style="color: var(--color-text-secondary); display:block; margin-bottom:8px;">
                        CT가 제한값을 초과하면 비가동 사이클로 판정. 대시보드·동작편차·Flow 평균에서 제외, 사이클 분석에서 회색 배경 표시.
                    </small>
                    <div class="form-group">
                        <label class="form-label">사이클 시간 제한</label>
                        <div style="display:flex; gap:8px; align-items:center;">
                            <div style="display:flex; align-items:center; gap:4px;">
                                <input type="number" class="form-field" style="width:70px; text-align:center;"
                                       @bind="MaxCycleHours" min="0" max="99" />
                                <span style="font-size:13px; color:var(--color-text-secondary);">시</span>
                            </div>
                            <div style="display:flex; align-items:center; gap:4px;">
                                <input type="number" class="form-field" style="width:70px; text-align:center;"
                                       @bind="MaxCycleMinutes" min="0" max="59" />
                                <span style="font-size:13px; color:var(--color-text-secondary);">분</span>
                            </div>
                            <div style="display:flex; align-items:center; gap:4px;">
                                <input type="number" class="form-field" style="width:70px; text-align:center;"
                                       @bind="MaxCycleSeconds" min="0" max="59" />
                                <span style="font-size:13px; color:var(--color-text-secondary);">초</span>
                            </div>
                        </div>
                        <small style="color: var(--color-text-secondary); margin-top: 4px; display: block;">
                            가장 긴 Flow 의 평균 CT + 여유시간 권장. 모두 0이면 비활성.
                        </small>
                    </div>

                    <hr style="border:none; border-top:1px solid var(--color-lines, #e0e0e0); margin:16px 0;" />

                    <h6 class="typo-subtitle2" style="margin-bottom:8px;">
                        <span class="material-icons" style="font-size:16px; vertical-align:middle; margin-right:4px;">speed</span>
                        개별 Call 최대 실행시간
                    </h6>
                    <small style="color: var(--color-text-secondary); display:block; margin-bottom:8px;">
                        GoingTime 이 이 값을 초과하면 동작편차 통계에서 제외.
                    </small>
                    <div class="form-group">
                        <label class="form-label">최대 실행시간 (ms)</label>
                        <input type="number" class="form-field"
                               @bind="_settings.HistoryView.MaxCallGoingTimeMs"
                               min="1000" max="600000" placeholder="30000" />
                        <small style="color: var(--color-text-secondary); margin-top: 4px; display: block;">
                            기본: 30,000ms (30초)
                        </small>
                    </div>
                </div>
            </div>

            @* Flow CT 기준 *@
            <div class="card" style="box-shadow: var(--shadow-2);">
                <div class="card-header">
                    <span class="material-icons mr-2">restart_alt</span>
                    <h6 class="typo-h6">Flow CT 기준</h6>
                </div>
                <div class="card-content">
                    <button class="btn btn-outlined" style="width:100%;" @onclick="ReloadFlowCycleDefaultsFromAasxAsync">
                        <span class="material-icons" style="font-size:18px;">restart_alt</span>
                        AASX 기준으로 복원
                    </button>
                    <small style="color: var(--color-text-secondary); margin-top: 6px; display: block;">
                        Flow 별 사용자 start/end Call override 를 모두 제거하고 AASX 해석 결과로 되돌립니다.
                        통계/히스토리는 보존.
                    </small>
                </div>
            </div>

        </div>
    </div>
}
else
{
    <div class="spinner mt-4"></div>
}

@code {
    private AppSettingsModel? _settings;
    private readonly string[] _logLevels = { "Trace", "Debug", "Information", "Warning", "Error", "Critical", "None" };

    // AASX 파일 상태 캐시 (페이지 진입 시점 스냅샷)
    private bool _aasxExists;
    private long _aasxSize;
    private DateTime? _aasxWriteUtc;
    private string? _aasxCurrentSha256;

    // MaxCycleTimeMs ↔ 시/분/초 변환
    private int MaxCycleHours
    {
        get => _settings?.HistoryView.MaxCycleTimeMs / 3_600_000 ?? 0;
        set { if (_settings is not null) _settings.HistoryView.MaxCycleTimeMs = value * 3_600_000 + MaxCycleMinutes * 60_000 + MaxCycleSeconds * 1_000; }
    }
    private int MaxCycleMinutes
    {
        get => (_settings?.HistoryView.MaxCycleTimeMs ?? 0) % 3_600_000 / 60_000;
        set { if (_settings is not null) _settings.HistoryView.MaxCycleTimeMs = MaxCycleHours * 3_600_000 + value * 60_000 + MaxCycleSeconds * 1_000; }
    }
    private int MaxCycleSeconds
    {
        get => (_settings?.HistoryView.MaxCycleTimeMs ?? 0) % 60_000 / 1_000;
        set { if (_settings is not null) _settings.HistoryView.MaxCycleTimeMs = MaxCycleHours * 3_600_000 + MaxCycleMinutes * 60_000 + value * 1_000; }
    }

    // DB ConnectionString 분리 편집용 필드
    private string _dbDir = "";
    private const string DbFileName = "plc.db";

    private string SyncBadgeText
    {
        get
        {
            if (!_aasxExists) return "—";
            if (ProjectService.LastLoadedUtc is null) return "미로드";

            var loadedSha = ProjectService.LastLoadedSha256;
            // 해시 비교를 우선 — 동일 모델 재 export(zip 타임스탬프만 다름) 오탐 방지.
            // 해시를 못 구한 경우만 mtime 으로 폴백.
            if (loadedSha is not null && _aasxCurrentSha256 is not null)
            {
                return string.Equals(loadedSha, _aasxCurrentSha256, StringComparison.OrdinalIgnoreCase)
                    ? "최신"
                    : "외부 변경 감지됨";
            }
            if (_aasxWriteUtc is null) return "최신";
            return _aasxWriteUtc > ProjectService.LastLoadedUtc ? "외부 변경 감지됨" : "최신";
        }
    }

    private string SyncBadgeColor =>
        SyncBadgeText == "외부 변경 감지됨" ? "#e67e22"
        : SyncBadgeText == "최신" ? "#27ae60"
        : "var(--color-text-secondary)";

    protected override void OnInitialized()
    {
        _settings = SettingsService.LoadSettings();
        ParseConnectionString(_settings.Database.ConnectionString);
        RefreshAasxStatus();
        ProjectService.AasxExternallyChanged += OnAasxExternallyChanged;
    }

    public void Dispose()
    {
        ProjectService.AasxExternallyChanged -= OnAasxExternallyChanged;
    }

    private async void OnAasxExternallyChanged()
    {
        try
        {
            RefreshAasxStatus();
            await InvokeAsync(StateHasChanged);
            await JS.InvokeVoidAsync("uiUtils.showSnackbar",
                "Promaker 에서 AASX 모델이 변경되었습니다. 반영하려면 \"AASX 모델 다시 불러오기\" 를 누르세요.",
                "info");
        }
        catch (ObjectDisposedException) { /* 페이지 이탈 */ }
        catch { /* best effort */ }
    }

    private void RefreshAasxStatus()
    {
        try
        {
            var path = ProjectService.AasxFilePath;
            _aasxExists = File.Exists(path);
            if (_aasxExists)
            {
                var info = new FileInfo(path);
                _aasxSize = info.Length;
                _aasxWriteUtc = info.LastWriteTimeUtc;
                _aasxCurrentSha256 = ProjectService.GetAasxFileSha256();
            }
            else
            {
                _aasxSize = 0;
                _aasxWriteUtc = null;
                _aasxCurrentSha256 = null;
            }
        }
        catch
        {
            _aasxExists = false;
            _aasxSize = 0;
            _aasxWriteUtc = null;
            _aasxCurrentSha256 = null;
        }
    }

    private static string FormatTime(DateTime? utc)
    {
        if (utc is null) return "—";
        return utc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    private void ReloadSettings()
    {
        _settings = SettingsService.LoadSettings();
        ParseConnectionString(_settings!.Database.ConnectionString);
        RefreshAasxStatus();
        _ = JS.InvokeVoidAsync("uiUtils.showSnackbar", "설정을 다시 불러왔습니다.", "info");
    }

    private void ParseConnectionString(string connStr)
    {
        _dbDir = "";

        if (string.IsNullOrWhiteSpace(connStr)) return;

        foreach (var part in connStr.Split(';', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = part.Split('=', 2);
            if (kv.Length != 2) continue;
            var key = kv[0].Trim();
            var val = kv[1].Trim();

            if (key.Equals("Data Source", StringComparison.OrdinalIgnoreCase))
            {
                var normalized = val.Replace('\\', '/');
                if (normalized.EndsWith($"/{DbFileName}", StringComparison.OrdinalIgnoreCase))
                    _dbDir = val[..^(DbFileName.Length + 1)];
                else
                    _dbDir = val;
            }
        }
    }

    private string BuildConnectionString()
    {
        var dir = _dbDir.TrimEnd('/', '\\');
        return $"Data Source={dir}/{DbFileName};Version=3;BusyTimeout=20000";
    }

    private void SaveSettings()
    {
        if (_settings is null) return;
        try
        {
            _settings.Database.ConnectionString = BuildConnectionString();
            SettingsService.SaveSettings(_settings);
            _ = JS.InvokeVoidAsync("uiUtils.showSnackbar",
                "설정이 저장되었습니다. 서비스 재시작이 필요한 항목은 자동 안내됩니다.",
                "success");
        }
        catch (Exception ex)
        {
            _ = JS.InvokeVoidAsync("uiUtils.showSnackbar", $"저장 실패: {ex.Message}", "error");
        }
    }

    private string GetDatabasePath()
    {
        try { return DatabasePathResolver.GetSharedDbPath(); }
        catch { return "알 수 없음"; }
    }

    private async Task ClearFlowHistory()
    {
        var result = await JS.InvokeAsync<bool>("uiUtils.showConfirm",
            "Flow 히스토리 삭제",
            "dspFlowHistory 와 Call 통계(평균/표준편차/사이클 카운트) 를 모두 초기화합니다.\n\nFlow/Call 정의는 유지되며, 즉시 새 사이클부터 다시 측정됩니다. 서버 재시작 불필요.",
            "초기화", "취소");

        if (!result) return;

        var rebuild = await DbLifecycle.ClearFlowHistoryAsync();
        await JS.InvokeVoidAsync("uiUtils.showSnackbar",
            rebuild.Message,
            rebuild.Success ? "success" : "error");
    }

    private async Task ReloadAasxModel()
    {
        var result = await JS.InvokeAsync<bool>("uiUtils.showConfirm",
            "AASX 모델 다시 불러오기",
            $"디스크의 AASX 파일을 다시 읽고 DB 를 재구축합니다.\n\n경로: {ProjectService.AasxFilePath}\n\n• AASX 재파싱 → dspFlow / dspCall 재생성\n• 모든 통계 / 히스토리 / 태그 로그 삭제\n• 엔진 자동 재시작\n• 서비스 재시작 불필요",
            "다시 불러오기", "취소");

        if (!result) return;

        var rebuild = await DbLifecycle.RebuildDatabaseAsync();
        RefreshAasxStatus();
        await JS.InvokeVoidAsync("uiUtils.showSnackbar",
            rebuild.Message,
            rebuild.Success ? "success" : "error");
    }

    private async Task ReloadFlowCycleDefaultsFromAasxAsync()
    {
        var result = await JS.InvokeAsync<bool>("uiUtils.showConfirm",
            "Flow CT 기준 복원",
            "Flow별 사용자 start/end Call override를 모두 제거하고 AASX 기준으로 다시 적용하시겠습니까?",
            "복원", "취소");

        if (!result) return;

        try
        {
            SettingsService.ClearFlowCycleOverrides();
            _settings = SettingsService.LoadSettings();
            ParseConnectionString(_settings.Database.ConnectionString);
            await FlowMetricsService.InitializeAsync();
            await JS.InvokeVoidAsync("uiUtils.showSnackbar", "Flow CT 기준을 AASX 기본값으로 다시 적용했습니다.", "success");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("uiUtils.showSnackbar", $"복원 실패: {ex.Message}", "error");
        }
    }
}
