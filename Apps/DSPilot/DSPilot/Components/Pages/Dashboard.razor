    private void SetSort(string field)
    {
        _sortField = field;
        UpdateChartCache();
    }

    private void ToggleSortDir()
    {
        _sortDesc = !_sortDesc;
        UpdateChartCache();
    }

    private void UpdateChartCache()
    {
        var rows = BlueprintService.Layout.FlowPlacements
            .Select(fp =>
            {
                var s = _dbSnapshot.Flows.FirstOrDefault(f => f.FlowName == fp.FlowName);

                // 평균/이전 토글에 따라 값 선택
                int mt, wt, ct;
                if (_showAverage)
                {
                    // 평균값 사용 (REAL -> int 변환)
                    mt = s?.AvgMT.HasValue == true ? (int)s.AvgMT.Value : 0;
                    wt = s?.AvgWT.HasValue == true ? (int)s.AvgWT.Value : 0;
                    ct = s?.AvgCT.HasValue == true ? (int)s.AvgCT.Value : 0;

                    // 평균값이 없으면 이전값으로 폴백
                    if (ct == 0)
                    {
                        mt = s?.MT ?? 0;
                        wt = s?.WT ?? 0;
                        ct = mt + wt;
                    }
                }
                else
                {
                    // 이전값 사용 (마지막 사이클)
                    mt = s?.MT ?? 0;
                    wt = s?.WT ?? 0;
                    ct = mt + wt;
                }

                return (fp.FlowName, mt, wt, ct, ct > 0 ? (double)wt / ct : 0.0);
            })
            .Where(f => f.ct > 0)
            .ToList();

        // 배지용: 항상 CT 기준 최대/최소, WT비율 기준 최대 대기
        _maxCtName = rows.Count > 0 ? rows.MaxBy(f => f.ct)!.FlowName : null;
        _minCtName = rows.Count > 1 ? rows.MinBy(f => f.ct)!.FlowName : null;
        _maxWtName = rows.Count > 0 ? rows.MaxBy(f => f.Item5)!.FlowName : null;
        _maxCtVal  = rows.Count > 0 ? rows.Max(f => f.ct) : 1;

        // 정렬 적용
        _chartData = (_sortField == "wt" ? (_sortDesc ? rows.OrderByDescending(f => f.wt) : rows.OrderBy(f => f.wt))
                    : _sortField == "mt" ? (_sortDesc ? rows.OrderByDescending(f => f.mt) : rows.OrderBy(f => f.mt))
                    :                      (_sortDesc ? rows.OrderByDescending(f => f.ct) : rows.OrderBy(f => f.ct)))
            .ToList();
    }

    private static string FormatMs(int ms)
    {
        if (ms <= 0) return "0s";
        if (ms < 1_000) return $"{ms}ms";
        if (ms < 60_000) return $"{ms / 1000.0:F1}s";
        if (ms < 3_600_000) return $"{ms / 60000}m {ms % 60000 / 1000}s";
        return $"{ms / 3_600_000}h {ms % 3_600_000 / 60000}m";
    }
