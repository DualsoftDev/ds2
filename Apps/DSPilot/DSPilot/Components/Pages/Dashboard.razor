@page "/"
@page "/dashboard"
@inject DsProjectService ProjectService
@inject DspDbService DbService
@inject BlueprintService BlueprintService
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Dashboard - DSPilot</PageTitle>

<style>
    /* 그리드: 두 방향 모두 뷰포트 채움 */
    .dashboard-grid {
        display: flex;
        gap: 12px;
        min-height: 0;
    }
    .dashboard-grid.grid-h {
        flex-direction: row;
        height: calc(100vh - 210px);
    }
    .dashboard-grid.grid-h.editing {
        height: calc(100vh - 300px);
    }
    .dashboard-grid.grid-v {
        flex-direction: column;
        height: calc(100vh - 210px);
    }
    .dashboard-grid.grid-v.editing {
        height: calc(100vh - 300px);
    }
    .widget-container {
        min-width: 0;
        min-height: 0;
        display: flex;
        flex-direction: column;
    }
    /* 모바일: 강제 단일 컬럼 */
    @@media (max-width: 768px) {
        .dashboard-grid.grid-h {
            flex-direction: column !important;
            height: auto !important;
        }
        .dashboard-grid.grid-h > .widget-container {
            flex: 0 0 auto !important;
            height: 60vh !important;
        }
    }
</style>

@if (!ProjectService.IsLoaded)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
        No project loaded. Configure the AASX file path in <code>appsettings.json</code> to get started.
    </MudAlert>
}
else
{
    @* ── 편집 모드 설정 패널 ── *@
    @if (_isEditing)
    {
        <MudCard Elevation="1" Class="mb-3">
            <MudCardContent Class="pa-3">
                <div style="display: flex; flex-wrap: wrap; gap: 20px; align-items: flex-start;">

                    @* 배치 *@
                    <div>
                        <div style="font-size:11px; color:#888; font-weight:600; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.5px;">배치</div>
                        <div style="display:flex; gap:6px;">
                            <MudButton Size="Size.Small"
                                       Variant="@(_direction == "horizontal" ? Variant.Filled : Variant.Outlined)"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.ViewColumn"
                                       OnClick="@(() => SetDirection("horizontal"))">좌우</MudButton>
                            <MudButton Size="Size.Small"
                                       Variant="@(_direction == "vertical" ? Variant.Filled : Variant.Outlined)"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.ViewStream"
                                       OnClick="@(() => SetDirection("vertical"))">상하</MudButton>
                        </div>
                    </div>

                    @* 순서 *@
                    <div>
                        <div style="font-size:11px; color:#888; font-weight:600; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.5px;">순서</div>
                        <div style="display:flex; align-items:center; gap:8px; background:#f5f5f5; border-radius:8px; padding:4px 12px;">
                            <span style="font-size:13px; font-weight:600; color:#0A1E5A;">@GetWidgetTitle(_widgetOrder[0])</span>
                            <MudIconButton Icon="@(_direction == "horizontal" ? Icons.Material.Filled.SwapHoriz : Icons.Material.Filled.SwapVert)"
                                           Size="Size.Small" Color="Color.Primary"
                                           OnClick="SwapWidgets" />
                            <span style="font-size:13px; font-weight:600; color:#0A1E5A;">@GetWidgetTitle(_widgetOrder[1])</span>
                        </div>
                    </div>

                    @* 비율 *@
                    <div>
                        <div style="font-size:11px; color:#888; font-weight:600; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.5px;">
                            @(_direction == "horizontal" ? "좌우 비율" : "상하 비율")
                        </div>
                        <div style="display:flex; gap:4px;">
                            @foreach (var r in RatioOptions)
                            {
                                var ratio = r;
                                <MudButton Size="Size.Small"
                                           Variant="@(_ratio == ratio ? Variant.Filled : Variant.Outlined)"
                                           Color="Color.Primary"
                                           OnClick="@(() => SetRatio(ratio))">@ratio</MudButton>
                            }
                        </div>
                    </div>

                    @* 표시 *@
                    <div>
                        <div style="font-size:11px; color:#888; font-weight:600; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.5px;">표시</div>
                        <div style="display:flex; gap:6px;">
                            @foreach (var wid in _widgetOrder)
                            {
                                var w      = wid;
                                var hidden = _hiddenWidgets.Contains(w);
                                <MudButton Size="Size.Small"
                                           Variant="@(hidden ? Variant.Outlined : Variant.Filled)"
                                           Color="@(hidden ? Color.Default : Color.Primary)"
                                           StartIcon="@(hidden ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                           OnClick="@(() => ToggleVisibility(w))">@GetWidgetTitle(w)</MudButton>
                            }
                        </div>
                    </div>

                </div>
            </MudCardContent>
        </MudCard>
    }

    @* ── 위젯 그리드 ── *@
    <div class="@($"dashboard-grid {(_direction == "horizontal" ? "grid-h" : "grid-v")}{(_isEditing ? " editing" : "")}")">
        @foreach (var widgetId in _widgetOrder)
        {
            var wid = widgetId;
            @if (!_hiddenWidgets.Contains(wid))
            {
                <div class="widget-container" style="@GetWidgetContainerStyle(wid)">

                    @if (wid == "layout")
                    {
                        <MudCard Elevation="2" Style="border-radius:8px; overflow:hidden; flex:1; min-height:0; display:flex; flex-direction:column;">
                            <MudCardContent Class="pa-3" Style="flex:1; min-height:0; display:flex; flex-direction:column; align-items:center; overflow:hidden;">
                                @if (!string.IsNullOrEmpty(BlueprintService.Layout.BlueprintImagePath))
                                {
                                    <div style="flex:1; min-height:0; width:100%; display:flex; justify-content:center; align-items:center; overflow:hidden;">
                                        <FlowLayoutSvg Style="@($"height:100%; max-width:100%; aspect-ratio:{_cw}/{_ch}; object-fit:contain;")"
                                                       CanvasWidth="_cw" CanvasHeight="_ch"
                                                       ImagePath="@BlueprintService.Layout.BlueprintImagePath"
                                                       ImageVersion="BlueprintService.ImageVersion"
                                                       OffsetX="_ox" OffsetY="_oy" CellWidth="_cellW" CellHeight="_cellH"
                                                       Placements="BlueprintService.Layout.FlowPlacements"
                                                       GetColor="@(fp => GetFlowColor(fp.FlowName, fp.SystemId))"
                                                       GetStateLabel="@(fp => GetFlowStateLabel(fp.FlowName))"
                                                       GetMtWt="@(fp => GetFlowMtWt(fp.FlowName))" />
                                    </div>
                                    <div class="d-flex justify-center gap-3 flex-wrap" style="padding:4px 0 2px; flex-shrink:0;">
                                        @foreach (var (label, clr) in _stateLegend)
                                        {
                                            <div class="d-flex align-center" style="gap:4px;">
                                                <span style="@($"width:12px;height:12px;border-radius:3px;background:{clr};display:inline-block;")"></span>
                                                <MudText Typo="Typo.caption">@label</MudText>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px; color:#bdbdbd;">
                                        <MudIcon Icon="@Icons.Material.Filled.Map" Style="font-size:48px;" />
                                        <MudText Typo="Typo.body2">도면 이미지가 등록되지 않았습니다</MudText>
                                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary"
                                                   OnClick="@(() => Nav.NavigateTo("/editor"))">레이아웃 수정</MudButton>
                                    </div>
                                }
                            </MudCardContent>
                        </MudCard>
                    }
                    else if (wid == "ct")
                    {
                        <MudCard Elevation="2" Style="border-radius:8px; overflow:hidden; flex:1; min-height:0; display:flex; flex-direction:column;">
                            <MudCardContent Class="pa-3" Style="flex:1; min-height:0; overflow-y:auto;">
                                @if (_chartData.Count > 0)
                                {
                                    <MudText Typo="Typo.subtitle2" Style="font-weight:600; color:#0A1E5A; margin-bottom:8px; display:block;">CT 분석 (가동 + 대기, 내림차순)</MudText>

                                    <div style="display:flex; gap:8px; margin-bottom:12px;">
                                        <div style="flex:1; padding:8px 10px; border-radius:8px; background:#ffeaea; outline:1.5px solid #ef5350;">
                                            <div style="font-size:9px; color:#ef5350; font-weight:700; margin-bottom:2px;">최대시간</div>
                                            <div style="font-size:13px; font-weight:700; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="@_maxCtName">@(_maxCtName ?? "-")</div>
                                            <div style="font-size:12px; color:#555;">@FormatMs(_maxCtVal)</div>
                                        </div>
                                        <div style="flex:1; padding:8px 10px; border-radius:8px; background:#fff3e0; outline:1.5px solid #fb8c00;">
                                            <div style="font-size:9px; color:#fb8c00; font-weight:700; margin-bottom:2px;">최대대기시간</div>
                                            <div style="font-size:13px; font-weight:700; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="@_maxWtName">@(_maxWtName ?? "-")</div>
                                            <div style="font-size:12px; color:#555;">@FormatMs(_chartData.FirstOrDefault(f => f.FlowName == _maxWtName).CT)</div>
                                        </div>
                                        <div style="flex:1; padding:8px 10px; border-radius:8px; background:#e0f7f5; outline:1.5px solid #26a69a;">
                                            <div style="font-size:9px; color:#26a69a; font-weight:700; margin-bottom:2px;">최소시간</div>
                                            <div style="font-size:13px; font-weight:700; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="@_minCtName">@(_minCtName ?? "-")</div>
                                            <div style="font-size:12px; color:#555;">@FormatMs(_chartData[^1].CT)</div>
                                        </div>
                                    </div>

                                    @foreach (var flow in _chartData)
                                    {
                                        var isMaxCT    = flow.FlowName == _maxCtName;
                                        var isMinCT    = flow.FlowName == _minCtName;
                                        var isMaxWT    = flow.FlowName == _maxWtName;
                                        var highlighted = isMaxCT || isMinCT || isMaxWT;
                                        var fillPct    = _maxCtVal > 0 ? flow.CT * 100.0 / _maxCtVal : 0;
                                        var mtPct      = flow.CT > 0 ? flow.MT * 100.0 / flow.CT : 0;
                                        var wtPct      = 100.0 - mtPct;
                                        var rowBorder  = isMaxCT ? "outline:1.5px solid #ef5350;"
                                                       : isMinCT ? "outline:1.5px solid #26a69a;"
                                                       : isMaxWT ? "outline:1.5px solid #fb8c00;" : "";
                                        var rowStyle   = $"display:flex; align-items:center; margin-bottom:3px; padding:3px 6px; border-radius:6px;{(highlighted ? " background:rgba(0,0,0,0.03); " + rowBorder : "")}";
                                        <div style="@rowStyle">
                                            <div style="@($"width:120px; font-size:12px; font-weight:{(highlighted ? "700" : "400")}; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; padding-right:6px;")">
                                                @flow.FlowName
                                            </div>
                                            <div style="flex:1; height:18px; background:#e9e9e9; border-radius:4px; overflow:hidden; margin:0 8px;">
                                                <div style="@($"display:flex; height:100%; width:{fillPct:F1}%;")">
                                                    <div style="@($"width:{mtPct:F1}%; background:#42A5F5; height:100%;")"></div>
                                                    <div style="@($"width:{wtPct:F1}%; background:#FFA726; height:100%;")"></div>
                                                </div>
                                            </div>
                                            <div style="width:60px; font-size:11px; color:#555; text-align:right;">@FormatMs(flow.CT)</div>
                                            <div style="width:80px; display:flex; gap:3px; justify-content:flex-end; padding-left:4px;">
                                                @if (isMaxCT) { <span style="font-size:8px; padding:1px 4px; border-radius:8px; background:#ef5350; color:white;">최대</span> }
                                                @if (isMinCT) { <span style="font-size:8px; padding:1px 4px; border-radius:8px; background:#26a69a; color:white;">최소</span> }
                                                @if (isMaxWT) { <span style="font-size:8px; padding:1px 4px; border-radius:8px; background:#fb8c00; color:white;">대기↑</span> }
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px; padding:40px 0; color:#bdbdbd;">
                                        <MudIcon Icon="@Icons.Material.Filled.BarChart" Style="font-size:48px;" />
                                        <MudText Typo="Typo.body2">CT 데이터가 없습니다</MudText>
                                    </div>
                                }
                            </MudCardContent>
                        </MudCard>
                    }

                </div>
            }
        }
    </div>
}

<div style="border-top:1px solid #e0e0e0; padding:8px 16px;
            display:flex; justify-content:space-between; align-items:center;">
    <MudButton Variant="@(_isEditing ? Variant.Filled : Variant.Outlined)"
               Color="@(_isEditing ? Color.Warning : Color.Default)"
               StartIcon="@(_isEditing ? Icons.Material.Filled.Check : Icons.Material.Filled.DashboardCustomize)"
               OnClick="ToggleEdit">
        @(_isEditing ? "수정 완료" : "대시보드 수정")
    </MudButton>
    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Edit"
               OnClick="@(() => Nav.NavigateTo("/editor"))">
        레이아웃 수정
    </MudButton>
</div>

@code {
    private DspDbSnapshot _dbSnapshot = new();

    // 도면 레이아웃 필드
    private int _cw, _ch, _cellW, _cellH, _ox, _oy;
    private readonly Dictionary<Guid, int> _systemColorIndex = [];
    private static readonly string[] SystemColors =
        ["#0A1E5A", "#FA002D", "#0569A0", "#009BB4", "#4CAF50"];
    private static readonly (string Label, string Color)[] _stateLegend =
    [
        ("Ready", "#9E9E9E"), ("Going", "#4CAF50"), ("Done", "#2196F3"),
        ("Error", "#F44336"), ("Pause", "#FF9800"), ("Abort", "#9C27B0")
    ];

    // CT 차트 필드
    private List<(string FlowName, int MT, int WT, int CT, double WTRatio)> _chartData = [];
    private string? _maxCtName, _minCtName, _maxWtName;
    private int _maxCtVal;

    // 대시보드 레이아웃 설정
    private bool _isEditing;
    private List<string> _widgetOrder    = ["layout", "ct"];
    private HashSet<string> _hiddenWidgets = [];
    private string _direction            = "vertical";   // "horizontal" | "vertical"
    private string _ratio                = "1:1";

    private static readonly string[] RatioOptions = ["1:3", "1:2", "1:1", "2:1", "3:1"];

    private static readonly Dictionary<string, string> WidgetTitles = new()
    {
        ["layout"] = "도면 레이아웃",
        ["ct"]     = "CT 분석",
    };
    private static string GetWidgetTitle(string id) =>
        WidgetTitles.TryGetValue(id, out var t) ? t : id;

    /// <summary>
    /// 비율에 따라 위젯 flex 스타일 반환.
    /// horizontal → flex-basis(너비), vertical → flex(높이) 모두 동일 로직.
    /// </summary>
    private string GetWidgetContainerStyle(string widgetId)
    {
        var parts     = _ratio.Split(':');
        var leftFlex  = int.Parse(parts[0]);
        var rightFlex = int.Parse(parts[1]);
        var isFirst   = _widgetOrder.Count > 0 && _widgetOrder[0] == widgetId;
        var flex      = isFirst ? leftFlex : rightFlex;
        return $"flex: {flex}; min-width: 0; min-height: 0;";
    }

    protected override void OnInitialized()
    {
        _dbSnapshot = DbService.Snapshot;
        DbService.OnDataChanged += OnDbDataChanged;

        var layout = BlueprintService.Layout;
        _cw = layout.CanvasWidth; _ch = layout.CanvasHeight;
        _cellW = layout.CellWidth; _cellH = layout.CellHeight;
        _ox = layout.OffsetX; _oy = layout.OffsetY;
        UpdateChartCache();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", "dsp-dashboard-layout-v5");
            if (json == null) return;
            var doc = System.Text.Json.JsonDocument.Parse(json);

            if (doc.RootElement.TryGetProperty("order", out var orderEl))
            {
                var loaded = orderEl.EnumerateArray()
                    .Select(e => e.GetString()!)
                    .Where(s => _widgetOrder.Contains(s))
                    .ToList();
                foreach (var w in _widgetOrder.Where(w => !loaded.Contains(w)))
                    loaded.Add(w);
                _widgetOrder = loaded;
            }
            if (doc.RootElement.TryGetProperty("hidden", out var hiddenEl))
                _hiddenWidgets = hiddenEl.EnumerateArray()
                    .Select(e => e.GetString()!)
                    .Where(s => s != null)
                    .ToHashSet();
            if (doc.RootElement.TryGetProperty("direction", out var dirEl) && dirEl.GetString() is string dir)
                _direction = dir;
            if (doc.RootElement.TryGetProperty("ratio", out var ratioEl) && ratioEl.GetString() is string rat)
                _ratio = rat;

            StateHasChanged();
        }
        catch { }
    }

    private async void OnDbDataChanged()
    {
        _dbSnapshot = DbService.Snapshot;
        UpdateChartCache();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose() => DbService.OnDataChanged -= OnDbDataChanged;

    private void ToggleEdit() => _isEditing = !_isEditing;

    private void SetDirection(string dir)
    {
        _direction = dir;
        _ = SaveLayoutAsync();
    }

    private void SetRatio(string ratio)
    {
        _ratio = ratio;
        _ = SaveLayoutAsync();
    }

    private void SwapWidgets()
    {
        (_widgetOrder[0], _widgetOrder[1]) = (_widgetOrder[1], _widgetOrder[0]);
        _ = SaveLayoutAsync();
    }

    private void ToggleVisibility(string widgetId)
    {
        if (!_hiddenWidgets.Add(widgetId)) _hiddenWidgets.Remove(widgetId);
        _ = SaveLayoutAsync();
    }

    private async Task SaveLayoutAsync()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(new
            {
                order     = _widgetOrder,
                hidden    = _hiddenWidgets.ToList(),
                direction = _direction,
                ratio     = _ratio,
            });
            await JS.InvokeVoidAsync("localStorage.setItem", "dsp-dashboard-layout-v5", json);
        }
        catch { }
    }

    private (int Mt, int Wt)? GetFlowMtWt(string flowName)
    {
        var s = _dbSnapshot.Flows.FirstOrDefault(f => f.FlowName == flowName);
        if (s?.MT == null && s?.WT == null) return null;
        return (s.MT ?? 0, s.WT ?? 0);
    }

    private string GetFlowColor(string flowName, Guid systemId)
    {
        var s = _dbSnapshot.Flows.FirstOrDefault(f => f.FlowName == flowName);
        if (s == null) return GetSystemColor(systemId);
        return s.State?.ToLowerInvariant() switch
        {
            "ready" => "#9E9E9E", "going" => "#4CAF50", "done"  => "#2196F3",
            "error" => "#F44336", "pause" => "#FF9800", "abort" => "#9C27B0",
            _ => "#9E9E9E",
        };
    }

    private string GetFlowStateLabel(string flowName) =>
        _dbSnapshot.Flows.FirstOrDefault(f => f.FlowName == flowName)?.State ?? "";

    private string GetSystemColor(Guid systemId)
    {
        if (!_systemColorIndex.ContainsKey(systemId))
            _systemColorIndex[systemId] = _systemColorIndex.Count % SystemColors.Length;
        return SystemColors[_systemColorIndex[systemId]];
    }

    private void UpdateChartCache()
    {
        _chartData = BlueprintService.Layout.FlowPlacements
            .Select(fp =>
            {
                var s = _dbSnapshot.Flows.FirstOrDefault(f => f.FlowName == fp.FlowName);
                var mt = s?.MT ?? 0; var wt = s?.WT ?? 0; var ct = mt + wt;
                return (fp.FlowName, mt, wt, ct, ct > 0 ? (double)wt / ct : 0.0);
            })
            .Where(f => f.ct > 0)
            .OrderByDescending(f => f.ct)
            .ToList();
        _maxCtName = _chartData.Count > 0 ? _chartData[0].FlowName : null;
        _minCtName = _chartData.Count > 1 ? _chartData[^1].FlowName : null;
        _maxWtName = _chartData.Count > 0 ? _chartData.OrderByDescending(f => f.WTRatio).First().FlowName : null;
        _maxCtVal  = _chartData.Count > 0 ? _chartData[0].CT : 1;
    }

    private static string FormatMs(int ms)
    {
        if (ms <= 0) return "0s";
        if (ms < 1_000) return $"{ms}ms";
        if (ms < 60_000) return $"{ms / 1000.0:F1}s";
        if (ms < 3_600_000) return $"{ms / 60000}m {ms % 60000 / 1000}s";
        return $"{ms / 3_600_000}h {ms % 3_600_000 / 60000}m";
    }
}
