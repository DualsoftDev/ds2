    /// horizontal → flex-basis(너비), vertical → flex(높이) 모두 동일 로직.
    /// </summary>
    private string GetWidgetContainerStyle(string widgetId)
    {
        var parts     = _ratio.Split(':');
        var leftFlex  = int.Parse(parts[0]);
        var rightFlex = int.Parse(parts[1]);
        var isFirst   = _widgetOrder.Count > 0 && _widgetOrder[0] == widgetId;
        var flex      = isFirst ? leftFlex : rightFlex;
        return $"flex: {flex}; min-width: 0; min-height: 0;";
    }

    protected override void OnInitialized()
    {
        _dbSnapshot = DbService.Snapshot;
        DbService.OnDataChanged += OnDbDataChanged;
        EditService.OnChanged += OnEditStateChanged;

        var layout = BlueprintService.Layout;
        _cw = layout.CanvasWidth; _ch = layout.CanvasHeight;
        _cellW = layout.CellWidth; _cellH = layout.CellHeight;
        _ox = layout.OffsetX; _oy = layout.OffsetY;
        UpdateChartCache();
    }

    protected override void OnParametersSet()
    {
        _selectedFlowName = string.IsNullOrWhiteSpace(QueryFlow) ? null : QueryFlow.Trim();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _dotNetRef = DotNetObjectReference.Create(this);

        try { _windowHeight = await JS.InvokeAsync<double>("eval", "window.innerHeight"); } catch { }

        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", "dsp-dashboard-layout-v5");
            if (json == null) return;
            var doc = System.Text.Json.JsonDocument.Parse(json);

            if (doc.RootElement.TryGetProperty("order", out var orderEl))
            {
                var loaded = orderEl.EnumerateArray()
                    .Select(e => e.GetString()!)
                    .Where(s => _widgetOrder.Contains(s))
                    .ToList();
                foreach (var w in _widgetOrder.Where(w => !loaded.Contains(w)))
                    loaded.Add(w);
                _widgetOrder = loaded;
            }
            if (doc.RootElement.TryGetProperty("hidden", out var hiddenEl))
                _hiddenWidgets = hiddenEl.EnumerateArray()
                    .Select(e => e.GetString()!)
                    .Where(s => s != null)
                    .ToHashSet();
            if (doc.RootElement.TryGetProperty("direction", out var dirEl) && dirEl.GetString() is string dir)
                _direction = dir;
            if (doc.RootElement.TryGetProperty("ratio", out var ratioEl) && ratioEl.GetString() is string rat)
                _ratio = rat;

            StateHasChanged();
        }
        catch { }
    }

    private bool _disposed;

    private async void OnDbDataChanged()
    {
        if (_disposed) return;
        _dbSnapshot = DbService.Snapshot;
        UpdateChartCache();
        try { await InvokeAsync(StateHasChanged); } catch (ObjectDisposedException) { }
    }

    private async void OnEditStateChanged()
    {
        if (_disposed) return;
        try { await InvokeAsync(StateHasChanged); } catch (ObjectDisposedException) { }
    }

    public void Dispose()
    {
        _disposed = true;
        DbService.OnDataChanged -= OnDbDataChanged;
        EditService.OnChanged -= OnEditStateChanged;
        _dotNetRef?.Dispose();
    }

    private async Task EnterFullscreen()
    {
        _isFullscreen = true;
        StateHasChanged();
        await Task.Yield(); // DOM 업데이트 대기
        await JS.InvokeVoidAsync("uiUtils.enterFullscreen", _fullscreenRef, _dotNetRef);
    }

    private async Task ExitFullscreen()
    {
        _isFullscreen = false;
        await JS.InvokeVoidAsync("uiUtils.exitFullscreen");
    }

    [JSInvokable]
    public async Task OnBrowserFullscreenExited()
    {
        _isFullscreen = false;
        await InvokeAsync(StateHasChanged);
    }

    private void ResetToDefault()
    {
        _direction     = "horizontal";
        _widgetOrder   = ["ct", "layout"];
        _ratio         = "1:3";
        _hiddenWidgets = [];
        _ = SaveLayoutAsync();
    }

    private void SetDirection(string dir)
    {
        _direction = dir;
        _ = SaveLayoutAsync();
    }

    private void SetRatio(string ratio)
    {
        _ratio = ratio;
        _ = SaveLayoutAsync();
    }

    private void SwapWidgets()
    {
        (_widgetOrder[0], _widgetOrder[1]) = (_widgetOrder[1], _widgetOrder[0]);
        _ = SaveLayoutAsync();
    }

    private void ToggleVisibility(string widgetId)
    {
        if (!_hiddenWidgets.Add(widgetId)) _hiddenWidgets.Remove(widgetId);
        _ = SaveLayoutAsync();
    }

    private async void SetDisplayMode(bool showAverage)
    {
        if (_showAverage != showAverage)
        {
            _showAverage = showAverage;
            Logger.LogInformation("Display mode changed to: {Mode}", showAverage ? "Average" : "Previous");

            // DB 스냅샷 새로고침
            _dbSnapshot = DbService.Snapshot;
            Logger.LogInformation("DB Snapshot reloaded. Flow count: {Count}", _dbSnapshot.Flows.Count);

            // 첫 번째 Flow의 평균값 로그 출력 (디버깅용)
            var firstFlow = _dbSnapshot.Flows.FirstOrDefault();
            if (firstFlow != null)
            {
                Logger.LogInformation("Sample Flow: {Name}, MT={MT}, AvgMT={AvgMT}, WT={WT}, AvgWT={AvgWT}",
                    firstFlow.FlowName, firstFlow.MT, firstFlow.AvgMT, firstFlow.WT, firstFlow.AvgWT);
            }

            UpdateChartCache();  // 차트 데이터 재계산
            Logger.LogInformation("Chart cache updated. Chart data count: {Count}", _chartData.Count);

            try
            {
                await InvokeAsync(StateHasChanged);  // UI 즉시 반영 (비동기)
                Logger.LogInformation("StateHasChanged invoked successfully");
