    private async Task SaveLayoutAsync()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(new
            {
                order     = _widgetOrder,
                hidden    = _hiddenWidgets.ToList(),
                direction = _direction,
                ratio     = _ratio,
            });
            await JS.InvokeVoidAsync("localStorage.setItem", "dsp-dashboard-layout-v5", json);
        }
        catch { }
    }

    private (int Mt, int Wt)? GetFlowMtWt(string flowName)
    {
        var s = _dbSnapshot.Flows.FirstOrDefault(f => f.FlowName == flowName);

        if (_showAverage)
        {
            // 평균값 사용
            if (s?.AvgMT.HasValue == true || s?.AvgWT.HasValue == true)
            {
                var mt = s?.AvgMT.HasValue == true ? (int)s.AvgMT.Value : 0;
                var wt = s?.AvgWT.HasValue == true ? (int)s.AvgWT.Value : 0;
                return (mt, wt);
            }
            // 평균값이 없으면 이전값으로 폴백
            if (s?.MT == null && s?.WT == null) return null;
            return (s.MT ?? 0, s.WT ?? 0);
        }
        else
        {
            // 이전값 사용
            if (s?.MT == null && s?.WT == null) return null;
            return (s.MT ?? 0, s.WT ?? 0);
        }
    }

    private string GetFlowColor(string flowName, Guid systemId)
    {
        var s = _dbSnapshot.Flows.FirstOrDefault(f => f.FlowName == flowName);
        if (s == null) return GetSystemColor(systemId);
        return s.State?.ToLowerInvariant() switch
        {
            "ready" => "#4CAF50", "going" => "#EAB308", "finish" => "#2196F3",
            "error" => "#F44336",
            _ => "#4CAF50",
        };
    }

    private string GetFlowStateLabel(string flowName) =>
        _dbSnapshot.Flows.FirstOrDefault(f => f.FlowName == flowName)?.State ?? "";

    private IEnumerable<(string Label, string Color)> GetFlowBadges(string flowName)
    {
        if (flowName == _maxCtName) yield return ("최대", "#ef5350");
        if (flowName == _minCtName) yield return ("최소", "#26a69a");
        if (flowName == _maxWtName) yield return ("대기", "#F48FB1");
    }

    private string GetSystemColor(Guid systemId)
    {
        if (!_systemColorIndex.ContainsKey(systemId))
            _systemColorIndex[systemId] = _systemColorIndex.Count % SystemColors.Length;
        return SystemColors[_systemColorIndex[systemId]];
    }

    private void OnFlowSelected(string? flowName)
    {
        _selectedFlowName = flowName;
        _popupFlow = null;
    }

    private async void OnFlowSelectedFromLayout(string? flowName)
    {
        _selectedFlowName = flowName;
        // 도면 레이아웃 flow 카드 클릭 시 팝업과 히스토리 열기
        if (flowName != null)
        {
            _popupFlow = _chartData.FirstOrDefault(f => f.FlowName == flowName);

            // Flow 히스토리 로드 (최근 100개, 최근 5개만 표시하고 나머지는 스크롤)
            await LoadFlowHistoryAsync(flowName);
        }
        else
        {
            _popupFlow = null;
            _flowHistory.Clear();
        }
    }

    private async Task LoadFlowHistoryAsync(string flowName)
    {
        try
        {
            var settings = SettingsService.LoadSettings();
            var filter = settings.HistoryView;
            if (filter.FilterMode == "Cycles")
            {
                _flowHistory = await DspRepository.GetFlowHistoryAsync(flowName, filter.MaxCycles);
            }
            else if (filter.FilterMode == "Days")
            {
                _flowHistory = await DspRepository.GetFlowHistoryByDaysAsync(flowName, filter.MaxDays);
            }
            else
            {
                // None: 제한 없이 로드 (안전 상한 10000)
                _flowHistory = await DspRepository.GetFlowHistoryAsync(flowName, 10000);
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load flow history for {FlowName}", flowName);
            _flowHistory.Clear();
        }
    }

    private void ClosePopup()
    {
        _popupFlow = null;
        _flowHistory.Clear();
    }

    private void OnRowMouseEnter(string flowName, MouseEventArgs e)
    {
        _hoverFlowName = flowName;
        _tooltipX = e.ClientX + 16;
        const double tooltipH = 200;
        var top = e.ClientY - 20;
        // 화면 하단 넘침 방지: 툴팁이 뷰포트 아래로 넘어가면 커서 위쪽에 표시
        _tooltipY = (top + tooltipH > _windowHeight)
            ? Math.Max(8, e.ClientY - tooltipH - 10)
            : top;
    }

    private void OnRowMouseLeave()
    {
