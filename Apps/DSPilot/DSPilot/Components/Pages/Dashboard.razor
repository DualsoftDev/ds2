@page "/"
@page "/dashboard"
@inject DsProjectService ProjectService
@inject DspDbService DbService
@inject BlueprintService BlueprintService
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject DashboardEditService EditService
@inject DSPilot.Adapters.DspRepositoryAdapter DspRepository
@inject AppSettingsService SettingsService
@inject ILogger<Dashboard> Logger
@implements IDisposable

<PageTitle>Dashboard - DSPilot</PageTitle>
<div style="display:flex; align-items:center; gap:12px; margin-bottom:16px;">
    <h5 class="typo-h5" style="font-weight: 600; color: var(--color-text-primary); margin:0;">대시보드</h5>
    <div style="flex:1;"></div>
    <button class="btn btn-sm btn-outlined" @onclick="EnterFullscreen" title="전체화면">
        <span class="material-icons" style="font-size:18px;">fullscreen</span> 전체화면
    </button>
</div>
<div @ref="_fullscreenRef" class="@(_isFullscreen ? "dashboard-fullscreen" : "")" style="display:flex; flex-direction:column; flex:1; min-height:0;">

@if (!ProjectService.IsLoaded)
{
    <div class="alert alert-info mb-4">
        <span class="material-icons">info</span>
        No project loaded. Configure the AASX file path in <code>appsettings.json</code> to get started.
    </div>
}
else
{
    @* ── 전체화면 닫기 버튼 ── *@
    @if (_isFullscreen)
    {
        <button class="fullscreen-close-btn" @onclick="ExitFullscreen" title="전체화면 닫기">
            <span class="material-icons">close</span>
        </button>
    }

    @* ── 편집 모드 설정 패널 ── *@
    @if (EditService.IsEditing && !_isFullscreen)
    {
        <div class="card mb-3" style="box-shadow: var(--shadow-1);">
            <div style="padding: 12px;">
                <div style="display: flex; flex-wrap: wrap; gap: 20px; align-items: flex-start;">

                    @* 배치 *@
                    <div>
                        <div style="font-size:11px; color:var(--color-text-secondary); font-weight:600; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.5px;">배치</div>
                        <div style="display:flex; gap:6px;">
                            <button class="btn btn-sm @(_direction == "horizontal" ? "btn-filled" : "btn-outlined")"
                                    @onclick="@(() => SetDirection("horizontal"))">
                                <span class="material-icons" style="font-size:18px;">view_column</span> 좌우
                            </button>
                            <button class="btn btn-sm @(_direction == "vertical" ? "btn-filled" : "btn-outlined")"
                                    @onclick="@(() => SetDirection("vertical"))">
                                <span class="material-icons" style="font-size:18px;">view_stream</span> 상하
                            </button>
                        </div>
                    </div>

                    @* 순서 *@
                    <div>
                        <div style="font-size:11px; color:var(--color-text-secondary); font-weight:600; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.5px;">순서</div>
                        <div style="display:flex; align-items:center; gap:8px; background:var(--color-background); border-radius:8px; padding:4px 12px;">
                            <span style="font-size:13px; font-weight:600; color:var(--color-primary);">@GetWidgetTitle(_widgetOrder[0])</span>
                            <button class="btn-icon" style="color:var(--color-primary);" @onclick="SwapWidgets">
                                <span class="material-icons">@(_direction == "horizontal" ? "swap_horiz" : "swap_vert")</span>
                            </button>
                            <span style="font-size:13px; font-weight:600; color:var(--color-primary);">@GetWidgetTitle(_widgetOrder[1])</span>
                        </div>
                    </div>

                    @* 비율 *@
                    <div>
                        <div style="font-size:11px; color:var(--color-text-secondary); font-weight:600; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.5px;">
                            @(_direction == "horizontal" ? "좌우 비율" : "상하 비율")
                        </div>
                        <div style="display:flex; gap:4px;">
                            @foreach (var r in RatioOptions)
                            {
                                var ratio = r;
                                <button class="btn btn-sm @(_ratio == ratio ? "btn-filled" : "btn-outlined")"
                                        @onclick="@(() => SetRatio(ratio))">@ratio</button>
                            }
                        </div>
                    </div>

                    @* 표시 *@
                    <div>
                        <div style="font-size:11px; color:var(--color-text-secondary); font-weight:600; margin-bottom:6px; text-transform:uppercase; letter-spacing:0.5px;">표시</div>
                        <div style="display:flex; gap:6px;">
                            @foreach (var wid in _widgetOrder)
                            {
                                var w      = wid;
                                var hidden = _hiddenWidgets.Contains(w);
                                <button class="btn btn-sm @(hidden ? "btn-outlined" : "btn-filled")"
                                        @onclick="@(() => ToggleVisibility(w))">
                                    <span class="material-icons" style="font-size:18px;">@(hidden ? "visibility_off" : "visibility")</span>
                                    @GetWidgetTitle(w)
                                </button>
                            }
                        </div>
                    </div>

                    @* 기본값 *@
                    <div style="margin-left:auto; display:flex; align-items:flex-end;">
                        <button class="btn btn-sm btn-outlined" @onclick="ResetToDefault">
                            <span class="material-icons" style="font-size:18px;">restart_alt</span> 기본값
                        </button>
                    </div>

                </div>
            </div>
        </div>
    }

    @* ── 위젯 그리드 ── *@
    <div class="@GridClass">
        @foreach (var widgetId in _widgetOrder)
        {
            var wid = widgetId;
            if (!_hiddenWidgets.Contains(wid))
            {
                <div class="widget-container" style="@GetWidgetContainerStyle(wid)">

                    @if (wid == "layout")
                    {
                        <div class="ds-card">
                            <div class="ds-card-header">
                                <span class="ct-section-title">도면 레이아웃</span>
                                <div style="display:flex; align-items:center; gap:calc(var(--u) * 0.7);">
                                    <div class="layout-legend">
                                        @foreach (var (label, clr) in _stateLegend)
                                        {
                                            <div class="layout-legend-item">
                                                <span class="layout-legend-dot" style="background:@clr;"></span>
                                                @label
                                            </div>
                                        }
                                    </div>
                                    @if (!_isFullscreen)
                                    {
                                        <button class="btn btn-sm btn-outlined" @onclick="@(() => Nav.NavigateTo("/editor"))">
                                            <span class="material-icons" style="font-size:calc(var(--u) * 1.3);">edit</span> 편집
                                        </button>
                                    }
                                </div>
                            </div>
                            <div class="ds-card-body" style="align-items:center; justify-content:center;">
                                @if (!string.IsNullOrEmpty(BlueprintService.Layout.BlueprintImagePath))
                                {
                                    <div style="flex:1; min-height:0; width:100%; display:flex; justify-content:center; align-items:center; overflow:hidden; padding:12px;">
                                        <FlowLayoutSvg Style="@($"height:100%; max-width:100%; aspect-ratio:{_cw}/{_ch}; object-fit:contain;")"
                                                       CanvasWidth="_cw" CanvasHeight="_ch"
                                                       ImagePath="@BlueprintService.Layout.BlueprintImagePath"
                                                       ImageVersion="BlueprintService.ImageVersion"
                                                       OffsetX="_ox" OffsetY="_oy" CellWidth="_cellW" CellHeight="_cellH"
                                                       Placements="BlueprintService.Layout.FlowPlacements"
                                                       GetColor="@(fp => GetFlowColor(fp.FlowName, fp.SystemId))"
                                                       GetStateLabel="@(fp => GetFlowStateLabel(fp.FlowName))"
                                                       GetMtWt="@(fp => GetFlowMtWt(fp.FlowName))"
                                                       GetBadges="@(fp => GetFlowBadges(fp.FlowName))"
                                                       SelectedFlowName="@_selectedFlowName"
                                                       OnFlowClicked="OnFlowSelectedFromLayout" />
                                    </div>
                                }
                                else
                                {
                                    <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px; color:var(--color-text-disabled); padding:40px 0;">
                                        <span class="material-icons" style="font-size:48px;">map</span>
                                        <span class="typo-body2">도면 이미지가 등록되지 않았습니다</span>
                                        <button class="btn btn-sm btn-outlined" @onclick="@(() => Nav.NavigateTo("/editor"))">레이아웃 수정</button>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else if (wid == "ct")
                    {
                        <div class="ds-card">
                            @* ── 헤더 (항상 표시, 도면 레이아웃 카드와 동일 높이) ── *@
                            <div class="ds-card-header">
                                <span class="ct-section-title">Time 분석</span>
                                <div style="display:flex; align-items:center; gap:calc(var(--u) * 0.35); flex-wrap:wrap;">
                                    @* 평균/이전 토글 - 두 버튼으로 표시 *@
                                    <div style="display:flex; gap:4px; background:var(--color-background); padding:4px; border-radius:8px;">
                                        <button class="btn btn-sm @(!_showAverage ? "btn-filled" : "btn-outlined")"
                                                @onclick="@(() => SetDisplayMode(false))"
                                                title="이전 사이클 값 표시">
                                            <span class="material-icons" style="font-size:18px;">history</span>
                                            이전
                                        </button>
                                        <button class="btn btn-sm @(_showAverage ? "btn-filled" : "btn-outlined")"
                                                @onclick="@(() => SetDisplayMode(true))"
                                                title="평균값 표시">
                                            <span class="material-icons" style="font-size:18px;">analytics</span>
                                            평균
                                        </button>
                                    </div>
                                    <div style="width:1px; height:16px; background:var(--color-border);"></div>
                                    <button class="btn btn-sm @(_sortField == "ct" ? "btn-filled" : "btn-outlined")"
                                            @onclick="@(() => SetSort("ct"))">전체</button>
                                    <button class="btn btn-sm @(_sortField == "mt" ? "btn-filled" : "btn-outlined")"
                                            @onclick="@(() => SetSort("mt"))">가동</button>
                                    <button class="btn btn-sm @(_sortField == "wt" ? "btn-filled" : "btn-outlined")"
                                            @onclick="@(() => SetSort("wt"))">대기</button>
                                    <button class="btn-icon" title="@(_sortDesc ? "내림차순" : "오름차순")"
                                            @onclick="ToggleSortDir">
                                        <span class="material-icons">@(_sortDesc ? "arrow_downward" : "arrow_upward")</span>
                                    </button>
                                </div>
                            </div>

                            @* ── 요약 셀 (항상 표시) ── *@
                            <div class="ct-summary-bar">
                                <div class="ct-summary-group group-time">
                                    <div class="ct-combined-cell">
                                        <div class="ct-combined-half danger @(_selectedFlowName != null && _selectedFlowName == _maxCtName ? "active" : "")"
                                             @onclick="() => OnFlowSelected(_maxCtName == _selectedFlowName ? null : _maxCtName)">
                                            <span class="ct-summary-title">최대시간</span>
                                            <span class="ct-summary-sub" title="@_maxCtName">@(_maxCtName ?? "-")</span>
                                            <span class="ct-summary-value">@(_maxCtName != null ? FormatMs(_maxCtVal) : "--")</span>
                                        </div>
                                        <div class="ct-combined-half success @(_selectedFlowName != null && _selectedFlowName == _minCtName ? "active" : "")"
                                             @onclick="() => OnFlowSelected(_minCtName == _selectedFlowName ? null : _minCtName)">
                                            <span class="ct-summary-title">최소시간</span>
                                            <span class="ct-summary-sub" title="@_minCtName">@(_minCtName ?? "-")</span>
                                            <span class="ct-summary-value">@(_minCtName != null ? FormatMs(_chartData.Min(f => f.CT)) : "--")</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="ct-summary-group group-wait">
                                    <div class="ct-top-cell warning @(_selectedFlowName != null && _selectedFlowName == _maxWtName ? "active" : "")"
                                         @onclick="() => OnFlowSelected(_maxWtName == _selectedFlowName ? null : _maxWtName)">
                                        <span class="ct-summary-title">최대 대기율</span>
                                        <span class="ct-summary-sub" title="@_maxWtName">@(_maxWtName ?? "-")</span>
                                        <span class="ct-summary-value">@(_maxWtName != null ? $"{_chartData.FirstOrDefault(f => f.FlowName == _maxWtName).WTRatio * 100:F1}%" : "--")</span>
                                    </div>
                                </div>
                            </div>

                            @if (_chartData.Count > 0)
                            {
                                @* ── 차트 리스트 ── *@
                                <div class="ct-chart-section" @onclick="() => OnFlowSelected(null)">
                                    @foreach (var flow in _chartData)
                                    {
                                        var fn          = flow.FlowName;
                                        var isMaxCT     = fn == _maxCtName;
                                        var isMinCT     = fn == _minCtName;
                                        var isMaxWT     = fn == _maxWtName;
                                        var highlighted  = isMaxCT || isMinCT || isMaxWT;
                                        var isSelected  = fn == _selectedFlowName;
                                        var fillPct     = _maxCtVal > 0 ? flow.CT * 100.0 / _maxCtVal : 0;
                                        var mtPct       = flow.CT > 0 ? flow.MT * 100.0 / flow.CT : 0;
                                        var wtPct       = 100.0 - mtPct;
                                        var accentColor = isMaxCT ? "#ef5350" : isMinCT ? "#26a69a" : isMaxWT ? "#F48FB1" : "";
                                        var categoryLabel = isMaxCT ? "최대시간" : isMinCT ? "최소시간" : isMaxWT ? "최대대기" : "";
                                        var borderStyle = highlighted ? $"border-left-color:{accentColor};" : "";
                                        var flowState = GetFlowStateLabel(fn);
                                        var stateColor = flowState?.ToLowerInvariant() switch
                                        {
                                            "ready" => "#4CAF50", "going" => "#EAB308", "finish" => "#2196F3",
                                            "error" => "#F44336", _ => "#4CAF50"
                                        };
                                        <div class="ct-chart-row @(highlighted ? "highlighted" : "") @(isSelected ? "selected" : "")"
                                             style="@borderStyle cursor:pointer;"
                                             @onclick="() => OnFlowSelected(fn == _selectedFlowName ? null : fn)"
                                             @onclick:stopPropagation
                                             @onmouseenter="(e) => OnRowMouseEnter(fn, e)"
                                             @onmouseleave="OnRowMouseLeave">
                                            <div class="ct-row-header">
                                                <span class="ct-row-name" style="font-weight:@(highlighted ? "700" : "500"); display: flex; align-items: center; gap: 6px;">
                                                    <img src="images/aas.png" alt="" style="width: 16px; height: 16px; object-fit: contain; flex-shrink: 0;" />
                                                    @flow.FlowName
                                                </span>
                                                @if (isMaxCT)
                                                {
                                                    <span class="ct-badge-pill" style="background:#ef5350;">최대</span>
                                                }
                                                @if (isMinCT)
                                                {
                                                    <span class="ct-badge-pill" style="background:#26a69a;">최소</span>
                                                }
                                                @if (isMaxWT)
                                                {
                                                    <span class="ct-badge-pill" style="background:#F48FB1;">대기</span>
                                                }
                                            </div>
                                            <div class="ct-row-footer">
                                                <div class="ct-bar-track">
                                                    <div style="display:flex; height:100%; width:@(fillPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%;">
                                                        <div class="ct-bar-mt" style="width:@(mtPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%;">
                                                            @if (mtPct >= 15) { <span class="ct-bar-pct">@($"{mtPct:F0}%")</span> }
                                                        </div>
                                                        <div class="ct-bar-wt" style="width:@(wtPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%;">
                                                            @if (wtPct >= 15) { <span class="ct-bar-pct">@($"{wtPct:F0}%")</span> }
                                                        </div>
                                                    </div>
                                                </div>
                                                <span class="ct-row-time">@FormatMs(flow.CT)</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px; padding:40px 0; color:var(--color-text-disabled); flex:1;">
                                    <span class="material-icons" style="font-size:48px;">bar_chart</span>
                                    <span class="typo-body2">Time 데이터가 없습니다</span>
                                </div>
                            }
                        </div>
                    }

                </div>
            }
        }
    </div>
}

@* ── 호버 툴팁 (고정 위치) ── *@
@if (_hoverFlowName != null && _popupFlow == null)
{
    var hFlow = _chartData.FirstOrDefault(f => f.FlowName == _hoverFlowName);
    if (hFlow.FlowName != null)
    {
        var hState = GetFlowStateLabel(hFlow.FlowName);
        var hStateColor = hState?.ToLowerInvariant() switch
        {
            "ready" => "#4CAF50", "going" => "#EAB308", "finish" => "#2196F3",
            "error" => "#F44336", _ => "#4CAF50"
        };
        var hIsMaxCT = hFlow.FlowName == _maxCtName;
        var hIsMinCT = hFlow.FlowName == _minCtName;
        var hIsMaxWT = hFlow.FlowName == _maxWtName;
        <div class="ct-tooltip-fixed"
             style="left:@(_tooltipX.ToString(System.Globalization.CultureInfo.InvariantCulture))px; top:@(_tooltipY.ToString(System.Globalization.CultureInfo.InvariantCulture))px;">
            <div class="ct-tooltip-header" style="border-left: 3px solid @hStateColor;">
                <span class="ct-tooltip-name">@hFlow.FlowName</span>
                <span class="ct-tooltip-state" style="background:@hStateColor;">@(string.IsNullOrEmpty(hState) ? "Ready" : hState)</span>
            </div>
            @if (hIsMaxCT || hIsMinCT || hIsMaxWT)
            {
                <div class="ct-tooltip-badges">
                    @if (hIsMaxCT) { <span class="ct-badge-pill" style="background:#ef5350;">최대시간</span> }
                    @if (hIsMinCT) { <span class="ct-badge-pill" style="background:#26a69a;">최소시간</span> }
                    @if (hIsMaxWT) { <span class="ct-badge-pill" style="background:#F48FB1;">최대대기율</span> }
                </div>
            }
            <div class="ct-tooltip-grid">
                <span class="ct-tooltip-label">가동시간 (MT)</span>
                <span class="ct-tooltip-val mt">@FormatMs(hFlow.MT)</span>
                <span class="ct-tooltip-label">대기시간 (WT)</span>
                <span class="ct-tooltip-val wt">@FormatMs(hFlow.WT)</span>
                <span class="ct-tooltip-label">전체시간 (CT)</span>
                <span class="ct-tooltip-val ct">@FormatMs(hFlow.CT)</span>
                <span class="ct-tooltip-label">대기율</span>
                <span class="ct-tooltip-val">@($"{hFlow.WTRatio * 100:F1}%")</span>
            </div>
        </div>
    }
}

@* ── 클릭 팝업 모달 ── *@
@if (_popupFlow is var (pName, pMT, pWT, pCT, pWTRatio) && _popupFlow != null)
{
    var flowState = GetFlowStateLabel(pName);
    var stateColor = flowState?.ToLowerInvariant() switch
    {
        "ready" => "#4CAF50", "going" => "#EAB308", "finish" => "#2196F3",
        "error" => "#F44336", _ => "#4CAF50"
    };
    var isMaxCT = pName == _maxCtName;
    var isMinCT = pName == _minCtName;
    var isMaxWT = pName == _maxWtName;
    var mtPct = pCT > 0 ? pMT * 100.0 / pCT : 0;
    var wtPct = 100.0 - mtPct;

    <div class="ct-popup-overlay" @onclick="ClosePopup">
        <div class="ct-popup-modal" @onclick:stopPropagation>
            <div class="ct-popup-header" style="border-left: 4px solid @stateColor;">
                <span class="ct-popup-name">@pName</span>
                <span class="ct-tooltip-state" style="background:@stateColor;">@(string.IsNullOrEmpty(flowState) ? "Ready" : flowState)</span>
                <button class="btn-icon ct-popup-close" @onclick="ClosePopup">
                    <span class="material-icons">close</span>
                </button>
            </div>
            @if (isMaxCT || isMinCT || isMaxWT)
            {
                <div class="ct-popup-badges">
                    @if (isMaxCT) { <span class="ct-badge-pill" style="background:#ef5350;">최대시간</span> }
                    @if (isMinCT) { <span class="ct-badge-pill" style="background:#26a69a;">최소시간</span> }
                    @if (isMaxWT) { <span class="ct-badge-pill" style="background:#F48FB1;">최대대기율</span> }
                </div>
            }
            <div class="ct-popup-bar-section">
                <div class="ct-popup-bar-track">
                    <div class="ct-bar-mt" style="width:@(mtPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%;">
                        @if (mtPct >= 10) { <span class="ct-bar-pct" style="font-size:12px;">@($"{mtPct:F0}%")</span> }
                    </div>
                    <div class="ct-bar-wt" style="width:@(wtPct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))%;">
                        @if (wtPct >= 10) { <span class="ct-bar-pct" style="font-size:12px;">@($"{wtPct:F0}%")</span> }
                    </div>
                </div>
            </div>
            <div class="ct-popup-grid">
                <div class="ct-popup-item">
                    <span class="ct-popup-label">가동시간 (MT)</span>
                    <span class="ct-popup-val" style="color:#0569A0;">@FormatMs(pMT)</span>
                </div>
                <div class="ct-popup-item">
                    <span class="ct-popup-label">대기시간 (WT)</span>
                    <span class="ct-popup-val" style="color:#F48FB1;">@FormatMs(pWT)</span>
                </div>
                <div class="ct-popup-item">
                    <span class="ct-popup-label">전체시간 (CT)</span>
                    <span class="ct-popup-val">@FormatMs(pCT)</span>
                </div>
                <div class="ct-popup-item">
                    <span class="ct-popup-label">대기율</span>
                    <span class="ct-popup-val">@($"{pWTRatio * 100:F1}%")</span>
                </div>
            </div>

            @* History Section *@
            @if (_flowHistory != null && _flowHistory.Count > 0)
            {
                <div class="ct-popup-history">
                    <div class="ct-popup-history-header">
                        <span class="material-icons" style="font-size:16px; vertical-align:middle;">history</span>
                        <span style="font-weight:600; margin-left:4px;">최근 히스토리</span>
                        <span style="margin-left:auto; font-size:12px; color:var(--color-text-secondary);">총 @(_flowHistory.Count)개</span>
                    </div>
                    <div class="ct-popup-history-list">
                        @foreach (var history in _flowHistory)
                        {
                            var histCT = history.CT ?? 0;
                            var histMT = history.MT ?? 0;
                            var histWT = history.WT ?? 0;
                            var histMtPct = histCT > 0 ? histMT * 100.0 / histCT : 0;
                            var histWtPct = 100.0 - histMtPct;

                            <div class="ct-history-item">
                                <div class="ct-history-meta">
                                    <span class="ct-history-cycle">#@(history.CycleNo ?? 0)</span>
                                    <span class="ct-history-time">@history.RecordedAt.ToLocalTime().ToString("MM-dd HH:mm")</span>
                                </div>
                                <div class="ct-history-bar">
