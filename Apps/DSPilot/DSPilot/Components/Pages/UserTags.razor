@page "/user-tags"
@using DSPilot.Services
@inject UserTagAlertService AlertService
@inject DsProjectService ProjectService
@implements IDisposable

<PageTitle>UserTag 알림 - DSPilot</PageTitle>

<div class="user-tags-page">
    <div class="page-header">
        <div>
            <h3>UserTag 알림</h3>
            <p class="page-subtitle">
                AASX 에 정의된 사용자 태그가 PLC 에서 모니터링될 때 발생한 알림 목록입니다.
            </p>
        </div>
        <div class="header-actions">
            <span class="chip chip-level-info" title="Info">INFO @_countByLevel.GetValueOrDefault("Info", 0)</span>
            <span class="chip chip-level-warning" title="Warning">WARN @_countByLevel.GetValueOrDefault("Warning", 0)</span>
            <span class="chip chip-level-error" title="Error">ERR @_countByLevel.GetValueOrDefault("Error", 0)</span>
            <button class="btn btn-outlined btn-sm" @onclick="ClearAlerts" disabled="@(_alerts.Count == 0)">
                <span class="material-icons" style="font-size:16px;">delete_sweep</span> 알림 비우기
            </button>
        </div>
    </div>

    @if (!ProjectService.IsLoaded)
    {
        <div class="alert alert-info">
            <span class="material-icons">info</span>
            프로젝트가 로드되지 않았습니다. AASX 파일을 인식하면 자동으로 사용자 태그 정의가 표시됩니다.
        </div>
    }
    else if (_definitions.Count == 0)
    {
        <div class="alert alert-info">
            <span class="material-icons">info</span>
            정의된 UserTag 가 없습니다. Promaker 에서 System 의 사용자 태그를 추가하세요.
        </div>
    }
    else
    {
        <div class="ut-section">
            <div class="ut-section-header" @onclick="ToggleDefinitions">
                <span class="material-icons" style="font-size:18px;">
                    @(_showDefinitions ? "expand_more" : "chevron_right")
                </span>
                <h4>정의된 UserTag (@_definitions.Count)</h4>
            </div>
            @if (_showDefinitions)
            {
                <div class="ut-table-wrapper">
                    <table class="ut-table">
                        <thead>
                            <tr>
                                <th>System</th>
                                <th>이름</th>
                                <th>로그 레벨</th>
                                <th>태그 주소</th>
                                <th>값 타입</th>
                                <th>최근 알림</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in _definitions)
                            {
                                var last = _lastAlertByAddress.GetValueOrDefault(d.TagAddress);
                                <tr>
                                    <td>@d.SystemName</td>
                                    <td><strong>@d.Name</strong></td>
                                    <td>
                                        <span class="chip @LevelChipClass(d.LogLevel)">@d.LogLevel</span>
                                    </td>
                                    <td><code>@d.TagAddress</code></td>
                                    <td>@d.ValueType</td>
                                    <td>
                                        @if (last is not null)
                                        {
                                            <span class="ut-last-time">@last.Timestamp.ToString("MM-dd HH:mm:ss.fff")</span>
                                        }
                                        else
                                        {
                                            <span class="typo-caption" style="color:var(--color-tertiary);">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }

    <div class="ut-section">
        <div class="ut-section-header">
            <h4>실시간 알림</h4>
            <div class="ut-filter-row">
                <input class="form-field" @bind="_searchText" @bind:event="oninput" placeholder="이름 / 주소 / System 검색..." />
                <select class="form-field" @bind="_levelFilter">
                    <option value="">전체 레벨</option>
                    <option value="Info">Info</option>
                    <option value="Warning">Warning</option>
                    <option value="Error">Error</option>
                </select>
            </div>
        </div>

        @if (FilteredAlerts.Count == 0)
        {
            <div class="ut-empty">
                <span class="material-icons">notifications_none</span>
                <p>아직 수신된 UserTag 알림이 없습니다.</p>
                <p class="typo-caption" style="color:var(--color-text-secondary);">
                    PLC 에서 정의된 주소가 모니터링되면 자동으로 위에 표시됩니다 (실시간 갱신).
                </p>
            </div>
        }
        else
        {
            <div class="ut-table-wrapper">
                <table class="ut-table">
                    <thead>
                        <tr>
                            <th style="width: 170px;">시각</th>
                            <th>레벨</th>
                            <th>System</th>
                            <th>이름</th>
                            <th>태그 주소</th>
                            <th>값</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in FilteredAlerts)
                        {
                            <tr class="@LevelRowClass(a.LogLevel)">
                                <td><span class="ut-time">@a.Timestamp.ToString("yyyy-MM-dd HH:mm:ss.fff")</span></td>
                                <td><span class="chip @LevelChipClass(a.LogLevel)">@a.LogLevel</span></td>
                                <td>@a.SystemName</td>
                                <td><strong>@a.Name</strong></td>
                                <td><code>@a.TagAddress</code></td>
                                <td><code>@a.Value</code></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private IReadOnlyList<UserTagDefinition> _definitions = Array.Empty<UserTagDefinition>();
    private IReadOnlyList<UserTagAlert> _alerts = Array.Empty<UserTagAlert>();
    private Dictionary<string, UserTagAlert> _lastAlertByAddress =
        new(StringComparer.OrdinalIgnoreCase);
    private Dictionary<string, int> _countByLevel = new(StringComparer.OrdinalIgnoreCase);
    private bool _showDefinitions = true;

    private string _searchText = string.Empty;
    private string _levelFilter = string.Empty;

    private List<UserTagAlert> FilteredAlerts
    {
        get
        {
            IEnumerable<UserTagAlert> q = _alerts;
            if (!string.IsNullOrWhiteSpace(_levelFilter))
                q = q.Where(a => string.Equals(a.LogLevel, _levelFilter, StringComparison.OrdinalIgnoreCase));
            if (!string.IsNullOrWhiteSpace(_searchText))
            {
                var s = _searchText.Trim();
                q = q.Where(a =>
                    (a.Name?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (a.TagAddress?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (a.SystemName?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false));
            }
            return q.ToList();
        }
    }

    protected override void OnInitialized()
    {
        RefreshSnapshot();
        AlertService.AlertsChanged += OnAlertsChanged;
    }

    private void OnAlertsChanged()
    {
        // BackgroundService 스레드 → UI 디스패처로 전환
        _ = InvokeAsync(() =>
        {
            RefreshSnapshot();
            StateHasChanged();
        });
    }

    private void RefreshSnapshot()
    {
        _definitions = AlertService.GetDefinitions();
        _alerts = AlertService.GetAlerts();

        var lastMap = new Dictionary<string, UserTagAlert>(StringComparer.OrdinalIgnoreCase);
        var counts = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        foreach (var a in _alerts)
        {
            // _alerts 는 최신순 — 첫 항목이 그 주소의 최신 알림.
            if (!lastMap.ContainsKey(a.TagAddress)) lastMap[a.TagAddress] = a;
            counts.TryGetValue(a.LogLevel ?? "Info", out var c);
            counts[a.LogLevel ?? "Info"] = c + 1;
        }
        _lastAlertByAddress = lastMap;
        _countByLevel = counts;
    }

    private void ToggleDefinitions() => _showDefinitions = !_showDefinitions;

    private void ClearAlerts()
    {
        AlertService.ClearAlerts();
        // ClearAlerts → AlertsChanged 이벤트 → OnAlertsChanged 가 다시 그림.
    }

    private static string LevelChipClass(string? level) => level switch
    {
        "Error" => "chip-level-error",
        "Warning" => "chip-level-warning",
        _ => "chip-level-info",
    };

    private static string LevelRowClass(string? level) => level switch
    {
        "Error" => "ut-row-error",
        "Warning" => "ut-row-warning",
        _ => "",
    };

    public void Dispose()
    {
        AlertService.AlertsChanged -= OnAlertsChanged;
    }
}
