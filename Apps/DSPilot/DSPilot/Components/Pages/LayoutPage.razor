@page "/layout"
@inject DsProjectService ProjectService
@inject BlueprintService BlueprintService
@inject NavigationManager Nav

<PageTitle>Layout - DSPilot</PageTitle>

<MudText Typo="Typo.h5" Class="mb-2" Style="font-weight: 600; color: #0A1E5A;">Layout</MudText>

@if (!ProjectService.IsLoaded)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        No project loaded.
    </MudAlert>
}
else if (string.IsNullOrEmpty(BlueprintService.Layout.BlueprintImagePath))
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
        No blueprint image registered. Go to the
        <MudLink Href="/editor">Editor</MudLink> page to upload one.
    </MudAlert>
}
else
{
    <MudPaper Elevation="2" Class="pa-0" Style="overflow: hidden; border-radius: 8px;">
        <div style="position: relative; width: 100%; max-height: calc(100vh - 160px);
                    aspect-ratio: @BlueprintService.Layout.CanvasWidth / @BlueprintService.Layout.CanvasHeight;">

            <img src="@(BlueprintService.Layout.BlueprintImagePath)?v=@(BlueprintService.ImageVersion)"
                 style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;
                        opacity: 0.3;" alt="Blueprint" />

            <svg xmlns="http://www.w3.org/2000/svg"
                 style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
                 viewBox="0 0 @BlueprintService.Layout.CanvasWidth @BlueprintService.Layout.CanvasHeight"
                 preserveAspectRatio="xMinYMin meet">

                @{
                    var cellW = BlueprintService.Layout.CellWidth;
                    var cellH = BlueprintService.Layout.CellHeight;
                }

                @foreach (var fp in BlueprintService.Layout.FlowPlacements)
                {
                    var color = GetSystemColor(fp.SystemId);
                    var px = fp.Col * cellW;
                    var py = fp.Row * cellH;
                    var pw = fp.ColSpan * cellW;
                    var ph = fp.RowSpan * cellH;
                    var pad = 4;

                    <g>
                        <rect x="@(px + pad)" y="@(py + pad)"
                              width="@(pw - pad * 2)" height="@(ph - pad * 2)"
                              rx="6" ry="6"
                              fill="@color" fill-opacity="0.85"
                              stroke="@color" stroke-width="2" />
                        <text x="@(px + pw / 2)" y="@(py + ph / 2 - 4)"
                              text-anchor="middle" fill="white"
                              font-size="13" font-weight="600">
                            @fp.FlowName
                        </text>
                        <text x="@(px + pw / 2)" y="@(py + ph / 2 + 14)"
                              text-anchor="middle" fill="rgba(255,255,255,0.8)"
                              font-size="10">
                            @fp.SystemName (@GetWorkCount(fp.FlowId) works)
                        </text>
                    </g>
                }
            </svg>
        </div>
    </MudPaper>

    <div class="d-flex justify-center mt-2">
        <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Fullscreen"
                   OnClick="OpenFullView">
            전체보기
        </MudButton>
    </div>
}

<MudFab Style="position: fixed; bottom: 32px; right: 32px; z-index: 100;"
        Color="Color.Secondary"
        StartIcon="@Icons.Material.Filled.Edit"
        OnClick="@(() => Nav.NavigateTo("/editor"))" />

<MudDialog @bind-Visible="_fullViewOpen" Options="_fullViewOptions">
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.Fullscreen" Class="mr-2" />
            <MudText Typo="Typo.h6">Layout - 전체보기</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (!string.IsNullOrEmpty(BlueprintService.Layout.BlueprintImagePath))
        {
            <div style="position: relative; width: 100%;
                        aspect-ratio: @BlueprintService.Layout.CanvasWidth / @BlueprintService.Layout.CanvasHeight;">

                <img src="@(BlueprintService.Layout.BlueprintImagePath)?v=@(BlueprintService.ImageVersion)"
                     style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;
                            opacity: 0.3;" alt="Blueprint" />

                <svg xmlns="http://www.w3.org/2000/svg"
                     style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
                     viewBox="0 0 @BlueprintService.Layout.CanvasWidth @BlueprintService.Layout.CanvasHeight"
                     preserveAspectRatio="xMinYMin meet">

                    @{
                        var dCellW = BlueprintService.Layout.CellWidth;
                        var dCellH = BlueprintService.Layout.CellHeight;
                    }

                    @foreach (var fp in BlueprintService.Layout.FlowPlacements)
                    {
                        var color = GetSystemColor(fp.SystemId);
                        var px = fp.Col * dCellW;
                        var py = fp.Row * dCellH;
                        var pw = fp.ColSpan * dCellW;
                        var ph = fp.RowSpan * dCellH;
                        var pad = 4;

                        <g>
                            <rect x="@(px + pad)" y="@(py + pad)"
                                  width="@(pw - pad * 2)" height="@(ph - pad * 2)"
                                  rx="6" ry="6"
                                  fill="@color" fill-opacity="0.85"
                                  stroke="@color" stroke-width="2" />
                            <text x="@(px + pw / 2)" y="@(py + ph / 2 - 4)"
                                  text-anchor="middle" fill="white"
                                  font-size="13" font-weight="600">
                                @fp.FlowName
                            </text>
                            <text x="@(px + pw / 2)" y="@(py + ph / 2 + 14)"
                                  text-anchor="middle" fill="rgba(255,255,255,0.8)"
                                  font-size="10">
                                @fp.SystemName (@GetWorkCount(fp.FlowId) works)
                            </text>
                        </g>
                    }
                </svg>
            </div>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _fullViewOpen = false)" Color="Color.Default">닫기</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private readonly Dictionary<Guid, int> _systemColorIndex = [];
    private bool _fullViewOpen;

    private static readonly DialogOptions _fullViewOptions = new()
    {
        MaxWidth = MaxWidth.ExtraExtraLarge,
        FullWidth = true,
        CloseOnEscapeKey = true,
        NoHeader = false
    };

    private static readonly string[] SystemColors =
        ["#0A1E5A", "#FA002D", "#0569A0", "#009BB4", "#4CAF50"];

    private int GetWorkCount(Guid flowId) => ProjectService.GetWorks(flowId).Count;

    private void OpenFullView() => _fullViewOpen = true;

    private string GetSystemColor(Guid systemId)
    {
        if (!_systemColorIndex.ContainsKey(systemId))
            _systemColorIndex[systemId] = _systemColorIndex.Count % SystemColors.Length;
        return SystemColors[_systemColorIndex[systemId]];
    }
}
