@page "/layout"
@inject DsProjectService ProjectService
@inject BlueprintService BlueprintService
@inject NavigationManager Nav

<PageTitle>Layout - DSPilot</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 600; color: #0A1E5A;">Layout</MudText>

@if (!ProjectService.IsLoaded)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        No project loaded.
    </MudAlert>
}
else if (string.IsNullOrEmpty(BlueprintService.Layout.BlueprintImagePath))
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
        No blueprint image registered. Go to the
        <MudLink Href="/editor">Editor</MudLink> page to upload one.
    </MudAlert>
}
else
{
    <MudPaper Elevation="2" Class="pa-0" Style="overflow: auto; border-radius: 8px; position: relative;">
        <div style="position: relative;
                    width: @(BlueprintService.Layout.CanvasWidth)px;
                    height: @(BlueprintService.Layout.CanvasHeight)px;">

            <img src="@BlueprintService.Layout.BlueprintImagePath"
                 style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;
                        object-fit: contain; opacity: 0.3;" alt="Blueprint" />

            <svg xmlns="http://www.w3.org/2000/svg"
                 style="position: absolute; top: 0; left: 0;"
                 width="@BlueprintService.Layout.CanvasWidth"
                 height="@BlueprintService.Layout.CanvasHeight">

                <defs>
                    <marker id="arrowhead" markerWidth="10" markerHeight="7"
                            refX="10" refY="3.5" orient="auto">
                        <polygon points="0 0, 10 3.5, 0 7" fill="#0569A0" />
                    </marker>
                </defs>

                @{
                    var cellW = BlueprintService.Layout.CellWidth;
                    var cellH = BlueprintService.Layout.CellHeight;
                }

                @foreach (var arrow in _arrowPaths)
                {
                    <path d="@arrow" fill="none" stroke="#0569A0"
                          stroke-width="2" stroke-dasharray="6,3"
                          marker-end="url(#arrowhead)" />
                }

                @foreach (var fp in BlueprintService.Layout.FlowPlacements)
                {
                    var color = GetSystemColor(fp.SystemId);
                    var px = fp.Col * cellW;
                    var py = fp.Row * cellH;
                    var pw = fp.ColSpan * cellW;
                    var ph = fp.RowSpan * cellH;
                    var pad = 4;

                    <g>
                        <rect x="@(px + pad)" y="@(py + pad)"
                              width="@(pw - pad * 2)" height="@(ph - pad * 2)"
                              rx="6" ry="6"
                              fill="@color" fill-opacity="0.85"
                              stroke="@color" stroke-width="2" />
                        <text x="@(px + pw / 2)" y="@(py + ph / 2 - 4)"
                              text-anchor="middle" fill="white"
                              font-size="13" font-weight="600">
                            @fp.FlowName
                        </text>
                        <text x="@(px + pw / 2)" y="@(py + ph / 2 + 14)"
                              text-anchor="middle" fill="rgba(255,255,255,0.8)"
                              font-size="10">
                            @fp.SystemName (@GetWorkCount(fp.FlowId) works)
                        </text>
                    </g>
                }
            </svg>
        </div>
    </MudPaper>
}

<MudFab Style="position: fixed; bottom: 32px; right: 32px; z-index: 100;"
        Color="Color.Secondary"
        StartIcon="@Icons.Material.Filled.Edit"
        OnClick="@(() => Nav.NavigateTo("/editor"))" />

@code {
    private List<Ds2.Core.DsSystem> _systems = [];
    private List<string> _arrowPaths = [];
    private readonly Dictionary<Guid, int> _systemColorIndex = [];

    private static readonly string[] SystemColors =
        ["#0A1E5A", "#FA002D", "#0569A0", "#009BB4", "#4CAF50"];

    protected override void OnInitialized()
    {
        if (!ProjectService.IsLoaded) return;
        _systems = ProjectService.GetActiveSystems();
        ComputeArrows();
    }

    private void ComputeArrows()
    {
        _arrowPaths.Clear();
        var placements = BlueprintService.Layout.FlowPlacements;
        var cellW = BlueprintService.Layout.CellWidth;
        var cellH = BlueprintService.Layout.CellHeight;

        var placementMap = placements.ToDictionary(p => p.FlowId);

        foreach (var sys in _systems)
        {
            var flows = ProjectService.GetFlows(sys.Id);
            var placedFlows = flows.Where(f => placementMap.ContainsKey(f.Id)).ToList();

            for (int i = 0; i < placedFlows.Count - 1; i++)
            {
                var src = placementMap[placedFlows[i].Id];
                var tgt = placementMap[placedFlows[i + 1].Id];

                var srcXywh = new Ds2.Core.Xywh(
                    src.Col * cellW, src.Row * cellH,
                    src.ColSpan * cellW, src.RowSpan * cellH);
                var tgtXywh = new Ds2.Core.Xywh(
                    tgt.Col * cellW, tgt.Row * cellH,
                    tgt.ColSpan * cellW, tgt.RowSpan * cellH);

                var points = ProjectService.ComputeArrowPath(srcXywh, tgtXywh);

                if (points.Count == 4)
                {
                    var (sx, sy) = points[0];
                    var (c1x, c1y) = points[1];
                    var (c2x, c2y) = points[2];
                    var (ex, ey) = points[3];
                    _arrowPaths.Add($"M {sx:F0},{sy:F0} C {c1x:F0},{c1y:F0} {c2x:F0},{c2y:F0} {ex:F0},{ey:F0}");
                }
            }
        }
    }

    private int GetWorkCount(Guid flowId) => ProjectService.GetWorks(flowId).Count;

    private string GetSystemColor(Guid systemId)
    {
        if (!_systemColorIndex.ContainsKey(systemId))
            _systemColorIndex[systemId] = _systemColorIndex.Count % SystemColors.Length;
        return SystemColors[_systemColorIndex[systemId]];
    }
}
