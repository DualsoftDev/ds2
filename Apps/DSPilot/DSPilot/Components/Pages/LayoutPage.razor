@page "/"
@page "/layout"
@inject DsProjectService ProjectService
@inject BlueprintService BlueprintService
@inject DspDbService DbService
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Layout - DSPilot</PageTitle>

@if (!ProjectService.IsLoaded)
{
    <MudText Typo="Typo.h5" Class="mb-2" Style="font-weight: 600; color: #0A1E5A;">Layout</MudText>
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        No project loaded.
    </MudAlert>
}
else if (string.IsNullOrEmpty(BlueprintService.Layout.BlueprintImagePath))
{
    <MudText Typo="Typo.h5" Class="mb-2" Style="font-weight: 600; color: #0A1E5A;">Layout</MudText>
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
        No blueprint image registered. Go to the
        <MudLink Href="/editor">Editor</MudLink> page to upload one.
    </MudAlert>
}
else
{
    @* ── 도면 ── *@
    <div style="display: flex; flex-direction: column; align-items: center;">
        <FlowLayoutSvg Style="@($"height: 62vh; max-width: 100%; aspect-ratio: {_cw} / {_ch};")"
                       CanvasWidth="_cw" CanvasHeight="_ch"
                       ImagePath="@BlueprintService.Layout.BlueprintImagePath"
                       ImageVersion="BlueprintService.ImageVersion"
                       OffsetX="_ox" OffsetY="_oy" CellWidth="_cellW" CellHeight="_cellH"
                       Placements="BlueprintService.Layout.FlowPlacements"
                       GetColor="@(fp => GetFlowColor(fp.FlowName, fp.SystemId))"
                       GetStateLabel="@(fp => GetFlowStateLabel(fp.FlowName))"
                       GetMtWt="@(fp => GetFlowMtWt(fp.FlowName))" />

        <div class="d-flex justify-center gap-3 flex-wrap" style="padding: 4px 0 6px;">
            @foreach (var (label, clr) in _stateLegend)
            {
                <div class="d-flex align-center" style="gap: 4px;">
                    <span style="width:12px;height:12px;border-radius:3px;background:@clr;display:inline-block;"></span>
                    <MudText Typo="Typo.caption">@label</MudText>
                </div>
            }
        </div>
    </div>

    @* ── CT 막대 그래프 ── *@
    @{
        var chartData = GetChartData();
        var maxCtName = chartData.Count > 0 ? chartData[0].FlowName : null;
        var minCtName = chartData.Count > 1 ? chartData[^1].FlowName : null;
        var maxWtName = chartData.Count > 0
            ? chartData.OrderByDescending(f => f.WTRatio).First().FlowName
            : null;
        var maxCtVal = chartData.Count > 0 ? chartData[0].CT : 1;
    }

    @if (chartData.Count > 0)
    {
        <div style="padding: 4px 16px 80px 16px;">
            <div style="display:flex; align-items:center; gap:12px; margin-bottom:8px;">
                <MudText Typo="Typo.subtitle2" Style="font-weight:600; color:#0A1E5A;">
                    CT 분석 (가동 + 대기, 내림차순)
                </MudText>
                <div style="display:flex; gap:6px;">
                    <span style="font-size:10px; padding:2px 7px; border-radius:10px; background:#ef5350; color:white;">최대 CT</span>
                    <span style="font-size:10px; padding:2px 7px; border-radius:10px; background:#26a69a; color:white;">최소 CT</span>
                    <span style="font-size:10px; padding:2px 7px; border-radius:10px; background:#fb8c00; color:white;">대기↑</span>
                </div>
            </div>

            @foreach (var flow in chartData)
            {
                var isMaxCT    = flow.FlowName == maxCtName;
                var isMinCT    = flow.FlowName == minCtName;
                var isMaxWT    = flow.FlowName == maxWtName;
                var highlighted = isMaxCT || isMinCT || isMaxWT;

                var fillPct = maxCtVal > 0 ? flow.CT * 100.0 / maxCtVal : 0;
                var mtPct   = flow.CT  > 0 ? flow.MT * 100.0 / flow.CT  : 0;
                var wtPct   = 100.0 - mtPct;

                var rowBorder = isMaxCT ? "outline:1.5px solid #ef5350;"
                              : isMinCT ? "outline:1.5px solid #26a69a;"
                              : isMaxWT ? "outline:1.5px solid #fb8c00;"
                              : "";

                <div style="display:flex; align-items:center; margin-bottom:3px; padding:3px 6px;
                            border-radius:6px; @(highlighted ? "background:rgba(0,0,0,0.03); " + rowBorder : "")">

                    <div style="width:130px; font-size:12px; font-weight:@(highlighted ? "700" : "400");
                                overflow:hidden; text-overflow:ellipsis; white-space:nowrap; padding-right:6px;">
                        @flow.FlowName
                    </div>

                    <div style="flex:1; height:22px; background:#e9e9e9; border-radius:4px; overflow:hidden; margin:0 8px;">
                        <div style="@($"display:flex; height:100%; width:{fillPct:F1}%;")">
                            <div style="@($"width:{mtPct:F1}%; background:#42A5F5; height:100%;")"></div>
                            <div style="@($"width:{wtPct:F1}%; background:#FFA726; height:100%;")"></div>
                        </div>
                    </div>

                    <div style="width:70px; font-size:11px; color:#555; text-align:right;">
                        @FormatMs(flow.CT)
                    </div>

                    <div style="width:90px; display:flex; gap:3px; justify-content:flex-end; padding-left:6px;">
                        @if (isMaxCT)
                        {
                            <span style="font-size:9px; padding:1px 5px; border-radius:8px; background:#ef5350; color:white; white-space:nowrap;">최대 CT</span>
                        }
                        @if (isMinCT)
                        {
                            <span style="font-size:9px; padding:1px 5px; border-radius:8px; background:#26a69a; color:white; white-space:nowrap;">최소 CT</span>
                        }
                        @if (isMaxWT)
                        {
                            <span style="font-size:9px; padding:1px 5px; border-radius:8px; background:#fb8c00; color:white; white-space:nowrap;">대기↑</span>
                        }
                    </div>
                </div>
            }
        </div>
    }
}

<MudFab Style="position: fixed; bottom: 32px; right: 32px; z-index: 100; background: #f5f5f5; color: #555;"
        StartIcon="@Icons.Material.Filled.Edit"
        OnClick="@(() => Nav.NavigateTo("/editor"))" />

@code {
    private readonly Dictionary<Guid, int> _systemColorIndex = [];
    private Dictionary<Guid, int> _workCounts = [];
    private int _cw, _ch, _cellW, _cellH, _ox, _oy;
    private DspDbSnapshot _dbSnapshot = new();

    private static readonly string[] SystemColors =
        ["#0A1E5A", "#FA002D", "#0569A0", "#009BB4", "#4CAF50"];

    private static readonly (string Label, string Color)[] _stateLegend =
    [
        ("Ready", "#9E9E9E"), ("Going", "#4CAF50"), ("Done", "#2196F3"),
        ("Error", "#F44336"), ("Pause", "#FF9800"), ("Abort", "#9C27B0")
    ];

    protected override void OnInitialized()
    {
        _dbSnapshot = DbService.Snapshot;
        DbService.OnDataChanged += OnDbDataChanged;

        var layout = BlueprintService.Layout;
        _cw = layout.CanvasWidth;
        _ch = layout.CanvasHeight;
        _cellW = layout.CellWidth;
        _cellH = layout.CellHeight;
        _ox = layout.OffsetX;
        _oy = layout.OffsetY;

        foreach (var fp in layout.FlowPlacements)
        {
            if (!_workCounts.ContainsKey(fp.FlowId))
                _workCounts[fp.FlowId] = ProjectService.GetWorks(fp.FlowId).Count;
        }
    }

    private async void OnDbDataChanged()
    {
        _dbSnapshot = DbService.Snapshot;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DbService.OnDataChanged -= OnDbDataChanged;
    }

    private int GetWorkCount(Guid flowId) =>
        _workCounts.TryGetValue(flowId, out var count) ? count : 0;

    private string GetFlowColor(string flowName, Guid systemId)
    {
        var flowState = _dbSnapshot.Flows.FirstOrDefault(f => f.FlowName == flowName);
        if (flowState == null) return GetSystemColor(systemId);

        return flowState.State?.ToLowerInvariant() switch
        {
            "ready" => "#9E9E9E",
            "going" => "#4CAF50",
            "done"  => "#2196F3",
            "error" => "#F44336",
            "pause" => "#FF9800",
            "abort" => "#9C27B0",
            _ => "#9E9E9E",
        };
    }

    private string GetFlowStateLabel(string flowName)
    {
        var flowState = _dbSnapshot.Flows.FirstOrDefault(f => f.FlowName == flowName);
        return flowState?.State ?? "";
    }

    private (int Mt, int Wt)? GetFlowMtWt(string flowName)
    {
        var flowState = _dbSnapshot.Flows.FirstOrDefault(f => f.FlowName == flowName);
        if (flowState?.MT == null && flowState?.WT == null) return null;
        return (flowState.MT ?? 0, flowState.WT ?? 0);
    }

    private string GetSystemColor(Guid systemId)
    {
        if (!_systemColorIndex.ContainsKey(systemId))
            _systemColorIndex[systemId] = _systemColorIndex.Count % SystemColors.Length;
        return SystemColors[_systemColorIndex[systemId]];
    }

    private List<(string FlowName, int MT, int WT, int CT, double WTRatio)> GetChartData()
    {
        return BlueprintService.Layout.FlowPlacements
            .Select(fp =>
            {
                var state = _dbSnapshot.Flows.FirstOrDefault(f => f.FlowName == fp.FlowName);
                var mt = state?.MT ?? 0;
                var wt = state?.WT ?? 0;
                var ct = mt + wt;
                return (fp.FlowName, mt, wt, ct, ct > 0 ? (double)wt / ct : 0.0);
            })
            .Where(f => f.ct > 0)
            .OrderByDescending(f => f.ct)
            .ToList();
    }

    private static string FormatMs(int ms)
    {
        if (ms <= 0) return "0s";
        if (ms < 1_000) return $"{ms}ms";
        if (ms < 60_000) return $"{ms / 1000.0:F1}s";
        if (ms < 3_600_000) return $"{ms / 60000}m {ms % 60000 / 1000}s";
        return $"{ms / 3_600_000}h {ms % 3_600_000 / 60000}m";
    }
}
