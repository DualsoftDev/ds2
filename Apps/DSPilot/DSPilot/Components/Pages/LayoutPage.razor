@page "/layout"
@inject DsProjectService ProjectService
@inject BlueprintService BlueprintService
@inject DspDbService DbService
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Layout - DSPilot</PageTitle>

@if (!ProjectService.IsLoaded)
{
    <MudText Typo="Typo.h5" Class="mb-2" Style="font-weight: 600; color: #0A1E5A;">Layout</MudText>
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        No project loaded.
    </MudAlert>
}
else if (string.IsNullOrEmpty(BlueprintService.Layout.BlueprintImagePath))
{
    <MudText Typo="Typo.h5" Class="mb-2" Style="font-weight: 600; color: #0A1E5A;">Layout</MudText>
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
        No blueprint image registered. Go to the
        <MudLink Href="/editor">Editor</MudLink> page to upload one.
    </MudAlert>
}
else
{
    <div style="display: flex; flex-direction: column; height: calc(100vh - 80px); align-items: center;">
        <svg xmlns="http://www.w3.org/2000/svg"
             style="display: block; height: calc(100vh - 120px); max-width: 100%;
                    aspect-ratio: @_cw / @_ch;"
             viewBox="0 0 @_cw @_ch"
             preserveAspectRatio="none">

            <image href="@(BlueprintService.Layout.BlueprintImagePath)?v=@(BlueprintService.ImageVersion)"
                   x="0" y="0" width="@_cw" height="@_ch" opacity="0.3" />

            @foreach (var fp in BlueprintService.Layout.FlowPlacements)
            {
                var color = GetFlowColor(fp.FlowName, fp.SystemId);
                var stateLabel = GetFlowStateLabel(fp.FlowName);
                var px = _ox + fp.Col * _cellW;
                var py = _oy + fp.Row * _cellH;
                var pw = fp.ColSpan * _cellW;
                var ph = fp.RowSpan * _cellH;
                var pad = 4;

                <g>
                    <rect x="@(px + pad)" y="@(py + pad)"
                          width="@(pw - pad * 2)" height="@(ph - pad * 2)"
                          rx="6" ry="6"
                          fill="@color" fill-opacity="0.85"
                          stroke="@color" stroke-width="2" />
                    <text x="@(px + pw / 2)" y="@(py + ph / 2 - 10)"
                          text-anchor="middle" fill="white"
                          font-size="13" font-weight="600">
                        @fp.FlowName
                    </text>
                    <text x="@(px + pw / 2)" y="@(py + ph / 2 + 6)"
                          text-anchor="middle" fill="rgba(255,255,255,0.8)"
                          font-size="10">
                        @fp.SystemName (@GetWorkCount(fp.FlowId) works)
                    </text>
                    <text x="@(px + pw / 2)" y="@(py + ph / 2 + 22)"
                          text-anchor="middle" fill="rgba(255,255,255,0.7)"
                          font-size="9">
                        @stateLabel
                    </text>
                </g>
            }
        </svg>

        <div class="d-flex justify-center gap-3 flex-wrap" style="flex: 0 0 auto; padding: 4px 0;">
            @foreach (var (label, clr) in _stateLegend)
            {
                <div class="d-flex align-center" style="gap: 4px;">
                    <span style="width:12px;height:12px;border-radius:3px;background:@clr;display:inline-block;"></span>
                    <MudText Typo="Typo.caption">@label</MudText>
                </div>
            }
            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Fullscreen"
                       OnClick="@(() => _fullViewOpen = true)">
                전체보기
            </MudButton>
        </div>
    </div>
}

<MudFab Style="position: fixed; bottom: 32px; right: 32px; z-index: 100;"
        Color="Color.Secondary"
        StartIcon="@Icons.Material.Filled.Edit"
        OnClick="@(() => Nav.NavigateTo("/editor"))" />

<MudDialog @bind-Visible="_fullViewOpen" Options="_fullViewOptions">
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.Fullscreen" Class="mr-2" />
            <MudText Typo="Typo.h6">Layout - 전체보기</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (!string.IsNullOrEmpty(BlueprintService.Layout.BlueprintImagePath))
        {
            <svg xmlns="http://www.w3.org/2000/svg"
                 style="display: block; width: 100%; aspect-ratio: @_cw / @_ch;"
                 viewBox="0 0 @_cw @_ch"
                 preserveAspectRatio="none">

                <image href="@(BlueprintService.Layout.BlueprintImagePath)?v=@(BlueprintService.ImageVersion)"
                       x="0" y="0" width="@_cw" height="@_ch" opacity="0.3" />

                @foreach (var fp in BlueprintService.Layout.FlowPlacements)
                {
                    var color = GetFlowColor(fp.FlowName, fp.SystemId);
                    var stateLabel = GetFlowStateLabel(fp.FlowName);
                    var px = _ox + fp.Col * _cellW;
                    var py = _oy + fp.Row * _cellH;
                    var pw = fp.ColSpan * _cellW;
                    var ph = fp.RowSpan * _cellH;
                    var pad = 4;

                    <g>
                        <rect x="@(px + pad)" y="@(py + pad)"
                              width="@(pw - pad * 2)" height="@(ph - pad * 2)"
                              rx="6" ry="6"
                              fill="@color" fill-opacity="0.85"
                              stroke="@color" stroke-width="2" />
                        <text x="@(px + pw / 2)" y="@(py + ph / 2 - 10)"
                              text-anchor="middle" fill="white"
                              font-size="13" font-weight="600">
                            @fp.FlowName
                        </text>
                        <text x="@(px + pw / 2)" y="@(py + ph / 2 + 6)"
                              text-anchor="middle" fill="rgba(255,255,255,0.8)"
                              font-size="10">
                            @fp.SystemName (@GetWorkCount(fp.FlowId) works)
                        </text>
                        <text x="@(px + pw / 2)" y="@(py + ph / 2 + 22)"
                              text-anchor="middle" fill="rgba(255,255,255,0.7)"
                              font-size="9">
                            @stateLabel
                        </text>
                    </g>
                }
            </svg>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _fullViewOpen = false)" Color="Color.Default">닫기</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private readonly Dictionary<Guid, int> _systemColorIndex = [];
    private bool _fullViewOpen;
    private int _cw, _ch, _cellW, _cellH, _ox, _oy;
    private DspDbSnapshot _dbSnapshot = new();

    private static readonly DialogOptions _fullViewOptions = new()
    {
        MaxWidth = MaxWidth.ExtraExtraLarge,
        FullWidth = true,
        CloseOnEscapeKey = true,
        NoHeader = false
    };

    private static readonly string[] SystemColors =
        ["#0A1E5A", "#FA002D", "#0569A0", "#009BB4", "#4CAF50"];

    private static readonly (string Label, string Color)[] _stateLegend =
    [
        ("Ready", "#9E9E9E"), ("Going", "#4CAF50"), ("Done", "#2196F3"),
        ("Error", "#F44336"), ("Pause", "#FF9800"), ("Abort", "#9C27B0")
    ];

    protected override void OnInitialized()
    {
        _dbSnapshot = DbService.Snapshot;
        DbService.OnDataChanged += OnDbDataChanged;
    }

    protected override void OnParametersSet()
    {
        var layout = BlueprintService.Layout;
        _cw = layout.CanvasWidth;
        _ch = layout.CanvasHeight;
        _cellW = layout.CellWidth;
        _cellH = layout.CellHeight;
        _ox = layout.OffsetX;
        _oy = layout.OffsetY;
    }

    private async void OnDbDataChanged()
    {
        _dbSnapshot = DbService.Snapshot;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DbService.OnDataChanged -= OnDbDataChanged;
    }

    private int GetWorkCount(Guid flowId) => ProjectService.GetWorks(flowId).Count;

    private string GetFlowColor(string flowName, Guid systemId)
    {
        var flowState = _dbSnapshot.Flows
            .FirstOrDefault(f => f.FlowName == flowName);

        if (flowState == null)
            return GetSystemColor(systemId);

        return flowState.State?.ToLowerInvariant() switch
        {
            "ready" => "#9E9E9E",
            "going" => "#4CAF50",
            "done" => "#2196F3",
            "error" => "#F44336",
            "pause" => "#FF9800",
            "abort" => "#9C27B0",
            _ => "#9E9E9E",
        };
    }

    private string GetFlowStateLabel(string flowName)
    {
        var flowState = _dbSnapshot.Flows
            .FirstOrDefault(f => f.FlowName == flowName);
        return flowState?.State ?? "";
    }

    private string GetSystemColor(Guid systemId)
    {
        if (!_systemColorIndex.ContainsKey(systemId))
            _systemColorIndex[systemId] = _systemColorIndex.Count % SystemColors.Length;
        return SystemColors[_systemColorIndex[systemId]];
    }
}
