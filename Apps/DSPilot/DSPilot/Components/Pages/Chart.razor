@page "/chart"
@inject DsProjectService ProjectService
@inject DspDbService DbService
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>상세정보 - DSPilot</PageTitle>

<h5 class="typo-h5 mb-4" style="font-weight: 600; color: #0A1E5A;">상세정보</h5>

@if (!ProjectService.IsLoaded)
{
    <div class="alert alert-info">
        <span class="material-icons">info</span>
        No project loaded.
    </div>
}
else
{
    <div class="card mb-4" style="box-shadow: var(--shadow-2); border-radius: 8px;">
        <div style="padding: 12px;">
            <div class="grid" style="gap: 8px;">
                <div class="grid-item-3">
                    <input class="form-field" placeholder="Call / Work 검색" value="@_searchText"
                           @oninput="@(e => SetFilter(search: e.Value?.ToString()))" />
                </div>
                <div class="grid-item-3">
                    <select class="form-select" @onchange="@(e => SetFilter(flow: e.Value?.ToString()))">
                        <option value="">Flow (전체)</option>
                        @foreach (var flow in _flowNames)
                        {
                            <option value="@flow" selected="@(flow == _selectedFlow)">@flow</option>
                        }
                    </select>
                </div>
                <div class="grid-item-3">
                    <select class="form-select" @onchange="@(e => SetFilter(state: e.Value?.ToString()))">
                        <option value="">State (전체)</option>
                        @foreach (var state in _stateOptions)
                        {
                            <option value="@state" selected="@(state == _selectedState)">@state</option>
                        }
                    </select>
                </div>
                <div class="grid-item-3">
                    <select class="form-select" @onchange="@(e => SetFilter(device: e.Value?.ToString()))">
                        <option value="">Device (전체)</option>
                        @foreach (var device in _deviceNames)
                        {
                            <option value="@device" selected="@(device == _selectedDevice)">@device</option>
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="card" style="box-shadow: var(--shadow-2); border-radius: 8px;">
        <div class="table-container" style="max-height: calc(100vh - 300px); overflow: auto;">
            <table class="table table-hover table-striped">
                <thead class="table-head-sticky">
                    <tr>
                        <th class="sortable" @onclick="@(() => SortBy("Id"))">
                            ID @SortIcon("Id")
                        </th>
                        <th class="sortable" @onclick="@(() => SortBy("CallName"))">
                            Call @SortIcon("CallName")
                        </th>
                        <th class="sortable" @onclick="@(() => SortBy("FlowName"))">
                            Flow @SortIcon("FlowName")
                        </th>
                        <th class="sortable" @onclick="@(() => SortBy("WorkName"))">
                            Work @SortIcon("WorkName")
                        </th>
                        <th class="sortable" @onclick="@(() => SortBy("State"))">
                            State @SortIcon("State")
                        </th>
                        <th class="sortable" @onclick="@(() => SortBy("ProgressRate"))">
                            Progress @SortIcon("ProgressRate")
                        </th>
                        <th class="sortable" @onclick="@(() => SortBy("GoingCount"))">
                            Count @SortIcon("GoingCount")
                        </th>
                        <th class="sortable" @onclick="@(() => SortBy("AverageGoingTime"))">
                            Avg Time @SortIcon("AverageGoingTime")
                        </th>
                        <th class="sortable" @onclick="@(() => SortBy("Device"))">
                            Device @SortIcon("Device")
                        </th>
                        <th>Error</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var rows = SortedCalls.ToList(); }
                    @if (rows.Count == 0)
                    {
                        <tr>
                            <td colspan="10" style="text-align:center; padding:24px; color:#7D8282;">
                                데이터가 없습니다.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var call in rows)
                        {
                            <tr>
                                <td>@call.Id</td>
                                <td>@call.CallName</td>
                                <td>@call.FlowName</td>
                                <td>@call.WorkName</td>
                                <td>
                                    <span class="chip" style="@GetStateStyle(call.State)">
                                        @call.State
                                    </span>
                                </td>
                                <td>
                                    <div class="progress-bar" style="min-width:60px; height:6px; border-radius:3px;">
                                        <div style="width:@((call.ProgressRate * 100).ToString("F0"))%; background:var(--color-primary); height:100%; border-radius:3px; transition:width 0.3s;"></div>
                                    </div>
                                </td>
                                <td>@call.GoingCount</td>
                                <td>@(call.AverageGoingTime?.ToString("F1") ?? "-")</td>
                                <td>@(call.Device ?? "-")</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(call.ErrorText))
                                    {
                                        <span data-tooltip="@call.ErrorText" style="color:var(--color-error); cursor:help;">
                                            <span class="material-icons" style="font-size:20px;">error_outline</span>
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <span class="typo-caption mt-2" style="display:block; color: #7D8282;">
        @SortedCalls.Count() / @_dbSnapshot.Calls.Count calls | Updated: @_dbSnapshot.Timestamp.ToLocalTime().ToString("HH:mm:ss")
    </span>
}

@code {
    [SupplyParameterFromQuery(Name = "flow")]
    public string? QueryFlow { get; set; }

    [SupplyParameterFromQuery(Name = "state")]
    public string? QueryState { get; set; }

    [SupplyParameterFromQuery(Name = "device")]
    public string? QueryDevice { get; set; }

    [SupplyParameterFromQuery(Name = "search")]
    public string? QuerySearch { get; set; }

    private DspDbSnapshot _dbSnapshot = new();

    private string _searchText = "";
    private string? _selectedFlow;
    private string? _selectedState;
    private string? _selectedDevice;

    // Sort state
    private string _sortField = "Id";
    private bool _sortAsc = true;

    private List<string> _flowNames = [];
    private List<string> _deviceNames = [];

    private static readonly string[] _stateOptions =
        ["Ready", "Going", "Done", "Error", "Pause", "Abort"];

    private IEnumerable<CallState> FilteredCalls
    {
        get
        {
            IEnumerable<CallState> calls = _dbSnapshot.Calls;

            if (!string.IsNullOrEmpty(_selectedFlow))
                calls = calls.Where(c => c.FlowName == _selectedFlow);

            if (!string.IsNullOrEmpty(_selectedState))
                calls = calls.Where(c => c.State.Equals(_selectedState, StringComparison.OrdinalIgnoreCase));

            if (!string.IsNullOrEmpty(_selectedDevice))
                calls = calls.Where(c => c.Device == _selectedDevice);

            if (!string.IsNullOrWhiteSpace(_searchText))
            {
                var search = _searchText.Trim();
                calls = calls.Where(c =>
                    c.CallName.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                    c.WorkName.Contains(search, StringComparison.OrdinalIgnoreCase));
            }

            return calls;
        }
    }

    private IEnumerable<CallState> SortedCalls
    {
        get
        {
            var calls = FilteredCalls;
            Func<CallState, object> keySelector = _sortField switch
            {
                "Id" => x => x.Id,
                "CallName" => x => x.CallName,
                "FlowName" => x => x.FlowName,
                "WorkName" => x => x.WorkName,
                "State" => x => x.State,
                "ProgressRate" => x => x.ProgressRate,
                "GoingCount" => x => x.GoingCount,
                "AverageGoingTime" => x => x.AverageGoingTime ?? 0,
                "Device" => x => x.Device ?? string.Empty,
                _ => x => x.Id,
            };
            return _sortAsc ? calls.OrderBy(keySelector) : calls.OrderByDescending(keySelector);
        }
    }

    private void SortBy(string field)
    {
        if (_sortField == field)
            _sortAsc = !_sortAsc;
        else
        {
            _sortField = field;
            _sortAsc = true;
        }
    }

    private MarkupString SortIcon(string field)
    {
        if (_sortField != field) return new MarkupString("");
        var icon = _sortAsc ? "arrow_upward" : "arrow_downward";
        return new MarkupString($"<span class=\"material-icons sort-icon\">{icon}</span>");
    }

    protected override void OnInitialized()
    {
        _dbSnapshot = DbService.Snapshot;
        DbService.OnDataChanged += OnDbDataChanged;
        UpdateFilterOptions();
    }

    protected override void OnParametersSet()
    {
        _selectedFlow = QueryFlow;
        _selectedState = QueryState;
        _selectedDevice = QueryDevice;
        _searchText = QuerySearch ?? "";
    }

    private void SetFilter(string? flow = "\0", string? state = "\0",
                            string? device = "\0", string? search = "\0")
    {
        if (flow != "\0") _selectedFlow = string.IsNullOrEmpty(flow) ? null : flow;
        if (state != "\0") _selectedState = string.IsNullOrEmpty(state) ? null : state;
        if (device != "\0") _selectedDevice = string.IsNullOrEmpty(device) ? null : device;
        if (search != "\0") _searchText = search ?? "";

        UpdateUrl();
    }

    private void UpdateUrl()
    {
        var queryParams = new Dictionary<string, object?>();

        if (!string.IsNullOrEmpty(_selectedFlow))
            queryParams["flow"] = _selectedFlow;
        else
            queryParams["flow"] = null;

        if (!string.IsNullOrEmpty(_selectedState))
            queryParams["state"] = _selectedState;
        else
            queryParams["state"] = null;

        if (!string.IsNullOrEmpty(_selectedDevice))
            queryParams["device"] = _selectedDevice;
        else
            queryParams["device"] = null;

        if (!string.IsNullOrWhiteSpace(_searchText))
            queryParams["search"] = _searchText;
        else
            queryParams["search"] = null;

        var uri = Nav.GetUriWithQueryParameters(queryParams);
        Nav.NavigateTo(uri, replace: true);
    }

    private bool _disposed;

    private async void OnDbDataChanged()
    {
        if (_disposed) return;
        _dbSnapshot = DbService.Snapshot;
        UpdateFilterOptions();
        try { await InvokeAsync(StateHasChanged); } catch (ObjectDisposedException) { }
    }

    private void UpdateFilterOptions()
    {
        _flowNames = _dbSnapshot.Calls
            .Select(c => c.FlowName)
            .Where(n => !string.IsNullOrEmpty(n))
            .Distinct()
            .OrderBy(n => n)
            .ToList();

        _deviceNames = _dbSnapshot.Calls
            .Select(c => c.Device)
            .Where(d => !string.IsNullOrEmpty(d))
            .Distinct()!
            .OrderBy(d => d)
            .ToList()!;
    }

    private static string GetStateStyle(string state) =>
        $"background-color: {GetStateColor(state)}; color: white;";

    private static string GetStateColor(string state) => state?.ToLowerInvariant() switch
    {
        "ready" => "#9E9E9E",
        "going" => "#4CAF50",
        "done" => "#2196F3",
        "error" => "#F44336",
        "pause" => "#FF9800",
        "abort" => "#9C27B0",
        _ => "#9E9E9E",
    };

    public void Dispose()
    {
        _disposed = true;
        DbService.OnDataChanged -= OnDbDataChanged;
    }
}
