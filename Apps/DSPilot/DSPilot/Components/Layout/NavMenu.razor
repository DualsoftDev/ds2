@inject DsProjectService ProjectService

<MudNavMenu Color="Color.Primary">
    <MudNavLink Href="/" Match="NavLinkMatch.All">
        대시보드
    </MudNavLink>
    <MudNavLink Href="/layout" Match="NavLinkMatch.Prefix">
        레이아웃
    </MudNavLink>
    <MudNavLink Href="/chart" Match="NavLinkMatch.Prefix">
        상세정보
    </MudNavLink>
    <MudNavLink Href="/heatmap" Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.Gradient">
        동작편차
    </MudNavLink>

    <MudDivider Class="my-2" />

    <MudText Typo="Typo.overline" Class="px-4 mt-2" Color="Color.Secondary">
        FLOWS
    </MudText>

    @if (!ProjectService.IsLoaded)
    {
        <MudText Typo="Typo.caption" Class="px-4 py-2" Color="Color.Tertiary">
            No project loaded
        </MudText>
    }
    else
    {
        @foreach (var systemFlows in _systemFlowMap)
        {
            <MudText Typo="Typo.subtitle2" Class="px-4 mt-2">@systemFlows.Key</MudText>
            <div style="margin-left: 24px; border-left: 1px solid #ccc;">
                @{ var flowList = systemFlows.Value; }
                @for (int i = 0; i < flowList.Count; i++)
                {
                    var idx = i;
                    var flow = flowList[idx];
                    var isLast = idx == flowList.Count - 1;
                    <div style="position: relative; padding: 4px 0 4px 16px;
                                @(isLast ? "border-left: 1px solid transparent; margin-left: -1px;" : "")">
                        <span style="position: absolute; left: -1px; top: 50%;
                                     width: 12px; height: 0;
                                     border-top: 1px solid #ccc;"></span>
                        @if (isLast)
                        {
                            <span style="position: absolute; left: -1px; top: 0;
                                         width: 0; height: 50%;
                                         border-left: 1px solid #ccc;"></span>
                        }
                        <MudText Typo="Typo.body2" Style="color: #424242;">@flow.Name</MudText>
                    </div>
                }
            </div>
        }
    }
</MudNavMenu>

@code {
    private Dictionary<string, List<Ds2.Core.Flow>> _systemFlowMap = new();

    protected override void OnInitialized()
    {
        if (!ProjectService.IsLoaded) return;

        var systems = ProjectService.GetActiveSystems();
        foreach (var system in systems)
        {
            var flows = ProjectService.GetFlows(system.Id);
            if (flows.Count > 0)
            {
                _systemFlowMap[system.Name] = flows;
            }
        }
    }
}
