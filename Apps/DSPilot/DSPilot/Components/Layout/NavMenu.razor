@inject DsProjectService ProjectService
@inject NavigationManager Nav
@inject DashboardEditService EditService

<MudNavMenu Color="Color.Primary">
    <div style="display:flex; align-items:center;">
        <MudNavLink Href="/" Match="NavLinkMatch.All"
                    Icon="@Icons.Material.Filled.SpaceDashboard"
                    Style="flex:1; min-width:0;">
            대시보드
        </MudNavLink>
        <MudButton Size="Size.Small"
                   Variant="@(EditService.IsEditing ? Variant.Filled : Variant.Outlined)"
                   Color="@(EditService.IsEditing ? Color.Warning : Color.Primary)"
                   StartIcon="@(EditService.IsEditing ? Icons.Material.Filled.Check : Icons.Material.Filled.DashboardCustomize)"
                   OnClick="EditService.Toggle"
                   Style="margin:0 6px; padding:0 10px; min-width:0; font-size:11px; height:28px; border-radius:6px; flex-shrink:0;">
            @(EditService.IsEditing ? "완료" : "편집")
        </MudButton>
    </div>
    <MudNavLink Href="/chart" Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.BarChart">
        상세정보
    </MudNavLink>
    <MudNavLink Href="/heatmap" Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.Gradient">
        동작편차
    </MudNavLink>
    <MudNavLink Href="/cycle" Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Filled.Timeline">
        Cycle 분석
    </MudNavLink>

    <MudDivider Class="my-2" />

    @if (!ProjectService.IsLoaded)
    {
        <MudText Typo="Typo.caption" Class="px-4 py-2" Color="Color.Tertiary">
            No project loaded
        </MudText>
    }
    else
    {
        @foreach (var systemFlows in _systemFlowMap)
        {
            <MudText Typo="Typo.h6" Class="px-4 mt-2 mb-1" Style="font-weight:700;">@systemFlows.Key</MudText>
            <div style="margin-left: 24px;">
                @{ var flowList = systemFlows.Value; }
                @for (int i = 0; i < flowList.Count; i++)
                {
                    var idx = i;
                    var flow = flowList[idx];
                    var isLast = idx == flowList.Count - 1;
                    var isSelected = _selectedFlow == flow.Name;
                    <div @onclick="@(() => SelectFlow(flow.Name))"
                         style="position: relative; padding: 4px 0 4px 16px; cursor: pointer; border-radius: 4px;
                                background: @(isSelected ? "rgba(var(--mud-palette-primary-rgb), 0.15)" : "transparent");">
                        <span style="position: absolute; left: 0; top: 0;
                                     width: 1px; height: @(isLast ? "50%" : "100%");
                                     background: #ccc;"></span>
                        <span style="position: absolute; left: 0; top: 50%;
                                     width: 12px; height: 1px;
                                     background: #ccc;"></span>
                        <span style="font-size: 0.875rem;
                                     font-weight: @(isSelected ? "700" : "400");
                                     color: @(isSelected ? "var(--mud-palette-primary)" : "#424242");">
                            @flow.Name
                        </span>
                    </div>
                }
            </div>
        }
    }
</MudNavMenu>

@code {
    private Dictionary<string, List<Ds2.Core.Flow>> _systemFlowMap = new();
    private string? _selectedFlow;

    protected override void OnInitialized()
    {
        if (!ProjectService.IsLoaded) return;

        var systems = ProjectService.GetActiveSystems();
        foreach (var system in systems)
        {
            var flows = ProjectService.GetFlows(system.Id);
            if (flows.Count > 0)
            {
                _systemFlowMap[system.Name] = flows;
            }
        }
    }

    private void SelectFlow(string flowName)
    {
        _selectedFlow = flowName;
        Nav.NavigateTo($"/chart?flow={Uri.EscapeDataString(flowName)}");
    }
}
