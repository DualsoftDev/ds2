@inherits LayoutComponentBase
@inject DsProjectService ProjectService
@inject NavigationManager Nav

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Style="background: #FFFFFF; color: #0A1E5A;" Fixed="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <div style="display: flex; align-items: center; cursor: pointer;" @onclick="@(() => Nav.NavigateTo("/"))">
            <MudImage Src="images/logo.png" Height="28" Class="mr-3" Alt="DSPilot Logo" />
        </div>
        <MudSpacer />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Elevation="2"
               Variant="DrawerVariant.Responsive">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Style="height: 100vh; overflow: hidden;">
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-4" Style="height: 100%; display: flex; flex-direction: column; overflow: hidden;">
            @Body
        </MudContainer>
    </MudMainContent>

</MudLayout>

@code {
    private bool _drawerOpen = true;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#0A1E5A",
            Secondary = "#FA002D",
            Tertiary = "#0569A0",
            Info = "#009BB4",
            Success = "#4CAF50",
            Background = "#F5F5F5",
            Surface = "#FFFFFF",
            AppbarBackground = "#FFFFFF",
            AppbarText = "#0A1E5A",
            DrawerBackground = "#FFFFFF",
            DrawerText = "#212121",
            DrawerIcon = "#0A1E5A",
            TextPrimary = "#212121",
            TextSecondary = "#7D8282",
            ActionDefault = "#0A1E5A",
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = ["Noto Sans KR", "sans-serif"]
            }
        },
        LayoutProperties = new LayoutProperties
        {
            DrawerWidthLeft = "260px"
        }
    };

    private string _projectName = "DSPilot";

    protected override void OnInitialized()
    {
        var project = ProjectService.GetProject();
        if (project != null)
            _projectName = project.Name;
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
