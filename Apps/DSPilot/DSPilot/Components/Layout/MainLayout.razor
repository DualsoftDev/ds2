@inherits LayoutComponentBase
@implements IDisposable
@using DSPilot.Services
@inject DsProjectService ProjectService
@inject NavigationManager Nav
@inject ThemeService ThemeService
@inject DspDbService DbService
@inject UserTagAlertService AlertService
@inject IJSRuntime JS

<div class="layout @ThemeService.GetThemeClass()">
    <header class="app-bar">
        <button class="btn-icon" @onclick="ToggleDrawer" title="메뉴">
            <span class="material-icons">menu</span>
        </button>
        <div style="display: flex; align-items: center; cursor: pointer;" @onclick="@(() => Nav.NavigateTo("/"))">
            <img src="images/logo.png" alt="DSPilot Logo" height="28" />
        </div>
        <span class="header-page-title">@GetPageTitle()</span>
        <div class="spacer"></div>
        <nav class="header-nav">
            <a href="" class="header-nav-link @(IsActive("/"))">대시보드</a>
            <a href="heatmap" class="header-nav-link @(IsActive("/heatmap"))">동작편차</a>
            <a href="cycle-time-analysis" class="header-nav-link @(IsActive("/cycle-time-analysis"))">사이클 분석</a>
        </nav>
        @if (!DbService.HasData)
        {
            <div class="header-loading-indicator" title="PLC 데이터 수집 중">
                <span class="material-icons">sync</span>
                <span>데이터 수집 중</span>
            </div>
        }
        <button class="header-usertag-badge level-@_topAlertLevel @(_totalAlertCount == 0 ? "is-empty" : "")"
                @onclick="@(() => Nav.NavigateTo("/user-tags"))"
                title="UserTag 알림 (Info @_infoCount / Warn @_warnCount / Err @_errorCount)">
            <span class="material-icons">@(_totalAlertCount == 0 ? "notifications_none" : "notifications_active")</span>
            @if (_totalAlertCount > 0)
            {
                <span class="header-usertag-count">@(_totalAlertCount > 99 ? "99+" : _totalAlertCount.ToString())</span>
            }
        </button>
        <button class="btn-icon" @onclick="ToggleTheme" title="테마 전환">
            <span class="material-icons">@(ThemeService.IsDarkMode ? "light_mode" : "dark_mode")</span>
        </button>
        <button class="btn-icon" @onclick="@(() => Nav.NavigateTo("/settings"))" title="설정">
            <span class="material-icons">settings</span>
        </button>
    </header>

    <aside class="drawer @(_drawerOpen ? "" : "drawer-closed")">
        <NavMenu />
    </aside>

    <main class="main-content @(_drawerOpen ? "" : "drawer-closed")">
        <div class="container">
            @Body
        </div>
    </main>
</div>

<div id="snackbar-container"></div>

@code {
    private bool _drawerOpen = false;

    private string _projectName = "DSPilot";
    private string _currentPath = "/";

    private int _infoCount;
    private int _warnCount;
    private int _errorCount;
    private int _totalAlertCount;
    private string _topAlertLevel = "none";

    protected override void OnInitialized()
    {
        var project = ProjectService.GetProject();
        if (project != null)
            _projectName = project.Name;

        _currentPath = "/" + Nav.ToBaseRelativePath(Nav.Uri);
        Nav.LocationChanged += OnLocationChanged;

        RefreshAlertCounts();
        AlertService.AlertsChanged += OnAlertsChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        ThemeService.OnThemeChanged += OnThemeChanged;
        DbService.OnDataChanged += OnDbDataChanged;

        var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "dspilot-theme");
        if (saved == "dark")
        {
            ThemeService.SetDarkMode(true);
        }
    }

    private void OnAlertsChanged()
    {
        _ = InvokeAsync(() =>
        {
            RefreshAlertCounts();
            StateHasChanged();
        });
    }

    private void RefreshAlertCounts()
    {
        var alerts = AlertService.GetAlerts();
        int info = 0, warn = 0, err = 0;
        foreach (var a in alerts)
        {
            switch (a.LogLevel)
            {
                case "Error": err++; break;
                case "Warning": warn++; break;
                default: info++; break;
            }
        }
        _infoCount = info;
        _warnCount = warn;
        _errorCount = err;
        _totalAlertCount = info + warn + err;
        _topAlertLevel = err > 0 ? "error" : warn > 0 ? "warning" : info > 0 ? "info" : "none";
    }

    private void OnDbDataChanged() => InvokeAsync(StateHasChanged);

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _currentPath = "/" + Nav.ToBaseRelativePath(e.Location);
        InvokeAsync(StateHasChanged);
    }

    private string IsActive(string path) =>
        _currentPath.Equals(path, StringComparison.OrdinalIgnoreCase) ? "active" : "";

    private string GetPageTitle()
    {
        var path = _currentPath.TrimEnd('/');
        return path switch
        {
            "" or "/" => "대시보드",
            "/heatmap" => "동작편차",
            "/cycle-time-analysis" => "사이클 분석",
            "/settings" => "설정",
            "/editor" => "에디터",
            _ => ""
        };
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task ToggleTheme()
    {
        ThemeService.ToggleTheme();
        await JS.InvokeVoidAsync("localStorage.setItem", "dspilot-theme", ThemeService.IsDarkMode ? "dark" : "light");
    }

    private void OnThemeChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        ThemeService.OnThemeChanged -= OnThemeChanged;
        DbService.OnDataChanged -= OnDbDataChanged;
        AlertService.AlertsChanged -= OnAlertsChanged;
    }
}
