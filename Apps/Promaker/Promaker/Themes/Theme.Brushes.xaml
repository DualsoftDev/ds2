<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Theme.Colors.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ===== Brushes ===== -->
    <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="{StaticResource PrimaryBackgroundColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="{StaticResource SecondaryBackgroundColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="TertiaryBackgroundBrush" Color="{StaticResource TertiaryBackgroundColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="PanelHeaderBrush" Color="{StaticResource PanelHeaderColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryTextColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryTextColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource DisabledTextColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="AccentTextBrush" Color="{StaticResource AccentTextColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="{StaticResource HoverBackgroundColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="CanvasBackgroundBrush" Color="{StaticResource CanvasBackgroundColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="CanvasGridBrush" Color="{StaticResource CanvasGridColor}" po:Freeze="False"/>
    <DrawingBrush x:Key="CanvasGridPatternBrush" TileMode="Tile" Viewport="0,0,120,120" ViewportUnits="Absolute">
        <DrawingBrush.Drawing>
            <GeometryDrawing>
                <GeometryDrawing.Pen>
                    <Pen Brush="{StaticResource CanvasGridBrush}" Thickness="0.5"/>
                </GeometryDrawing.Pen>
                <GeometryDrawing.Geometry>
                    <GeometryGroup>
                        <LineGeometry StartPoint="120,0" EndPoint="120,120"/>
                        <LineGeometry StartPoint="0,120" EndPoint="120,120"/>
                    </GeometryGroup>
                </GeometryDrawing.Geometry>
            </GeometryDrawing>
        </DrawingBrush.Drawing>
    </DrawingBrush>
    <SolidColorBrush x:Key="SelectedBrush" Color="{StaticResource SelectedColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="ShadowBrush" Color="{StaticResource ShadowColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="CloseButtonHoverBrush" Color="{StaticResource CloseButtonHoverColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="CloseButtonPressedBrush" Color="{StaticResource CloseButtonPressedColor}" po:Freeze="False"/>

    <!-- Node Brushes -->
    <SolidColorBrush x:Key="NodeStartBackgroundBrush" Color="{StaticResource NodeStartBackgroundColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="NodeWorkBackgroundBrush" Color="{StaticResource NodeWorkBackgroundColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="NodeWorkSelectedBackgroundBrush" Color="{StaticResource NodeWorkSelectedBackgroundColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="NodeCallBackgroundBrush" Color="{StaticResource NodeCallBackgroundColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="NodeCallSelectedBackgroundBrush" Color="{StaticResource NodeCallSelectedBackgroundColor}" po:Freeze="False"/>

    <!-- Accent Brushes -->
    <SolidColorBrush x:Key="OrangeAccentBrush" Color="{StaticResource OrangeAccentColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="GreenAccentBrush" Color="{StaticResource GreenAccentColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="RedAccentBrush" Color="{StaticResource RedAccentColor}" po:Freeze="False"/>

    <!-- Icon Brushes -->
    <SolidColorBrush x:Key="IconOrangeBrush" Color="{StaticResource IconOrangeColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="IconBlueBrush" Color="{StaticResource IconBlueColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="IconRedBrush" Color="{StaticResource IconRedColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="IconGrayBrush" Color="{StaticResource IconGrayColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="IconGreenBrush" Color="{StaticResource IconGreenColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="IconPurpleBrush" Color="{StaticResource IconPurpleColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="IconDarkGrayBrush" Color="{StaticResource IconDarkGrayColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="SimulationReadyBrush" Color="{StaticResource SimulationReadyColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="SimulationGoingBrush" Color="{StaticResource SimulationGoingColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="SimulationFinishBrush" Color="{StaticResource SimulationFinishColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="SimulationHomingBrush" Color="{StaticResource SimulationHomingColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="SimulationGoingBackgroundBrush" Color="{StaticResource SimulationGoingBackgroundColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="SimulationFinishBackgroundBrush" Color="{StaticResource SimulationFinishBackgroundColor}" po:Freeze="False"/>
    <SolidColorBrush x:Key="SimulationHomingBackgroundBrush" Color="{StaticResource SimulationHomingBackgroundColor}" po:Freeze="False"/>

    <!-- TreeView Arrow Brush -->
    <SolidColorBrush x:Key="TreeViewArrowBrush" Color="{StaticResource TreeViewArrowColor}" po:Freeze="False"/>

</ResourceDictionary>
