    <Geometry x:Key="IconFolderOpen">M 1,17 1,1 7,1 9,4 17,4 17,6 M 1,17 3,6 18,6 16,17 Z</Geometry>
    <Geometry x:Key="IconSave">M 2,1 L 13,1 16,4 16,17 2,17 Z M 6,1 L 6,6 12,6 12,1 Z M 5,11 L 13,11 13,17 5,17 Z</Geometry>
    <Geometry x:Key="IconCube">M 9,2 L 16,6 16,13 9,17 2,13 2,6 Z M 2,6 L 9,10 16,6 M 9,10 L 9,17</Geometry>

    <!-- Edit group -->
    <Geometry x:Key="IconUndo">M 2,7 L 6,3 M 2,7 L 6,11 M 2,7 L 10,7 C 16,7 16,15 10,15 L 8,15</Geometry>
    <Geometry x:Key="IconRedo">M 16,7 L 12,3 M 16,7 L 12,11 M 16,7 L 8,7 C 2,7 2,15 8,15 L 10,15</Geometry>
    <Geometry x:Key="IconGrid">M 2,2 L 7,2 7,7 2,7 Z M 11,2 L 16,2 16,7 11,7 Z M 2,11 L 7,11 7,16 2,16 Z M 11,11 L 16,11 16,16 11,16 Z</Geometry>
    <Geometry x:Key="IconTrash">M 3,5 L 15,5 M 7,5 L 7,3 11,3 11,5 M 4.5,5 L 5.5,16 12.5,16 13.5,5 M 8,7.5 L 8,13.5 M 10,7.5 L 10,13.5</Geometry>

    <!-- Simulation group -->
    <Geometry x:Key="IconPlay">M 5,2 L 15,9 5,16 Z</Geometry>
    <Geometry x:Key="IconPause">M 4,3 L 7,3 7,15 4,15 Z M 11,3 L 14,3 14,15 11,15 Z</Geometry>
    <Geometry x:Key="IconStop">M 4,4 L 14,4 14,14 4,14 Z</Geometry>
    <Geometry x:Key="IconRefresh">M 12,3 C 15,5 16,9 14,12.5 C 12,16 7,17 4,14.5 C 1,12 1,7 4,4.5 C 6,3 8,2.5 10,3 M 12,3 L 15.5,3 M 12,3 L 12,6.5</Geometry>
    <Geometry x:Key="IconClock">M 9,1 A 8,8 0 0 1 17,9 A 8,8 0 0 1 9,17 A 8,8 0 0 1 1,9 A 8,8 0 0 1 9,1 M 9,5 L 9,9.5 12,11</Geometry>

    <!-- Tool group -->
    <Geometry x:Key="IconToolbox">M 2,7 L 16,7 16,16 2,16 Z M 6,7 L 6,4 12,4 12,7 M 2,10.5 L 7,10.5 7,12.5 11,12.5 11,10.5 16,10.5</Geometry>
    <Geometry x:Key="IconGear">M 8,1 L 10,1 10.5,3 13,4 15,2.5 16.5,4.5 14.5,6.5 15.5,8.5 17,9 17,11 15.5,11.5 14.5,13.5 16,15.5 14.5,17 12.5,15 10,15.5 10,17 8,17 7.5,15.5 5,15 3,17 1.5,15.5 3.5,13.5 2.5,11.5 1,11 1,9 2.5,8.5 3.5,6.5 1.5,4.5 3,2.5 5,4 7.5,3 Z M 6.5,9 A 2.5,2.5 0 1 1 11.5,9 A 2.5,2.5 0 1 1 6.5,9</Geometry>

    <!-- Misc -->
    <Geometry x:Key="IconChevronDown">M 5,7 L 9,11 13,7</Geometry>

    <!-- ═══ Toolbar icon base style ═══ -->

    <Style x:Key="ToolbarIcon" TargetType="Path">
        <Setter Property="Stroke" Value="{DynamicResource PrimaryTextBrush}"/>
        <Setter Property="StrokeThickness" Value="1.3"/>
        <Setter Property="Fill" Value="Transparent"/>
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="StrokeLineJoin" Value="Round"/>
        <Setter Property="StrokeStartLineCap" Value="Round"/>
        <Setter Property="StrokeEndLineCap" Value="Round"/>
    </Style>

    <!-- ═══ Toolbar group wrapper ═══ -->

    <Style x:Key="ToolbarGroup" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Margin" Value="3,3"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style x:Key="ToolbarGroupLabelBorder" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PrimaryBackgroundBrush}"/>
        <Setter Property="CornerRadius" Value="0,0,5,5"/>
        <Setter Property="Padding" Value="4,1,4,3"/>
    </Style>

    <Style x:Key="ToolbarGroupLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="9"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
    </Style>

</ResourceDictionary>
