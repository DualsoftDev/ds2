<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <!-- ===== DS2 Promaker Dark Theme (Eye-Comfort) ===== -->
    <!-- Canvas: #1E1E22 | Panel: #27272B | Text: #D4D4D6 | Border: #45454A -->
    <!-- Accent: Blue 계열 | 배경/텍스트: Eye-Comfort Gray 유지 -->

    <!-- Core Colors -->
    <Color x:Key="PrimaryBackgroundColor">#27272B</Color>
    <Color x:Key="SecondaryBackgroundColor">#2C2C31</Color>
    <Color x:Key="TertiaryBackgroundColor">#32323A</Color>
    <Color x:Key="PanelHeaderColor">#2C2C31</Color>
    <Color x:Key="BorderColor">#45454A</Color>
    <Color x:Key="PrimaryTextColor">#D4D4D6</Color>
    <Color x:Key="SecondaryTextColor">#8A8A90</Color>
    <Color x:Key="DisabledTextColor">#55555C</Color>
    <Color x:Key="AccentColor">#4F82C9</Color>
    <Color x:Key="AccentHoverColor">#69A0E5</Color>
    <Color x:Key="AccentTextColor">#FFFFFF</Color>
    <Color x:Key="HoverBackgroundColor">#32323A</Color>
    <Color x:Key="CanvasBackgroundColor">#1E1E22</Color>
    <Color x:Key="CanvasGridColor">#2E2E34</Color>
    <Color x:Key="SelectedColor">#325784</Color>
    <Color x:Key="ShadowColor">#000000</Color>
    <Color x:Key="CloseButtonHoverColor">#E81123</Color>
    <Color x:Key="CloseButtonPressedColor">#F1707A</Color>

    <!-- Node Colors -->
    <Color x:Key="NodeWorkBackgroundColor">#2C2C31</Color>
    <Color x:Key="NodeWorkSelectedBackgroundColor">#38383E</Color>
    <Color x:Key="NodeCallBackgroundColor">#28303A</Color>
    <Color x:Key="NodeCallSelectedBackgroundColor">#324050</Color>

    <!-- Accent Colors -->
    <Color x:Key="OrangeAccentColor">#F5B33C</Color>
    <Color x:Key="GreenAccentColor">#5BC56D</Color>
    <Color x:Key="PurpleAccentColor">#AB47BC</Color>
    <Color x:Key="RedAccentColor">#E46566</Color>

    <!-- Toolbar grouped flat palette -->
    <Color x:Key="ToolbarShellColor">#1E1E22</Color>
    <Color x:Key="ToolbarButtonColor">#2C2C31</Color>

    <!-- Status Colors -->
    <Color x:Key="SimulationReadyColor">#32CD32</Color>
    <Color x:Key="SimulationGoingColor">#FFA500</Color>
    <Color x:Key="SimulationFinishColor">#1E90FF</Color>
    <Color x:Key="SimulationHomingColor">#55555C</Color>
    <Color x:Key="SimulationGoingBackgroundColor">#44FFA500</Color>
    <Color x:Key="SimulationFinishBackgroundColor">#441E90FF</Color>
    <Color x:Key="SimulationHomingBackgroundColor">#4455555C</Color>
    <Color x:Key="SimulationSkipColor">#7A7A82</Color>
    <Color x:Key="SimulationSkipBackgroundColor">#447A7A82</Color>

    <!-- Gantt Bar Colors -->
    <Color x:Key="GanttBarReadyColor">#3D9970</Color>
    <Color x:Key="GanttBarGoingColor">#D4883A</Color>
    <Color x:Key="GanttBarFinishColor">#5B9BD5</Color>
    <Color x:Key="GanttBarHomingColor">#55555C</Color>

    <!-- Gantt Row Colors -->
    <Color x:Key="GanttWorkRowBackgroundColor">#242C2C31</Color>
    <Color x:Key="GanttCallRowBackgroundColor">#1F28303A</Color>

    <!-- Icon Colors -->
    <Color x:Key="IconOrangeColor">#F2B134</Color>
    <Color x:Key="IconBlueColor">#78A9E3</Color>
    <Color x:Key="IconRedColor">#E15B5B</Color>
    <Color x:Key="IconGrayColor">#8A8A90</Color>
    <Color x:Key="IconGreenColor">#57C06D</Color>
    <Color x:Key="IconTealColor">#2EC4B6</Color>
    <Color x:Key="IconPurpleColor">#AB47BC</Color>
    <Color x:Key="IconDarkGrayColor">#1E1E22</Color>

    <!-- TreeView Arrow Color -->
    <Color x:Key="TreeViewArrowColor">#D4D4D6</Color>
    <Color x:Key="ContrastDarkTextColor">#1E1E22</Color>
    <Color x:Key="AlwaysLightTextColor">#FFFFFF</Color>
    <Color x:Key="ConditionAutoBadgeColor">#A65B00</Color>
    <Color x:Key="ConditionComBadgeColor">#2A7A4E</Color>
    <Color x:Key="ConditionSkipBadgeColor">#55555C</Color>
    <Color x:Key="ReferenceBorderColor">#6B6B78</Color>
    <Color x:Key="ReferenceBackgroundColor">#252530</Color>

    <!-- Token UI Colors -->
    <Color x:Key="TokenOrangeColor">#ffb74d</Color>

</ResourceDictionary>
