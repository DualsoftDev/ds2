<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <!-- ===== Colors ===== -->
    <Color x:Key="PrimaryBackgroundColor">#2B2D30</Color>
    <Color x:Key="SecondaryBackgroundColor">#32353A</Color>
    <Color x:Key="TertiaryBackgroundColor">#3A3D42</Color>
    <Color x:Key="PanelHeaderColor">#434548</Color>
    <Color x:Key="BorderColor">#5A5D62</Color>
    <Color x:Key="PrimaryTextColor">#E8E8E8</Color>
    <Color x:Key="SecondaryTextColor">#B8B8B8</Color>
    <Color x:Key="DisabledTextColor">#808080</Color>
    <Color x:Key="AccentColor">#3A8FD9</Color>
    <Color x:Key="AccentHoverColor">#5AA5E8</Color>
    <Color x:Key="AccentTextColor">#F0F0F0</Color>
    <Color x:Key="HoverBackgroundColor">#454850</Color>
    <Color x:Key="CanvasBackgroundColor">#282A2E</Color>
    <Color x:Key="CanvasGridColor">#3E4145</Color>
    <Color x:Key="SelectedColor">#2D6DA3</Color>
    <Color x:Key="ShadowColor">#000000</Color>
    <Color x:Key="CloseButtonHoverColor">#E81123</Color>
    <Color x:Key="CloseButtonPressedColor">#F1707A</Color>

    <!-- Node Colors -->
    <Color x:Key="NodeStartBackgroundColor">#2D4A2D</Color>
    <Color x:Key="NodeWorkBackgroundColor">#3A3D42</Color>
    <Color x:Key="NodeWorkSelectedBackgroundColor">#5D5D3D</Color>
    <Color x:Key="NodeCallBackgroundColor">#2D3D4A</Color>
    <Color x:Key="NodeCallSelectedBackgroundColor">#3D5D7A</Color>

    <!-- Accent Colors -->
    <Color x:Key="OrangeAccentColor">#FFA726</Color>
    <Color x:Key="GreenAccentColor">#66D9EF</Color>
    <Color x:Key="RedAccentColor">#FF6B9D</Color>

    <!-- Status Colors -->
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <Color x:Key="WarningColor">#FF9800</Color>
    <Color x:Key="ErrorColor">#F44336</Color>
    <Color x:Key="InfoColor">#2196F3</Color>
    <Color x:Key="SimulationReadyColor">#32CD32</Color>
    <Color x:Key="SimulationGoingColor">#FFA500</Color>
    <Color x:Key="SimulationFinishColor">#1E90FF</Color>
    <Color x:Key="SimulationHomingColor">#808080</Color>
    <Color x:Key="SimulationGoingBackgroundColor">#44FFA500</Color>
    <Color x:Key="SimulationFinishBackgroundColor">#441E90FF</Color>
    <Color x:Key="SimulationHomingBackgroundColor">#44808080</Color>

    <!-- Icon Colors -->
    <Color x:Key="IconOrangeColor">#FFA726</Color>
    <Color x:Key="IconBlueColor">#64B5F6</Color>
    <Color x:Key="IconRedColor">#FF6B9D</Color>
    <Color x:Key="IconGrayColor">#B0BEC5</Color>
    <Color x:Key="IconGreenColor">#4CAF50</Color>
    <Color x:Key="IconPurpleColor">#AB47BC</Color>
    <Color x:Key="IconDarkGrayColor">#010101</Color>

    <!-- TreeView Arrow Color -->
    <Color x:Key="TreeViewArrowColor">#FFFFFF</Color>

</ResourceDictionary>
