<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">

    <!-- ===== DS2 Promaker Light Theme (Eye-Comfort) ===== -->
    <!-- Canvas: #E8EAED | Panel: #F5F6F8 | Text: #24292F | Border: #D0D7DE -->
    <!-- Accent: Blue 계열 | 배경/텍스트: Eye-Comfort Gray 유지 -->

    <!-- Core Colors -->
    <Color x:Key="PrimaryBackgroundColor">#F5F6F8</Color>
    <Color x:Key="SecondaryBackgroundColor">#F5F6F8</Color>
    <Color x:Key="TertiaryBackgroundColor">#E0E2E6</Color>
    <Color x:Key="PanelHeaderColor">#EFF0F2</Color>
    <Color x:Key="BorderColor">#D0D7DE</Color>
    <Color x:Key="PrimaryTextColor">#24292F</Color>
    <Color x:Key="SecondaryTextColor">#6A7078</Color>
    <Color x:Key="DisabledTextColor">#A0A6AE</Color>
    <Color x:Key="AccentColor">#5A82B5</Color>
    <Color x:Key="AccentHoverColor">#6B93C6</Color>
    <Color x:Key="AccentTextColor">#FFFFFF</Color>
    <Color x:Key="HoverBackgroundColor">#E8EAED</Color>
    <Color x:Key="CanvasBackgroundColor">#E8EAED</Color>
    <Color x:Key="CanvasGridColor">#D0D7DE</Color>
    <Color x:Key="SelectedColor">#D5E5FF</Color>
    <Color x:Key="ShadowColor">#2A2D33</Color>
    <Color x:Key="CloseButtonHoverColor">#E14F5F</Color>
    <Color x:Key="CloseButtonPressedColor">#F08D99</Color>

    <!-- Node Colors -->
    <Color x:Key="NodeWorkBackgroundColor">#E8EAED</Color>
    <Color x:Key="NodeWorkSelectedBackgroundColor">#DDE0E4</Color>
    <Color x:Key="NodeCallBackgroundColor">#E2E6EA</Color>
    <Color x:Key="NodeCallSelectedBackgroundColor">#D5DAE0</Color>

    <!-- Accent Colors -->
    <Color x:Key="OrangeAccentColor">#D48A1A</Color>
    <Color x:Key="GreenAccentColor">#3E9A57</Color>
    <Color x:Key="PurpleAccentColor">#7E4AB5</Color>
    <Color x:Key="RedAccentColor">#CF5657</Color>

    <!-- Toolbar grouped flat palette -->
    <Color x:Key="ToolbarShellColor">#E8EAED</Color>
    <Color x:Key="ToolbarButtonColor">#E8EAED</Color>

    <!-- Status Colors -->
    <Color x:Key="SimulationReadyColor">#2E9B45</Color>
    <Color x:Key="SimulationGoingColor">#D38A22</Color>
    <Color x:Key="SimulationFinishColor">#2F7ED8</Color>
    <Color x:Key="SimulationHomingColor">#8A8D92</Color>
    <Color x:Key="SimulationGoingBackgroundColor">#33D38A22</Color>
    <Color x:Key="SimulationFinishBackgroundColor">#332F7ED8</Color>
    <Color x:Key="SimulationHomingBackgroundColor">#338A8D92</Color>
    <Color x:Key="SimulationSkipColor">#A0A4AA</Color>
    <Color x:Key="SimulationSkipBackgroundColor">#33A0A4AA</Color>

    <!-- Gantt Bar Colors -->
    <Color x:Key="GanttBarReadyColor">#47A26A</Color>
    <Color x:Key="GanttBarGoingColor">#D29344</Color>
    <Color x:Key="GanttBarFinishColor">#5A97D0</Color>
    <Color x:Key="GanttBarHomingColor">#8A8D92</Color>

    <!-- Gantt Row Colors -->
    <Color x:Key="GanttWorkRowBackgroundColor">#33D0D7DE</Color>
    <Color x:Key="GanttCallRowBackgroundColor">#2AE0E2E6</Color>

    <!-- Icon Colors -->
    <Color x:Key="IconOrangeColor">#C47B15</Color>
    <Color x:Key="IconBlueColor">#376FBE</Color>
    <Color x:Key="IconRedColor">#C44F4F</Color>
    <Color x:Key="IconGrayColor">#5A5D62</Color>
    <Color x:Key="IconGreenColor">#2F8E4A</Color>
    <Color x:Key="IconTealColor">#1E8E85</Color>
    <Color x:Key="IconPurpleColor">#7E4AB5</Color>
    <Color x:Key="IconDarkGrayColor">#24292F</Color>

    <!-- TreeView Arrow Color -->
    <Color x:Key="TreeViewArrowColor">#24292F</Color>
    <Color x:Key="ContrastDarkTextColor">#24292F</Color>
    <Color x:Key="AlwaysLightTextColor">#FFFFFF</Color>
    <Color x:Key="ConditionAutoBadgeColor">#A65B00</Color>
    <Color x:Key="ConditionComBadgeColor">#2A7A4E</Color>
    <Color x:Key="ConditionSkipBadgeColor">#8A8D92</Color>

    <!-- Token UI Colors -->
    <Color x:Key="TokenOrangeColor">#B87A1A</Color>

</ResourceDictionary>
