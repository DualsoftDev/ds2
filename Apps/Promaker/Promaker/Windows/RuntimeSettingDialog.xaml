<Window x:Class="Promaker.Windows.RuntimeSettingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Promaker.Presentation"
        Title="런타임 세팅"
        Width="1280" Height="1080"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        Background="{DynamicResource CanvasBackgroundBrush}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- 좌/우 pill: 이미지 위, 라벨 아래 — mode-accent 테두리 -->
        <Style x:Key="SidePillBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="{DynamicResource TertiaryBackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <!-- 라디오 카드 컨테이너 — 선택 시 accent 테두리로 강조 -->
        <Style x:Key="ModeCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Margin" Value="6"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="BorderBrush" Value="#38bdf8"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource PrimaryBackgroundBrush}"
                    Padding="24,16"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="런타임 세팅"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontSize="17" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="✕" Click="Cancel_Click"
                                Background="Transparent"
                                Foreground="{DynamicResource SecondaryTextBrush}"
                                BorderThickness="0"
                                Width="30" Height="30" FontSize="15"
                                Cursor="Hand" ToolTip="닫기"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Body -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Vertical" Margin="24,20,24,16">
                    <TextBlock Text="런타임 모드"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="13" FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="실행 환경을 고르고 [적용]을 누르세요."
                               Foreground="{DynamicResource DisabledTextBrush}"
                               FontSize="11" FontStyle="Italic"
                               Margin="0,0,0,12"/>

                    <ItemsControl x:Name="ModeList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" Rows="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ModeCardStyle}"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="ModeCard_Click">
                                    <!-- 카드 전체 클릭 영역으로 사용 : RadioButton 없이 Border.MouseLeftButtonUp 이 선택 커밋 -->
                                    <StackPanel Orientation="Vertical" Margin="22,16,22,16">
                                            <!-- Title row : NameEn (bold) + NameKr (dim) -->
                                            <TextBlock FontSize="16" FontWeight="Bold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}">
                                                <Run Text="{Binding Mode}"/><Run Text=" ("/><Run Text="{Binding NameKr}"/><Run Text=")"/>
                                            </TextBlock>

                                            <!-- Description -->
                                            <TextBlock Text="{Binding Description}"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Margin="0,6,0,12"/>

                                            <!-- Flow row : 외곽 박스 없이 콘텐츠만. IsInternalLoop 으로 두-박스 vs Sim 점선 박스 분기 -->
                                            <Grid HorizontalAlignment="Center" Margin="0,4,0,0">
                                                <!-- 두-박스 콘텐츠 : Ctrl/Mon/Vp — IsInternalLoop=false 시. 전체 영역 한 검정 액자 -->
                                                <Border Background="#0f172a" CornerRadius="10" Padding="16" HorizontalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsInternalLoop}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <!-- Left : 이미지 + 라벨 -->
                                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                            <Image Source="{Binding LeftThumb}"
                                                                   Width="170" Height="170"
                                                                   Stretch="Uniform"/>
                                                            <TextBlock Text="{Binding LeftLabel}"
                                                                       Foreground="{Binding LeftAccent}"
                                                                       FontSize="13" FontWeight="Bold"
                                                                       HorizontalAlignment="Center"
                                                                       Margin="0,8,0,0"/>
                                                        </StackPanel>

                                                        <!-- Arrow column : 입력(Green) + 출력(Orange) -->
                                                        <StackPanel Orientation="Vertical"
                                                                    VerticalAlignment="Center"
                                                                    Margin="18,0" Width="112">
                                                            <Grid Margin="0,5" Width="104" Height="26" HorizontalAlignment="Center">
                                                                <Path Data="M 0 13 L 13 0 L 96 0 A 4 4 0 0 1 100 4 L 100 22 A 4 4 0 0 1 96 26 L 13 26 Z"
                                                                      Fill="#34d399"/>
                                                                <TextBlock Text="입력"
                                                                           Foreground="#0f172a"
                                                                           FontSize="11" FontWeight="Bold"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Margin="8,0,0,0"/>
                                                            </Grid>

                                                            <Grid Margin="0,5" Width="104" Height="26" HorizontalAlignment="Center"
                                                                  Visibility="{Binding ForwardVisibility}">
                                                                <Path Data="M 104 13 L 91 0 L 8 0 A 4 4 0 0 0 4 4 L 4 22 A 4 4 0 0 0 8 26 L 91 26 Z"
                                                                      Fill="#fbbf24"/>
                                                                <TextBlock Text="출력"
                                                                           Foreground="#0f172a"
                                                                           FontSize="11" FontWeight="Bold"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,8,0"/>
                                                            </Grid>
                                                        </StackPanel>

                                                        <!-- Right : 이미지 + 라벨 -->
                                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                            <Image Source="{Binding RightThumb}"
                                                                   Width="170" Height="170"
                                                                   Stretch="Uniform"/>
                                                            <TextBlock Text="{Binding RightLabel}"
                                                                       Foreground="{Binding RightAccent}"
                                                                       FontSize="13" FontWeight="Bold"
                                                                       HorizontalAlignment="Center"
                                                                       Margin="0,8,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Sim 전용 점선 박스 + 가로 [이미지 | 텍스트 2줄] + 우상단 "내부 순환" 칩 -->
                                                <Grid HorizontalAlignment="Center">
                                                    <Grid.Style>
                                                        <Style TargetType="Grid">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsInternalLoop}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Grid.Style>

                                                    <!-- 점선 외곽 + 검정 배경 -->
                                                    <Rectangle Stroke="{Binding LeftAccent}"
                                                               StrokeThickness="1.5"
                                                               StrokeDashArray="3,2"
                                                               Fill="#0f172a"
                                                               RadiusX="10" RadiusY="10"
                                                               Margin="8,8,8,0"/>

                                                    <!-- 콘텐츠 : 이미지 + 텍스트 (점선 박스 안 가운데 정렬) -->
                                                    <StackPanel Orientation="Horizontal" Margin="24,22,24,18"
                                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Image Source="{Binding LeftThumb}"
                                                               Width="170" Height="170"
                                                               Stretch="Uniform"
                                                               VerticalAlignment="Center"/>
                                                        <StackPanel Orientation="Vertical"
                                                                    VerticalAlignment="Center"
                                                                    Margin="24,0,0,0">
                                                            <TextBlock Text="{Binding SoloHeading}"
                                                                       Foreground="{Binding LeftAccent}"
                                                                       FontSize="16" FontWeight="Bold"/>
                                                        </StackPanel>
                                                    </StackPanel>

                                                </Grid>
                                            </Grid>
                                        </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 선택 모드 + Hub 주소 — 카드 그룹화. Sim 일 때 라벨만 중앙 표시 -->
                    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="22,12"
                            HorizontalAlignment="Center"
                            Margin="0,18,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="SelectedModeLabel"
                                       Text=""
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="14" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Rectangle x:Name="ModeHubDivider"
                                       Width="1" Height="22"
                                       Fill="{DynamicResource BorderBrush}"
                                       Margin="20,0,20,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding ElementName=HubAddressArea, Path=Visibility}"/>
                            <StackPanel x:Name="HubAddressArea"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Hub 주소"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                                <TextBox Text="{Binding HubAddress, UpdateSourceTrigger=PropertyChanged}"
                                         Width="220" Height="28"
                                         VerticalContentAlignment="Center"
                                         Padding="8,0"
                                         ToolTip="host:port (예: localhost:5050)"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer buttons -->
            <Border Grid.Row="2"
                    Background="{DynamicResource PrimaryBackgroundBrush}"
                    Padding="24,14"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="취소" Click="Cancel_Click" Width="96" Height="36"
                            Background="{DynamicResource TertiaryBackgroundBrush}"
                            Foreground="{DynamicResource PrimaryTextBrush}"
                            BorderThickness="0" FontSize="13" Cursor="Hand"
                            Margin="0,0,10,0"/>
                    <Button Content="적용" Click="Apply_Click" Width="96" Height="36"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="{DynamicResource AccentTextBrush}"
                            BorderThickness="0" FontSize="13" FontWeight="SemiBold"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
