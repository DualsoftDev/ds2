<Window x:Class="Promaker.Windows.CustomModelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="커스텀 3D 모델 등록"
        Width="1100" Height="720"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#0f172a">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- SystemType 입력 -->
            <RowDefinition Height="*"/>      <!-- 편집기 + 프리뷰 -->
            <RowDefinition Height="Auto"/>   <!-- 에러 메시지 -->
            <RowDefinition Height="Auto"/>   <!-- 하단 버튼 -->
        </Grid.RowDefinitions>

        <!-- Row 0: SystemType 선택 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="SystemType 이름" Foreground="#e2e8f0" FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="(프로젝트의 SystemType을 드롭다운에서 선택)"
                           Foreground="#64748b" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="SystemTypeInput" Grid.Column="0" Height="32" FontSize="13"
                          Background="#1e293b" Foreground="#e2e8f0" BorderBrush="#475569"
                          Padding="8,2"
                          SelectionChanged="SystemTypeInput_SelectionChanged"/>
                <Button x:Name="CreateNewButton" Grid.Column="1" Content="+ 새로 만들기"
                        Click="CreateNew_Click" Margin="8,0,0,0" Height="32" Padding="12,0"
                        Background="#334155" Foreground="#e2e8f0" BorderBrush="#475569"
                        FontSize="12" Cursor="Hand"
                        ToolTip="프로젝트에 정의되지 않은 SystemType을 빠르게 등록 (이름 + ApiDef만 입력)"/>
            </Grid>
        </StackPanel>

        <!-- Row 1: 편집기 + 프리뷰 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측: JSON 편집기 -->
            <Border x:Name="JsonBorder" Grid.Column="0" Background="#1e293b" BorderBrush="#334155" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#0f172a" Padding="10,6" CornerRadius="4,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="JSON" Foreground="#94a3b8" FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Button x:Name="LoadFileButton" Content="📁 파일 불러오기" Click="LoadFile_Click"
                                    Background="#334155" Foreground="#94a3b8" BorderBrush="#475569"
                                    Padding="8,3" FontSize="11" Cursor="Hand" Margin="0,0,6,0"
                                    IsEnabled="False"/>
                            <Button x:Name="AIPromptButton" Content="🤖 AI 프롬프트 복사" Click="CopyAIPrompt_Click"
                                    Background="#334155" Foreground="#94a3b8" BorderBrush="#475569"
                                    Padding="8,3" FontSize="11" Cursor="Hand"
                                    IsEnabled="False"
                                    ToolTip="AI에게 전달할 스펙 + 장비 정보를 클립보드에 복사"/>
                        </StackPanel>
                    </Border>
                    <TextBox x:Name="JsonEditor" Grid.Row="1"
                             AcceptsReturn="True" AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             FontFamily="Cascadia Code, Consolas, Courier New"
                             FontSize="12" Background="#0f172a" Foreground="#e2e8f0"
                             BorderThickness="0" Padding="10,8"
                             SpellCheck.IsEnabled="False"
                             IsEnabled="False"
                             TextChanged="JsonEditor_TextChanged"/>
                </Grid>
            </Border>

            <!-- 우측: 3D 프리뷰 -->
            <Border x:Name="PreviewBorder" Grid.Column="2" Background="#1e293b" BorderBrush="#334155" BorderThickness="1" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#0f172a" Padding="10,6" CornerRadius="4,4,0,0">
                        <TextBlock Text="3D 미리보기" Foreground="#94a3b8" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                    <wv2:WebView2 x:Name="PreviewWebView" Grid.Row="1"/>
                </Grid>
            </Border>

            <!-- SystemType 미선택 시 중앙 힌트 (양 패널 위에 표시) -->
            <TextBlock x:Name="DisabledHint" Grid.Column="0" Grid.ColumnSpan="3"
                       Text="먼저 위에서 SystemType을 선택하세요"
                       Foreground="#94a3b8" FontSize="14" FontStyle="Italic"
                       IsHitTestVisible="False"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- Row 2: 에러/상태 메시지 -->
        <Border Grid.Row="2" Margin="0,8,0,0" Padding="10,6" CornerRadius="4"
                Background="#1e293b" BorderBrush="#334155" BorderThickness="1"
                Visibility="Collapsed" x:Name="MessageBar">
            <TextBlock x:Name="MessageText" Foreground="#f87171" FontSize="11"/>
        </Border>

        <!-- Row 3: 하단 버튼 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="취소" Click="Cancel_Click" Width="80" Height="32"
                    Background="#334155" Foreground="#94a3b8" BorderBrush="#475569"
                    FontSize="13" Cursor="Hand" Margin="0,0,8,0"/>
            <Button x:Name="RegisterButton" Content="등록" Click="Register_Click" Width="80" Height="32"
                    Background="#3b82f6" Foreground="White" BorderThickness="0"
                    FontSize="13" FontWeight="SemiBold" Cursor="Hand" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
