<Window x:Class="Promaker.Windows.LlmChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Promaker.Windows"
        Title="LLM Chat (Phase 1a)" Width="720" Height="640"
        MinWidth="420" MinHeight="320"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding StatusText}" Margin="0,0,0,4" FontSize="11" Foreground="Gray" TextTrimming="CharacterEllipsis"/>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Turns}"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,2"
                            Padding="6"
                            CornerRadius="4"
                            BorderThickness="1"
                            BorderBrush="LightGray">
                        <StackPanel>
                            <TextBlock Text="{Binding Role}" FontWeight="SemiBold" Margin="0,0,0,2" Foreground="DodgerBlue"/>
                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBox Grid.Row="2"
                 Margin="0,8,0,0"
                 MinHeight="60"
                 MaxHeight="160"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}"
                 IsEnabled="{Binding IsSending, Converter={StaticResource InverseBoolConverter}}"
                 KeyDown="InputBox_KeyDown"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="초기화" Command="{Binding ResetCommand}" Width="80" Margin="0,0,8,0"/>
            <Button Content="취소" Command="{Binding CancelCommand}" Width="80" Margin="0,0,8,0"/>
            <Button Content="전송" Command="{Binding SendCommand}" Width="100" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
