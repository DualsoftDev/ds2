<Window x:Class="Promaker.Dialogs.DurationBatchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Duration 일괄 편집"
        Width="920"
        Height="680"
        MinWidth="760"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Duration 일괄 편집"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Width="28"
                        Height="28"
                        Style="{StaticResource DarkButton}"
                        Padding="0"
                        Click="Close_Click"
                        ToolTip="닫기">
                    <TextBlock Text="&#xE711;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>
            </Grid>

            <!-- Work Duration -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Work Filters -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Flow" Margin="0,0,0,4" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox x:Name="WorkFlowFilterBox" Padding="8,6" ToolTip="Flow 이름으로 필터링"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Work" Margin="0,0,0,4" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox x:Name="WorkNameFilterBox" Padding="8,6" ToolTip="Work 이름으로 필터링"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Duration" Margin="0,0,0,4" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox x:Name="WorkDurationFilterBox" Padding="8,6" ToolTip="duration 값으로 필터링 (예: 1000, &gt;500, &lt;2000)"/>
                    </StackPanel>

                    <Button Grid.Column="6"
                            Height="34"
                            MinWidth="102"
                            VerticalAlignment="Bottom"
                            Style="{StaticResource DarkButton}"
                            IsEnabled="False"
                            Content="CSV 내보내기"/>

                    <Button Grid.Column="8"
                            Height="34"
                            MinWidth="102"
                            VerticalAlignment="Bottom"
                            Style="{StaticResource DarkButton}"
                            IsEnabled="False"
                            Content="CSV 가져오기"/>
                </Grid>

                <!-- Work DataGrid -->
                <Border Grid.Row="2"
                        Background="{DynamicResource TertiaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <DataGrid x:Name="WorkDurationGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                              VerticalGridLinesBrush="{DynamicResource BorderBrush}"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              RowHeaderWidth="0"
                              PreviewMouseLeftButtonDown="Grid_PreviewMouseLeftButtonDown">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="선택 항목 체크" Click="CheckSelected_Click"/>
                                <MenuItem Header="선택 항목 체크 해제" Click="UncheckSelected_Click"/>
                                <Separator/>
                                <MenuItem Header="전체 체크" Click="CheckAll_Click"/>
                                <MenuItem Header="전체 체크 해제" Click="UncheckAll_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="34">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Flow" Binding="{Binding FlowName}" Width="120" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Work" Binding="{Binding WorkName}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Duration (ms)" Binding="{Binding Duration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Batch Apply -->
                <Border Grid.Row="4"
                        Background="{DynamicResource TertiaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="8,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="선택: " VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Grid.Column="1" x:Name="WorkSelectedCountText" Text="0"
                                   VerticalAlignment="Center" FontWeight="SemiBold"/>

                        <TextBlock Grid.Column="3" Text="일괄 설정: duration =" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Grid.Column="5" x:Name="WorkBatchValueBox" Text="1000" Padding="8,6"
                                 VerticalAlignment="Center"
                                 PreviewTextInput="BatchValueBox_PreviewTextInput"/>
                        <TextBlock Grid.Column="7" Text="ms" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>

                        <Button Grid.Column="10"
                                MinWidth="120"
                                Style="{StaticResource DarkButton}"
                                Content="선택 항목에 적용"
                                Click="WorkApplySelection_Click"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Footer -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="변경된 행만 프로젝트에 반영됩니다."
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>

                <Button Grid.Column="1"
                        MinWidth="82"
                        Style="{StaticResource DarkButton}"
                        Content="적용"
                        Click="Accept_Click"/>

                <Button Grid.Column="3"
                        MinWidth="82"
                        Style="{StaticResource DarkButton}"
                        Content="취소"
                        IsCancel="True"/>
            </Grid>
        </Grid>
    </Border>
</Window>
