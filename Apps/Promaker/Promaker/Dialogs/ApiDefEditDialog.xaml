<Window x:Class="Promaker.Dialogs.ApiDefEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:Ds2.Core.Store;assembly=Ds2.Core"
        Title="ApiDef 편집"
        Width="420" Height="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 이름 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="이름"
                           FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,2"/>
                <TextBox x:Name="NameBox" Padding="6,4"/>
            </StackPanel>

            <!-- 타입 -->
            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                <TextBlock Text="타입"
                           FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,4"/>

                <!-- Normal / Push / Pulse: 인자 없음 -->
                <RadioButton x:Name="NormalRadio" Content="{x:Static core:Labels.Normal}"
                             Foreground="{DynamicResource PrimaryTextBrush}"
                             GroupName="ActionType" IsChecked="True" Margin="0,2,0,2"/>
                <RadioButton x:Name="PushRadio" Content="{x:Static core:Labels.Push}"
                             Foreground="{DynamicResource PrimaryTextBrush}"
                             GroupName="ActionType" Margin="0,2,0,2"/>
                <RadioButton x:Name="PulseRadio" Content="{x:Static core:Labels.Pulse}"
                             Foreground="{DynamicResource PrimaryTextBrush}"
                             GroupName="ActionType" Margin="0,2,0,2"/>

                <!-- TimeTotal: 지정 시간만큼 절대 출력 ON -->
                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                    <RadioButton x:Name="TimeTotalRadio" Content="{x:Static core:Labels.TimeTotal}"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 GroupName="ActionType" Width="110" VerticalAlignment="Center"
                                 Checked="TimeTotalRadio_Checked" Unchecked="TimeTotalRadio_Unchecked"/>
                    <TextBlock Text="ms" VerticalAlignment="Center" Margin="0,0,4,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox x:Name="TimeTotalMsBox" Width="60" Padding="4,2"
                             VerticalAlignment="Center" IsEnabled="False"
                             Text="1000" PreviewTextInput="DigitOnly_PreviewTextInput"/>
                </StackPanel>

                <!-- TimeAppend: 센서 감지 후 +N ms 추가 출력 -->
                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                    <RadioButton x:Name="TimeAppendRadio" Content="{x:Static core:Labels.TimeAppend}"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 GroupName="ActionType" Width="110" VerticalAlignment="Center"
                                 Checked="TimeAppendRadio_Checked" Unchecked="TimeAppendRadio_Unchecked"/>
                    <TextBlock Text="ms" VerticalAlignment="Center" Margin="0,0,4,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox x:Name="TimeAppendMsBox" Width="60" Padding="4,2"
                             VerticalAlignment="Center" IsEnabled="False"
                             Text="200" PreviewTextInput="DigitOnly_PreviewTextInput"/>
                </StackPanel>

                <!-- MultiAction: N회 · 간격 ms 로 출력 반복 -->
                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                    <RadioButton x:Name="MultiActionRadio" Content="{x:Static core:Labels.MultiAction}"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 GroupName="ActionType" Width="110" VerticalAlignment="Center"
                                 Checked="MultiActionRadio_Checked" Unchecked="MultiActionRadio_Unchecked"/>
                    <TextBlock Text="count" VerticalAlignment="Center" Margin="0,0,4,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox x:Name="MultiActionCountBox" Width="40" Padding="4,2"
                             VerticalAlignment="Center" IsEnabled="False"
                             Text="3" PreviewTextInput="DigitOnly_PreviewTextInput"/>
                    <TextBlock Text="interval(ms)" VerticalAlignment="Center" Margin="8,0,4,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox x:Name="MultiActionIntervalBox" Width="60" Padding="4,2"
                             VerticalAlignment="Center" IsEnabled="False"
                             Text="50" PreviewTextInput="DigitOnly_PreviewTextInput"/>
                </StackPanel>
            </StackPanel>

            <!-- TX Work / RX Work -->
            <Grid Grid.Row="2" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{x:Static core:Labels.TxWork}"
                               FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,0,0,2"/>
                    <ComboBox x:Name="TxWorkCombo" DisplayMemberPath="Name" Padding="6,4"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="{x:Static core:Labels.RxWork}"
                               FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,0,0,2"/>
                    <ComboBox x:Name="RxWorkCombo" DisplayMemberPath="Name" Padding="6,4"/>
                </StackPanel>
            </Grid>

            <!-- 설명 -->
            <DockPanel Grid.Row="4" Grid.RowSpan="2" Margin="0,0,0,8" LastChildFill="True">
                <TextBlock Text="설명" DockPanel.Dock="Top"
                           FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,2"/>
                <TextBox x:Name="DescriptionBox" Padding="6,4"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"/>
            </DockPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button Content="확인" Style="{StaticResource DarkButton}"
                        Padding="12,4" Margin="0,0,4,0"
                        Click="Ok_Click" IsDefault="True"/>
                <Button Content="취소" Style="{StaticResource DarkButton}"
                        Padding="12,4" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
