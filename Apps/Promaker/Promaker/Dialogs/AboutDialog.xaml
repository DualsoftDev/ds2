<Window x:Class="Promaker.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Promaker 정보"
        Width="340" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <StackPanel Margin="32,28,32,24" HorizontalAlignment="Center">
            <!-- App Name -->
            <TextBlock Text="Promaker"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>

            <!-- Version -->
            <TextBlock x:Name="VersionText"
                       FontSize="12"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"/>

            <!-- Separator -->
            <Border Height="1" Margin="0,0,0,16"
                    Background="{DynamicResource BorderBrush}"/>

            <!-- Description -->
            <TextBlock Text="DS2 기반 시뮬레이션 모델링 도구"
                       FontSize="12"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>

            <!-- Copyright -->
            <TextBlock x:Name="CopyrightText"
                       FontSize="11"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>

            <TextBlock Text="Dualsoft Technology Inc."
                       FontSize="11"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>

            <TextBlock Text="https://dualsoft.com"
                       FontSize="11"
                       Foreground="{DynamicResource AccentBrush}"
                       HorizontalAlignment="Center"
                       Cursor="Hand"
                       MouseLeftButtonUp="Url_Click"
                       Margin="0,0,0,20"/>

            <!-- Close Button -->
            <Button Content="닫기" Style="{StaticResource DarkButton}"
                    Padding="20,6"
                    HorizontalAlignment="Center"
                    IsCancel="True"/>
        </StackPanel>
    </Border>
</Window>
