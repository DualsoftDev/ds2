<Window x:Class="Promaker.Dialogs.ModelDocPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="발행 doc — YAML view"
        Width="900" Height="700"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <!-- chat-ui boost: apply_model_doc 발행 doc 의 yaml view dialog. button (>30 line) 클릭 시 열림.
         추후 확장: syntax highlight (Markdig.Wpf / AvalonEdit) — 본 dialog 의 TextBox 만 교체. -->
    <Border Background="{DynamicResource PrimaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: meta info -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="apply_model_doc 발행 doc — YAML view"
                           FontWeight="SemiBold" FontSize="13"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           x:Name="MetaText"
                           FontSize="11"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Body: read-only TextBox (multiline + scrollbar) -->
            <Border Grid.Row="1"
                    Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <TextBox x:Name="YamlBox"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="False"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="8,6"
                         FontFamily="Cascadia Mono, Consolas, Courier New, monospace"
                         FontSize="12"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         SelectionBrush="{DynamicResource AccentBrush}"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"/>
            </Border>

            <!-- Footer: copy / close -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,10,0,0">
                <!-- review m5a: emoji 제거 — Segoe MDL2 Assets icon (Copy = E8C8) 으로 대체 (Promaker 의 다른 button 패턴 일관). -->
                <Button Click="Copy_Click"
                        Padding="14,5" Margin="0,0,8,0"
                        Background="{DynamicResource SecondaryBackgroundBrush}"
                        Foreground="{DynamicResource PrimaryTextBrush}"
                        BorderBrush="{DynamicResource BorderBrush}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="클립보드 복사" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Content="닫기"
                        IsCancel="True"
                        Padding="20,5"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="{DynamicResource AccentTextBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
