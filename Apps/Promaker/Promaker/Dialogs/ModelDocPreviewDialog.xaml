<Window x:Class="Promaker.Dialogs.ModelDocPreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="발행 doc — YAML / Mermaid view"
        Width="900" Height="700"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <!-- chat-ui boost (Mermaid 확장): apply_model_doc 발행 doc 의 YAML view + Mermaid view (work-flow / call-flow).
         Mermaid 텍스트는 F# `ModelProtocolMermaid.jsonElementToBlocks` 로 생성 (Ev2 패턴 차용).
         passive-only / patch-only doc 은 Mermaid block 0건 → 코드비하인드 가 Mermaid tab 자체 미생성. -->
    <Border Background="{DynamicResource PrimaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: meta info -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="apply_model_doc 발행 doc"
                           FontWeight="SemiBold" FontSize="13"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           x:Name="MetaText"
                           FontSize="11"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Body: TabControl (YAML / Mermaid) -->
            <TabControl Grid.Row="1" x:Name="ViewTabs"
                        Background="{DynamicResource PrimaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}">
                <TabItem Header="YAML">
                    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1">
                        <TextBox x:Name="YamlBox"
                                 IsReadOnly="True"
                                 IsReadOnlyCaretVisible="False"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="8,6"
                                 FontFamily="Cascadia Mono, Consolas, Courier New, monospace"
                                 FontSize="12"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 SelectionBrush="{DynamicResource AccentBrush}"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"/>
                    </Border>
                </TabItem>
                <TabItem x:Name="MermaidTab" Header="Mermaid">
                    <!-- 단일 WebView2 — wwwroot/mermaid-view.html 이 block 들을 동적 DOM 렌더 + mermaid.js 로 SVG.
                         block 마다 복사 button 은 HTML 측에서 navigator.clipboard.writeText (실패 시 C# fallback).
                         passive-only / patch-only doc 은 코드비하인드 가 본 TabItem 자체 미생성. -->
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <wv2:WebView2 x:Name="MermaidWebView"/>
                    </Border>
                </TabItem>
            </TabControl>

            <!-- Footer: copy yaml / close -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,10,0,0">
                <!-- 본 button 은 YAML 전체 복사. Mermaid block 의 복사는 각 block 안 button. -->
                <Button Click="Copy_Click"
                        Padding="14,5" Margin="0,0,8,0"
                        Background="{DynamicResource SecondaryBackgroundBrush}"
                        Foreground="{DynamicResource PrimaryTextBrush}"
                        BorderBrush="{DynamicResource BorderBrush}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="YAML 복사" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Content="닫기"
                        IsCancel="True"
                        Padding="20,5"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="{DynamicResource AccentTextBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
