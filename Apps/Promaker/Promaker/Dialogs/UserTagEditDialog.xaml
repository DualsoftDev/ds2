<Window x:Class="Promaker.Dialogs.UserTagEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="사용자 태그 편집"
        Width="420" Height="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 이름 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text="이름"
                           FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,2"/>
                <TextBox x:Name="NameBox" Padding="6,4"/>
            </StackPanel>

            <!-- 로그 레벨 -->
            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                <TextBlock Text="로그 레벨"
                           FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="InfoRadio" Content="Info"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 GroupName="LogLevel" IsChecked="True"
                                 Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <RadioButton x:Name="WarningRadio" Content="Warning"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 GroupName="LogLevel"
                                 Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <RadioButton x:Name="ErrorRadio" Content="Error"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 GroupName="LogLevel"
                                 VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <!-- 태그 주소 -->
            <StackPanel Grid.Row="2" Margin="0,0,0,8">
                <TextBlock Text="태그 주소"
                           FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,2"/>
                <TextBox x:Name="AddressBox" Padding="6,4"/>
            </StackPanel>

            <!-- 값 타입 -->
            <StackPanel Grid.Row="3" Margin="0,0,0,8">
                <TextBlock Text="값 타입"
                           FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,2"/>
                <ComboBox x:Name="ValueTypeCombo" Padding="6,4"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button Content="확인" Style="{StaticResource DarkButton}"
                        Padding="12,4" Margin="0,0,4,0"
                        Click="Ok_Click" IsDefault="True"/>
                <Button Content="취소" Style="{StaticResource DarkButton}"
                        Padding="12,4" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
