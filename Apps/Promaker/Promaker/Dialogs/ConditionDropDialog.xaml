<Window x:Class="Promaker.Dialogs.ConditionDropDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="조건 ApiCall 추가"
        Width="420"
        Height="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: 안내 -->
            <TextBlock Grid.Row="0"
                       Text="트리에서 Call을 드래그하면 ApiCall 목록이 표시됩니다"
                       FontSize="11"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,0,0,4"/>

            <!-- Row 1: 드롭 영역 + ApiCall 체크리스트 -->
            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Background="{DynamicResource TertiaryBackgroundBrush}">
                <Grid>
                    <!-- 드롭 힌트 (ApiCall 리스트 비어있을 때) -->
                    <Border x:Name="DropTargetBorder"
                            AllowDrop="True"
                            DragEnter="DropTarget_DragEnter"
                            DragLeave="DropTarget_DragLeave"
                            DragOver="DropTarget_DragOver"
                            Drop="DropTarget_Drop"
                            Background="Transparent"
                            MinHeight="60">
                        <StackPanel x:Name="EmptyHintPanel"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="&#x1F4CB;"
                                       FontSize="24"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="왼쪽 트리에서 Call을 여기로 드래그하세요"
                                       FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontStyle="Italic"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- ApiCall 체크리스트 (드롭 후 표시) -->
                    <DockPanel x:Name="ApiCallListPanel" Visibility="Collapsed">
                        <TextBlock DockPanel.Dock="Top"
                                   x:Name="DroppedCallLabel"
                                   FontSize="11"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Margin="6,4,6,4"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ApiCallItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding DisplayName}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Foreground="{DynamicResource PrimaryTextBrush}"
                                                  FontSize="11"
                                                  Margin="6,2"
                                                  Checked="ApiCallCheckBox_Changed"
                                                  Unchecked="ApiCallCheckBox_Changed"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Grid>
            </Border>

            <!-- Row 2: 확인/취소 -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button x:Name="SelectAllButton"
                        Content="전체 선택"
                        Style="{StaticResource DarkButton}"
                        Padding="12,4"
                        Margin="0,0,4,0"
                        Visibility="Collapsed"
                        Click="SelectAll_Click"/>
                <Button x:Name="OkButton"
                        Content="확인"
                        Style="{StaticResource DarkButton}"
                        Padding="16,4"
                        Margin="0,0,4,0"
                        IsEnabled="False"
                        Click="OK_Click"/>
                <Button Content="취소"
                        Style="{StaticResource DarkButton}"
                        Padding="16,4"
                        Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
