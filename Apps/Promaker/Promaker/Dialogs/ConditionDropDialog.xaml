<Window x:Class="Promaker.Dialogs.ConditionDropDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:Promaker.Controls"
        Title="조건 ApiCall 추가"
        Width="400"
        Height="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: 추가된 항목 목록 -->
            <TextBlock Grid.Row="0"
                       Text="추가된 조건 목록"
                       FontSize="11"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,0,0,4"/>

            <!-- Row 1: 드롭 영역 + 리스트 -->
            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Background="{DynamicResource TertiaryBackgroundBrush}">
                <Grid>
                    <ListBox x:Name="ConditionListBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource PrimaryTextBrush}"
                             Visibility="Collapsed">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DisplayName}"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SpecText}"
                                               FontSize="10"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center"
                                               Margin="8,0"/>
                                    <Button Grid.Column="2"
                                            Content="x"
                                            Style="{StaticResource DarkButton}"
                                            Padding="4,1"
                                            Click="RemoveItem_Click"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 드롭 타겟 (비어있을 때 표시) -->
                    <Border x:Name="DropTargetBorder"
                            AllowDrop="True"
                            DragEnter="DropTarget_DragEnter"
                            DragLeave="DropTarget_DragLeave"
                            DragOver="DropTarget_DragOver"
                            Drop="DropTarget_Drop"
                            Background="Transparent"
                            MinHeight="60">
                        <StackPanel x:Name="EmptyHintPanel"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="📋"
                                       FontSize="24"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="왼쪽 트리에서 Call을 여기로 드래그하세요"
                                       FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontStyle="Italic"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="(한 번에 하나씩)"
                                       FontSize="10"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Row 2: ValueSpec 편집 패널 (드롭 후 표시) -->
            <Border Grid.Row="2"
                    x:Name="ValueSpecPanel"
                    Visibility="Collapsed"
                    Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock x:Name="SelectedApiCallText"
                               FontSize="11"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,0,4"/>
                    <ctrl:ValueSpecEditorControl x:Name="SpecEditor" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="AddButton"
                                Content="추가"
                                Style="{StaticResource DarkButton}"
                                Padding="12,4"
                                Margin="0,0,4,0"
                                Click="ConfirmAdd_Click"/>
                        <Button Content="취소"
                                Style="{StaticResource DarkButton}"
                                Padding="12,4"
                                Click="CancelAdd_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Row 3: 확인/취소 -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button x:Name="OkButton"
                        Content="확인"
                        Style="{StaticResource DarkButton}"
                        Padding="16,4"
                        Margin="0,0,4,0"
                        IsEnabled="False"
                        Click="OK_Click"/>
                <Button Content="취소"
                        Style="{StaticResource DarkButton}"
                        Padding="16,4"
                        Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
