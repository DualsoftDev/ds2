<Window x:Class="Promaker.Windows.PlcSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Promaker.ViewModels"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        Title="PLC 연결 설정"
        Width="780"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        Background="{DynamicResource CanvasBackgroundBrush}">

    <Window.Resources>
        <!-- Vendor enum 별 가시성 분기용 컨버터 — 필요할 때만 생성. 여기서는 단순 비교 트리거 사용 -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
        <Style x:Key="FieldBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource PrimaryBackgroundBrush}"
                    Padding="24,16"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="PLC 연결 설정"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               FontSize="17" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button Content="✕" Click="Cancel_Click"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            BorderThickness="0"
                            Width="30" Height="30" FontSize="15"
                            Cursor="Hand" ToolTip="닫기"/>
                </Grid>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="24,18,24,12">

                <!-- Vendor 선택 -->
                <TextBlock Text="벤더" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                    <RadioButton x:Name="RbLsXgi" Content="LS XGI"
                                 GroupName="Vendor" Margin="0,0,16,0"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 Checked="VendorRadio_Checked"/>
                    <RadioButton x:Name="RbLsXgk" Content="LS XGK"
                                 GroupName="Vendor" Margin="0,0,16,0"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 Checked="VendorRadio_Checked"/>
                    <RadioButton x:Name="RbMx" Content="Mitsubishi (MELSEC)"
                                 GroupName="Vendor"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 Checked="VendorRadio_Checked"/>
                </StackPanel>

                <!-- 공통 연결 정보 -->
                <TextBlock Text="연결 정보" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="이름" Style="{StaticResource LabelStyle}"/>
                    <TextBox  Grid.Column="1" x:Name="NameBox" Style="{StaticResource FieldBoxStyle}"/>
                    <TextBlock Grid.Column="2" Text="IP" Style="{StaticResource LabelStyle}"/>
                    <TextBox  Grid.Column="3" x:Name="IpBox" Style="{StaticResource FieldBoxStyle}"
                              ToolTip="예: 192.168.0.10"/>
                    <TextBlock Grid.Column="4" Text="Port" Style="{StaticResource LabelStyle}"/>
                    <TextBox  Grid.Column="5" x:Name="PortBox" Style="{StaticResource FieldBoxStyle}"
                              ToolTip="LS 기본 2004 / Mitsubishi 기본 5007"/>
                </Grid>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Timeout (ms)" Style="{StaticResource LabelStyle}"/>
                    <TextBox  Grid.Column="1" x:Name="TimeoutBox" Style="{StaticResource FieldBoxStyle}"/>
                    <TextBlock Grid.Column="2" Text="Scan (ms)" Style="{StaticResource LabelStyle}"/>
                    <TextBox  Grid.Column="3" x:Name="ScanBox" Style="{StaticResource FieldBoxStyle}"/>
                </Grid>

                <!-- LS 전용 -->
                <Grid x:Name="LsOnlyPanel" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="LS 전용" Style="{StaticResource LabelStyle}"/>
                    <CheckBox Grid.Column="1" x:Name="LocalEthernetBox"
                              Content="내장 이더넷 (체크 해제 시 FEnet 모듈)"
                              Foreground="{DynamicResource PrimaryTextBrush}"
                              VerticalAlignment="Center"/>
                </Grid>

                <!-- MX 전용 -->
                <StackPanel x:Name="MxOnlyPanel" Margin="0,0,0,12">
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Network No." Style="{StaticResource LabelStyle}"/>
                        <TextBox  Grid.Column="1" x:Name="NetworkNumberBox" Style="{StaticResource FieldBoxStyle}"
                                  ToolTip="기본 0 (자국)"/>
                        <TextBlock Grid.Column="2" Text="Station No." Style="{StaticResource LabelStyle}"/>
                        <TextBox  Grid.Column="3" x:Name="StationNumberBox" Style="{StaticResource FieldBoxStyle}"
                                  ToolTip="기본 255 (자국 CPU, hex FF)"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="전송 방식" Style="{StaticResource LabelStyle}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <RadioButton x:Name="RbTransportTcp" Content="TCP"
                                         GroupName="MxTransport" Margin="0,0,16,0"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         VerticalAlignment="Center"
                                         ToolTip="MC 프로토콜 TCP (기본). PLC Ethernet 모듈이 TCP 로 설정된 경우."/>
                            <RadioButton x:Name="RbTransportUdp" Content="UDP"
                                         GroupName="MxTransport"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         VerticalAlignment="Center"
                                         ToolTip="MC 프로토콜 UDP. PLC Ethernet 모듈이 UDP 로 설정된 경우 (모니터링에 흔함)."/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- 태그 매핑은 AASX IO 설정에서 자동 import — 수동 입력 불필요. -->
                <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14,10"
                        Margin="0,4,0,0">
                    <StackPanel>
                        <TextBlock Text="태그 매핑"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap"
                                   FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}">
                            AASX IO 설정 (ApiCall 의 OutTag / InTag 주소) 에서 자동 가져옵니다.
                            데이터 타입은 주소 패턴(<Run FontWeight="SemiBold">%MX*</Run>=Bit,
                            <Run FontWeight="SemiBold">%DW*</Run>·<Run FontWeight="SemiBold">D*</Run>=Word 등)으로 추론합니다.
                        </TextBlock>
                        <TextBlock x:Name="TagSummaryText"
                                   FontSize="11"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{DynamicResource PrimaryBackgroundBrush}"
                    Padding="24,14"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="적용" Click="Apply_Click" Width="96" Height="36"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="{DynamicResource AccentTextBrush}"
                            BorderThickness="0" FontSize="13" FontWeight="SemiBold"
                            Cursor="Hand"
                            Margin="0,0,10,0"/>
                    <Button Content="취소" Click="Cancel_Click" Width="96" Height="36"
                            Background="{DynamicResource TertiaryBackgroundBrush}"
                            Foreground="{DynamicResource PrimaryTextBrush}"
                            BorderThickness="0" FontSize="13" Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
