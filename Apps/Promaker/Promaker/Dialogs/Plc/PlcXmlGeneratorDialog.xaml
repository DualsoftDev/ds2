<Window x:Class="Promaker.Dialogs.PlcXmlGeneratorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:le="clr-namespace:AAStoPLC.LadderEditor.Views;assembly=AAStoPLC.LadderEditor"
        Title="PLC 생성"
        Width="1180" Height="720"
        MinWidth="980" MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 제목 -->
            <Grid Grid.Row="0">
                <TextBlock Text="PLC 생성"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- 미리보기 탭 -->
            <TabControl Grid.Row="2"
                        x:Name="PreviewTabs"
                        Background="{DynamicResource TertiaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}">
                <TabItem Header="요약">
                    <TextBox x:Name="SummaryText"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="12"
                             Background="{DynamicResource TertiaryBackgroundBrush}"
                             BorderThickness="0"
                             TextWrapping="Wrap"
                             HorizontalScrollBarVisibility="Disabled"
                             VerticalScrollBarVisibility="Auto"
                             Padding="14,10"
                             Text="생성 중..."/>
                </TabItem>
                <TabItem Header="래더 보기">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 래더 툴바 -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource TertiaryBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="8,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="프로그램:"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <ComboBox x:Name="LadderProgramComboBox"
                                          MinWidth="180"
                                          SelectionChanged="LadderProgram_SelectionChanged"/>
                                <TextBlock Text="(Ctrl+휠로 확대/축소)" VerticalAlignment="Center"
                                           Margin="10,0,0,0" FontStyle="Italic"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- 래더 뷰 — LadderEditor read-only. Ctrl+휠 zoom 내장. -->
                        <le:LadderEditorControl Grid.Row="1"
                                                 x:Name="LadderView"
                                                 IsReadOnly="True"/>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- 푸터 -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Text="대기 중"/>

                <Button Grid.Column="1"
                        x:Name="SaveButton"
                        MinWidth="100"
                        Style="{StaticResource DarkButton}"
                        Content="저장..."
                        IsEnabled="False"
                        Click="Save_Click"
                        ToolTip="생성된 XML을 파일로 저장"/>

                <Button Grid.Column="3"
                        MinWidth="82"
                        Style="{StaticResource DarkButton}"
                        Content="닫기"
                        IsCancel="True"/>
            </Grid>
        </Grid>
    </Border>
</Window>
