<Window x:Class="Promaker.Dialogs.MermaidImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mermaid 임포트"
        Width="440"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <StackPanel Margin="16">

            <!-- 구조 정보 -->
            <TextBlock x:Name="DepthInfoText"
                       FontSize="13"
                       Margin="0,0,0,12"/>

            <!-- 임포트 레벨 -->
            <TextBlock Text="임포트 레벨:"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <ComboBox x:Name="LevelCombo"
                      FontSize="13"
                      Margin="0,0,0,12"
                      SelectionChanged="LevelCombo_SelectionChanged"/>

            <!-- 대상 -->
            <TextBlock x:Name="TargetText"
                       FontSize="12"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,0,0,12"/>

            <!-- 프리뷰 -->
            <TextBlock Text="생성 예정:"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <Border Background="{DynamicResource TertiaryBackgroundBrush}"
                    CornerRadius="3"
                    Padding="10,8"
                    Margin="0,0,0,12">
                <TextBlock x:Name="PreviewText"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- 경고 (숨김 가능) -->
            <Border x:Name="WarningBorder"
                    Background="#30FFA500"
                    CornerRadius="3"
                    Padding="10,8"
                    Margin="0,0,0,12"
                    Visibility="Collapsed">
                <TextBlock x:Name="WarningText"
                           FontSize="12"
                           Foreground="{DynamicResource OrangeAccentBrush}"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- 버튼 -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,4,0,0">
                <Button x:Name="OkButton"
                        Content="확인"
                        Style="{StaticResource DarkButton}"
                        Padding="12,4"
                        Margin="0,0,4,0"
                        IsDefault="True"
                        Click="Ok_Click"/>
                <Button Content="취소"
                        Style="{StaticResource DarkButton}"
                        Padding="12,4"
                        IsCancel="True"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
