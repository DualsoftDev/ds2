<UserControl x:Class="Promaker.Dialogs.TagWizardStep2Section"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Promaker.Dialogs">
                    <Grid Margin="30,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Step 2: 신호 템플릿"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 좌측: SystemType 리스트 -->
                                    <Border Grid.Column="0"
                                            Background="{DynamicResource PrimaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- SystemType 리스트 헤더 -->
                                            <Border Grid.Row="0"
                                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="15,12">
                                                <TextBlock Text="📂 시스템 타입"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            </Border>

                                            <!-- SystemType 리스트 -->
                                            <ListBox x:Name="DeviceTemplateListBox"
                                                     Grid.Row="1"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Padding="5"
                                                     SelectionChanged="DeviceTemplateListBox_SelectionChanged">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   FontSize="12"
                                                                   Padding="8,6"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>

                                    <!-- 우측: 템플릿 편집 영역 (TabControl 방식) -->
                                    <Border Grid.Column="2"
                                            Background="{DynamicResource PrimaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- 헤더: SystemType 이름 (편집 즉시 자동 저장됨, 저장 버튼 없음). -->
                                            <Border Grid.Row="0"
                                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="20,12">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="📝 " FontSize="14" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="CurrentDeviceTemplateText"
                                                               Text="템플릿을 선택하세요"
                                                               FontSize="14" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="  ✓ 자동 저장"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                               VerticalAlignment="Center"
                                                               Margin="12,0,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- 안내 메시지 + 글로벌 FB 타입 선택 -->
                                            <Border Grid.Row="1"
                                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="15,12">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="8"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                               TextWrapping="Wrap">
                                                        <Run Text="💡 "/>
                                                        <Run Text="각 API별 신호 패턴을 설정합니다. 변수 치환: $(F)=Flow명, $(D)=Device명, $(A)=Api명, $(S)=Active System 이름, $(C)=SignalCounts[ApiName] 값 (FB의 Adv_Amount/Ret_Amount 등 카운트 입력 포트용 — entry 의 ApiName 이 ADV/RET 이어야 함)"/>
                                                    </TextBlock>
                                                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                                                        <TextBlock Text="🎯 FB 타입 (SystemType 당 1개):"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                        <ComboBox x:Name="GlobalFBTypeCombo"
                                                                  Width="280"
                                                                  Margin="10,0,0,0"
                                                                  IsEditable="False"
                                                                  SelectionChanged="GlobalFBType_Changed"
                                                                  ToolTip="이 SystemType 이 사용하는 FB (XGI_Template.xml 에 정의된 UserFB). AUX 탭에서 이 FB 의 포트 목록이 표시됩니다."/>
                                                        <TextBlock Text="  (변경 시 AUX 포트 선택지가 갱신됩니다)"
                                                                   VerticalAlignment="Center"
                                                                   Margin="10,0,0,0"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- 메인 편집 영역: IW/QW/MW 탭 -->
                                            <TabControl x:Name="SignalSectionTabControl"
                                                        Grid.Row="2"
                                                        Background="{DynamicResource SecondaryBackgroundBrush}"
                                                        BorderThickness="0"
                                                        SelectionChanged="SignalSectionTab_SelectionChanged">

                                                <!-- IW 탭 -->
                                                <TabItem Header="입력 (IW)"
                                                         Foreground="{DynamicResource PrimaryTextBrush}">
                                                        <local:TagWizardIwTab x:Name="IwTab"/>
                                                </TabItem>

                                                <!-- QW 탭 -->
                                                <TabItem Header="출력 (QW)"
                                                         Foreground="{DynamicResource PrimaryTextBrush}">
                                                        <local:TagWizardQwTab x:Name="QwTab"/>
                                                </TabItem>

                                                <!-- MW 탭 -->
                                                <TabItem Header="메모리 (MW)"
                                                         Foreground="{DynamicResource PrimaryTextBrush}">
                                                        <local:TagWizardMwTab x:Name="MwTab"/>
                                                </TabItem>

                                                <!-- AUX 포트 탭 (AutoAux / ComAux 대상 FB 포트 매핑) -->
                                                <TabItem Header="AUX 포트"
                                                         Foreground="{DynamicResource PrimaryTextBrush}">
                                                        <local:TagWizardAuxTab x:Name="AuxTab"/>
                                                </TabItem>

                                                <TabItem Header="End 포트"
                                                         Foreground="{DynamicResource PrimaryTextBrush}">
                                                        <local:TagWizardEndTab x:Name="EndTab"/>
                                                </TabItem>

                                            </TabControl>

                                            <!-- 하단 상태바 -->
                                            <Border Grid.Row="3"
                                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,1,0,0"
                                                    Padding="15,10">
                                                <TextBlock x:Name="DeviceTemplateStatusText"
                                                           Text="템플릿을 선택하면 편집할 수 있습니다."
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                    </Grid>
</UserControl>
