<Window x:Class="Promaker.Dialogs.TagWizardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:Promaker.Dialogs"
        Title="TAG Wizard - 신호 자동 생성"
        Width="1680"
        Height="1000"
        MinWidth="1400"
        MinHeight="860"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        PreviewKeyDown="TagWizardKeyDown">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Dialog.Resources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더: 단계 표시 (얇은 컬러 바) -->
            <Grid Grid.Row="0" Height="50">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Step 1 Bar -->
                <Border x:Name="Step1Bar" Grid.Column="0"
                        Background="{DynamicResource AccentBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <TextBlock x:Name="Step1Text" Text="1. 프로젝트 + 주소"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource AlwaysLightTextBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Step 2 Bar -->
                <Border x:Name="Step2Bar" Grid.Column="1"
                        Background="{DynamicResource SecondaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <TextBlock x:Name="Step2Text" Text="2. 신호 템플릿"
                               FontSize="12" FontWeight="Normal"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Step 3 Bar -->
                <Border x:Name="Step3Bar" Grid.Column="2"
                        Background="{DynamicResource SecondaryBackgroundBrush}">
                    <TextBlock x:Name="Step3Text" Text="3. 신호 생성 + 적용"
                               FontSize="12" FontWeight="Normal"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- 본문: 단계별 컨텐츠 -->
            <Grid Grid.Row="1">
                <!-- Step 1: 프로젝트 확인 -->
                <!-- Step 1: 프로젝트 확인 + 선두 주소 설정 -->
                <local:TagWizardStep1Section x:Name="Step1Section" Visibility="Visible"/>

                <!-- Step 2: 신호 템플릿 -->
                <local:TagWizardStep2Section x:Name="Step2Section" Visibility="Collapsed"/>

                <!-- Step 3: 신호 생성 -->
                <local:TagWizardStep3Section x:Name="Step3Section" Visibility="Collapsed"/>

            </Grid>

            <!-- 하단: 버튼 -->
            <Border Grid.Row="2"
                    Background="{DynamicResource PrimaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="40,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BackButton"
                            Grid.Column="1"
                            Content="◀ 이전"
                            Style="{StaticResource SecondaryButton}"
                            Click="Back_Click"
                            Visibility="Collapsed"/>

                    <Button x:Name="NextButton"
                            Grid.Column="3"
                            Content="다음 ▶"
                            Style="{StaticResource WizardButton}"
                            Click="Next_Click"/>

                    <Button x:Name="CloseButton"
                            Grid.Column="3"
                            Content="닫기"
                            Style="{StaticResource SecondaryButton}"
                            Click="Close_Click"
                            Visibility="Collapsed"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
