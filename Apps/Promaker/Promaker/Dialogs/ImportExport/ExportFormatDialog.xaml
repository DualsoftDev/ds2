<Window x:Class="Promaker.Dialogs.ExportFormatDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export IO List"
        Width="420"
        Height="280"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <TextBlock Grid.Row="0"
                       Text="내보내기 형식을 선택하세요"
                       FontSize="16"
                       FontWeight="SemiBold"/>

            <!-- 포맷 선택 -->
            <StackPanel Grid.Row="2" VerticalAlignment="Center">
                <RadioButton x:Name="CsvRadio"
                             GroupName="ExportFormat"
                             Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="CSV (2개 파일)" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="io.csv + dummy.csv (DS2 모델 추적 정보 포함)"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="11"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </RadioButton>

                <RadioButton x:Name="ExcelRadio"
                             GroupName="ExportFormat"
                             IsChecked="True">
                    <StackPanel>
                        <TextBlock Text="Excel (.xlsx)" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="IO/Dummy 시트 + 요약 정보 포함"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="11"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </RadioButton>
            </StackPanel>

            <!-- 템플릿 옵션 (Excel 선택 시만) -->
            <Border Grid.Row="4"
                    x:Name="TemplateOptionsPanel"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12"
                    Background="{DynamicResource PrimaryBackgroundBrush}"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4"
                              x:Name="UseTemplateCheckBox"
                              Content="Excel 템플릿 사용 (기존 파일 기반)"
                              FontSize="12"
                              Checked="UseTemplateCheckBox_Changed"
                              Unchecked="UseTemplateCheckBox_Changed"/>

                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="템플릿:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               FontSize="11"/>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             x:Name="TemplatePathBox"
                             IsEnabled="False"
                             FontFamily="Consolas"
                             FontSize="11"
                             Padding="6,4"/>
                    <Button Grid.Row="2" Grid.Column="3"
                            x:Name="BrowseTemplateButton"
                            Content="찾아보기..."
                            MinWidth="80"
                            IsEnabled="False"
                            Click="BrowseTemplate_Click"/>
                </Grid>
            </Border>

            <!-- 버튼 -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        MinWidth="82"
                        Style="{StaticResource DarkButton}"
                        Content="확인"
                        Click="Ok_Click"
                        IsDefault="True"/>

                <Button Grid.Column="3"
                        MinWidth="82"
                        Style="{StaticResource DarkButton}"
                        Content="취소"
                        IsCancel="True"/>
            </Grid>
        </Grid>
    </Border>
</Window>
