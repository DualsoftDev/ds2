<Window x:Class="Promaker.Windows.ManualControlDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Promaker.ViewModels.Manual"
        Title="수동 컨트롤러"
        Width="780"
        Height="640"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        Background="{DynamicResource CanvasBackgroundBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- IN LED 스타일: bool true=녹색, false=회색 -->
        <Style x:Key="InLedStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Fill" Value="{DynamicResource IconGrayBrush}"/>
            <Setter Property="Stroke" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding InValue}" Value="True">
                    <Setter Property="Fill" Value="{DynamicResource IconGreenBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 단일 토글 버튼: 현재 OutValue 표시 + 클릭 시 반대 상태로 전환.
             OutValue=true → 녹색 ON / OutValue=false → 회색 OFF. 라벨도 자동. -->
        <Style x:Key="ToggleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="{DynamicResource TertiaryBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding OutValue}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource IconGreenBrush}"/>
                    <Setter Property="Foreground" Value="#0f172a"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource IconGreenBrush}"/>
                </DataTrigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0"
                    Background="#7f1d1d"
                    Padding="24,14"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="10" Height="10" Fill="#fbbf24" Margin="0,0,10,0"/>
                        <TextBlock Text="🔴 수동 운전 중 — 실 PLC 라인이 사용자 명령에 따라 동작합니다"
                                   Foreground="White"
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕" Click="Close_Click"
                            HorizontalAlignment="Right"
                            Background="Transparent" Foreground="White"
                            BorderThickness="0"
                            Width="30" Height="30" FontSize="15"
                            Cursor="Hand" ToolTip="닫기 (수동 운전 종료)"/>
                </Grid>
            </Border>

            <!-- Status / Emergency -->
            <Border Grid.Row="1"
                    Background="{DynamicResource PrimaryBackgroundBrush}"
                    Padding="20,12"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⛔  비상 OFF (모든 OUT)"
                            Command="{Binding EmergencyOffAllCommand}"
                            Width="180" Height="34"
                            Background="{DynamicResource IconRedBrush}"
                            Foreground="#0f172a"
                            BorderThickness="0"
                            FontWeight="Bold" FontSize="13"
                            Cursor="Hand"
                            Margin="0,0,16,0"/>
                    <Ellipse Width="10" Height="10"
                             Margin="0,0,6,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource IconRedBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHubConnected}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource IconGreenBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Device groups list -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="16,8">
                <ItemsControl ItemsSource="{Binding DeviceGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:DeviceGroupVm}">
                            <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="0,4,0,8"
                                    Padding="14,10">
                                <StackPanel>
                                    <TextBlock Text="{Binding DeviceName}"
                                               Foreground="{DynamicResource AccentBrush}"
                                               FontSize="14" FontWeight="Bold"
                                               Margin="0,0,0,8"/>
                                    <ItemsControl ItemsSource="{Binding Calls}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:ApiCallControlVm}">
                                                <Grid Margin="0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="22"/>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="160"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- IN LED -->
                                                    <Ellipse Grid.Column="0"
                                                             Style="{StaticResource InLedStyle}"
                                                             VerticalAlignment="Center"
                                                             ToolTip="{Binding InAddress}"/>

                                                    <!-- 동작 이름 -->
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding ActionName}"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                                               FontSize="13"/>

                                                    <!-- 주소 정보 -->
                                                    <StackPanel Grid.Column="2"
                                                                Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                                                   FontSize="11" FontFamily="Consolas">
                                                            <Run Text="OUT="/><Run Text="{Binding OutAddress, Mode=OneWay}"/>
                                                            <Run Text="  IN="/><Run Text="{Binding InAddress, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </StackPanel>

                                                    <!-- 단일 토글 버튼 (ON/OFF 자동 라벨, 색상으로 현재 상태 표시) -->
                                                    <Button Grid.Column="3"
                                                            Style="{StaticResource ToggleButtonStyle}"
                                                            Command="{Binding ToggleCommand}"
                                                            ToolTip="현재 상태를 토글 (반대로 송출)">
                                                        <TextBlock>
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="OFF"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding OutValue}" Value="True">
                                                                            <Setter Property="Text" Value="ON"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Button>

                                                    <!-- 마지막 송신 결과 -->
                                                    <TextBlock Grid.Column="4"
                                                               Text="{Binding LastWriteStatus}"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"
                                                               Margin="10,0,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="3"
                    Background="{DynamicResource PrimaryBackgroundBrush}"
                    Padding="20,10"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="다이얼로그를 닫으면 모든 OUT off 후 Hub/PLC 게이트웨이가 종료됩니다."
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"/>
                    <Button Content="닫기" Click="Close_Click"
                            Width="100" Height="30"
                            Background="{DynamicResource TertiaryBackgroundBrush}"
                            Foreground="{DynamicResource PrimaryTextBrush}"
                            BorderThickness="0"
                            FontSize="13"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
