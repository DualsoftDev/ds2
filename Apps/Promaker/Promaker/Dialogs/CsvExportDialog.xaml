<Window x:Class="Promaker.Dialogs.CsvExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CSV 내보내기"
        Width="600"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <StackPanel Margin="16">

            <TextBlock Text="CSV 내보내기"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>
            <TextBlock Text="프로젝트를 CSV 파일로 내보냅니다."
                       FontSize="12"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,0,0,12"/>

            <Border Background="{DynamicResource TertiaryBackgroundBrush}"
                    CornerRadius="3"
                    Padding="10,8"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock x:Name="ProjectText"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="PreviewText"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <TextBlock Text="CSV 형식 정보"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <Border Background="{DynamicResource TertiaryBackgroundBrush}"
                    CornerRadius="3"
                    Padding="10,8"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock FontFamily="Consolas"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}">Flow,Work,Device,Api,InName,InAddress,OutName,OutAddress</TextBlock>
                    <TextBlock Text="• Active System의 모든 Flow, Work, Call이 포함됩니다&#10;• InName/OutName은 PLC 태그의 설명이 포함됩니다"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <TextBlock Text="저장 위치"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="PathBox"
                         Grid.Column="0"
                         Padding="8,6"/>
                <Button Grid.Column="2"
                        Content="찾아보기..."
                        Style="{StaticResource DarkButton}"
                        Padding="12,4"
                        Click="Browse_Click"/>
            </Grid>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,4,0,0">
                <Button Content="내보내기"
                        Style="{StaticResource DarkButton}"
                        Padding="12,4"
                        Margin="0,0,4,0"
                        IsDefault="True"
                        Click="Ok_Click"/>
                <Button Content="취소"
                        Style="{StaticResource DarkButton}"
                        Padding="12,4"
                        IsCancel="True"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
