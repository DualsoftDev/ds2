<Window x:Class="Promaker.Dialogs.CsvExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CSV 내보내기"
        Width="520"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <StackPanel Margin="16">

            <TextBlock x:Name="ProjectText"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Margin="0,0,0,12"/>

            <TextBlock Text="내보내기 경로"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="PathBox"
                         Grid.Column="0"
                         Padding="8,6"/>
                <Button Grid.Column="2"
                        Content="찾아보기..."
                        Style="{StaticResource DarkButton}"
                        Padding="12,4"
                        Click="Browse_Click"/>
            </Grid>

            <TextBlock Text="미리보기"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <Border Background="{DynamicResource TertiaryBackgroundBrush}"
                    CornerRadius="3"
                    Padding="10,8"
                    Margin="0,0,0,12">
                <TextBlock x:Name="PreviewText"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </Border>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,4,0,0">
                <Button Content="내보내기"
                        Style="{StaticResource DarkButton}"
                        Padding="12,4"
                        Margin="0,0,4,0"
                        IsDefault="True"
                        Click="Ok_Click"/>
                <Button Content="취소"
                        Style="{StaticResource DarkButton}"
                        Padding="12,4"
                        IsCancel="True"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
