<Window x:Class="Promaker.Dialogs.TagWizardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="TAG Wizard - 신호 자동 생성"
        Width="1400"
        Height="850"
        MinWidth="1200"
        MinHeight="750"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="WizardButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AlwaysLightTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StepIndicator" TargetType="Border">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <Style x:Key="ActiveStepIndicator" TargetType="Border" BasedOn="{StaticResource StepIndicator}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        </Style>

        <Style x:Key="CompletedStepIndicator" TargetType="Border" BasedOn="{StaticResource StepIndicator}">
            <Setter Property="Background" Value="{DynamicResource GreenAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GreenAccentBrush}"/>
        </Style>

        <Style x:Key="WizardGridStyle" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더: 단계 표시 (얇은 컬러 바) -->
            <Grid Grid.Row="0" Height="50">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Step 1 Bar -->
                <Border x:Name="Step1Bar" Grid.Column="0"
                        Background="{DynamicResource AccentBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <TextBlock x:Name="Step1Text" Text="1. 프로젝트 확인"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource AlwaysLightTextBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Step 2 Bar -->
                <Border x:Name="Step2Bar" Grid.Column="1"
                        Background="{DynamicResource SecondaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <TextBlock x:Name="Step2Text" Text="2. 템플릿 편집"
                               FontSize="12" FontWeight="Normal"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Step 3 Bar -->
                <Border x:Name="Step3Bar" Grid.Column="2"
                        Background="{DynamicResource SecondaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <TextBlock x:Name="Step3Text" Text="3. 신호 생성"
                               FontSize="12" FontWeight="Normal"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Step 4 Bar -->
                <Border x:Name="Step4Bar" Grid.Column="3"
                        Background="{DynamicResource SecondaryBackgroundBrush}">
                    <TextBlock x:Name="Step4Text" Text="4. 완료"
                               FontSize="12" FontWeight="Normal"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- 본문: 단계별 컨텐츠 -->
            <Grid Grid.Row="1">
                <!-- Step 1: 프로젝트 확인 -->
                <Grid x:Name="Step1Content" Visibility="Visible">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="40,30" MaxWidth="700">
                            <TextBlock Text="Step 1: 프로젝트 확인"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>

                            <!-- 프로젝트 정보 -->
                            <Border Background="{DynamicResource PrimaryBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="20"
                                    Margin="0,30,0,0">
                                <StackPanel>
                                    <TextBlock Text="📊 프로젝트 정보"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>

                                    <Grid Margin="0,15,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Flow 수:"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBlock x:Name="FlowCountText" Grid.Row="0" Grid.Column="1"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Work 수:"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBlock x:Name="WorkCountText" Grid.Row="2" Grid.Column="1"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Call 수:"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBlock x:Name="CallCountText" Grid.Row="4" Grid.Column="1"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>

                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Device 수:"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBlock x:Name="DeviceCountText" Grid.Row="6" Grid.Column="1"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 템플릿 정보 -->
                            <Border Background="{DynamicResource PrimaryBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="20"
                                    Margin="0,20,0,0">
                                <StackPanel>
                                    <TextBlock Text="📝 템플릿 설정"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>

                                    <TextBlock Text="신호 생성에 사용할 템플릿이 준비되어 있습니다."
                                               FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Margin="0,8,0,0"
                                               TextWrapping="Wrap"/>

                                    <Grid Margin="0,15,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="템플릿 위치:"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TemplatePathText" Grid.Column="1"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                    </Grid>

                                    <Button Content="📂 템플릿 폴더 열기"
                                            Style="{StaticResource SecondaryButton}"
                                            HorizontalAlignment="Left"
                                            Margin="0,15,0,0"
                                            Padding="15,8"
                                            Click="OpenTemplateFolder_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Step 2: 주소 설정 (3개 탭) -->
                <Grid x:Name="Step2Content" Visibility="Collapsed">
                    <Grid Margin="40,30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="15"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Step 2: 주소 설정"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>

                            <TextBlock Text="각 탭에서 시스템 주소, Flow 주소, 신호 템플릿을 설정하세요."
                                       FontSize="14"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- 3개 탭 -->
                        <TabControl Grid.Row="2"
                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                    BorderThickness="0">

                            <!-- Tab 1: 시스템 주소 -->
                            <TabItem Header="🔧 시스템 주소"
                                     Foreground="{DynamicResource PrimaryTextBrush}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- 헤더 -->
                                    <Border Grid.Row="0"
                                            Background="{DynamicResource PrimaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="20,12">
                                        <Grid>
                                            <TextBlock Text="시스템 타입별 주소 설정"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       VerticalAlignment="Center"/>
                                            <Button Content="💾 저장"
                                                    Style="{StaticResource WizardButton}"
                                                    Padding="12,6"
                                                    HorizontalAlignment="Right"
                                                    Click="SaveSystemBase_Click"/>
                                        </Grid>
                                    </Border>

                                    <!-- 안내 메시지 -->
                                    <Border Grid.Row="1"
                                            Background="{DynamicResource SecondaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="15,12">
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap">
                                            <Run Text="💡 "/>
                                            <Run Text="각 시스템 타입(RBT, PIN, CLAMP 등)의 글로벌 주소를 설정합니다. 입력/출력/메모리 워드의 시작 주소를 지정하세요."/>
                                        </TextBlock>
                                    </Border>

                                    <!-- 시스템 주소 그리드 -->
                                    <DataGrid x:Name="SystemBaseGrid"
                                              Grid.Row="2"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              CanUserSortColumns="True"
                                              CanUserReorderColumns="False"
                                              CanUserResizeColumns="True"
                                              SelectionMode="Single"
                                              GridLinesVisibility="All"
                                              BorderBrush="{DynamicResource BorderBrush}"
                                              BorderThickness="1"
                                              HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                              VerticalGridLinesBrush="{DynamicResource BorderBrush}"
                                              Foreground="{DynamicResource PrimaryTextBrush}"
                                              Background="{DynamicResource SecondaryBackgroundBrush}">
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn Header="사용"
                                                                    Binding="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}"
                                                                    Width="60">
                                                <DataGridCheckBoxColumn.ElementStyle>
                                                    <Style TargetType="CheckBox">
                                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                                    </Style>
                                                </DataGridCheckBoxColumn.ElementStyle>
                                            </DataGridCheckBoxColumn>
                                            <DataGridTextColumn Header="시스템 타입"
                                                                Binding="{Binding SystemType}"
                                                                Width="120"
                                                                IsReadOnly="True">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="Padding" Value="8,0"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="입력 워드 시작 (IW_BASE)"
                                                                Binding="{Binding IW_Base, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="*">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                        <Setter Property="Padding" Value="8,0"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="출력 워드 시작 (QW_BASE)"
                                                                Binding="{Binding QW_Base, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="*">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                        <Setter Property="Padding" Value="8,0"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="메모리 워드 시작 (MW_BASE)"
                                                                Binding="{Binding MW_Base, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="*">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                        <Setter Property="Padding" Value="8,0"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <!-- 상태바 -->
                                    <Border Grid.Row="3"
                                            Background="{DynamicResource SecondaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,1,0,0"
                                            Padding="15,10">
                                        <TextBlock x:Name="SystemBaseStatusText"
                                                   Text="시스템 타입별 글로벌 주소를 설정합니다."
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <!-- Tab 2: Flow 주소 -->
                            <TabItem Header="📊 Flow 주소"
                                     Foreground="{DynamicResource PrimaryTextBrush}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- 헤더 -->
                                    <Border Grid.Row="0"
                                            Background="{DynamicResource PrimaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="20,12">
                                        <Grid>
                                            <TextBlock Text="Flow별 주소 설정"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       VerticalAlignment="Center"/>
                                            <Button Content="💾 저장"
                                                    Style="{StaticResource WizardButton}"
                                                    Padding="12,6"
                                                    HorizontalAlignment="Right"
                                                    Click="SaveFlowBase_Click"/>
                                        </Grid>
                                    </Border>

                                    <!-- 안내 메시지 -->
                                    <Border Grid.Row="1"
                                            Background="{DynamicResource SecondaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="15,12">
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap">
                                            <Run Text="💡 "/>
                                            <Run Text="프로젝트의 각 Flow에 대해 별도 주소 영역을 할당할 수 있습니다. Flow 목록은 현재 열려있는 모델에서 자동으로 가져옵니다."/>
                                        </TextBlock>
                                    </Border>

                                    <!-- Flow 주소 그리드 -->
                                    <DataGrid x:Name="FlowBaseGrid"
                                              Grid.Row="2"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              CanUserSortColumns="True"
                                              CanUserReorderColumns="False"
                                              CanUserResizeColumns="True"
                                              SelectionMode="Single"
                                              GridLinesVisibility="All"
                                              BorderBrush="{DynamicResource BorderBrush}"
                                              BorderThickness="1"
                                              HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                              VerticalGridLinesBrush="{DynamicResource BorderBrush}"
                                              Foreground="{DynamicResource PrimaryTextBrush}"
                                              Background="{DynamicResource SecondaryBackgroundBrush}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Flow 이름"
                                                                Binding="{Binding FlowName}"
                                                                Width="150"
                                                                IsReadOnly="True">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="Padding" Value="8,0"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="입력 워드 시작 (IW_BASE)"
                                                                Binding="{Binding IW_Base, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="*">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                        <Setter Property="Padding" Value="8,0"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="출력 워드 시작 (QW_BASE)"
                                                                Binding="{Binding QW_Base, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="*">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                        <Setter Property="Padding" Value="8,0"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="메모리 워드 시작 (MW_BASE)"
                                                                Binding="{Binding MW_Base, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="*">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                        <Setter Property="Padding" Value="8,0"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <!-- 상태바 -->
                                    <Border Grid.Row="3"
                                            Background="{DynamicResource SecondaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,1,0,0"
                                            Padding="15,10">
                                        <TextBlock x:Name="FlowBaseStatusText"
                                                   Text="Flow별 로컬 주소를 설정합니다. (선택사항)"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <!-- Tab 3: 신호 템플릿 -->
                            <TabItem Header="📋 신호 템플릿"
                                     Foreground="{DynamicResource PrimaryTextBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 좌측: SystemType 리스트 -->
                                    <Border Grid.Column="0"
                                            Background="{DynamicResource PrimaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- SystemType 리스트 헤더 -->
                                            <Border Grid.Row="0"
                                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="15,12">
                                                <TextBlock Text="📂 시스템 타입"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            </Border>

                                            <!-- SystemType 리스트 -->
                                            <ListBox x:Name="DeviceTemplateListBox"
                                                     Grid.Row="1"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Padding="5"
                                                     SelectionChanged="DeviceTemplateListBox_SelectionChanged">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   FontSize="12"
                                                                   Padding="8,6"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>

                                    <!-- 우측: 템플릿 편집 영역 (TabControl 방식) -->
                                    <Border Grid.Column="2"
                                            Background="{DynamicResource PrimaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- 헤더: SystemType 이름 + 저장 버튼 -->
                                            <Border Grid.Row="0"
                                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="20,12">
                                                <Grid>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📝 "
                                                                   FontSize="14"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="CurrentDeviceTemplateText"
                                                                   Text="템플릿을 선택하세요"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <Button Content="💾 저장"
                                                            Style="{StaticResource WizardButton}"
                                                            Padding="12,6"
                                                            HorizontalAlignment="Right"
                                                            Click="SaveDeviceTemplate_Click"/>
                                                </Grid>
                                            </Border>

                                            <!-- 안내 메시지 -->
                                            <Border Grid.Row="1"
                                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="15,12">
                                                <TextBlock FontSize="12"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           TextWrapping="Wrap">
                                                    <Run Text="💡 "/>
                                                    <Run Text="각 API별 신호 패턴을 설정합니다. 변수 치환: $(F)=Flow명, $(D)=Device명, $(A)=Api명"/>
                                                </TextBlock>
                                            </Border>

                                            <!-- 메인 편집 영역: IW/QW/MW 탭 -->
                                            <TabControl x:Name="SignalSectionTabControl"
                                                        Grid.Row="2"
                                                        Background="{DynamicResource SecondaryBackgroundBrush}"
                                                        BorderThickness="0">

                                                <!-- IW 탭 -->
                                                <TabItem Header="입력 워드 (IW)"
                                                         Foreground="{DynamicResource PrimaryTextBrush}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>

                                                        <!-- 툴바 -->
                                                        <Border Grid.Row="0"
                                                                Background="{DynamicResource SecondaryBackgroundBrush}"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="0,0,0,1"
                                                                Padding="10,8">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Button Content="➕ 행 추가"
                                                                        Padding="10,5"
                                                                        Margin="0,0,5,0"
                                                                        Click="AddIwRow_Click"/>
                                                                <Button Content="➖ 선택 행 삭제"
                                                                        Padding="10,5"
                                                                        Click="RemoveIwRow_Click"/>
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- IW 그리드 -->
                                                        <DataGrid x:Name="IwSignalGrid"
                                                                  Grid.Row="1"
                                                                  AutoGenerateColumns="False"
                                                                  CanUserAddRows="False"
                                                                  CanUserDeleteRows="False"
                                                                  CanUserSortColumns="False"
                                                                  SelectionMode="Extended"
                                                                  GridLinesVisibility="All"
                                                                  BorderBrush="{DynamicResource BorderBrush}"
                                                                  BorderThickness="0"
                                                                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                                                  VerticalGridLinesBrush="{DynamicResource BorderBrush}"
                                                                  Foreground="{DynamicResource PrimaryTextBrush}"
                                                                  Background="{DynamicResource SecondaryBackgroundBrush}">
                                                            <DataGrid.Columns>
                                                                <DataGridTextColumn Header="API 이름"
                                                                                    Binding="{Binding ApiName, UpdateSourceTrigger=PropertyChanged}"
                                                                                    Width="150">
                                                                    <DataGridTextColumn.ElementStyle>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                                            <Setter Property="Padding" Value="8,0"/>
                                                                        </Style>
                                                                    </DataGridTextColumn.ElementStyle>
                                                                </DataGridTextColumn>
                                                                <DataGridTextColumn Header="신호 패턴"
                                                                                    Binding="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                                                                    Width="*">
                                                                    <DataGridTextColumn.ElementStyle>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                                            <Setter Property="FontFamily" Value="Consolas"/>
                                                                            <Setter Property="Padding" Value="8,0"/>
                                                                        </Style>
                                                                    </DataGridTextColumn.ElementStyle>
                                                                </DataGridTextColumn>
                                                            </DataGrid.Columns>
                                                        </DataGrid>
                                                    </Grid>
                                                </TabItem>

                                                <!-- QW 탭 -->
                                                <TabItem Header="출력 워드 (QW)"
                                                         Foreground="{DynamicResource PrimaryTextBrush}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>

                                                        <!-- 툴바 -->
                                                        <Border Grid.Row="0"
                                                                Background="{DynamicResource SecondaryBackgroundBrush}"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="0,0,0,1"
                                                                Padding="10,8">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Button Content="➕ 행 추가"
                                                                        Padding="10,5"
                                                                        Margin="0,0,5,0"
                                                                        Click="AddQwRow_Click"/>
                                                                <Button Content="➖ 선택 행 삭제"
                                                                        Padding="10,5"
                                                                        Click="RemoveQwRow_Click"/>
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- QW 그리드 -->
                                                        <DataGrid x:Name="QwSignalGrid"
                                                                  Grid.Row="1"
                                                                  AutoGenerateColumns="False"
                                                                  CanUserAddRows="False"
                                                                  CanUserDeleteRows="False"
                                                                  CanUserSortColumns="False"
                                                                  SelectionMode="Extended"
                                                                  GridLinesVisibility="All"
                                                                  BorderBrush="{DynamicResource BorderBrush}"
                                                                  BorderThickness="0"
                                                                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                                                  VerticalGridLinesBrush="{DynamicResource BorderBrush}"
                                                                  Foreground="{DynamicResource PrimaryTextBrush}"
                                                                  Background="{DynamicResource SecondaryBackgroundBrush}">
                                                            <DataGrid.Columns>
                                                                <DataGridTextColumn Header="API 이름"
                                                                                    Binding="{Binding ApiName, UpdateSourceTrigger=PropertyChanged}"
                                                                                    Width="150">
                                                                    <DataGridTextColumn.ElementStyle>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                                            <Setter Property="Padding" Value="8,0"/>
                                                                        </Style>
                                                                    </DataGridTextColumn.ElementStyle>
                                                                </DataGridTextColumn>
                                                                <DataGridTextColumn Header="신호 패턴"
                                                                                    Binding="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                                                                    Width="*">
                                                                    <DataGridTextColumn.ElementStyle>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                                            <Setter Property="FontFamily" Value="Consolas"/>
                                                                            <Setter Property="Padding" Value="8,0"/>
                                                                        </Style>
                                                                    </DataGridTextColumn.ElementStyle>
                                                                </DataGridTextColumn>
                                                            </DataGrid.Columns>
                                                        </DataGrid>
                                                    </Grid>
                                                </TabItem>

                                                <!-- MW 탭 -->
                                                <TabItem Header="메모리 워드 (MW)"
                                                         Foreground="{DynamicResource PrimaryTextBrush}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>

                                                        <!-- 툴바 -->
                                                        <Border Grid.Row="0"
                                                                Background="{DynamicResource SecondaryBackgroundBrush}"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="0,0,0,1"
                                                                Padding="10,8">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Button Content="➕ 행 추가"
                                                                        Padding="10,5"
                                                                        Margin="0,0,5,0"
                                                                        Click="AddMwRow_Click"/>
                                                                <Button Content="➖ 선택 행 삭제"
                                                                        Padding="10,5"
                                                                        Click="RemoveMwRow_Click"/>
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- MW 그리드 -->
                                                        <DataGrid x:Name="MwSignalGrid"
                                                                  Grid.Row="1"
                                                                  AutoGenerateColumns="False"
                                                                  CanUserAddRows="False"
                                                                  CanUserDeleteRows="False"
                                                                  CanUserSortColumns="False"
                                                                  SelectionMode="Extended"
                                                                  GridLinesVisibility="All"
                                                                  BorderBrush="{DynamicResource BorderBrush}"
                                                                  BorderThickness="0"
                                                                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                                                  VerticalGridLinesBrush="{DynamicResource BorderBrush}"
                                                                  Foreground="{DynamicResource PrimaryTextBrush}"
                                                                  Background="{DynamicResource SecondaryBackgroundBrush}">
                                                            <DataGrid.Columns>
                                                                <DataGridTextColumn Header="API 이름"
                                                                                    Binding="{Binding ApiName, UpdateSourceTrigger=PropertyChanged}"
                                                                                    Width="150">
                                                                    <DataGridTextColumn.ElementStyle>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                                            <Setter Property="Padding" Value="8,0"/>
                                                                        </Style>
                                                                    </DataGridTextColumn.ElementStyle>
                                                                </DataGridTextColumn>
                                                                <DataGridTextColumn Header="신호 패턴"
                                                                                    Binding="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                                                                    Width="*">
                                                                    <DataGridTextColumn.ElementStyle>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                                            <Setter Property="FontFamily" Value="Consolas"/>
                                                                            <Setter Property="Padding" Value="8,0"/>
                                                                        </Style>
                                                                    </DataGridTextColumn.ElementStyle>
                                                                </DataGridTextColumn>
                                                            </DataGrid.Columns>
                                                        </DataGrid>
                                                    </Grid>
                                                </TabItem>

                                            </TabControl>

                                            <!-- 하단 상태바 -->
                                            <Border Grid.Row="3"
                                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,1,0,0"
                                                    Padding="15,10">
                                                <TextBlock x:Name="DeviceTemplateStatusText"
                                                           Text="템플릿을 선택하면 편집할 수 있습니다."
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Grid>

                <!-- Step 3: 신호 생성 -->
                <Grid x:Name="Step3Content" Visibility="Collapsed">
                    <Grid Margin="40,30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Step 3: 신호 생성 및 미리보기"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>

                            <TextBlock x:Name="GenerationStatusText"
                                       Text="생성된 신호를 확인하세요. 문제가 없으면 '다음'을 클릭하여 적용하세요."
                                       FontSize="14"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>

                            <!-- 필터 영역 -->
                            <Border Background="{DynamicResource PrimaryBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="15"
                                    Margin="0,15,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔍 필터:" VerticalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               FontWeight="SemiBold" Margin="0,0,10,0"/>

                                    <TextBlock Text="Flow:" VerticalAlignment="Center"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Margin="0,0,5,0"/>
                                    <TextBox x:Name="PreviewFlowFilterBox" Width="100"
                                             Margin="0,0,15,0"/>

                                    <TextBlock Text="Device:" VerticalAlignment="Center"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Margin="0,0,5,0"/>
                                    <TextBox x:Name="PreviewDeviceFilterBox" Width="120"
                                             Margin="0,0,15,0"/>

                                    <TextBlock Text="Api:" VerticalAlignment="Center"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Margin="0,0,5,0"/>
                                    <TextBox x:Name="PreviewApiFilterBox" Width="120"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <TabControl Grid.Row="2"
                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                    BorderThickness="0">
                            <!-- IO 신호 탭 -->
                            <TabItem Header="IO 신호"
                                     Foreground="{DynamicResource PrimaryTextBrush}">
                                <DataGrid x:Name="IoSignalPreviewGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserSortColumns="True"
                                          CanUserReorderColumns="True"
                                          CanUserResizeColumns="True"
                                          SelectionMode="Extended"
                                          Style="{StaticResource WizardGridStyle}"
                                          Foreground="{DynamicResource PrimaryTextBrush}"
                                          Background="{DynamicResource SecondaryBackgroundBrush}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Flow" Binding="{Binding Flow}" Width="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Device" Binding="{Binding Device}" Width="100">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Api" Binding="{Binding Api}" Width="120">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Out Tag" Binding="{Binding OutSymbol}" Width="1.5*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Out Address" Binding="{Binding OutAddress}" Width="110">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="In Tag" Binding="{Binding InSymbol}" Width="1.5*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="In Address" Binding="{Binding InAddress}" Width="110">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>

                            <!-- Dummy 신호 탭 -->
                            <TabItem Header="Dummy 신호"
                                     Foreground="{DynamicResource PrimaryTextBrush}">
                                <DataGrid x:Name="DummySignalPreviewGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserSortColumns="True"
                                          CanUserReorderColumns="True"
                                          CanUserResizeColumns="True"
                                          SelectionMode="Extended"
                                          Style="{StaticResource WizardGridStyle}"
                                          Foreground="{DynamicResource PrimaryTextBrush}"
                                          Background="{DynamicResource SecondaryBackgroundBrush}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Flow" Binding="{Binding Flow}" Width="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Work" Binding="{Binding Work}" Width="100">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Call" Binding="{Binding Call}" Width="120">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="2*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="110">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>

                            <!-- 매칭 실패 탭 -->
                            <TabItem x:Name="UnmatchedTabItem"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     Visibility="Collapsed">
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚠ 매칭 실패 (" Foreground="{DynamicResource OrangeAccentBrush}"/>
                                        <TextBlock x:Name="UnmatchedCountText" Text="0" Foreground="{DynamicResource OrangeAccentBrush}" FontWeight="Bold"/>
                                        <TextBlock Text=")" Foreground="{DynamicResource OrangeAccentBrush}"/>
                                    </StackPanel>
                                </TabItem.Header>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- 안내 메시지 -->
                                    <Border Grid.Row="0"
                                            Background="{DynamicResource SecondaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource OrangeAccentBrush}"
                                            BorderThickness="0,0,0,2"
                                            Padding="15,12">
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap">
                                            <Run Text="⚠ "/>
                                            <Run Text="아래 항목들은 DS2 모델과 매칭되지 않았습니다. Flow, Device, Api 이름이 정확히 일치하는지 확인하세요."/>
                                        </TextBlock>
                                    </Border>

                                    <!-- 매칭 실패 항목 그리드 -->
                                    <DataGrid x:Name="UnmatchedSignalGrid"
                                              Grid.Row="1"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              CanUserSortColumns="True"
                                              CanUserReorderColumns="True"
                                              CanUserResizeColumns="True"
                                              SelectionMode="Extended"
                                              Style="{StaticResource WizardGridStyle}"
                                              Foreground="{DynamicResource PrimaryTextBrush}"
                                              Background="{DynamicResource SecondaryBackgroundBrush}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Flow" Binding="{Binding Flow}" Width="100">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource OrangeAccentBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Device" Binding="{Binding Device}" Width="120">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource OrangeAccentBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Api" Binding="{Binding Api}" Width="140">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource OrangeAccentBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Out Tag" Binding="{Binding OutSymbol}" Width="1.5*">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Out Address" Binding="{Binding OutAddress}" Width="110">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="In Tag" Binding="{Binding InSymbol}" Width="1.5*">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="In Address" Binding="{Binding InAddress}" Width="110">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="매칭 실패 이유" Binding="{Binding FailureReason}" Width="1.5*">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource OrangeAccentBrush}"/>
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </TabItem>

                            <!-- 오류 탭 -->
                            <TabItem x:Name="ErrorsTabItem"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     Visibility="Collapsed">
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✖ 오류 (" Foreground="{DynamicResource RedAccentBrush}"/>
                                        <TextBlock x:Name="ErrorCountText" Text="0" Foreground="{DynamicResource RedAccentBrush}" FontWeight="Bold"/>
                                        <TextBlock Text=")" Foreground="{DynamicResource RedAccentBrush}"/>
                                    </StackPanel>
                                </TabItem.Header>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- 안내 메시지 -->
                                    <Border Grid.Row="0"
                                            Background="{DynamicResource SecondaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource RedAccentBrush}"
                                            BorderThickness="0,0,0,2"
                                            Padding="15,12">
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap">
                                            <Run Text="✖ "/>
                                            <Run Text="신호 생성 중 오류가 발생했습니다. 템플릿 설정을 확인하세요."/>
                                        </TextBlock>
                                    </Border>

                                    <!-- 오류 항목 리스트 -->
                                    <ListBox x:Name="ErrorsListBox"
                                             Grid.Row="1"
                                             Background="{DynamicResource PrimaryBackgroundBrush}"
                                             BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                                        BorderBrush="{DynamicResource RedAccentBrush}"
                                                        BorderThickness="1,0,0,0"
                                                        Padding="15,12"
                                                        Margin="5">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                                   Text="✖"
                                                                   FontSize="16"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource RedAccentBrush}"
                                                                   VerticalAlignment="Top"
                                                                   Margin="0,0,15,0"/>

                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding ErrorType}"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource RedAccentBrush}"
                                                                       Margin="0,0,0,5"/>
                                                            <TextBlock Text="{Binding Message}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Grid>

                <!-- Step 4: 완료 -->
                <Grid x:Name="Step4Content" Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="40,30" MaxWidth="700">
                            <StackPanel HorizontalAlignment="Center">
                                <iconPacks:PackIconMaterial Kind="CheckCircle"
                                                            Width="80" Height="80"
                                                            Foreground="{DynamicResource GreenAccentBrush}"/>
                                <TextBlock Text="신호 적용 완료!"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,20,0,0"/>
                            </StackPanel>

                            <Border Background="{DynamicResource PrimaryBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="30"
                                    Margin="0,40,0,0">
                                <StackPanel>
                                    <TextBlock Text="✅ 적용 결과"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>

                                    <TextBlock x:Name="CompletionSummaryText"
                                               FontSize="14"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Margin="0,15,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource PrimaryBackgroundBrush}"
                                    BorderBrush="{DynamicResource AccentBrush}"
                                    BorderThickness="2"
                                    CornerRadius="8"
                                    Padding="25"
                                    Margin="0,20,0,0">
                                <StackPanel>
                                    <TextBlock Text="💡 다음 단계"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>

                                    <TextBlock Margin="0,10,0,0" TextWrapping="Wrap"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               LineHeight="22">
                                        <Run Text="1. Properties 패널에서 각 Call의 IO 태그를 확인하세요."/><LineBreak/>
                                        <Run Text="2. Canvas에서 Call을 선택하면 OutTag와 InTag를 볼 수 있습니다."/><LineBreak/>
                                        <Run Text="3. 필요시 직접 수정하거나 Utility > IO 일괄 편집에서 수정할 수 있습니다."/><LineBreak/>
                                        <Run Text="4. File > Export AASX로 PLC 프로그램을 생성하세요."/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- 하단: 버튼 -->
            <Border Grid.Row="2"
                    Background="{DynamicResource PrimaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="40,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BackButton"
                            Grid.Column="1"
                            Content="◀ 이전"
                            Style="{StaticResource SecondaryButton}"
                            Click="Back_Click"
                            Visibility="Collapsed"/>

                    <Button x:Name="NextButton"
                            Grid.Column="3"
                            Content="다음 ▶"
                            Style="{StaticResource WizardButton}"
                            Click="Next_Click"/>

                    <Button x:Name="CloseButton"
                            Grid.Column="3"
                            Content="닫기"
                            Style="{StaticResource SecondaryButton}"
                            Click="Close_Click"
                            Visibility="Collapsed"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
