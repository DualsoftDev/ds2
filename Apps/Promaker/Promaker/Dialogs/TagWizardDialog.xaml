<Window x:Class="Promaker.Dialogs.TagWizardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="TAG Wizard - 신호 자동 생성"
        Width="1680"
        Height="1000"
        MinWidth="1400"
        MinHeight="860"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Step 3 IoSignalPreviewGrid 컬럼 헤더 내장 필터 템플릿 ───────────── -->
        <DataTemplate x:Key="PvHeaderFlow">
            <Grid HorizontalAlignment="Stretch"
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGridColumnHeader}}">
                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Flow" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBox   Grid.Row="1" Padding="4,2" HorizontalAlignment="Stretch"
                           Text="{Binding DataContext.PvFlowFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="PvHeaderDevice">
            <Grid HorizontalAlignment="Stretch"
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGridColumnHeader}}">
                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Device" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBox   Grid.Row="1" Padding="4,2" HorizontalAlignment="Stretch"
                           Text="{Binding DataContext.PvDeviceFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="PvHeaderApi">
            <Grid HorizontalAlignment="Stretch"
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGridColumnHeader}}">
                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Api" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBox   Grid.Row="1" Padding="4,2" HorizontalAlignment="Stretch"
                           Text="{Binding DataContext.PvApiFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="PvHeaderOutTag">
            <Grid HorizontalAlignment="Stretch"
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGridColumnHeader}}">
                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Out Tag" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBox   Grid.Row="1" Padding="4,2" HorizontalAlignment="Stretch"
                           Text="{Binding DataContext.PvOutSymbolFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="PvHeaderOutAddress">
            <Grid HorizontalAlignment="Stretch"
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGridColumnHeader}}">
                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Out Address" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBox   Grid.Row="1" Padding="4,2" HorizontalAlignment="Stretch"
                           Text="{Binding DataContext.PvOutAddressFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="PvHeaderInTag">
            <Grid HorizontalAlignment="Stretch"
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGridColumnHeader}}">
                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="In Tag" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBox   Grid.Row="1" Padding="4,2" HorizontalAlignment="Stretch"
                           Text="{Binding DataContext.PvInSymbolFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="PvHeaderInAddress">
            <Grid HorizontalAlignment="Stretch"
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGridColumnHeader}}">
                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="In Address" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBox   Grid.Row="1" Padding="4,2" HorizontalAlignment="Stretch"
                           Text="{Binding DataContext.PvInAddressFilter, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </DataTemplate>

        <Style x:Key="WizardButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AlwaysLightTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StepIndicator" TargetType="Border">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <Style x:Key="ActiveStepIndicator" TargetType="Border" BasedOn="{StaticResource StepIndicator}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        </Style>

        <Style x:Key="CompletedStepIndicator" TargetType="Border" BasedOn="{StaticResource StepIndicator}">
            <Setter Property="Background" Value="{DynamicResource GreenAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GreenAccentBrush}"/>
        </Style>

        <Style x:Key="WizardGridStyle" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더: 단계 표시 (얇은 컬러 바) -->
            <Grid Grid.Row="0" Height="50">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Step 1 Bar -->
                <Border x:Name="Step1Bar" Grid.Column="0"
                        Background="{DynamicResource AccentBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <TextBlock x:Name="Step1Text" Text="1. 프로젝트 + 주소"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource AlwaysLightTextBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Step 2 Bar -->
                <Border x:Name="Step2Bar" Grid.Column="1"
                        Background="{DynamicResource SecondaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <TextBlock x:Name="Step2Text" Text="2. 신호 템플릿"
                               FontSize="12" FontWeight="Normal"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Step 3 Bar -->
                <Border x:Name="Step3Bar" Grid.Column="2"
                        Background="{DynamicResource SecondaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,1,0">
                    <TextBlock x:Name="Step3Text" Text="3. 신호 생성"
                               FontSize="12" FontWeight="Normal"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Step 4 Bar -->
                <Border x:Name="Step4Bar" Grid.Column="3"
                        Background="{DynamicResource SecondaryBackgroundBrush}">
                    <TextBlock x:Name="Step4Text" Text="4. 요약"
                               FontSize="12" FontWeight="Normal"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- 본문: 단계별 컨텐츠 -->
            <Grid Grid.Row="1">
                <!-- Step 1: 프로젝트 확인 -->
                <!-- Step 1: 프로젝트 확인 + 선두 주소 설정 -->
                <Grid x:Name="Step1Content" Visibility="Visible">
                    <Grid Margin="30,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="15"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Step 1: 프로젝트 확인 + 선두 주소 설정"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>

                        <!-- 프로젝트 요약 (압축 뷰) -->
                        <Border Grid.Row="1"
                                Background="{DynamicResource PrimaryBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16,10"
                                Margin="0,12,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊 프로젝트: "
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Flow " Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" Margin="6,0,2,0"/>
                                <TextBlock x:Name="FlowCountText" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text=" · Work " Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="WorkCountText" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text=" · Call " Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="CallCountText" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text=" · Device " Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="DeviceCountText" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- 선두 주소 설정 (기존 Step 2 Tab 2 내용을 이관) -->
                                <Grid Grid.Row="3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>      <!-- Flow 헤더 -->
                                        <RowDefinition Height="Auto"/>      <!-- Flow 안내 -->
                                        <RowDefinition Height="5*" MinHeight="180"/>   <!-- Flow 그리드 -->
                                        <RowDefinition Height="Auto"/>      <!-- System 헤더 -->
                                        <RowDefinition Height="5*" MinHeight="260"/>   <!-- System 영역 (확대) -->
                                        <RowDefinition Height="Auto"/>      <!-- 상태바 -->
                                    </Grid.RowDefinitions>

                                    <!-- 헤더: Flow 주소 (기본) -->
                                    <Border Grid.Row="0"
                                            Background="{DynamicResource PrimaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="20,12">
                                        <Grid>
                                            <TextBlock Text="📊 Flow 주소 (기본)"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       VerticalAlignment="Center"/>
                                            <Button Content="💾 Flow 주소 저장"
                                                    Style="{StaticResource WizardButton}"
                                                    Padding="12,6" HorizontalAlignment="Right"
                                                    Click="SaveFlowBase_Click"/>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1"
                                            Background="{DynamicResource SecondaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="15,10">
                                        <TextBlock FontSize="11"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="💡 Flow 별 IW/QW/MW 시작 주소를 설정합니다. 특정 시스템 타입 오버라이드가 필요하면 아래 '🔧 시스템 주소 추가' 를 펼치세요."/>
                                    </Border>

                                    <DataGrid x:Name="FlowBaseGrid"
                                              Grid.Row="2"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              CanUserSortColumns="True"
                                              SelectionMode="Single"
                                              GridLinesVisibility="All"
                                              BorderBrush="{DynamicResource BorderBrush}"
                                              BorderThickness="1"
                                              Foreground="{DynamicResource PrimaryTextBrush}"
                                              Background="{DynamicResource SecondaryBackgroundBrush}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Flow 이름" Width="150" IsReadOnly="True"
                                                                Binding="{Binding FlowName}"/>
                                            <DataGridTextColumn Header="IW_BASE" Width="*"
                                                                Binding="{Binding IW_Base, UpdateSourceTrigger=PropertyChanged}"/>
                                            <DataGridTextColumn Header="QW_BASE" Width="*"
                                                                Binding="{Binding QW_Base, UpdateSourceTrigger=PropertyChanged}"/>
                                            <DataGridTextColumn Header="MW_BASE" Width="*"
                                                                Binding="{Binding MW_Base, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <!-- System 주소: 항상 표시, 콤보 추가/삭제 방식 -->
                                    <Border Grid.Row="3"
                                            Background="{DynamicResource SecondaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,1,0,1"
                                            Padding="20,10" Margin="0,8,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="🔧 시스템 타입별 주소 오버라이드"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Content="💾 시스템 주소 저장"
                                                    Style="{StaticResource WizardButton}"
                                                    Padding="12,6"
                                                    Click="SaveSystemBase_Click"/>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- 추가 입력 툴바: 타입 ▼ + IW + QW + MW + [추가] [선택 삭제] -->
                                        <Border Grid.Row="0"
                                                Background="{DynamicResource PrimaryBackgroundBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="15,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="2*" MinWidth="180"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*" MinWidth="90"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*" MinWidth="90"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*" MinWidth="90"/>
                                                    <ColumnDefinition Width="14"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="6"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" Text="타입:"
                                                           VerticalAlignment="Center" Margin="0,0,6,0"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                <ComboBox Grid.Column="1" x:Name="NewSystemTypeCombo"
                                                          ItemsSource="{Binding AvailableSystemTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          IsEditable="True"
                                                          VerticalAlignment="Center"/>

                                                <TextBlock Grid.Column="3" Text="IW_BASE:"
                                                           VerticalAlignment="Center" Margin="0,0,4,0"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                <TextBox   Grid.Column="4" x:Name="NewSystemIwBox"
                                                           VerticalAlignment="Center"/>

                                                <TextBlock Grid.Column="6" Text="QW_BASE:"
                                                           VerticalAlignment="Center" Margin="0,0,4,0"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                <TextBox   Grid.Column="7" x:Name="NewSystemQwBox"
                                                           VerticalAlignment="Center"/>

                                                <TextBlock Grid.Column="9" Text="MW_BASE:"
                                                           VerticalAlignment="Center" Margin="0,0,4,0"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                <TextBox   Grid.Column="10" x:Name="NewSystemMwBox"
                                                           VerticalAlignment="Center"/>

                                                <Button Grid.Column="12" Content="➕ 추가"
                                                        Style="{StaticResource DarkButton}"
                                                        Padding="14,6"
                                                        Click="AddSystemBaseRow_Click"/>
                                                <Button Grid.Column="14" Content="🗑 선택 삭제"
                                                        Style="{StaticResource DarkButton}"
                                                        Padding="14,6"
                                                        Click="RemoveSystemBaseRow_Click"/>
                                            </Grid>
                                        </Border>

                                        <DataGrid x:Name="SystemBaseGrid"
                                                  Grid.Row="1"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  SelectionMode="Single"
                                                  SelectionUnit="FullRow"
                                                  GridLinesVisibility="All"
                                                  BorderBrush="{DynamicResource BorderBrush}"
                                                  BorderThickness="1"
                                                  MinHeight="140"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  ScrollViewer.CanContentScroll="True"
                                                  Foreground="{DynamicResource PrimaryTextBrush}"
                                                  Background="{DynamicResource SecondaryBackgroundBrush}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="시스템 타입" Width="160" IsReadOnly="True"
                                                                    Binding="{Binding SystemType}"/>
                                                <DataGridTextColumn Header="IW_BASE" Width="*"
                                                                    Binding="{Binding IW_Base, UpdateSourceTrigger=PropertyChanged}"/>
                                                <DataGridTextColumn Header="QW_BASE" Width="*"
                                                                    Binding="{Binding QW_Base, UpdateSourceTrigger=PropertyChanged}"/>
                                                <DataGridTextColumn Header="MW_BASE" Width="*"
                                                                    Binding="{Binding MW_Base, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>

                                    <!-- 상태바 -->
                                    <Border Grid.Row="5"
                                            Background="{DynamicResource SecondaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,1,0,0"
                                            Padding="15,10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="FlowBaseStatusText"
                                                       Text="Flow별 선두 주소를 설정합니다."
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Margin="0,0,16,0"/>
                                            <TextBlock x:Name="SystemBaseStatusText"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                    </Grid>
                </Grid>

                <!-- Step 2: 신호 템플릿 -->
                <Grid x:Name="Step2Content" Visibility="Collapsed">
                    <Grid Margin="30,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Step 2: 신호 템플릿"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 좌측: SystemType 리스트 -->
                                    <Border Grid.Column="0"
                                            Background="{DynamicResource PrimaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- SystemType 리스트 헤더 -->
                                            <Border Grid.Row="0"
                                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="15,12">
                                                <TextBlock Text="📂 시스템 타입"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            </Border>

                                            <!-- SystemType 리스트 -->
                                            <ListBox x:Name="DeviceTemplateListBox"
                                                     Grid.Row="1"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Padding="5"
                                                     SelectionChanged="DeviceTemplateListBox_SelectionChanged">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   FontSize="12"
                                                                   Padding="8,6"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>

                                    <!-- 우측: 템플릿 편집 영역 (TabControl 방식) -->
                                    <Border Grid.Column="2"
                                            Background="{DynamicResource PrimaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- 헤더: SystemType 이름 + 저장 버튼 -->
                                            <Border Grid.Row="0"
                                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="20,12">
                                                <Grid>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📝 "
                                                                   FontSize="14"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="CurrentDeviceTemplateText"
                                                                   Text="템플릿을 선택하세요"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <Button Content="💾 저장"
                                                            Style="{StaticResource WizardButton}"
                                                            Padding="12,6"
                                                            HorizontalAlignment="Right"
                                                            Click="SaveDeviceTemplate_Click"/>
                                                </Grid>
                                            </Border>

                                            <!-- 안내 메시지 + 글로벌 FB 타입 선택 -->
                                            <Border Grid.Row="1"
                                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="15,12">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="8"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                               TextWrapping="Wrap">
                                                        <Run Text="💡 "/>
                                                        <Run Text="각 API별 신호 패턴을 설정합니다. 변수 치환: $(F)=Flow명, $(D)=Device명, $(A)=Api명"/>
                                                    </TextBlock>
                                                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                                                        <TextBlock Text="🎯 FB 타입 (SystemType 당 1개):"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                        <ComboBox x:Name="GlobalFBTypeCombo"
                                                                  Width="280"
                                                                  Margin="10,0,0,0"
                                                                  IsEditable="False"
                                                                  SelectionChanged="GlobalFBType_Changed"
                                                                  ToolTip="이 SystemType 이 사용하는 FB (XGI_Template.xml 에 정의된 UserFB). AUX 탭에서 이 FB 의 포트 목록이 표시됩니다."/>
                                                        <TextBlock Text="  (변경 시 AUX 포트 선택지가 갱신됩니다)"
                                                                   VerticalAlignment="Center"
                                                                   Margin="10,0,0,0"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- 메인 편집 영역: IW/QW/MW 탭 -->
                                            <TabControl x:Name="SignalSectionTabControl"
                                                        Grid.Row="2"
                                                        Background="{DynamicResource SecondaryBackgroundBrush}"
                                                        BorderThickness="0">

                                                <!-- IW 탭 -->
                                                <TabItem Header="입력 (IW)"
                                                         Foreground="{DynamicResource PrimaryTextBrush}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>

                                                        <!-- 툴바 -->
                                                        <Border Grid.Row="0"
                                                                Background="{DynamicResource SecondaryBackgroundBrush}"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="0,0,0,1"
                                                                Padding="10,8">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Button Content="➕ 행 추가"
                                                                        Padding="10,5"
                                                                        Margin="0,0,5,0"
                                                                        Background="{DynamicResource AccentBrush}"
                                                                        Foreground="{DynamicResource ForegroundBrush}"
                                                                        BorderBrush="{DynamicResource AccentBrush}"
                                                                        Click="AddIwRow_Click"/>
                                                                <Button Content="➖ 선택 행 삭제"
                                                                        Padding="10,5"
                                                                        Background="{DynamicResource SecondaryBackgroundBrush}"
                                                                        Foreground="{DynamicResource ForegroundBrush}"
                                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                                        Click="RemoveIwRow_Click"/>
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- IW 그리드 -->
                                                        <DataGrid x:Name="IwSignalGrid"
                                                                  Grid.Row="1"
                                                                  AutoGenerateColumns="False"
                                                                  CanUserAddRows="False"
                                                                  CanUserDeleteRows="False"
                                                                  CanUserSortColumns="False"
                                                                  SelectionMode="Extended"
                                                                  GridLinesVisibility="All"
                                                                  BorderBrush="{DynamicResource BorderBrush}"
                                                                  BorderThickness="0"
                                                                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                                                  VerticalGridLinesBrush="{DynamicResource BorderBrush}"
                                                                  Foreground="{DynamicResource PrimaryTextBrush}"
                                                                  Background="{DynamicResource SecondaryBackgroundBrush}">
                                                            <DataGrid.Columns>
                                                                <DataGridTemplateColumn Header="API 이름" Width="140">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <ComboBox ItemsSource="{Binding DataContext.WizApiNames, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                      SelectedItem="{Binding ApiName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                      IsEditable="False"
                                                                                      IsSynchronizedWithCurrentItem="False"/>
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTextColumn Header="신호 패턴"
                                                                                    Binding="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                                                                    Width="*"/>
                                                                <DataGridTemplateColumn Header="FB Local Label" Width="170">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <ComboBox ItemsSource="{Binding PortOptions}"
                                                                                      SelectedItem="{Binding TargetFBPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                      IsSynchronizedWithCurrentItem="False"/>
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                            </DataGrid.Columns>
                                                        </DataGrid>
                                                    </Grid>
                                                </TabItem>

                                                <!-- QW 탭 -->
                                                <TabItem Header="출력 (QW)"
                                                         Foreground="{DynamicResource PrimaryTextBrush}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>

                                                        <!-- 툴바 -->
                                                        <Border Grid.Row="0"
                                                                Background="{DynamicResource SecondaryBackgroundBrush}"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="0,0,0,1"
                                                                Padding="10,8">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Button Content="➕ 행 추가"
                                                                        Padding="10,5"
                                                                        Margin="0,0,5,0"
                                                                        Background="{DynamicResource AccentBrush}"
                                                                        Foreground="{DynamicResource ForegroundBrush}"
                                                                        BorderBrush="{DynamicResource AccentBrush}"
                                                                        Click="AddQwRow_Click"/>
                                                                <Button Content="➖ 선택 행 삭제"
                                                                        Padding="10,5"
                                                                        Background="{DynamicResource SecondaryBackgroundBrush}"
                                                                        Foreground="{DynamicResource ForegroundBrush}"
                                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                                        Click="RemoveQwRow_Click"/>
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- QW 그리드 -->
                                                        <DataGrid x:Name="QwSignalGrid"
                                                                  Grid.Row="1"
                                                                  AutoGenerateColumns="False"
                                                                  CanUserAddRows="False"
                                                                  CanUserDeleteRows="False"
                                                                  SelectionMode="Extended"
                                                                  GridLinesVisibility="All"
                                                                  BorderBrush="{DynamicResource BorderBrush}"
                                                                  BorderThickness="0"
                                                                  Foreground="{DynamicResource PrimaryTextBrush}"
                                                                  Background="{DynamicResource SecondaryBackgroundBrush}">
                                                            <DataGrid.Columns>
                                                                <DataGridTemplateColumn Header="API 이름" Width="140">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <ComboBox ItemsSource="{Binding DataContext.WizApiNames, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                      SelectedItem="{Binding ApiName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                      IsEditable="False"
                                                                                      IsSynchronizedWithCurrentItem="False"/>
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTextColumn Header="신호 패턴" Width="*"
                                                                                    Binding="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"/>
                                                                <DataGridTemplateColumn Header="FB Local Label" Width="170">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <ComboBox ItemsSource="{Binding PortOptions}"
                                                                                      SelectedItem="{Binding TargetFBPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                      IsSynchronizedWithCurrentItem="False"/>
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                            </DataGrid.Columns>
                                                        </DataGrid>
                                                    </Grid>
                                                </TabItem>

                                                <!-- MW 탭 -->
                                                <TabItem Header="메모리 (MW)"
                                                         Foreground="{DynamicResource PrimaryTextBrush}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>

                                                        <!-- 툴바 -->
                                                        <Border Grid.Row="0"
                                                                Background="{DynamicResource SecondaryBackgroundBrush}"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="0,0,0,1"
                                                                Padding="10,8">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Button Content="➕ 행 추가"
                                                                        Padding="10,5"
                                                                        Margin="0,0,5,0"
                                                                        Background="{DynamicResource AccentBrush}"
                                                                        Foreground="{DynamicResource ForegroundBrush}"
                                                                        BorderBrush="{DynamicResource AccentBrush}"
                                                                        Click="AddMwRow_Click"/>
                                                                <Button Content="➖ 선택 행 삭제"
                                                                        Padding="10,5"
                                                                        Background="{DynamicResource SecondaryBackgroundBrush}"
                                                                        Foreground="{DynamicResource ForegroundBrush}"
                                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                                        Click="RemoveMwRow_Click"/>
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- MW 그리드 -->
                                                        <DataGrid x:Name="MwSignalGrid"
                                                                  Grid.Row="1"
                                                                  AutoGenerateColumns="False"
                                                                  CanUserAddRows="False"
                                                                  CanUserDeleteRows="False"
                                                                  SelectionMode="Extended"
                                                                  GridLinesVisibility="All"
                                                                  BorderBrush="{DynamicResource BorderBrush}"
                                                                  BorderThickness="0"
                                                                  Foreground="{DynamicResource PrimaryTextBrush}"
                                                                  Background="{DynamicResource SecondaryBackgroundBrush}">
                                                            <DataGrid.Columns>
                                                                <DataGridTemplateColumn Header="API 이름" Width="140">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <ComboBox ItemsSource="{Binding DataContext.WizApiNames, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                      SelectedItem="{Binding ApiName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                      IsEditable="False"
                                                                                      IsSynchronizedWithCurrentItem="False"/>
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTextColumn Header="신호 패턴" Width="*"
                                                                                    Binding="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"/>
                                                                <DataGridTemplateColumn Header="FB Local Label" Width="170">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <ComboBox ItemsSource="{Binding PortOptions}"
                                                                                      SelectedItem="{Binding TargetFBPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                      IsSynchronizedWithCurrentItem="False"/>
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                            </DataGrid.Columns>
                                                        </DataGrid>
                                                    </Grid>
                                                </TabItem>

                                                <!-- AUX 포트 탭 (AutoAux / ComAux 대상 FB 포트 매핑) -->
                                                <TabItem Header="AUX 포트"
                                                         Foreground="{DynamicResource PrimaryTextBrush}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>

                                                        <Border Grid.Row="0"
                                                                Background="{DynamicResource SecondaryBackgroundBrush}"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="0,0,0,1"
                                                                Padding="10,8">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="API 별로 FB 의 AutoAux / ComAux 입력 포트를 선택합니다. ComAux 를 비워두면 해당 API 는 ComAux coil 을 생성하지 않습니다 (로봇 FB 등)."
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                                           FontSize="11"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Border>

                                                        <DataGrid x:Name="AuxPortGrid"
                                                                  Grid.Row="1"
                                                                  AutoGenerateColumns="False"
                                                                  CanUserAddRows="False"
                                                                  CanUserDeleteRows="False"
                                                                  CanUserSortColumns="False"
                                                                  SelectionMode="Extended"
                                                                  GridLinesVisibility="All"
                                                                  BorderBrush="{DynamicResource BorderBrush}"
                                                                  BorderThickness="0"
                                                                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                                                  VerticalGridLinesBrush="{DynamicResource BorderBrush}"
                                                                  Foreground="{DynamicResource PrimaryTextBrush}"
                                                                  Background="{DynamicResource SecondaryBackgroundBrush}">
                                                            <DataGrid.Columns>
                                                                <DataGridTextColumn Header="API 이름"
                                                                                    Binding="{Binding ApiName}"
                                                                                    Width="160"
                                                                                    IsReadOnly="True"/>
                                                                <DataGridTemplateColumn Header="AutoAux Port" Width="220">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <ComboBox ItemsSource="{Binding PortOptions}"
                                                                                      SelectedItem="{Binding AutoAuxPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                      IsSynchronizedWithCurrentItem="False"
                                                                                      IsEditable="False"/>
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                                <DataGridTemplateColumn Header="ComAux Port (옵션)" Width="220">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <ComboBox ItemsSource="{Binding PortOptions}"
                                                                                      SelectedItem="{Binding ComAuxPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                      IsSynchronizedWithCurrentItem="False"
                                                                                      IsEditable="False"/>
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>
                                                            </DataGrid.Columns>
                                                        </DataGrid>
                                                    </Grid>
                                                </TabItem>

                                            </TabControl>

                                            <!-- 하단 상태바 -->
                                            <Border Grid.Row="3"
                                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,1,0,0"
                                                    Padding="15,10">
                                                <TextBlock x:Name="DeviceTemplateStatusText"
                                                           Text="템플릿을 선택하면 편집할 수 있습니다."
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                    </Grid>
                </Grid>

                <!-- Step 3: 신호 생성 -->
                <Grid x:Name="Step3Content" Visibility="Collapsed">
                    <Grid Margin="40,30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Step 3: 신호 생성 및 미리보기"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>

                            <TextBlock x:Name="GenerationStatusText"
                                       Text="프리뷰를 확인하세요. 모든 ApiCall 에 일괄 반영하려면 아래 '패턴 적용' 버튼을 누르세요. '다음' 은 적용 없이 다음 단계로만 이동합니다."
                                       FontSize="14"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"/>

                            <!-- 패턴 적용 버튼 (명시적 덮어쓰기 — IoBatch 와의 충돌 방지 위해 분리) -->
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button x:Name="ApplyPatternsButton"
                                        Content="⚠ 패턴 적용 (ApiCall 덮어쓰기)"
                                        Style="{StaticResource DarkButton}"
                                        Padding="14,8"
                                        FontWeight="SemiBold"
                                        Click="ApplyPatterns_Click"/>
                                <TextBlock Text="이 버튼을 누르면 IoBatch 에서 수동 설정한 이름이 모두 덮어써집니다."
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <TabControl Grid.Row="2"
                                    Background="{DynamicResource SecondaryBackgroundBrush}"
                                    BorderThickness="0">
                            <!-- IO 신호 탭 -->
                            <TabItem Header="IO 신호"
                                     Foreground="{DynamicResource PrimaryTextBrush}">
                                <DataGrid x:Name="IoSignalPreviewGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserSortColumns="True"
                                          CanUserReorderColumns="True"
                                          CanUserResizeColumns="True"
                                          SelectionMode="Extended"
                                          Style="{StaticResource WizardGridStyle}"
                                          Foreground="{DynamicResource PrimaryTextBrush}"
                                          Background="{DynamicResource SecondaryBackgroundBrush}">
                                    <DataGrid.ColumnHeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </DataGrid.ColumnHeaderStyle>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Binding="{Binding Flow}"       Width="100"
                                                            HeaderTemplate="{StaticResource PvHeaderFlow}"/>
                                        <DataGridTextColumn Binding="{Binding Device}"     Width="120"
                                                            HeaderTemplate="{StaticResource PvHeaderDevice}"/>
                                        <DataGridTextColumn Binding="{Binding Api}"        Width="120"
                                                            HeaderTemplate="{StaticResource PvHeaderApi}"/>
                                        <DataGridTextColumn Binding="{Binding InSymbol}"   Width="1.5*"
                                                            HeaderTemplate="{StaticResource PvHeaderInTag}"/>
                                        <DataGridTextColumn Binding="{Binding InAddress}"  Width="120"
                                                            HeaderTemplate="{StaticResource PvHeaderInAddress}"/>
                                        <DataGridTextColumn Binding="{Binding OutSymbol}"  Width="1.5*"
                                                            HeaderTemplate="{StaticResource PvHeaderOutTag}"/>
                                        <DataGridTextColumn Binding="{Binding OutAddress}" Width="120"
                                                            HeaderTemplate="{StaticResource PvHeaderOutAddress}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>

                            <!-- Dummy 신호 탭 -->
                            <TabItem Header="Dummy 신호"
                                     Foreground="{DynamicResource PrimaryTextBrush}">
                                <DataGrid x:Name="DummySignalPreviewGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserSortColumns="True"
                                          CanUserReorderColumns="True"
                                          CanUserResizeColumns="True"
                                          SelectionMode="Extended"
                                          Style="{StaticResource WizardGridStyle}"
                                          Foreground="{DynamicResource PrimaryTextBrush}"
                                          Background="{DynamicResource SecondaryBackgroundBrush}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Flow" Binding="{Binding Flow}" Width="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Work" Binding="{Binding Work}" Width="100">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Call" Binding="{Binding Call}" Width="120">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="2*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="110">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>

                            <!-- 매칭 실패 탭 -->
                            <TabItem x:Name="UnmatchedTabItem"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     Visibility="Collapsed">
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚠ 매칭 실패 (" Foreground="{DynamicResource OrangeAccentBrush}"/>
                                        <TextBlock x:Name="UnmatchedCountText" Text="0" Foreground="{DynamicResource OrangeAccentBrush}" FontWeight="Bold"/>
                                        <TextBlock Text=")" Foreground="{DynamicResource OrangeAccentBrush}"/>
                                    </StackPanel>
                                </TabItem.Header>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- 안내 메시지 -->
                                    <Border Grid.Row="0"
                                            Background="{DynamicResource SecondaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource OrangeAccentBrush}"
                                            BorderThickness="0,0,0,2"
                                            Padding="15,12">
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap">
                                            <Run Text="⚠ "/>
                                            <Run Text="아래 항목들은 DS2 모델과 매칭되지 않았습니다. Flow, Device, Api 이름이 정확히 일치하는지 확인하세요."/>
                                        </TextBlock>
                                    </Border>

                                    <!-- 매칭 실패 항목 그리드 -->
                                    <DataGrid x:Name="UnmatchedSignalGrid"
                                              Grid.Row="1"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              CanUserSortColumns="True"
                                              CanUserReorderColumns="True"
                                              CanUserResizeColumns="True"
                                              SelectionMode="Extended"
                                              Style="{StaticResource WizardGridStyle}"
                                              Foreground="{DynamicResource PrimaryTextBrush}"
                                              Background="{DynamicResource SecondaryBackgroundBrush}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Flow" Binding="{Binding Flow}" Width="100">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource OrangeAccentBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Device" Binding="{Binding Device}" Width="120">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource OrangeAccentBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Api" Binding="{Binding Api}" Width="140">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource OrangeAccentBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="In Tag" Binding="{Binding InSymbol}" Width="1.5*">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="In Address" Binding="{Binding InAddress}" Width="110">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Out Tag" Binding="{Binding OutSymbol}" Width="1.5*">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Out Address" Binding="{Binding OutAddress}" Width="110">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="매칭 실패 이유" Binding="{Binding FailureReason}" Width="1.5*">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource OrangeAccentBrush}"/>
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </TabItem>

                            <!-- 오류 탭 -->
                            <TabItem x:Name="ErrorsTabItem"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     Visibility="Collapsed">
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✖ 오류 (" Foreground="{DynamicResource RedAccentBrush}"/>
                                        <TextBlock x:Name="ErrorCountText" Text="0" Foreground="{DynamicResource RedAccentBrush}" FontWeight="Bold"/>
                                        <TextBlock Text=")" Foreground="{DynamicResource RedAccentBrush}"/>
                                    </StackPanel>
                                </TabItem.Header>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- 안내 메시지 -->
                                    <Border Grid.Row="0"
                                            Background="{DynamicResource SecondaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource RedAccentBrush}"
                                            BorderThickness="0,0,0,2"
                                            Padding="15,12">
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap">
                                            <Run Text="✖ "/>
                                            <Run Text="신호 생성 중 오류가 발생했습니다. 템플릿 설정을 확인하세요."/>
                                        </TextBlock>
                                    </Border>

                                    <!-- 오류 항목 리스트 -->
                                    <ListBox x:Name="ErrorsListBox"
                                             Grid.Row="1"
                                             Background="{DynamicResource PrimaryBackgroundBrush}"
                                             BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                                        BorderBrush="{DynamicResource RedAccentBrush}"
                                                        BorderThickness="1,0,0,0"
                                                        Padding="15,12"
                                                        Margin="5">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                                   Text="✖"
                                                                   FontSize="16"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource RedAccentBrush}"
                                                                   VerticalAlignment="Top"
                                                                   Margin="0,0,15,0"/>

                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding ErrorType}"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource RedAccentBrush}"
                                                                       Margin="0,0,0,5"/>
                                                            <TextBlock Text="{Binding Message}"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Grid>

                <!-- Step 4: 요약 (완료 화면) -->
                <Grid x:Name="Step4Content" Visibility="Collapsed" Margin="30,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Step 4: 요약"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="생성된 신호와 FB 바인딩 결과를 확인합니다."
                                   FontSize="13"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Background="{DynamicResource PrimaryBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="24,18"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="📊 신호 통계"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Margin="0,0,0,10"/>
                                    <TextBlock x:Name="SummarySignalStats"
                                               FontSize="13"
                                               LineHeight="22"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource PrimaryBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="24,18"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🔗 FB 바인딩 요약"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Margin="0,0,0,10"/>
                                    <TextBlock x:Name="SummaryBindingStats"
                                               FontSize="13"
                                               LineHeight="22"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource PrimaryBackgroundBrush}"
                                    BorderBrush="{DynamicResource AccentBrush}"
                                    BorderThickness="2"
                                    CornerRadius="8"
                                    Padding="24,18">
                                <StackPanel>
                                    <TextBlock Text="💡 다음 단계"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Margin="0,0,0,10"/>
                                    <TextBlock FontSize="13" LineHeight="22"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               TextWrapping="Wrap">
                                        <Run Text="• Properties 패널에서 각 Call 의 IO 태그를 확인"/><LineBreak/>
                                        <Run Text="• I/O 일괄 편집 에서 개별 신호 주소/바인딩 수정"/><LineBreak/>
                                        <Run Text="• File > Export AASX 로 PLC 프로그램 생성"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <TextBlock x:Name="CompletionSummaryText"
                                       FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,12,0,0"
                                       TextWrapping="Wrap"/>

                            <Button x:Name="OpenMigrationButton"
                                    Content="🔧 Call 구조 마이그레이션..."
                                    Style="{StaticResource DarkButton}"
                                    HorizontalAlignment="Left"
                                    Margin="0,10,0,0" Padding="12,6"
                                    Visibility="Collapsed"
                                    Click="OpenMigration_Click"/>

                            <Button x:Name="OpenRobotMetadataButton"
                                    Content="🤖 Robot 메타데이터 편집..."
                                    Style="{StaticResource DarkButton}"
                                    HorizontalAlignment="Left"
                                    Margin="0,8,0,0" Padding="12,6"
                                    Click="OpenRobotMetadata_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

            </Grid>

            <!-- 하단: 버튼 -->
            <Border Grid.Row="2"
                    Background="{DynamicResource PrimaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="40,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BackButton"
                            Grid.Column="1"
                            Content="◀ 이전"
                            Style="{StaticResource SecondaryButton}"
                            Click="Back_Click"
                            Visibility="Collapsed"/>

                    <Button x:Name="NextButton"
                            Grid.Column="3"
                            Content="다음 ▶"
                            Style="{StaticResource WizardButton}"
                            Click="Next_Click"/>

                    <Button x:Name="CloseButton"
                            Grid.Column="3"
                            Content="닫기"
                            Style="{StaticResource SecondaryButton}"
                            Click="Close_Click"
                            Visibility="Collapsed"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
