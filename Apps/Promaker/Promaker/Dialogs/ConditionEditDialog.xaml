<Window x:Class="Promaker.Dialogs.ConditionEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:le="clr-namespace:AAStoPLC.LadderEditor.Views;assembly=AAStoPLC.LadderEditor"
        Title="조건 편집"
        Width="1280"
        Height="784"
        MinWidth="960"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0"
                       x:Name="SectionTitle"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       VerticalAlignment="Center"/>

            <!-- 조작 안내 배너 -->
            <Border Grid.Row="2"
                    Background="{DynamicResource TertiaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="10,6">
                <TextBlock TextWrapping="Wrap" FontSize="11"
                           Foreground="{DynamicResource SecondaryTextBrush}">
                    <Run FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}">조작:</Run>
                    <Run> 접점 더블클릭 = 심볼 편집 ·</Run>
                    <Run> 빈 셀 더블클릭 = 신규 접점 ·</Run>
                    <Run> 접점 우클릭 = 종류(NO/NC/Pulse) / 복사·붙여넣기 / 삭제 ·</Run>
                    <Run> 접점 드래그 → = 직렬 추가 ·</Run>
                    <Run> 접점 드래그 ↓ = OR 분기 ·</Run>
                    <Run> Ctrl+Z/Y = Undo/Redo ·</Run>
                    <Run> Ctrl+휠 = 확대/축소</Run>
                </TextBlock>
            </Border>

            <!-- LadderEditor — 전체 영역. 드래그/우클릭/Ctrl+Z 모두 활성. -->
            <Border Grid.Row="4"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Background="{DynamicResource TertiaryBackgroundBrush}">
                <le:LadderEditorControl x:Name="EditorView" IsReadOnly="False"/>
            </Border>

            <!-- Footer -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"
                           FontSize="11"/>
                <Button Grid.Column="1"
                        Content="닫기"
                        Style="{StaticResource DarkButton}"
                        Padding="20,6"
                        MinWidth="80"
                        IsCancel="True"
                        Click="Close_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
