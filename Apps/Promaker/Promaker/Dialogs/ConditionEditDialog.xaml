<Window x:Class="Promaker.Dialogs.ConditionEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="조건 편집"
        Width="640"
        Height="560"
        MinWidth="480"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="SectionTitle"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="+ 조건 추가"
                        Style="{StaticResource DarkButton}"
                        Padding="12,4"
                        Click="AddCondition_Click"/>
            </Grid>

            <!-- Condition tree -->
            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Background="{DynamicResource TertiaryBackgroundBrush}">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Padding="4">
                        <ItemsControl x:Name="ConditionList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="6,6"
                                            Margin="2,2">
                                        <StackPanel>
                                            <!-- Condition header -->
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <Button Content="x"
                                                            Style="{StaticResource DarkButton}"
                                                            Padding="6,2"
                                                            FontSize="10"
                                                            Margin="0,0,6,0"
                                                            ToolTip="조건 삭제"
                                                            Tag="{Binding}"
                                                            Click="RemoveCondition_Click"/>
                                                    <CheckBox Content="OR"
                                                              IsChecked="{Binding IsOR, Mode=OneWay}"
                                                              Foreground="{DynamicResource PrimaryTextBrush}"
                                                              Margin="0,0,8,0"
                                                              VerticalAlignment="Center"
                                                              FontSize="11"
                                                              Tag="{Binding}"
                                                              Click="ToggleOR_Click"/>
                                                    <CheckBox Content="Rising"
                                                              IsChecked="{Binding IsRising, Mode=OneWay}"
                                                              Foreground="{DynamicResource PrimaryTextBrush}"
                                                              Margin="0,0,8,0"
                                                              VerticalAlignment="Center"
                                                              FontSize="11"
                                                              Tag="{Binding}"
                                                              Click="ToggleRising_Click"/>
                                                    <Button Content="+ 하위그룹"
                                                            Style="{StaticResource DarkButton}"
                                                            Padding="8,2"
                                                            FontSize="10"
                                                            Tag="{Binding}"
                                                            Click="AddChildCondition_Click"/>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Content="+"
                                                        Style="{StaticResource DarkButton}"
                                                        Padding="6,2"
                                                        FontSize="12"
                                                        FontWeight="Bold"
                                                        ToolTip="ApiCall 추가"
                                                        Tag="{Binding}"
                                                        Click="AddApiCallToCondition_Click"/>
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding Items}" Margin="12,0,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,2" Background="Transparent">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Button Grid.Column="0"
                                                                    Content="x"
                                                                    Style="{StaticResource DarkButton}"
                                                                    Padding="6,1"
                                                                    FontSize="10"
                                                                    Margin="0,0,4,0"
                                                                    Tag="{Binding}"
                                                                    Click="RemoveApiCall_Click"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding ApiDefDisplayName}"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                                       FontSize="11"
                                                                       VerticalAlignment="Center"
                                                                       Margin="4,0"/>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding OutputSpecText}"
                                                                       FontSize="11"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource AccentBrush}"
                                                                       Margin="4,0"/>
                                                            <Button Grid.Column="3"
                                                                    Content="편집"
                                                                    Style="{StaticResource DarkButton}"
                                                                    Padding="8,1"
                                                                    FontSize="10"
                                                                    Tag="{Binding}"
                                                                    Click="EditApiCallSpec_Click"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <!-- Children (recursive — uses code-behind BuildChildrenUI) -->
                                            <ItemsControl x:Name="ChildrenHost"
                                                          ItemsSource="{Binding Children}"
                                                          Margin="20,4,0,0"
                                                          Loaded="ChildrenHost_Loaded"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty hint -->
                    <TextBlock x:Name="EmptyHint"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12"
                               FontStyle="Italic"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               Visibility="Collapsed">
                        <Run Text="조건이 없습니다."/>
                        <LineBreak/>
                        <Run Text="'+ 조건 추가' 버튼을 눌러 조건을 추가하세요."/>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Footer -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="변경사항은 즉시 적용됩니다."
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"
                           FontSize="11"/>
                <Button Grid.Column="1"
                        Content="닫기"
                        Style="{StaticResource DarkButton}"
                        Padding="20,6"
                        MinWidth="80"
                        IsCancel="True"
                        Click="Close_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
