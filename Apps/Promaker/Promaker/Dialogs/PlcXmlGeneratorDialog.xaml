<Window x:Class="Promaker.Dialogs.PlcXmlGeneratorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PLC 생성"
        Width="1180" Height="720"
        MinWidth="980" MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 제목 + 생성 버튼 -->
            <Grid Grid.Row="0">
                <TextBlock Text="PLC 생성"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button x:Name="GenerateButton"
                        HorizontalAlignment="Right"
                        MinWidth="100"
                        Style="{StaticResource DarkButton}"
                        Content="생성"
                        Click="Generate_Click"
                        ToolTip="IOList 신호를 사용하여 XG5000 PLC 래더 미리보기"/>
            </Grid>

            <!-- 미리보기 탭 -->
            <TabControl Grid.Row="2"
                        x:Name="PreviewTabs"
                        Background="{DynamicResource TertiaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}">
                <TabItem Header="요약">
                    <TextBox x:Name="SummaryText"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="12"
                             Background="{DynamicResource TertiaryBackgroundBrush}"
                             BorderThickness="0"
                             TextWrapping="Wrap"
                             HorizontalScrollBarVisibility="Disabled"
                             VerticalScrollBarVisibility="Auto"
                             Padding="14,10"
                             Text="'생성' 버튼을 눌러 결과를 확인하세요."/>
                </TabItem>
                <TabItem Header="래더 보기">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 래더 툴바 -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource TertiaryBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="8,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="프로그램:"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <ComboBox x:Name="LadderProgramComboBox"
                                          MinWidth="180"
                                          SelectionChanged="LadderProgram_SelectionChanged"/>
                                <Separator Margin="10,2" Width="1" Background="{DynamicResource BorderBrush}"/>
                                <Button Content="−" MinWidth="28" Margin="0,0,2,0"
                                        Style="{StaticResource DarkButton}"
                                        Click="LadderZoomOut_Click" ToolTip="축소"/>
                                <TextBlock x:Name="LadderZoomLabel" Text="100%"
                                           VerticalAlignment="Center" MinWidth="38"
                                           TextAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <Button Content="＋" MinWidth="28" Margin="2,0,4,0"
                                        Style="{StaticResource DarkButton}"
                                        Click="LadderZoomIn_Click" ToolTip="확대"/>
                                <Button Content="↺" MinWidth="28"
                                        Style="{StaticResource DarkButton}"
                                        Click="LadderZoomReset_Click" ToolTip="100% 복원"/>
                            </StackPanel>
                        </Border>

                        <!-- 래더 캔버스 -->
                        <ScrollViewer Grid.Row="1"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      PreviewMouseWheel="LadderScroll_PreviewMouseWheel">
                            <Canvas x:Name="LadderCanvas"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Left">
                                <Canvas.RenderTransform>
                                    <ScaleTransform x:Name="LadderScale" ScaleX="1" ScaleY="1"/>
                                </Canvas.RenderTransform>
                            </Canvas>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- 푸터 -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusText"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Text="대기 중"/>

                <Button Grid.Column="1"
                        x:Name="SaveButton"
                        MinWidth="100"
                        Style="{StaticResource DarkButton}"
                        Content="저장..."
                        IsEnabled="False"
                        Click="Save_Click"
                        ToolTip="생성된 XML을 파일로 저장"/>

                <Button Grid.Column="3"
                        MinWidth="82"
                        Style="{StaticResource DarkButton}"
                        Content="닫기"
                        IsCancel="True"/>
            </Grid>
        </Grid>
    </Border>
</Window>
