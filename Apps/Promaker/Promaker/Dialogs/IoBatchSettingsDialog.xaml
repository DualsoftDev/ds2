<Window x:Class="Promaker.Dialogs.IoBatchSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="I/O 조회"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="BatchGridHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <!-- Padding=0 → 헤더 DataTemplate 의 Grid 가 header ActualWidth 전체를 사용 -->
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

        <!-- 공용 필터 헤더 DataTemplate: 레이블 + 컬럼 폭에 맞는 TextBox -->
        <DataTemplate x:Key="FilterHeaderFlow">
            <Grid HorizontalAlignment="Stretch"
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGridColumnHeader}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Flow" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBox   Grid.Row="1"
                           Tag="Flow" TextChanged="FilterTextBox_TextChanged"
                           Padding="4,2" HorizontalAlignment="Stretch" ToolTip="Flow 이름 필터"/>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="FilterHeaderWork">
            <Grid HorizontalAlignment="Stretch"
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGridColumnHeader}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Work" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBox   Grid.Row="1"
                           Tag="Work" TextChanged="FilterTextBox_TextChanged"
                           Padding="4,2" HorizontalAlignment="Stretch" ToolTip="Work 이름 필터"/>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="FilterHeaderDevice">
            <Grid HorizontalAlignment="Stretch"
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGridColumnHeader}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Device" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBox   Grid.Row="1"
                           Tag="Device" TextChanged="FilterTextBox_TextChanged"
                           Padding="4,2" HorizontalAlignment="Stretch" ToolTip="Device 이름 필터"/>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="FilterHeaderApi">
            <Grid HorizontalAlignment="Stretch"
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGridColumnHeader}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Api" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBox   Grid.Row="1"
                           Tag="Api" TextChanged="FilterTextBox_TextChanged"
                           Padding="4,2" HorizontalAlignment="Stretch" ToolTip="Api 이름 필터"/>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="FilterHeaderInName">
            <Grid HorizontalAlignment="Stretch"
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGridColumnHeader}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="InName" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBox   Grid.Row="1"
                           Tag="InName" TextChanged="FilterTextBox_TextChanged"
                           Padding="4,2" HorizontalAlignment="Stretch" ToolTip="In Symbol 필터"/>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="FilterHeaderInType">
            <Grid HorizontalAlignment="Stretch"
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGridColumnHeader}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="In Type" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBox   Grid.Row="1"
                           Tag="InType" TextChanged="FilterTextBox_TextChanged"
                           Padding="4,2" HorizontalAlignment="Stretch" ToolTip="In DataType 필터"/>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="FilterHeaderInAddress">
            <Grid HorizontalAlignment="Stretch"
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGridColumnHeader}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="In Address" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBox   Grid.Row="1"
                           Tag="InAddress" TextChanged="FilterTextBox_TextChanged"
                           Padding="4,2" HorizontalAlignment="Stretch" ToolTip="In Address 필터"/>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="FilterHeaderOutName">
            <Grid HorizontalAlignment="Stretch"
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGridColumnHeader}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="OutName" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBox   Grid.Row="1"
                           Tag="OutName" TextChanged="FilterTextBox_TextChanged"
                           Padding="4,2" HorizontalAlignment="Stretch" ToolTip="Out Symbol 필터"/>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="FilterHeaderOutType">
            <Grid HorizontalAlignment="Stretch"
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGridColumnHeader}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Out Type" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBox   Grid.Row="1"
                           Tag="OutType" TextChanged="FilterTextBox_TextChanged"
                           Padding="4,2" HorizontalAlignment="Stretch" ToolTip="Out DataType 필터"/>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="FilterHeaderOutAddress">
            <Grid HorizontalAlignment="Stretch"
                  Width="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGridColumnHeader}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Out Address" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBox   Grid.Row="1"
                           Tag="OutAddress" TextChanged="FilterTextBox_TextChanged"
                           Padding="4,2" HorizontalAlignment="Stretch" ToolTip="Out Address 필터"/>
            </Grid>
        </DataTemplate>

        <Style x:Key="BatchGridCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style x:Key="BatchGridStyle" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource BatchGridHeaderStyle}"/>
            <Setter Property="CellStyle" Value="{StaticResource BatchGridCellStyle}"/>
        </Style>
    </Window.Resources>
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="I/O 조회"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="(읽기 전용 — 편집은 TAG Wizard 에서만 가능)"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="12,4,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>
            </Grid>

            <!-- 필터는 그리드 컬럼 헤더 안으로 이전됨. 조회 전용이므로 편집 버튼 제거. -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <CheckBox x:Name="ShowOnlyUnmatchedCheckBox"
                          Grid.Column="1"
                          Content="미매치만 보기"
                          Visibility="Collapsed"
                          VerticalAlignment="Center"
                          Checked="ShowOnlyUnmatched_Changed"
                          Unchecked="ShowOnlyUnmatched_Changed"/>
            </Grid>

            <Border Grid.Row="3"
                    Background="{DynamicResource TertiaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <DataGrid x:Name="IoGrid"
                          Style="{StaticResource BatchGridStyle}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          RowHeaderWidth="0"
                          PreviewMouseLeftButtonDown="Grid_PreviewMouseLeftButtonDown">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsUnmatched}" Value="True">
                                    <Setter Property="Background" Value="#30FF6B6B"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="선택 항목 체크" Click="CheckSelected_Click"/>
                            <MenuItem Header="선택 항목 체크 해제" Click="UncheckSelected_Click"/>
                            <Separator/>
                            <MenuItem Header="전체 체크" Click="CheckAll_Click"/>
                            <MenuItem Header="전체 체크 해제" Click="UncheckAll_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="34">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Click="RowCheckBox_Click"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Binding="{Binding Flow}"   Width="120" IsReadOnly="True"
                                            HeaderTemplate="{StaticResource FilterHeaderFlow}"/>
                        <DataGridTextColumn Binding="{Binding Work}"   Width="140" IsReadOnly="True"
                                            HeaderTemplate="{StaticResource FilterHeaderWork}"/>
                        <DataGridTextColumn Binding="{Binding Device}" Width="140" IsReadOnly="True"
                                            HeaderTemplate="{StaticResource FilterHeaderDevice}"/>
                        <DataGridTextColumn Binding="{Binding Api}"    Width="140" IsReadOnly="True"
                                            HeaderTemplate="{StaticResource FilterHeaderApi}"/>
                        <DataGridTextColumn Binding="{Binding InSymbol}"    Width="*"   IsReadOnly="True"
                                            HeaderTemplate="{StaticResource FilterHeaderInName}"/>
                        <DataGridTextColumn Binding="{Binding InDataType}"  Width="80"  IsReadOnly="True"
                                            HeaderTemplate="{StaticResource FilterHeaderInType}"/>
                        <DataGridTextColumn Binding="{Binding InAddress}"   Width="120" IsReadOnly="True"
                                            HeaderTemplate="{StaticResource FilterHeaderInAddress}"/>
                        <DataGridTextColumn Binding="{Binding OutSymbol}"   Width="*"   IsReadOnly="True"
                                            HeaderTemplate="{StaticResource FilterHeaderOutName}"/>
                        <DataGridTextColumn Binding="{Binding OutDataType}" Width="80"  IsReadOnly="True"
                                            HeaderTemplate="{StaticResource FilterHeaderOutType}"/>
                        <DataGridTextColumn Binding="{Binding OutAddress}"  Width="120" IsReadOnly="True"
                                            HeaderTemplate="{StaticResource FilterHeaderOutAddress}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- 선택 카운트 표시만 (자동 생성 섹션 제거 — 조회 전용) -->
            <Border Grid.Row="5"
                    Background="{DynamicResource TertiaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="16,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💡 I/O 편집은 TAG Wizard 에서만 가능합니다. (메뉴: TAG Wizard → Step 3 → '패턴 적용' 버튼)"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12"/>
                    <TextBlock Text="   |   선택:"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="16,0,4,0"/>
                    <TextBlock x:Name="SelectedCountText"
                               Text="0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        MinWidth="140"
                        Style="{StaticResource DarkButton}"
                        Content="📥 CSV 내보내기"
                        Click="ExportCsv_Click"
                        ToolTip="현재 필터 적용된 행을 CSV 파일로 저장"/>

                <Button Grid.Column="2"
                        MinWidth="82"
                        Style="{StaticResource DarkButton}"
                        Content="닫기"
                        IsCancel="True"/>
            </Grid>
        </Grid>
    </Border>
</Window>
