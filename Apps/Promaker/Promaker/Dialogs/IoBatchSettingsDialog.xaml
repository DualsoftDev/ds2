<Window x:Class="Promaker.Dialogs.IoBatchSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="I/O 일괄 편집"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="BatchGridHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style x:Key="BatchGridCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style x:Key="BatchGridStyle" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource BatchGridHeaderStyle}"/>
            <Setter Property="CellStyle" Value="{StaticResource BatchGridCellStyle}"/>
        </Style>
    </Window.Resources>
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <TextBlock Text="I/O 일괄 편집"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Flow" Margin="0,0,0,4" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox x:Name="FlowFilterBox" Padding="8,6" ToolTip="Flow 이름으로 필터링"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Device" Margin="0,0,0,4" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox x:Name="DeviceFilterBox" Padding="8,6" ToolTip="Device 이름으로 필터링"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="Api" Margin="0,0,0,4" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox x:Name="ApiFilterBox" Padding="8,6" ToolTip="Api 이름으로 필터링"/>
                </StackPanel>

                <Button Grid.Column="6"
                        Height="34"
                        MinWidth="102"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource DarkButton}"
                        Content="TAG Wizard"
                        Click="TagWizard_Click"
                        ToolTip="템플릿 기반 자동 신호 생성"/>

                <Button Grid.Column="8"
                        Height="34"
                        MinWidth="120"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource DarkButton}"
                        Content="Export IO List"
                        Click="ExportIoList_Click"
                        ToolTip="IO 신호를 CSV/Excel로 내보내기"/>

                <Button Grid.Column="10"
                        Height="34"
                        MinWidth="102"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource DarkButton}"
                        IsEnabled="False"
                        Content="CSV 가져오기"/>
            </Grid>

            <Border Grid.Row="3"
                    Background="{DynamicResource TertiaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <DataGrid x:Name="IoGrid"
                          Style="{StaticResource BatchGridStyle}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          RowHeaderWidth="0"
                          PreviewMouseLeftButtonDown="Grid_PreviewMouseLeftButtonDown">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="선택 항목 체크" Click="CheckSelected_Click"/>
                            <MenuItem Header="선택 항목 체크 해제" Click="UncheckSelected_Click"/>
                            <Separator/>
                            <MenuItem Header="전체 체크" Click="CheckAll_Click"/>
                            <MenuItem Header="전체 체크 해제" Click="UncheckAll_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="34">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Flow" Binding="{Binding Flow}" Width="100" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Device" Binding="{Binding Device}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Api" Binding="{Binding Api}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Out tag" Binding="{Binding OutSymbol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridTextColumn Header="Out Type" Binding="{Binding OutDataType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                        <DataGridTextColumn Header="Out Address" Binding="{Binding OutAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                        <DataGridTextColumn Header="In tag" Binding="{Binding InSymbol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridTextColumn Header="In Type" Binding="{Binding InDataType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                        <DataGridTextColumn Header="In Address" Binding="{Binding InAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="5"
                    Background="{DynamicResource TertiaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="16,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 헤더 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="🔧 태그 자동 생성"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0"/>
                        <TextBlock Text="선택:"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,4,0"/>
                        <TextBlock x:Name="SelectedCountText"
                                   Text="0"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- 자동 생성 컨트롤 -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Out Tag 행 -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Out Tag:"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Grid.Row="0" Grid.Column="2"
                                 x:Name="OutTagPatternBox"
                                 Text="$(F)_Q_$(D)_$(A)"
                                 Padding="8,6"
                                 FontFamily="Consolas"
                                 ToolTip="매크로: $(F)=Flow, $(D)=Device, $(A)=ApiDef"/>
                        <TextBlock Grid.Row="0" Grid.Column="4"
                                   Text="Out Addr:"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <StackPanel Grid.Row="0" Grid.Column="6" Orientation="Horizontal">
                            <TextBox x:Name="OutAddressPrefixBox"
                                     Text="%QW"
                                     Width="60"
                                     Padding="8,6"
                                     FontFamily="Consolas"
                                     ToolTip="주소 접두사"/>
                            <TextBox x:Name="OutAddressStartBox"
                                     Text="3070"
                                     Width="70"
                                     Padding="8,6"
                                     Margin="6,0,0,0"
                                     FontFamily="Consolas"
                                     ToolTip="시작 주소"/>
                        </StackPanel>
                        <Button Grid.Row="0" Grid.Column="8"
                                MinWidth="120"
                                Style="{StaticResource DarkButton}"
                                Content="Out 태그 생성"
                                Click="GenerateOutTags_Click"
                                ToolTip="선택된 행에 Out Tag/Address 자동 생성"/>

                        <!-- In Tag 행 -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="In Tag:"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Grid.Row="2" Grid.Column="2"
                                 x:Name="InTagPatternBox"
                                 Text="$(F)_I_$(D)_$(A)"
                                 Padding="8,6"
                                 FontFamily="Consolas"
                                 ToolTip="매크로: $(F)=Flow, $(D)=Device, $(A)=ApiDef"/>
                        <TextBlock Grid.Row="2" Grid.Column="4"
                                   Text="In Addr:"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <StackPanel Grid.Row="2" Grid.Column="6" Orientation="Horizontal">
                            <TextBox x:Name="InAddressPrefixBox"
                                     Text="%IW"
                                     Width="60"
                                     Padding="8,6"
                                     FontFamily="Consolas"
                                     ToolTip="주소 접두사"/>
                            <TextBox x:Name="InAddressStartBox"
                                     Text="3070"
                                     Width="70"
                                     Padding="8,6"
                                     Margin="6,0,0,0"
                                     FontFamily="Consolas"
                                     ToolTip="시작 주소"/>
                        </StackPanel>
                        <Button Grid.Row="2" Grid.Column="8"
                                MinWidth="120"
                                Style="{StaticResource DarkButton}"
                                Content="In 태그 생성"
                                Click="GenerateInTags_Click"
                                ToolTip="선택된 행에 In Tag/Address 자동 생성"/>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="변경된 행만 프로젝트에 반영됩니다."
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>

                <Button Grid.Column="1"
                        MinWidth="82"
                        Style="{StaticResource DarkButton}"
                        Content="적용"
                        Click="Accept_Click"/>

                <Button Grid.Column="3"
                        MinWidth="82"
                        Style="{StaticResource DarkButton}"
                        Content="취소"
                        IsCancel="True"/>
            </Grid>
        </Grid>
    </Border>
</Window>
