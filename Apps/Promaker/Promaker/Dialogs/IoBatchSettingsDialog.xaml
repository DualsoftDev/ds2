<Window x:Class="Promaker.Dialogs.IoBatchSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="I/O 일괄 편집"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="BatchGridHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style x:Key="BatchGridCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style x:Key="BatchGridStyle" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource BatchGridHeaderStyle}"/>
            <Setter Property="CellStyle" Value="{StaticResource BatchGridCellStyle}"/>
        </Style>
    </Window.Resources>
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="I/O 일괄 편집"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Width="28"
                        Height="28"
                        Style="{StaticResource DarkButton}"
                        Padding="0"
                        Click="Close_Click"
                        ToolTip="닫기">
                    <TextBlock Text="&#xE711;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Flow" Margin="0,0,0,4" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox x:Name="FlowFilterBox" Padding="8,6" ToolTip="Flow 이름으로 필터링"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Work" Margin="0,0,0,4" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox x:Name="WorkFilterBox" Padding="8,6" ToolTip="Work 이름으로 필터링"/>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="Call" Margin="0,0,0,4" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox x:Name="CallFilterBox" Padding="8,6" ToolTip="Call 이름으로 필터링"/>
                </StackPanel>

                <Button Grid.Column="6"
                        Height="34"
                        MinWidth="102"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource DarkButton}"
                        IsEnabled="False"
                        Content="CSV 내보내기"/>

                <Button Grid.Column="8"
                        Height="34"
                        MinWidth="102"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource DarkButton}"
                        IsEnabled="False"
                        Content="CSV 가져오기"/>
            </Grid>

            <Border Grid.Row="3"
                    Background="{DynamicResource TertiaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <DataGrid x:Name="IoGrid"
                          Style="{StaticResource BatchGridStyle}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          RowHeaderWidth="0"
                          PreviewMouseLeftButtonDown="Grid_PreviewMouseLeftButtonDown">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="선택 항목 체크" Click="CheckSelected_Click"/>
                            <MenuItem Header="선택 항목 체크 해제" Click="UncheckSelected_Click"/>
                            <Separator/>
                            <MenuItem Header="전체 체크" Click="CheckAll_Click"/>
                            <MenuItem Header="전체 체크 해제" Click="UncheckAll_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="34">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Flow" Binding="{Binding Flow}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Work" Binding="{Binding Work}" Width="140" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Call" Binding="{Binding Call}" Width="150" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Out tag" Binding="{Binding OutSymbol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                        <DataGridTextColumn Header="Out Address" Binding="{Binding OutAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                        <DataGridTextColumn Header="In tag" Binding="{Binding InSymbol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                        <DataGridTextColumn Header="In Address" Binding="{Binding InAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                        <DataGridTextColumn Header="Memo" Binding="{Binding Memo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="5"
                    Background="{DynamicResource TertiaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="선택:"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBlock Grid.Column="1"
                               x:Name="SelectedCountText"
                               Text="0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"/>

                    <TextBlock Grid.Column="3"
                               Text="일괄 필드:"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>

                    <ComboBox Grid.Column="4"
                              x:Name="BatchFieldCombo"
                              MinWidth="150"
                              VerticalAlignment="Center"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Out tag"/>
                        <ComboBoxItem Content="Out Address"/>
                        <ComboBoxItem Content="In tag"/>
                        <ComboBoxItem Content="In Address"/>
                        <ComboBoxItem Content="Memo"/>
                    </ComboBox>

                    <TextBox Grid.Column="6"
                             x:Name="BatchValueBox"
                             MinWidth="220"
                             Padding="8,6"
                             VerticalAlignment="Center"/>

                    <Button Grid.Column="8"
                            x:Name="ApplySelectionButton"
                            MinWidth="144"
                            Style="{StaticResource DarkButton}"
                            Content="선택 항목에 적용"
                            Click="ApplySelection_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="변경된 행만 프로젝트에 반영됩니다."
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>

                <Button Grid.Column="1"
                        MinWidth="82"
                        Style="{StaticResource DarkButton}"
                        Content="적용"
                        Click="Accept_Click"/>

                <Button Grid.Column="3"
                        MinWidth="82"
                        Style="{StaticResource DarkButton}"
                        Content="취소"
                        IsCancel="True"/>
            </Grid>
        </Grid>
    </Border>
</Window>
