<Window x:Class="Promaker.Dialogs.ProjectPropertiesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:b="clr-namespace:Promaker.Behaviors"
        Title="프로젝트 속성"
        Width="480" Height="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            b:CtrlWheelZoom.IsEnabled="True">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="6">
                <StackPanel>
                    <!-- Project Name -->
                    <TextBlock Text="프로젝트 이름"
                               FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,0,0,2"/>
                    <TextBox x:Name="ProjectNameBox" Padding="6,4" Margin="0,0,0,12"/>

                    <!-- Author -->
                    <TextBlock Text="작성자"
                               FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,0,0,2"/>
                    <TextBox x:Name="AuthorBox" Padding="6,4" Margin="0,0,0,12"/>

                    <!-- Version -->
                    <TextBlock Text="버전"
                               FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,0,0,2"/>
                    <TextBox x:Name="VersionBox" Padding="6,4" Margin="0,0,0,12"/>

                    <!-- Description -->
                    <TextBlock Text="설명"
                               FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,0,0,2"/>
                    <TextBox x:Name="DescriptionBox" Padding="6,4"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             Height="160"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="확인" Style="{StaticResource DarkButton}"
                        Padding="12,4" Margin="0,0,4,0"
                        Click="Ok_Click" IsDefault="True"/>
                <Button Content="취소" Style="{StaticResource DarkButton}"
                        Padding="12,4" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
