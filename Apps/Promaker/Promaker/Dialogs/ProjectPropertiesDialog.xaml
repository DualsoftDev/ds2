<Window x:Class="Promaker.Dialogs.ProjectPropertiesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정"
        Width="500" Height="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 탭 컨트롤 -->
            <TabControl Grid.Row="0" Margin="0,0,0,10">
                <!-- 탭 1: 일반 -->
                <TabItem Header="일반">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                        <StackPanel>
                            <!-- Project Name -->
                            <TextBlock Text="프로젝트 이름"
                                       FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,2"/>
                            <TextBox x:Name="ProjectNameBox" Padding="6,4" Margin="0,0,0,12"/>

                            <!-- Author -->
                            <TextBlock Text="작성자"
                                       FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,2"/>
                            <TextBox x:Name="AuthorBox" Padding="6,4" Margin="0,0,0,12"/>

                            <!-- Version -->
                            <TextBlock Text="버전"
                                       FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,2"/>
                            <TextBox x:Name="VersionBox" Padding="6,4" Margin="0,0,0,12"/>

                            <!-- Description -->
                            <TextBlock Text="설명"
                                       FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,2"/>
                            <TextBox x:Name="DescriptionBox" Padding="6,4"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     Height="200"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- 탭 2: AASX -->
                <TabItem Header="AASX">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                        <StackPanel>
                            <!-- IRI Prefix -->
                            <TextBlock Text="IRI Prefix"
                                       FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,2"/>
                            <TextBox x:Name="IriPrefixBox" Padding="6,4" Margin="0,0,0,2"/>
                            <TextBlock Text="Global Asset ID는 IRI Prefix + 프로젝트 이름으로 자동 생성됩니다"
                                       FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,16" FontStyle="Italic"/>

                            <!-- SplitDeviceAasx -->
                            <CheckBox x:Name="SplitDeviceAasxBox"
                                      Content="Device System을 별도 AASX 파일로 분리 저장"
                                      Foreground="{DynamicResource PrimaryTextBrush}"
                                      FontSize="12" Margin="0,0,0,2"/>
                            <TextBlock Text="저장 시 {파일명}_devices/ 폴더에 Device별 AASX를 생성합니다"
                                       FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="20,0,0,16" FontStyle="Italic"/>

                            <!-- CreateDefaultEntitiesOnEmptyAasx -->
                            <CheckBox x:Name="CreateDefaultEntitiesBox"
                                      Content="AASX 저장 시 빈 서브모델 Properties 자동 생성"
                                      Foreground="{DynamicResource PrimaryTextBrush}"
                                      FontSize="12" Margin="0,0,0,2"/>
                            <TextBlock Text="저장할 때 엔티티에 도메인 서브모델 Properties가 없으면 자동으로 생성합니다 (Simulation, Control, Monitoring 등)"
                                       FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="20,0,0,0" FontStyle="Italic" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- 탭 3: 프리셋 -->
                <TabItem Header="프리셋">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 프리셋/SystemType 입력 패널 -->
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 프리셋 입력 -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="프리셋" FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Margin="0,0,0,2"/>
                                <TextBox x:Name="PresetTextBox" Padding="6,4"/>
                            </StackPanel>

                            <!-- SystemType 입력 -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="SystemType" FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Margin="0,0,0,2"/>
                                <TextBox x:Name="SystemTypeTextBox" Padding="6,4" Text="Multi"/>
                            </StackPanel>

                            <!-- 추가 버튼 -->
                            <Button Grid.Column="4" Content="추가"
                                    Style="{StaticResource DarkButton}"
                                    Padding="12,4" VerticalAlignment="Bottom"
                                    Click="AddPreset_Click"/>

                            <!-- 제거 버튼 -->
                            <Button Grid.Column="6" Content="제거"
                                    Style="{StaticResource DarkButton}"
                                    Padding="12,4" VerticalAlignment="Bottom"
                                    Click="RemovePreset_Click"/>
                        </Grid>

                        <!-- 매핑 리스트 + 순서 조절 버튼 -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ListBox Grid.Column="0" x:Name="PresetMappingListBox"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     Background="{DynamicResource SecondaryBackgroundBrush}"
                                     SelectionChanged="PresetMappingListBox_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- 순서 조절 버튼 -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <Button Content="▲"
                                        Style="{StaticResource DarkButton}"
                                        Padding="8,2" Margin="0,0,0,4"
                                        ToolTip="위로 이동"
                                        Click="MoveUp_Click"/>
                                <Button Content="▼"
                                        Style="{StaticResource DarkButton}"
                                        Padding="8,2"
                                        ToolTip="아래로 이동"
                                        Click="MoveDown_Click"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- Buttons (ScrollViewer 밖에 배치) -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="확인" Style="{StaticResource DarkButton}"
                        Padding="12,4" Margin="0,0,4,0"
                        Click="Ok_Click" IsDefault="True"/>
                <Button Content="취소" Style="{StaticResource DarkButton}"
                        Padding="12,4" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
