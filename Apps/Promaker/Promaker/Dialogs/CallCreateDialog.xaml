<Window x:Class="Promaker.Dialogs.CallCreateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Call"
        Width="675"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TabControl x:Name="ModeTabControl" Grid.Row="0"
                        Background="{DynamicResource SecondaryBackgroundBrush}"
                        Foreground="{DynamicResource PrimaryTextBrush}"
                        BorderBrush="{DynamicResource BorderBrush}">

                <!-- ═══ 기본 탭 ═══ -->
                <TabItem Header="기본">
                    <StackPanel Margin="8">
                        <TextBlock Text="Call + Device System 추가"
                                   FontWeight="SemiBold" FontSize="13"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Call은 {DevicesAlias}.{ApiName} 형식으로 생성됩니다"
                                   FontSize="11" FontStyle="Italic"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,10"/>

                        <!-- DevicesAlias + Preset -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="DevicesAlias"
                                       FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="SystemType"
                                       FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,2"/>

                            <TextBox Grid.Row="1" Grid.Column="0" x:Name="BasicAliasTextBox"
                                     Padding="6,4"/>
                            <ComboBox Grid.Row="1" Grid.Column="2" x:Name="PresetComboBox"
                                      SelectionChanged="OnPresetChanged"/>
                        </Grid>

                        <!-- ApiName -->
                        <TextBlock Text="ApiName (';'로 구분)"
                                   FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,2"/>
                        <TextBox x:Name="BasicApiNameTextBox"
                                 Padding="6,4" Text="" IsEnabled="False"
                                 Margin="0,0,0,12"
                                 TextChanged="OnBasicApiNameChanged"/>

                        <!-- 추가 기능 (접힌 상태) -->
                        <Expander x:Name="AdvancedExpander"
                                  Header="추가 기능"
                                  IsExpanded="False"
                                  Foreground="{DynamicResource SecondaryTextBrush}"
                                  FontSize="11"
                                  Margin="0,0,0,0">
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="4" Padding="8" Margin="0,6,0,0">
                                <Border.Resources>
                                    <Style x:Key="ReplicationHint" TargetType="TextBlock">
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="FontStyle" Value="Italic"/>
                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.35"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Resources>
                                <Grid HorizontalAlignment="Left">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 왼쪽: Call 복제 (좁게) -->
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <RadioButton x:Name="RadioCallReplication"
                                                         GroupName="ReplicationMode"
                                                         Content="Call 복제" IsChecked="True"
                                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                                         FontWeight="SemiBold"
                                                         Checked="OnReplicationRadioChanged"
                                                         VerticalAlignment="Center"/>
                                            <TextBlock Text="개수" FontSize="11"
                                                       VerticalAlignment="Center" Margin="8,0,4,0"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBox x:Name="CallCountTextBox" Width="40"
                                                     Padding="6,3" Text="1" TextAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     GotFocus="OnCallCountFocus"
                                                     TextChanged="OnCallCountChanged"/>
                                        </StackPanel>
                                        <TextBlock x:Name="CallReplicationPanel" Style="{StaticResource ReplicationHint}"
                                                   Text="Conv → Conv1, Conv2"/>
                                    </StackPanel>

                                    <!-- 구분선 -->
                                    <Border Grid.Column="1"
                                            Width="1" Margin="10,0"
                                            Background="{DynamicResource BorderBrush}"/>

                                    <!-- 가운데: ApiCall 복제 -->
                                    <StackPanel Grid.Column="2">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <RadioButton x:Name="RadioApiCallReplication"
                                                         GroupName="ReplicationMode"
                                                         Content="ApiCall 복제"
                                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                                         FontWeight="SemiBold"
                                                         Checked="OnReplicationRadioChanged"
                                                         VerticalAlignment="Center"/>
                                            <TextBlock Text="개수" FontSize="11"
                                                       VerticalAlignment="Center" Margin="8,0,4,0"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBox x:Name="ApiCallCountTextBox" Width="40"
                                                     Padding="6,3" Text="1" TextAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     GotFocus="OnApiCallCountFocus"
                                                     TextChanged="OnApiCallCountChanged"/>
                                        </StackPanel>
                                        <TextBlock x:Name="ApiCallReplicationPanel" Style="{StaticResource ReplicationHint}"
                                                   Text="1 Call 안 N ApiCall"/>
                                    </StackPanel>

                                    <!-- 구분선 -->
                                    <Border Grid.Column="3"
                                            Width="1" Margin="10,0"
                                            Background="{DynamicResource BorderBrush}"/>

                                    <!-- 오른쪽: 신호 수량 (API 별 콤보) — ApiCall 복제 모드에서만 활성 -->
                                    <StackPanel x:Name="SignalCountsContainer" Grid.Column="4" Visibility="Collapsed"
                                                IsEnabled="{Binding IsChecked, ElementName=RadioApiCallReplication}">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Opacity" Value="0.35"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="신호 수량" FontWeight="SemiBold" FontSize="12"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <ComboBox x:Name="SignalCountApiCombo" Width="110" Margin="8,0,4,0"
                                                      VerticalAlignment="Center"
                                                      SelectionChanged="OnSignalCountApiChanged"/>
                                            <TextBox x:Name="SignalCountValueBox" Width="44"
                                                     Padding="6,3" Text="1" TextAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     TextChanged="OnSignalCountValueChanged"/>
                                            <TextBlock x:Name="SignalCountMaxLabel" Text=""
                                                       FontSize="10" VerticalAlignment="Center" Margin="6,0,0,0"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        </StackPanel>
                                        <TextBlock Text="ApiName 선택 → 수량 입력 (FB max 자동 클램프)"
                                                   FontSize="10" FontStyle="Italic"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Expander>
                    </StackPanel>
                </TabItem>

                <!-- ═══ 고급 탭: ApiDef 연결 ═══ -->
                <TabItem Header="고급">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="ApiName으로 기존 ApiDef를 검색하고 DevicesAlias를 지정해 Call과 연결합니다."
                                   FontSize="11" FontStyle="Italic"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,8"/>

                        <Grid Grid.Row="1" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="DevicesAlias"
                                       FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,2"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="ApiName"
                                       FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,0,0,2"/>
                            <TextBox Grid.Row="1" Grid.Column="0" x:Name="AdvAliasFilterBox"
                                     Padding="6,4"/>
                            <TextBox Grid.Row="1" Grid.Column="2" x:Name="AdvApiNameFilterBox"
                                     Padding="6,4" TextChanged="OnApiNameFilterChanged"/>
                        </Grid>

                        <TextBlock Grid.Row="2"
                                   Text="검색 결과"
                                   FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,2"/>
                        <ListBox Grid.Row="3" x:Name="ApiDefListBox"
                                 DisplayMemberPath="DisplayName"
                                 SelectionMode="Extended"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Background="{DynamicResource PrimaryBackgroundBrush}"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}"/>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- Buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="0,4,0,0">
                <Button Content="추가" Style="{StaticResource DarkButton}"
                        Padding="12,4" Margin="0,0,4,0"
                        Click="Add_Click" IsDefault="True"/>
                <Button Content="취소" Style="{StaticResource DarkButton}"
                        Padding="12,4" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
