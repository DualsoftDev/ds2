<Window x:Class="Promaker.Dialogs.CsvImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CSV 불러오기"
        Width="680"
        Height="720"
        MinWidth="620"
        MinHeight="560"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="CSV 가져오기"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="헤더는 flow,work,device,api,in,out 입니다. flow/work/device는 필수이고, api가 비면 Signal_&lt;addr&gt;로 보정됩니다."
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"/>

                    <Border Background="{DynamicResource TertiaryBackgroundBrush}"
                            CornerRadius="3"
                            Padding="10,8"
                            Margin="0,0,0,12">
                        <TextBlock FontFamily="Consolas"
                                   FontSize="12"
                                   xml:space="preserve">flow,work,device,api,in,out
Cutting,Load,PLC,ClampOn,M100.0,
Cutting,Load,Conveyor,,M10.0,Q20.0</TextBlock>
                    </Border>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="CSV 파일 불러오기..."
                                Style="{StaticResource DarkButton}"
                                Padding="12,4"
                                Click="Browse_Click"/>
                        <TextBlock x:Name="SourceText"
                                   Grid.Column="2"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"/>
                    </Grid>

                    <TextBlock Text="CSV 내용"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="ContentBox"
                             MinHeight="220"
                             Padding="8,6"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="12"
                             TextChanged="ContentBox_TextChanged"/>

                    <TextBlock Text="파일을 불러오면 여기에 채워지고, 직접 수정하거나 그대로 붙여넣어도 됩니다."
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,8,0,12"
                               TextWrapping="Wrap"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Project 이름"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="ProjectNameBox"
                                     Padding="8,6"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Active System 이름"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="SystemNameBox"
                                     Padding="8,6"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="미리보기"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <Border Background="{DynamicResource TertiaryBackgroundBrush}"
                            CornerRadius="3"
                            Padding="10,8"
                            Margin="0,0,0,12">
                        <TextBlock x:Name="PreviewText"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Border x:Name="ErrorBorder"
                            Background="#30FF5050"
                            CornerRadius="3"
                            Padding="10,8"
                            Margin="0,0,0,12"
                            Visibility="Collapsed">
                        <TextBlock x:Name="ErrorText"
                                   FontSize="12"
                                   Foreground="{DynamicResource RedAccentBrush}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Border x:Name="WarningBorder"
                            Background="#30FFA500"
                            CornerRadius="3"
                            Padding="10,8"
                            Margin="0,0,0,12"
                            Visibility="Collapsed">
                        <TextBlock x:Name="WarningText"
                                   FontSize="12"
                                   Foreground="{DynamicResource OrangeAccentBrush}"
                                   TextWrapping="Wrap"/>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">
                <Button x:Name="OkButton"
                        Content="불러오기"
                        Style="{StaticResource DarkButton}"
                        Padding="12,4"
                        Margin="0,0,4,0"
                        IsDefault="True"
                        Click="Ok_Click"/>
                <Button Content="취소"
                        Style="{StaticResource DarkButton}"
                        Padding="12,4"
                        IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
