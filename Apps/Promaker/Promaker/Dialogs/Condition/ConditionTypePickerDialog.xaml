<Window x:Class="Promaker.Dialogs.ConditionTypePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="조건 유형 선택"
        Width="300" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Padding="16">
        <StackPanel>
            <TextBlock Text="조건 유형을 선택하세요:"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       FontSize="13" FontWeight="SemiBold"
                       Margin="0,0,0,12"/>

            <RadioButton x:Name="AutoAuxRadio" GroupName="CondType"
                         Content="AutoAux" IsChecked="True"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         Margin="0,0,0,6"/>
            <RadioButton x:Name="ComAuxRadio" GroupName="CondType"
                         Content="ComAux"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         Margin="0,0,0,6"/>
            <RadioButton x:Name="SkipUnmatchRadio" GroupName="CondType"
                         Content="SkipUnmatch"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         Margin="0,0,0,12"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="확인" Style="{StaticResource DarkButton}"
                        Padding="12,4" Margin="0,0,4,0"
                        IsDefault="True" Click="OK_Click"/>
                <Button Content="취소" Style="{StaticResource DarkButton}"
                        Padding="12,4" IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
