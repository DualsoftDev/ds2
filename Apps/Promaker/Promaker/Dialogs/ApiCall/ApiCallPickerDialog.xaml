<Window x:Class="Promaker.Dialogs.ApiCallPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ApiCall 선택"
        Width="380"
        Height="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="추가할 ApiCall을 선택하세요"
                       FontSize="11"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,0,0,6"/>

            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Background="{DynamicResource TertiaryBackgroundBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ItemsHost">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding DisplayName}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          Foreground="{DynamicResource PrimaryTextBrush}"
                                          FontSize="11"
                                          Margin="6,2"
                                          Checked="CheckBox_Changed"
                                          Unchecked="CheckBox_Changed"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button Content="전체 선택"
                        Style="{StaticResource DarkButton}"
                        Padding="12,4"
                        Margin="0,0,4,0"
                        Click="SelectAll_Click"/>
                <Button x:Name="OkButton"
                        Content="확인"
                        Style="{StaticResource DarkButton}"
                        Padding="16,4"
                        Margin="0,0,4,0"
                        IsDefault="True"
                        IsEnabled="False"
                        Click="OK_Click"/>
                <Button Content="취소"
                        Style="{StaticResource DarkButton}"
                        Padding="16,4"
                        IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
