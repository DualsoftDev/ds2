<Window x:Class="Promaker.Dialogs.ArrowTypeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="화살표 유형 선택"
        Width="450"
        Height="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="ArrowOptionRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="OptionBorder"
                                Background="{DynamicResource TertiaryBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="10,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Width="16" Height="16" Margin="3,0,3,0" VerticalAlignment="Top">
                                    <Ellipse Stroke="{DynamicResource AccentBrush}" StrokeThickness="2"/>
                                    <Ellipse x:Name="Dot"
                                             Width="8"
                                             Height="8"
                                             Fill="{DynamicResource AccentBrush}"
                                             Visibility="Collapsed"/>
                                </Grid>
                                <ContentPresenter Grid.Column="1"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Dot" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="OptionBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="OptionBorder" Property="Background" Value="{DynamicResource SelectedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OptionBorder" Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="OptionBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PinToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTip" Value="우클릭 메뉴에 표시"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Padding="2">
                            <Grid>
                                <iconPacks:PackIconMaterial x:Name="UnpinnedIcon"
                                      Kind="StarOutline"
                                      Foreground="{DynamicResource SecondaryTextBrush}"
                                      Width="16" Height="16"/>
                                <iconPacks:PackIconMaterial x:Name="PinnedIcon"
                                      Kind="Star"
                                      Foreground="{DynamicResource AccentBrush}"
                                      Width="16" Height="16"
                                      Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="UnpinnedIcon" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="PinnedIcon" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="연결 형식:"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10"/>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <RadioButton x:Name="StartRadio" GroupName="ArrowType" Style="{StaticResource ArrowOptionRadio}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <Canvas Width="44" Height="16" Margin="0,0,10,0">
                                        <Line X1="0" Y1="8" X2="34" Y2="8"
                                              Stroke="{DynamicResource GreenAccentBrush}" StrokeThickness="2.5"/>
                                        <Path Canvas.Left="34" Canvas.Top="2.5"
                                              Data="M0,0 L8,5.5 L0,11 Z"
                                              Fill="{DynamicResource GreenAccentBrush}"/>
                                    </Canvas>
                                    <TextBlock Text="시작 인과" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="A작업이 끝난 후 B작업 시작"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="11"
                                           Margin="54,2,0,0"/>
                            </StackPanel>
                            <ToggleButton x:Name="StartPin" Grid.Column="1"
                                          Style="{StaticResource PinToggleStyle}"
                                          VerticalAlignment="Top" Margin="8,0,0,0"
                                          Click="Pin_Click" Tag="Start"/>
                        </Grid>
                    </RadioButton>

                    <RadioButton x:Name="ResetRadio" GroupName="ArrowType" Style="{StaticResource ArrowOptionRadio}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <Canvas Width="44" Height="16" Margin="0,0,10,0">
                                        <Line X1="0" Y1="8" X2="34" Y2="8"
                                              Stroke="{DynamicResource OrangeAccentBrush}" StrokeThickness="2.5"
                                              StrokeDashArray="2,1.5"/>
                                        <Path Canvas.Left="34" Canvas.Top="2.5"
                                              Data="M0,0 L8,5.5 L0,11 Z"
                                              Fill="{DynamicResource OrangeAccentBrush}"/>
                                    </Canvas>
                                    <TextBlock Text="리셋 인과" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="A작업 시작과 동시에 B작업이 리셋"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="11"
                                           Margin="54,2,0,0"/>
                            </StackPanel>
                            <ToggleButton x:Name="ResetPin" Grid.Column="1"
                                          Style="{StaticResource PinToggleStyle}"
                                          VerticalAlignment="Top" Margin="8,0,0,0"
                                          Click="Pin_Click" Tag="Reset"/>
                        </Grid>
                    </RadioButton>

                    <RadioButton x:Name="StartResetRadio" GroupName="ArrowType" Style="{StaticResource ArrowOptionRadio}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <Canvas Width="44" Height="16" Margin="0,0,10,0">
                                        <Rectangle Canvas.Left="0" Canvas.Top="3.5" Width="6" Height="9" Fill="{DynamicResource RedAccentBrush}" RadiusX="0.5" RadiusY="0.5"/>
                                        <Line X1="6" Y1="8" X2="34" Y2="8"
                                              Stroke="{DynamicResource RedAccentBrush}" StrokeThickness="2.5"/>
                                        <Path Canvas.Left="34" Canvas.Top="2.5"
                                              Data="M0,0 L8,5.5 L0,11 Z"
                                              Fill="{DynamicResource RedAccentBrush}"/>
                                    </Canvas>
                                    <TextBlock Text="시작리셋 인과" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="A가 끝나면 B시작과 동시에 A가 리셋"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Margin="54,2,0,0"/>
                            </StackPanel>
                            <ToggleButton x:Name="StartResetPin" Grid.Column="1"
                                          Style="{StaticResource PinToggleStyle}"
                                          VerticalAlignment="Top" Margin="8,0,0,0"
                                          Click="Pin_Click" Tag="StartReset"/>
                        </Grid>
                    </RadioButton>

                    <RadioButton x:Name="ResetResetRadio" GroupName="ArrowType" Style="{StaticResource ArrowOptionRadio}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <Canvas Width="44" Height="16" Margin="0,0,10,0">
                                        <Path Canvas.Left="0" Canvas.Top="2.5"
                                              Data="M8,0 L0,5.5 L8,11 Z"
                                              Fill="{DynamicResource OrangeAccentBrush}"/>
                                        <Line X1="8" Y1="8" X2="34" Y2="8"
                                              Stroke="{DynamicResource OrangeAccentBrush}" StrokeThickness="2.5"
                                              StrokeDashArray="2,1.5"/>
                                        <Path Canvas.Left="34" Canvas.Top="2.5"
                                              Data="M0,0 L8,5.5 L0,11 Z"
                                              Fill="{DynamicResource OrangeAccentBrush}"/>
                                    </Canvas>
                                    <TextBlock Text="상호리셋 인과" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="A와 B가 서로 리셋"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="11"
                                           Margin="54,2,0,0"/>
                            </StackPanel>
                            <ToggleButton x:Name="ResetResetPin" Grid.Column="1"
                                          Style="{StaticResource PinToggleStyle}"
                                          VerticalAlignment="Top" Margin="8,0,0,0"
                                          Click="Pin_Click" Tag="ResetReset"/>
                        </Grid>
                    </RadioButton>

                    <RadioButton x:Name="GroupRadio" GroupName="ArrowType" Style="{StaticResource ArrowOptionRadio}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <Canvas Width="44" Height="16" Margin="0,0,10,0">
                                        <Line X1="0" Y1="8" X2="44" Y2="8"
                                              Stroke="{DynamicResource AccentBrush}" StrokeThickness="2.5"/>
                                    </Canvas>
                                    <TextBlock Text="그룹연결" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="그룹 간 연결 (직선)"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="11"
                                           Margin="54,2,0,0"/>
                            </StackPanel>
                            <ToggleButton x:Name="GroupPin" Grid.Column="1"
                                          Style="{StaticResource PinToggleStyle}"
                                          VerticalAlignment="Top" Margin="8,0,0,0"
                                          Click="Pin_Click" Tag="Group"/>
                        </Grid>
                    </RadioButton>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button x:Name="OkButton"
                        Content="확인"
                        Style="{StaticResource DarkButton}"
                        Padding="12,4"
                        Margin="0,0,4,0"
                        IsDefault="True"
                        Click="Ok_Click"/>
                <Button Content="취소"
                        Style="{StaticResource DarkButton}"
                        Padding="12,4"
                        IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
