<Window x:Class="Promaker.Dialogs.TokenSpecDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TokenSpec 관리"
        Width="640"
        Height="480"
        MinWidth="500"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="CanResize">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Text="TokenSpec 관리"
                       FontSize="18"
                       FontWeight="SemiBold"/>

            <!-- Toolbar -->
            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <Button Content="추가" Style="{StaticResource DarkButton}"
                        MinWidth="64" Height="28" Click="Add_Click" Margin="0,0,6,0"/>
                <Button Content="삭제" Style="{StaticResource DarkButton}"
                        MinWidth="64" Height="28" Click="Remove_Click" Margin="0,0,6,0"/>
                <Button Content="CSV 불러오기" Style="{StaticResource DarkButton}"
                        MinWidth="100" Height="28" Click="ImportCsv_Click"/>
            </StackPanel>

            <!-- DataGrid -->
            <Border Grid.Row="4"
                    Background="{DynamicResource TertiaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1">
                <DataGrid x:Name="SpecGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          SelectionMode="Extended"
                          SelectionUnit="FullRow"
                          RowHeaderWidth="0"
                          PreviewKeyDown="SpecGrid_PreviewKeyDown">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                        <DataGridTextColumn Header="Label" Binding="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="160"/>
                        <DataGridTextColumn Header="Source Work"
                                            Binding="{Binding WorkName}"
                                            IsReadOnly="True"
                                            Width="140"/>
                        <DataGridTextColumn Header="Fields (key=val, ...)" Binding="{Binding FieldsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Footer -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}">
                    <Run Text="토큰 사양 "/>
                    <Run x:Name="CountRun" Text="0" FontWeight="Bold"/>
                    <Run Text="건"/>
                </TextBlock>

                <Button Grid.Column="1"
                        MinWidth="82"
                        Style="{StaticResource DarkButton}"
                        Content="적용"
                        Click="Accept_Click"/>

                <Button Grid.Column="3"
                        MinWidth="82"
                        Style="{StaticResource DarkButton}"
                        Content="취소"
                        IsCancel="True"/>
            </Grid>
        </Grid>
    </Border>
</Window>
