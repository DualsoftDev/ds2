<?xml version="1.0" encoding="utf-8" ?>
<log4net>
  <!-- 날짜별 롤링 파일 (최대 10MB × 10개 백업) -->
  <appender name="RollingFile" type="log4net.Appender.RollingFileAppender">
    <file value="logs/ds2.log" />
    <appendToFile value="true" />
    <rollingStyle value="Composite" />
    <datePattern value="yyyyMMdd" />
    <maxSizeRollBackups value="10" />
    <maximumFileSize value="10MB" />
    <staticLogFileName value="false" />
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date{yyyy-MM-dd HH:mm:ss.fff} [%-5level] %logger{1} — %message%newline%exception" />
    </layout>
  </appender>

  <!-- Visual Studio 출력 창 -->
  <appender name="Debug" type="log4net.Appender.DebugAppender">
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="[%-5level] %logger{1} — %message%newline" />
    </layout>
  </appender>

  <root>
    <level value="DEBUG" />
    <appender-ref ref="RollingFile" />
    <appender-ref ref="Debug" />
  </root>

  <!-- ASP.NET Core / Kestrel / SignalR 의 Information 레벨 노이즈 차단:
       원위치·Control 모드에서 hub/PLC 게이트웨이 시작·종료 시 hosting/routing/connection
       관련 Information 로그가 다량 출력돼 우리 도메인 로그를 묻기 때문에 WARN 이상만 통과.
       (Graceful shutdown 시 cancel 토큰 1차 예외 자체는 .NET 런타임이 직접 출력하므로
        log4net 필터로는 막을 수 없다. VS 디버그 → 예외 설정에서 별도로 제어.) -->
  <logger name="Microsoft.AspNetCore">
    <level value="WARN" />
  </logger>
  <logger name="Microsoft.Hosting">
    <level value="WARN" />
  </logger>
  <logger name="Microsoft.Extensions.Hosting">
    <level value="WARN" />
  </logger>
</log4net>
