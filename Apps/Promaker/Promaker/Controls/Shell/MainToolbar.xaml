<UserControl x:Class="Promaker.Controls.MainToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:res="clr-namespace:Promaker.Resources"
             x:Name="ThisControl">
    <Border Background="{DynamicResource ToolbarShellBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="8,6">
        <Grid HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="RibbonGroupSelectorPanel"
                    Grid.Column="0"
                    Style="{StaticResource ToolbarGroup}"
                    Background="{DynamicResource ToolbarButtonBrush}"
                    Width="370">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <UniformGrid Rows="1"
                                 Columns="4"
                                 Margin="4,2,4,0">
                        <Button x:Name="ProjectRibbonGroupButton"
                                Command="{Binding ShowProjectRibbonGroupCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource RibbonGroupSelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRibbonGroup}" Value="Project">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                <Grid Width="18" Height="18">
                                    <Path Width="18"
                                          Height="18"
                                          Stretch="Uniform"
                                          Data="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="P"
                                               FontSize="8"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="0,1,0,0"
                                               Foreground="{DynamicResource ToolbarShellBrush}"/>
                                </Grid>
                                <TextBlock Text="{x:Static res:Strings.Project}"
                                           FontSize="9"
                                           HorizontalAlignment="Center"
                                           Margin="0,2,0,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="EditRibbonGroupButton"
                                Command="{Binding ShowEditRibbonGroupCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource RibbonGroupSelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRibbonGroup}" Value="Edit">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                <Path Width="18" Height="18" Stretch="Uniform"
                                      Data="M3 10h11v2H3v-2zm0-4h15v2H3V6zm0 8h9v2H3v-2zm12.59-5.41L17 10l3-3-1.41-1.41L17 7.17l-1.59-1.58L14 7l3 3-3 3 1.41 1.41L17 12.83l1.59 1.58L20 13z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="{x:Static res:Strings.Edit}"
                                           FontSize="9"
                                           HorizontalAlignment="Center"
                                           Margin="0,2,0,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="SimulationRibbonGroupButton"
                                Command="{Binding ShowSimulationRibbonGroupCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource RibbonGroupSelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRibbonGroup}" Value="Simulation">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                <Path Width="18" Height="18" Stretch="Uniform"
                                      Data="{StaticResource IconPlay}"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="{x:Static res:Strings.Simulation}"
                                           FontSize="9"
                                           HorizontalAlignment="Center"
                                           Margin="0,2,0,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="ToolsRibbonGroupButton"
                                Command="{Binding ShowToolsRibbonGroupCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource RibbonGroupSelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRibbonGroup}" Value="Tools">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                <Path Width="18" Height="18" Stretch="Uniform"
                                      Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.06-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.73,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.06,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.49-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="{x:Static res:Strings.Tools}"
                                           FontSize="9"
                                           HorizontalAlignment="Center"
                                           Margin="0,2,0,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>
                    </UniformGrid>

                    <Border Grid.Row="1" Style="{StaticResource ToolbarGroupLabelBorder}">
                        <TextBlock Text="메뉴" Style="{StaticResource ToolbarGroupLabel}"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource ToolbarGroup}"
                    Background="{DynamicResource ToolbarButtonBrush}"
                    MinWidth="200"
                    HorizontalAlignment="Left">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="4,2,4,0">
                        <WrapPanel x:Name="ProjectRibbonContentPanel"
                                   Orientation="Horizontal"
                                   VerticalAlignment="Center">
                            <WrapPanel.Style>
                                <Style TargetType="WrapPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRibbonGroup}" Value="Project">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </WrapPanel.Style>

                            <Button Style="{StaticResource SlimToolbarButton}"
                                    Command="{Binding NewProjectCommand}"
                                    ToolTip="{x:Static res:Strings.NewFileTooltip}">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <Path Width="18" Height="18" Stretch="Uniform"
                                          Data="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"
                                          Fill="{DynamicResource IconGrayBrush}"/>
                                    <TextBlock Text="{x:Static res:Strings.NewFile}" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource SlimToolbarButton}"
                                    Command="{Binding OpenFileCommand}"
                                    ToolTip="{x:Static res:Strings.LoadTooltip}">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <Path Width="18" Height="18" Stretch="Uniform"
                                          Data="M19,20H4C2.89,20 2,19.1 2,18V6C2,4.89 2.89,4 4,4H10L12,6H19A2,2 0 0,1 21,8H21L4,8V18L6.14,10H23.21L20.93,18.5C20.7,19.37 19.92,20 19,20Z"
                                          Fill="{DynamicResource IconGrayBrush}"/>
                                    <TextBlock Text="{x:Static res:Strings.Load}" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Button>

                            <Grid VerticalAlignment="Stretch">
                                <ToggleButton x:Name="SaveMenuToggle"
                                              Style="{StaticResource SlimToggleButton}"
                                              ToolTip="{x:Static res:Strings.SaveTooltip}">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                        <Path Width="18" Height="18" Stretch="Uniform"
                                              Data="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z"
                                              Fill="{DynamicResource IconGrayBrush}"/>
                                        <TextBlock Text="{x:Static res:Strings.Save}" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </ToggleButton>
                                <Popup IsOpen="{Binding IsChecked, ElementName=SaveMenuToggle, Mode=TwoWay}"
                                       StaysOpen="False"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding ElementName=SaveMenuToggle}"
                                       DataContext="{Binding DataContext, ElementName=ThisControl}">
                                    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="4"
                                            MinWidth="160">
                                        <StackPanel Orientation="Vertical">
                                            <Button Style="{StaticResource AddMenuItemButton}"
                                                    Command="{Binding SaveFileCommand}"
                                                    Click="CloseSavePopup">
                                                <TextBlock Text="{x:Static res:Strings.Save}" VerticalAlignment="Center"/>
                                            </Button>
                                            <Button Style="{StaticResource AddMenuItemButton}"
                                                    Command="{Binding SaveFileAsCommand}"
                                                    Click="CloseSavePopup">
                                                <TextBlock Text="{x:Static res:Strings.SaveAs}" VerticalAlignment="Center"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                        </WrapPanel>

                        <WrapPanel x:Name="EditRibbonContentPanel"
                                   Orientation="Horizontal"
                                   VerticalAlignment="Center">
                            <WrapPanel.Style>
                                <Style TargetType="WrapPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRibbonGroup}" Value="Edit">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </WrapPanel.Style>

                            <Button Style="{StaticResource SlimToolbarButton}" Command="{Binding UndoCommand}" ToolTip="{x:Static res:Strings.UndoTooltip}">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <Path Width="18" Height="18" Stretch="Uniform" Data="{StaticResource IconUndo}" Fill="{DynamicResource IconGrayBrush}"/>
                                    <TextBlock Text="{x:Static res:Strings.Undo}" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource SlimToolbarButton}" Command="{Binding RedoCommand}" ToolTip="{x:Static res:Strings.RedoTooltip}">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <Path Width="18" Height="18" Stretch="Uniform" Data="{StaticResource IconRedo}" Fill="{DynamicResource IconGrayBrush}"/>
                                    <TextBlock Text="{x:Static res:Strings.Redo}" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Button>

                            <ToggleButton x:Name="AddToggleBtn"
                                          Style="{StaticResource SlimToggleButton}"
                                          ToolTip="{x:Static res:Strings.Add}"
                                          IsEnabled="{Binding HasProject}">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <Path Width="18" Height="18" Stretch="Uniform"
                                          Data="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-1 9h-4v4h-2v-4H9V9h4V5h2v4h4v2z"
                                          Fill="{DynamicResource IconGrayBrush}"/>
                                    <TextBlock Text="{x:Static res:Strings.Add}" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </ToggleButton>
                            <Popup IsOpen="{Binding IsChecked, ElementName=AddToggleBtn, Mode=TwoWay}"
                                   StaysOpen="False"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=AddToggleBtn}"
                                   DataContext="{Binding DataContext, ElementName=ThisControl}">
                                <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="4"
                                        MinWidth="160">
                                    <StackPanel Orientation="Vertical">
                                        <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding AddSystemCommand}" Click="CloseAddPopup">
                                            <TextBlock Text="System" VerticalAlignment="Center"/>
                                        </Button>
                                        <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding AddFlowCommand}" Click="CloseAddPopup">
                                            <TextBlock Text="Flow" VerticalAlignment="Center"/>
                                        </Button>
                                        <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding AddWorkCommand}" Click="CloseAddPopup">
                                            <TextBlock Text="Work" VerticalAlignment="Center"/>
                                        </Button>
                                        <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding AddCallCommand}" Click="CloseAddPopup">
                                            <TextBlock Text="Call" VerticalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Popup>

                            <Button Style="{StaticResource SlimToolbarButton}"
                                    Command="{Binding DeleteSelectedCommand}"
                                    ToolTip="{x:Static res:Strings.DeleteTooltip}">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <Path Width="18" Height="18" Stretch="Uniform"
                                          Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                                          Fill="{DynamicResource IconRedBrush}"/>
                                    <TextBlock Text="{x:Static res:Strings.Delete}" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Button>

                            <ToggleButton x:Name="ModelToggleBtn"
                                          Style="{StaticResource SlimToggleButton}"
                                          ToolTip="{x:Static res:Strings.BatchEditTooltip}"
                                          IsEnabled="{Binding HasProject}">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <Path Width="18" Height="18" Stretch="Uniform"
                                          Data="M3 10h11v2H3v-2zm0-2h11V6H3v2zm0 8h7v-2H3v2zm15.01-3.13l1.41-1.41c.2-.2.51-.2.71 0l1.41 1.41c.2.2.2.51 0 .71l-1.41 1.41-2.12-2.12zm-.71.71l-5.3 5.3V21h2.12l5.3-5.3-2.12-2.12z"
                                          Fill="{DynamicResource IconGrayBrush}"/>
                                    <TextBlock Text="{x:Static res:Strings.BatchEdit}" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </ToggleButton>
                            <Popup IsOpen="{Binding IsChecked, ElementName=ModelToggleBtn, Mode=TwoWay}"
                                   StaysOpen="False"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=ModelToggleBtn}"
                                   DataContext="{Binding DataContext, ElementName=ThisControl}">
                                <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="4"
                                        MinWidth="160">
                                    <StackPanel Orientation="Vertical">
                                        <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding OpenIoBatchDialogCommand}" Click="CloseModelPopup">
                                            <TextBlock Text="I/O" VerticalAlignment="Center"/>
                                        </Button>
                                        <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding OpenDurationBatchDialogCommand}" Click="CloseModelPopup">
                                            <TextBlock Text="Duration" VerticalAlignment="Center"/>
                                        </Button>
                                        <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding OpenTokenSpecDialogCommand}" Click="CloseModelPopup">
                                            <TextBlock Text="TokenSpec" VerticalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Popup>

                            <Button Style="{StaticResource SlimToolbarButton}" Command="{Binding AutoLayoutCommand}" ToolTip="{x:Static res:Strings.AutoLayoutTooltip}">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <Path Width="18" Height="18" Stretch="Uniform" Data="{StaticResource IconGrid}" Fill="{DynamicResource IconGrayBrush}"/>
                                    <TextBlock Text="{x:Static res:Strings.AutoLayout}" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>

                        <WrapPanel x:Name="SimulationRibbonContentPanel"
                                   Orientation="Horizontal"
                                   VerticalAlignment="Center"
                                   DataContext="{Binding Simulation}">
                            <WrapPanel.Style>
                                <Style TargetType="WrapPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.SelectedRibbonGroup, ElementName=ThisControl}" Value="Simulation">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </WrapPanel.Style>

                            <Button IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SlimToolbarButton}">
                                        <Setter Property="Command" Value="{Binding StartSimulationCommand}"/>
                                        <Setter Property="ToolTip" Value="{x:Static res:Strings.StartSimulationTooltip}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource IconGreenBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSimulating}" Value="True">
                                                <Setter Property="Command" Value="{Binding StopSimulationCommand}"/>
                                                <Setter Property="ToolTip" Value="{x:Static res:Strings.StopSimulationTooltip}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource IconRedBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <Path Width="18" Height="18" Stretch="Uniform"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Data" Value="{StaticResource IconPlay}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSimulating}" Value="True">
                                                        <Setter Property="Data" Value="{StaticResource IconStop}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                    <TextBlock FontSize="9"
                                               HorizontalAlignment="Center"
                                               Margin="0,2,0,0"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{x:Static res:Strings.Start}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSimulating}" Value="True">
                                                        <Setter Property="Text" Value="{x:Static res:Strings.Stop}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource SlimToolbarButton}" Command="{Binding PauseSimulationCommand}" ToolTip="{x:Static res:Strings.PauseSimulationTooltip}" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <Path Width="18" Height="18" Stretch="Uniform" Data="{StaticResource IconPause}" Fill="{DynamicResource IconGrayBrush}"/>
                                    <TextBlock Text="{x:Static res:Strings.Pause}" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource SlimToolbarButton}"
                                    Command="{Binding ResetSimulationCommand}"
                                    ToolTip="{x:Static res:Strings.ResetSimulationTooltip}"
                                    IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}"
                                    Foreground="{DynamicResource IconOrangeBrush}">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <Path Width="18"
                                          Height="18"
                                          Stretch="Uniform"
                                          Data="{StaticResource IconRefresh}"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="{x:Static res:Strings.Reset}"
                                               FontSize="9"
                                               HorizontalAlignment="Center"
                                               Margin="0,2,0,0"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </StackPanel>
                            </Button>

                            <Border Style="{StaticResource RibbonContentSeparator}"/>

                            <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,6,0" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}">
                                <TextBlock Text="공정" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                <ComboBox x:Name="SimWorkComboBox"
                                          ItemsSource="{Binding SimWorkItems}"
                                          SelectedItem="{Binding SelectedSimWork}"
                                          Width="130"
                                          FontSize="11"/>
                                <UniformGrid Columns="2" Margin="0,6,0,0">
                                    <Button x:Name="ForceWorkStartButton"
                                            Command="{Binding ForceWorkStartCommand}"
                                            ToolTip="{x:Static res:Strings.ForceWorkStartTooltip}"
                                            IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}"
                                            Margin="0,0,4,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SlimToolbarButton}">
                                                <Setter Property="Foreground" Value="{DynamicResource IconGreenBrush}"/>
                                                <Setter Property="MinWidth" Value="0"/>
                                                <Setter Property="MinHeight" Value="0"/>
                                                <Setter Property="Padding" Value="8,4"/>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Path Width="10"
                                                  Height="10"
                                                  Stretch="Uniform"
                                                  Data="{StaticResource IconPlay}"
                                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  Margin="0,0,4,0"/>
                                            <TextBlock Text="{x:Static res:Strings.Start}"
                                                       VerticalAlignment="Center"
                                                       FontSize="11"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="ForceWorkResetButton"
                                            Command="{Binding ForceWorkResetCommand}"
                                            ToolTip="{x:Static res:Strings.ForceWorkResetTooltip}"
                                            IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}"
                                            Margin="4,0,0,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SlimToolbarButton}">
                                                <Setter Property="Foreground" Value="{DynamicResource IconOrangeBrush}"/>
                                                <Setter Property="MinWidth" Value="0"/>
                                                <Setter Property="MinHeight" Value="0"/>
                                                <Setter Property="Padding" Value="8,4"/>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Path Width="10"
                                                  Height="10"
                                                  Stretch="Uniform"
                                                  Data="{StaticResource IconRefresh}"
                                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  Margin="0,0,4,0"/>
                                            <TextBlock Text="{x:Static res:Strings.Reset}"
                                                       VerticalAlignment="Center"
                                                       FontSize="11"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                        </StackPanel>
                                    </Button>
                                </UniformGrid>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,4,0" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}">
                                <TextBlock Text="{x:Static res:Strings.Speed}" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                <ComboBox x:Name="SimSpeedComboBox" SelectedValue="{Binding SimSpeed}" SelectedValuePath="Tag" Width="72" FontSize="11">
                                    <ComboBoxItem Content="0.5x">
                                        <ComboBoxItem.Tag>
                                            <sys:Double>0.5</sys:Double>
                                        </ComboBoxItem.Tag>
                                    </ComboBoxItem>
                                    <ComboBoxItem Content="1x">
                                        <ComboBoxItem.Tag>
                                            <sys:Double>1.0</sys:Double>
                                        </ComboBoxItem.Tag>
                                    </ComboBoxItem>
                                    <ComboBoxItem Content="2x">
                                        <ComboBoxItem.Tag>
                                            <sys:Double>2.0</sys:Double>
                                        </ComboBoxItem.Tag>
                                    </ComboBoxItem>
                                    <ComboBoxItem Content="5x">
                                        <ComboBoxItem.Tag>
                                            <sys:Double>5.0</sys:Double>
                                        </ComboBoxItem.Tag>
                                    </ComboBoxItem>
                                    <ComboBoxItem Content="10x">
                                        <ComboBoxItem.Tag>
                                            <sys:Double>10.0</sys:Double>
                                        </ComboBoxItem.Tag>
                                    </ComboBoxItem>
                                    <ComboBoxItem Content="{x:Static res:Strings.IgnoreTime}">
                                        <ComboBoxItem.Tag>
                                            <sys:Double>0</sys:Double>
                                        </ComboBoxItem.Tag>
                                    </ComboBoxItem>
                                </ComboBox>
                            </StackPanel>
                        </WrapPanel>

                        <WrapPanel x:Name="ToolsRibbonContentPanel"
                                   Orientation="Horizontal"
                                   VerticalAlignment="Center">
                            <WrapPanel.Style>
                                <Style TargetType="WrapPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRibbonGroup}" Value="Tools">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </WrapPanel.Style>

                            <!-- I/O편집 -->
                            <Button Style="{StaticResource SlimToolbarButton}"
                                    Command="{Binding OpenIoBatchDialogCommand}"
                                    IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}"
                                    ToolTip="I/O 일괄 편집">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <Path Width="18" Height="18" Stretch="Uniform"
                                          Data="M3 3h18v2H3V3zm0 4h12v2H3V7zm0 4h18v2H3v-2zm0 4h12v2H3v-2zm0 4h18v2H3v-2z"
                                          Fill="{DynamicResource IconGrayBrush}"/>
                                    <TextBlock Text="I/O편집" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Button>

                            <!-- Duration 편집 -->
                            <Button Style="{StaticResource SlimToolbarButton}"
                                    Command="{Binding OpenDurationBatchDialogCommand}"
                                    IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}"
                                    ToolTip="Duration 일괄 편집">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <Path Width="18" Height="18" Stretch="Uniform"
                                          Data="{StaticResource IconClock}"
                                          Fill="{DynamicResource IconGrayBrush}"/>
                                    <TextBlock Text="시간편집" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="ThemeToggleButton"
                                    Style="{StaticResource SlimToolbarButton}"
                                    Command="{Binding ToggleThemeCommand}"
                                    ToolTip="{Binding ThemeButtonToolTip}">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <Path Width="18" Height="18" Stretch="Uniform"
                                          Data="M12 3a1 1 0 0 1 .98 1.2A7 7 0 0 0 20.8 12a1 1 0 0 1 1.2.98A10 10 0 1 1 12 3z"
                                          Fill="{DynamicResource IconGrayBrush}"/>
                                    <TextBlock Text="{Binding ThemeButtonText}" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Button>

                            <!-- 데이터 (리포트 + CSV) -->
                            <Grid VerticalAlignment="Stretch">
                                <ToggleButton x:Name="DataToggleBtn"
                                              Style="{StaticResource SlimToggleButton}"
                                              ToolTip="{x:Static res:Strings.Data}">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                        <Path Width="18" Height="18" Stretch="Uniform"
                                              Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"
                                              Fill="{DynamicResource IconGrayBrush}"/>
                                        <TextBlock Text="{x:Static res:Strings.Data}" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </ToggleButton>
                                <Popup IsOpen="{Binding IsChecked, ElementName=DataToggleBtn, Mode=TwoWay}"
                                       StaysOpen="False"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding ElementName=DataToggleBtn}"
                                       DataContext="{Binding DataContext, ElementName=ThisControl}">
                                    <Border Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="4" MinWidth="160">
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="{x:Static res:Strings.Report}" FontSize="11" FontWeight="SemiBold" Margin="8,4,8,4" Foreground="{DynamicResource ForegroundBrush}"/>
                                            <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding Simulation.ExportReportCsvCommand}" Click="CloseDataPopup" IsEnabled="{Binding Simulation.HasReportData}"><TextBlock Text="CSV (.csv)"/></Button>
                                            <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding Simulation.ExportReportXlsxCommand}" Click="CloseDataPopup" IsEnabled="{Binding Simulation.HasReportData}"><TextBlock Text="Excel (.xlsx)"/></Button>
                                            <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding Simulation.ExportReportHtmlCommand}" Click="CloseDataPopup" IsEnabled="{Binding Simulation.HasReportData}"><TextBlock Text="HTML (.html)"/></Button>
                                            <Separator Margin="4,4"/>
                                            <TextBlock Text="CSV" FontSize="11" FontWeight="SemiBold" Margin="8,4,8,4" Foreground="{DynamicResource ForegroundBrush}"/>
                                            <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding ImportCsvCommand}" Click="CloseDataPopup"><TextBlock Text="{x:Static res:Strings.LoadCsv}"/></Button>
                                            <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding ExportCsvCommand}" Click="CloseDataPopup"><TextBlock Text="{x:Static res:Strings.ExportCsv}"/></Button>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>

                            <!-- 설정 -->
                            <Button Style="{StaticResource SlimToolbarButton}"
                                    Command="{Binding ShowProjectSettingsCommand}"
                                    IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}"
                                    ToolTip="{x:Static res:Strings.Settings}">
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                    <Path Width="18" Height="18" Stretch="Uniform"
                                          Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.06-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.73,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.06,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.49-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z"
                                          Fill="{DynamicResource IconGrayBrush}"/>
                                    <TextBlock Text="{x:Static res:Strings.Settings}" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </Grid>

                    <Border Grid.Row="1" Style="{StaticResource ToolbarGroupLabelBorder}">
                        <TextBlock Text="{Binding SelectedRibbonGroupLabel}" Style="{StaticResource ToolbarGroupLabel}"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
