<UserControl x:Class="Promaker.Controls.MainToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Promaker.Controls"
             xmlns:res="clr-namespace:Promaker.Resources">
    <Border Background="{DynamicResource ToolbarShellBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="8,6">
        <Grid HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="RibbonGroupSelectorPanel"
                    Grid.Column="0"
                    Style="{StaticResource ToolbarGroup}"
                    Background="{DynamicResource ToolbarButtonBrush}"
                    Width="370">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <UniformGrid Rows="1"
                                 Columns="4"
                                 Margin="4,2,4,0">
                        <Button x:Name="ProjectRibbonGroupButton"
                                Command="{Binding ShowProjectRibbonGroupCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource RibbonGroupSelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRibbonGroup}" Value="Project">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                <Grid Width="18" Height="18">
                                    <Path Width="18"
                                          Height="18"
                                          Stretch="Uniform"
                                          Data="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="P"
                                               FontSize="8"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="0,1,0,0"
                                               Foreground="{DynamicResource ToolbarShellBrush}"/>
                                </Grid>
                                <TextBlock Text="{x:Static res:Strings.Project}"
                                           FontSize="9"
                                           HorizontalAlignment="Center"
                                           Margin="0,2,0,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="EditRibbonGroupButton"
                                Command="{Binding ShowEditRibbonGroupCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource RibbonGroupSelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRibbonGroup}" Value="Edit">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                <Path Width="18"
                                      Height="18"
                                      Stretch="Uniform"
                                      Data="M3 10h11v2H3v-2zm0-4h15v2H3V6zm0 8h9v2H3v-2zm12.59-5.41L17 10l3-3-1.41-1.41L17 7.17l-1.59-1.58L14 7l3 3-3 3 1.41 1.41L17 12.83l1.59 1.58L20 13z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="{x:Static res:Strings.Edit}"
                                           FontSize="9"
                                           HorizontalAlignment="Center"
                                           Margin="0,2,0,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="SimulationRibbonGroupButton"
                                Command="{Binding ShowSimulationRibbonGroupCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource RibbonGroupSelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRibbonGroup}" Value="Simulation">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                <Path Width="18"
                                      Height="18"
                                      Stretch="Uniform"
                                      Data="{StaticResource IconPlay}"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="{x:Static res:Strings.Simulation}"
                                           FontSize="9"
                                           HorizontalAlignment="Center"
                                           Margin="0,2,0,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="ToolsRibbonGroupButton"
                                Command="{Binding ShowToolsRibbonGroupCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource RibbonGroupSelectorButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedRibbonGroup}" Value="Tools">
                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                <Path Width="18"
                                      Height="18"
                                      Stretch="Uniform"
                                      Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.06-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.73,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.06,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.49-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <TextBlock Text="{x:Static res:Strings.Tools}"
                                           FontSize="9"
                                           HorizontalAlignment="Center"
                                           Margin="0,2,0,0"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </StackPanel>
                        </Button>
                    </UniformGrid>

                    <Border Grid.Row="1" Style="{StaticResource ToolbarGroupLabelBorder}">
                        <TextBlock Text="메뉴" Style="{StaticResource ToolbarGroupLabel}"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource ToolbarGroup}"
                    Background="{DynamicResource ToolbarButtonBrush}"
                    MinWidth="200"
                    HorizontalAlignment="Left">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="4,2,4,0">
                        <local:MainToolbarProjectEditContent/>
                        <local:MainToolbarSimulationContent/>
                        <local:MainToolbarToolsContent/>
                    </Grid>

                    <Border Grid.Row="1" Style="{StaticResource ToolbarGroupLabelBorder}">
                        <TextBlock Text="{Binding SelectedRibbonGroupLabel}" Style="{StaticResource ToolbarGroupLabel}"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
