<UserControl x:Class="Promaker.Controls.MainToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:core="clr-namespace:Ds2.Core;assembly=Ds2.Core"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:res="clr-namespace:Promaker.Resources"
             xmlns:pres="clr-namespace:Promaker.Presentation"
             xmlns:controls="clr-namespace:Promaker.Controls"
             x:Name="ThisControl">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="MainToolbarResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <pres:FileNameConverter x:Key="FileNameConverter"/>
            <pres:ZeroToVisibilityConverter x:Key="ZeroToVisibleConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{DynamicResource ToolbarShellBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="6,2,6,4">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/> <!-- 0: File -->
                <ColumnDefinition Width="Auto"/> <!-- 1: sep -->
                <ColumnDefinition Width="Auto"/> <!-- 2: Edit -->
                <ColumnDefinition Width="Auto"/> <!-- 3: sep -->
                <ColumnDefinition Width="Auto"/> <!-- 4: Check -->
                <ColumnDefinition Width="Auto"/> <!-- 5: sep -->
                <ColumnDefinition Width="Auto"/> <!-- 6: Connect -->
                <ColumnDefinition Width="Auto"/> <!-- 7: sep -->
                <ColumnDefinition Width="Auto"/> <!-- 8: Simulation -->
                <ColumnDefinition Width="Auto"/> <!-- 9: sep -->
                <ColumnDefinition Width="*"/>    <!-- 10: spacer -->
                <ColumnDefinition Width="Auto"/> <!-- 11: Util -->
                <ColumnDefinition Width="Auto"/> <!-- 12: Settings -->
            </Grid.ColumnDefinitions>

            <!-- File Section -->
            <Grid x:Name="ProjectQuickAccessSection" Grid.Column="0">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <WrapPanel Orientation="Horizontal">
                    <Button x:Name="NewProjectQuickButton" Style="{StaticResource RibbonFlatButton}" Command="{Binding NewProjectCommand}" ToolTip="{x:Static res:Strings.NewFileTooltip}">
                        <StackPanel Orientation="Vertical"><iconPacks:PackIconMaterial Kind="FileDocumentPlus" Width="18" Height="18" HorizontalAlignment="Center" Foreground="{DynamicResource IconGrayBrush}"/><TextBlock Text="{x:Static res:Strings.NewFile}" Style="{StaticResource RibbonIconLabel}"/></StackPanel>
                    </Button>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="OpenFileQuickButton" Style="{StaticResource RibbonFlatButton}" Command="{Binding OpenFileCommand}" ToolTip="{x:Static res:Strings.LoadTooltip}" Padding="6,4,2,4">
                            <StackPanel Orientation="Vertical"><iconPacks:PackIconMaterial Kind="FolderOpen" Width="18" Height="18" HorizontalAlignment="Center" Foreground="{DynamicResource IconGrayBrush}"/><TextBlock Text="{x:Static res:Strings.Load}" Style="{StaticResource RibbonIconLabel}"/></StackPanel>
                        </Button>
                        <Grid>
                            <ToggleButton x:Name="OpenMenuToggle" Style="{StaticResource RibbonFlatToggleButton}" ToolTip="최근 파일" Padding="0,4" MinWidth="14" VerticalAlignment="Stretch">
                                <iconPacks:PackIconMaterial Kind="ChevronDown" Width="10" Height="10" Foreground="{DynamicResource IconGrayBrush}"/>
                            </ToggleButton>
                            <Popup IsOpen="{Binding IsChecked, ElementName=OpenMenuToggle, Mode=TwoWay}" StaysOpen="False" Placement="Bottom" PlacementTarget="{Binding ElementName=OpenMenuToggle}" DataContext="{Binding DataContext, ElementName=ThisControl}">
                                <Border Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="4" MinWidth="300" MaxWidth="500">
                                    <StackPanel>
                                        <TextBlock Text="최근 파일" FontSize="11" FontWeight="SemiBold" Margin="8,4,8,8" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <ItemsControl ItemsSource="{Binding RecentFiles}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource AddMenuItemButton}"
                                                            Command="{Binding DataContext.OpenRecentFileCommand, ElementName=ThisControl}"
                                                            CommandParameter="{Binding}"
                                                            Click="CloseOpenPopup"
                                                            ToolTip="{Binding}"
                                                            HorizontalContentAlignment="Left">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <iconPacks:PackIconMaterial Kind="FileDocument" Width="14" Height="14"
                                                                                        Foreground="{DynamicResource AccentBrush}"
                                                                                        Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding}"
                                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="최근 파일이 없습니다"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   Margin="8,8,8,4"
                                                   HorizontalAlignment="Center"
                                                   Visibility="{Binding RecentFiles.Count, Converter={StaticResource ZeroToVisibleConverter}}"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource RibbonFlatButton}" Command="{Binding SaveFileCommand}" ToolTip="{x:Static res:Strings.SaveTooltip}" IsEnabled="{Binding HasProject}" Padding="6,4,2,4">
                            <StackPanel Orientation="Vertical"><iconPacks:PackIconMaterial Kind="ContentSave" Width="18" Height="18" HorizontalAlignment="Center" Foreground="{DynamicResource IconGrayBrush}"/><TextBlock Text="{x:Static res:Strings.Save}" Style="{StaticResource RibbonIconLabel}"/></StackPanel>
                        </Button>
                        <Grid>
                            <ToggleButton x:Name="SaveMenuToggle" Style="{StaticResource RibbonFlatToggleButton}" ToolTip="{x:Static res:Strings.SaveAs}" IsEnabled="{Binding HasProject}" Padding="0,4" MinWidth="14" VerticalAlignment="Stretch">
                                <iconPacks:PackIconMaterial Kind="ChevronDown" Width="10" Height="10" Foreground="{DynamicResource IconGrayBrush}"/>
                            </ToggleButton>
                            <Popup IsOpen="{Binding IsChecked, ElementName=SaveMenuToggle, Mode=TwoWay}" StaysOpen="False" Placement="Bottom" PlacementTarget="{Binding ElementName=SaveMenuToggle}" DataContext="{Binding DataContext, ElementName=ThisControl}">
                                <Border Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="4" MinWidth="160">
                                    <StackPanel>
                                        <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding SaveFileAsCommand}" Click="CloseSavePopup"><TextBlock Text="{x:Static res:Strings.SaveAs}"/></Button>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                    </StackPanel>
                </WrapPanel>
                <TextBlock Grid.Row="1" Text="파일" Style="{StaticResource RibbonSectionLabel}"/>
            </Grid>

            <Border x:Name="ProjectEditSeparator" Grid.Column="1" Style="{StaticResource RibbonSectionSeparator}"/>

            <!-- Edit Section (dropdown) -->
            <Grid x:Name="EditSection" Grid.Column="2">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid x:Name="EditRibbonContentPanel">
                    <ToggleButton x:Name="EditMenuToggle" Style="{StaticResource RibbonFlatToggleButton}" ToolTip="편집 메뉴" IsEnabled="{Binding HasProject}">
                        <StackPanel Orientation="Vertical">
                            <iconPacks:PackIconMaterial Kind="FileDocumentEdit" Width="18" Height="18" HorizontalAlignment="Center" Foreground="{DynamicResource IconGrayBrush}"/>
                            <TextBlock Text="편집" Style="{StaticResource RibbonIconLabel}"/>
                        </StackPanel>
                    </ToggleButton>
                    <Popup IsOpen="{Binding IsChecked, ElementName=EditMenuToggle, Mode=TwoWay}"
                           StaysOpen="False"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=EditMenuToggle}"
                           DataContext="{Binding DataContext, ElementName=ThisControl}">
                        <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="4"
                                MinWidth="180">
                            <StackPanel>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding UndoCommand}" Click="CloseEditPopup"><TextBlock Text="실행 취소"/></Button>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding RedoCommand}" Click="CloseEditPopup"><TextBlock Text="다시 실행"/></Button>
                                <Separator Margin="4,4"/>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding AddSystemCommand}" Click="CloseEditPopup"><TextBlock Text="System 추가"/></Button>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding AddFlowCommand}" Click="CloseEditPopup"><TextBlock Text="Flow 추가"/></Button>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding AddWorkCommand}" Click="CloseEditPopup"><TextBlock Text="Work 추가"/></Button>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding AddCallCommand}" Click="CloseEditPopup"><TextBlock Text="Call 추가"/></Button>
                                <Separator Margin="4,4"/>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding AutoLayoutCommand}" Click="CloseEditPopup"><TextBlock Text="자동 배치"/></Button>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
                <TextBlock Grid.Row="1" Text="편집" Style="{StaticResource RibbonSectionLabel}"/>
            </Grid>
            <!-- Check Section (model validation) -->
            <Grid x:Name="CheckSection" Grid.Column="4">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Button x:Name="CheckModelButton"
                        Style="{StaticResource RibbonFlatButton}"
                        Command="{Binding Simulation.CheckModelCommand}"
                        IsEnabled="{Binding HasProject}"
                        ToolTip="모델 검증 (그래프 경고 확인)">
                    <StackPanel Orientation="Vertical">
                        <iconPacks:PackIconMaterial Kind="ShieldCheck" Width="18" Height="18" HorizontalAlignment="Center" Foreground="{DynamicResource IconGrayBrush}"/>
                        <TextBlock Text="검증" Style="{StaticResource RibbonIconLabel}"/>
                    </StackPanel>
                </Button>
                <TextBlock Grid.Row="1" Text="검증" Style="{StaticResource RibbonSectionLabel}"/>
            </Grid>
            <Border x:Name="CheckConnectSeparator" Grid.Column="5" Style="{StaticResource RibbonSectionSeparator}"/>

            <!-- Connect Section (dropdown with arrow type selection) -->
            <Grid x:Name="ConnectSection" Grid.Column="6">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <WrapPanel Orientation="Horizontal">
                    <Button x:Name="ConnectExecuteButton" Style="{StaticResource RibbonFlatButton}"
                            Command="{Binding ConnectSelectedNodesCommand}"
                            ToolTip="선택된 노드를 연결" Margin="2,0,0,0" Padding="8,8,2,8">
                        <StackPanel Orientation="Vertical">
                            <Grid Width="26" Height="18" HorizontalAlignment="Center">
                                <Canvas x:Name="ConnectStartIcon" Width="26" Height="18">
                                    <Border Canvas.Left="1" Canvas.Top="7.5" Width="18" Height="3" Background="{DynamicResource GreenAccentBrush}" CornerRadius="1"/>
                                    <Path Canvas.Left="19" Canvas.Top="4" Data="M0,0 L6,5 L0,10 Z" Fill="{DynamicResource GreenAccentBrush}"/>
                                    <Canvas.Style>
                                        <Style TargetType="Canvas">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedConnectArrowType}" Value="{x:Static core:ArrowType.Start}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedConnectArrowType}" Value="{x:Static core:ArrowType.Reset}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedConnectArrowType}" Value="{x:Static core:ArrowType.StartReset}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedConnectArrowType}" Value="{x:Static core:ArrowType.ResetReset}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedConnectArrowType}" Value="{x:Static core:ArrowType.Group}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Canvas.Style>
                                </Canvas>
                                <Canvas x:Name="ConnectResetIcon" Width="26" Height="18">
                                    <Line X1="1" Y1="9" X2="19" Y2="9" Stroke="{DynamicResource OrangeAccentBrush}" StrokeThickness="2.5" StrokeDashArray="2,1.5"/>
                                    <Path Canvas.Left="19" Canvas.Top="4" Data="M0,0 L6,5 L0,10 Z" Fill="{DynamicResource OrangeAccentBrush}"/>
                                    <Canvas.Style>
                                        <Style TargetType="Canvas">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedConnectArrowType}" Value="{x:Static core:ArrowType.Reset}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Canvas.Style>
                                </Canvas>
                                <Canvas x:Name="ConnectStartResetIcon" Width="26" Height="18">
                                    <Rectangle Canvas.Left="1" Canvas.Top="6" Width="5" Height="6" Fill="{DynamicResource RedAccentBrush}" RadiusX="0.5" RadiusY="0.5"/>
                                    <Border Canvas.Left="6" Canvas.Top="7.5" Width="13" Height="3" Background="{DynamicResource RedAccentBrush}" CornerRadius="1"/>
                                    <Path Canvas.Left="19" Canvas.Top="4" Data="M0,0 L6,5 L0,10 Z" Fill="{DynamicResource RedAccentBrush}"/>
                                    <Canvas.Style>
                                        <Style TargetType="Canvas">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedConnectArrowType}" Value="{x:Static core:ArrowType.StartReset}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Canvas.Style>
                                </Canvas>
                                <Canvas x:Name="ConnectResetResetIcon" Width="26" Height="18">
                                    <Path Canvas.Left="1" Canvas.Top="4" Data="M6,0 L0,5 L6,10 Z" Fill="{DynamicResource OrangeAccentBrush}"/>
                                    <Line X1="7" Y1="9" X2="19" Y2="9" Stroke="{DynamicResource OrangeAccentBrush}" StrokeThickness="2" StrokeDashArray="2,1.5"/>
                                    <Path Canvas.Left="19" Canvas.Top="4" Data="M0,0 L6,5 L0,10 Z" Fill="{DynamicResource OrangeAccentBrush}"/>
                                    <Canvas.Style>
                                        <Style TargetType="Canvas">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedConnectArrowType}" Value="{x:Static core:ArrowType.ResetReset}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Canvas.Style>
                                </Canvas>
                                <Canvas x:Name="ConnectGroupIcon" Width="26" Height="18">
                                    <Border Canvas.Left="1" Canvas.Top="7.5" Width="24" Height="3" Background="{DynamicResource AccentBrush}" CornerRadius="1"/>
                                    <Canvas.Style>
                                        <Style TargetType="Canvas">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedConnectArrowType}" Value="{x:Static core:ArrowType.Group}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Canvas.Style>
                                </Canvas>
                            </Grid>
                            <TextBlock Text="연결" Style="{StaticResource RibbonIconLabel}"/>
                        </StackPanel>
                    </Button>
                    <Grid>
                        <ToggleButton x:Name="ConnectTypeToggle" Style="{StaticResource RibbonFlatToggleButton}"
                                      IsEnabled="{Binding HasProject}" ToolTip="연결 타입 선택"
                                      MinWidth="20" Margin="0" Padding="0,8">
                            <iconPacks:PackIconMaterial Kind="ChevronDown" Width="10" Height="10" Foreground="{DynamicResource IconGrayBrush}"/>
                        </ToggleButton>
                        <Popup IsOpen="{Binding IsChecked, ElementName=ConnectTypeToggle, Mode=TwoWay}"
                               StaysOpen="False" Placement="Bottom"
                               PlacementTarget="{Binding ElementName=ConnectTypeToggle}"
                               DataContext="{Binding DataContext, ElementName=ThisControl}"
                               Opened="ConnectTypePopup_Opened">
                            <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4" Padding="8" MinWidth="340">
                                <StackPanel x:Name="ConnectTypeList">
                                    <TextBlock Text="연결 형식:" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>

                                    <RadioButton x:Name="ConnStartRadio" GroupName="ConnectType" Tag="Start" IsChecked="True"
                                                 Style="{StaticResource ConnectArrowOptionRadio}" Click="ConnectType_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Canvas Width="40" Height="14" Margin="0,0,8,0">
                                                        <Line X1="0" Y1="7" X2="30" Y2="7" Stroke="{DynamicResource GreenAccentBrush}" StrokeThickness="2.5"/>
                                                        <Path Canvas.Left="30" Canvas.Top="1.5" Data="M0,0 L8,5.5 L0,11 Z" Fill="{DynamicResource GreenAccentBrush}"/>
                                                    </Canvas>
                                                    <TextBlock Text="시작 인과" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12"/>
                                                </StackPanel>
                                                <TextBlock Text="A작업이 끝난 후 B작업 시작" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="10" Margin="48,2,0,0"/>
                                            </StackPanel>
                                            <ToggleButton x:Name="ConnStartPin" Grid.Column="1" Style="{StaticResource ConnectPinToggleStyle}"
                                                          VerticalAlignment="Top" Margin="6,0,0,0" Click="ConnectPin_Click" Tag="Start"/>
                                        </Grid>
                                    </RadioButton>

                                    <RadioButton x:Name="ConnResetRadio" GroupName="ConnectType" Tag="Reset"
                                                 Style="{StaticResource ConnectArrowOptionRadio}" Click="ConnectType_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Canvas Width="40" Height="14" Margin="0,0,8,0">
                                                        <Line X1="0" Y1="7" X2="30" Y2="7" Stroke="{DynamicResource OrangeAccentBrush}" StrokeThickness="2.5" StrokeDashArray="2,1.5"/>
                                                        <Path Canvas.Left="30" Canvas.Top="1.5" Data="M0,0 L8,5.5 L0,11 Z" Fill="{DynamicResource OrangeAccentBrush}"/>
                                                    </Canvas>
                                                    <TextBlock Text="리셋 인과" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12"/>
                                                </StackPanel>
                                                <TextBlock Text="A작업 시작과 동시에 B작업이 리셋" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="10" Margin="48,2,0,0"/>
                                            </StackPanel>
                                            <ToggleButton x:Name="ConnResetPin" Grid.Column="1" Style="{StaticResource ConnectPinToggleStyle}"
                                                          VerticalAlignment="Top" Margin="6,0,0,0" Click="ConnectPin_Click" Tag="Reset"/>
                                        </Grid>
                                    </RadioButton>

                                    <RadioButton x:Name="ConnStartResetRadio" GroupName="ConnectType" Tag="StartReset"
                                                 Style="{StaticResource ConnectArrowOptionRadio}" Click="ConnectType_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Canvas Width="40" Height="14" Margin="0,0,8,0">
                                                        <Rectangle Canvas.Left="0" Canvas.Top="2.5" Width="6" Height="9" Fill="{DynamicResource RedAccentBrush}" RadiusX="0.5" RadiusY="0.5"/>
                                                        <Line X1="6" Y1="7" X2="30" Y2="7" Stroke="{DynamicResource RedAccentBrush}" StrokeThickness="2.5"/>
                                                        <Path Canvas.Left="30" Canvas.Top="1.5" Data="M0,0 L8,5.5 L0,11 Z" Fill="{DynamicResource RedAccentBrush}"/>
                                                    </Canvas>
                                                    <TextBlock Text="시작리셋 인과" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12"/>
                                                </StackPanel>
                                                <TextBlock Text="A가 끝나면 B시작과 동시에 A가 리셋" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="10" Margin="48,2,0,0"/>
                                            </StackPanel>
                                            <ToggleButton x:Name="ConnStartResetPin" Grid.Column="1" Style="{StaticResource ConnectPinToggleStyle}"
                                                          VerticalAlignment="Top" Margin="6,0,0,0" Click="ConnectPin_Click" Tag="StartReset"/>
                                        </Grid>
                                    </RadioButton>

                                    <RadioButton x:Name="ConnResetResetRadio" GroupName="ConnectType" Tag="ResetReset"
                                                 Style="{StaticResource ConnectArrowOptionRadio}" Click="ConnectType_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Canvas Width="40" Height="14" Margin="0,0,8,0">
                                                        <Path Canvas.Left="0" Canvas.Top="1.5" Data="M8,0 L0,5.5 L8,11 Z" Fill="{DynamicResource OrangeAccentBrush}"/>
                                                        <Line X1="8" Y1="7" X2="30" Y2="7" Stroke="{DynamicResource OrangeAccentBrush}" StrokeThickness="2.5" StrokeDashArray="2,1.5"/>
                                                        <Path Canvas.Left="30" Canvas.Top="1.5" Data="M0,0 L8,5.5 L0,11 Z" Fill="{DynamicResource OrangeAccentBrush}"/>
                                                    </Canvas>
                                                    <TextBlock Text="상호리셋 인과" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12"/>
                                                </StackPanel>
                                                <TextBlock Text="A와 B가 서로 리셋" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="10" Margin="48,2,0,0"/>
                                            </StackPanel>
                                            <ToggleButton x:Name="ConnResetResetPin" Grid.Column="1" Style="{StaticResource ConnectPinToggleStyle}"
                                                          VerticalAlignment="Top" Margin="6,0,0,0" Click="ConnectPin_Click" Tag="ResetReset"/>
                                        </Grid>
                                    </RadioButton>

                                    <RadioButton x:Name="ConnGroupRadio" GroupName="ConnectType" Tag="Group"
                                                 Style="{StaticResource ConnectArrowOptionRadio}" Click="ConnectType_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Canvas Width="40" Height="14" Margin="0,0,8,0">
                                                        <Line X1="0" Y1="7" X2="40" Y2="7" Stroke="{DynamicResource AccentBrush}" StrokeThickness="2.5"/>
                                                    </Canvas>
                                                    <TextBlock Text="그룹연결" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12"/>
                                                </StackPanel>
                                                <TextBlock Text="그룹 간 연결 (직선)" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="10" Margin="48,2,0,0"/>
                                            </StackPanel>
                                            <ToggleButton x:Name="ConnGroupPin" Grid.Column="1" Style="{StaticResource ConnectPinToggleStyle}"
                                                          VerticalAlignment="Top" Margin="6,0,0,0" Click="ConnectPin_Click" Tag="Group"/>
                                        </Grid>
                                    </RadioButton>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </WrapPanel>
                <TextBlock Grid.Row="1" Text="연결" Style="{StaticResource RibbonSectionLabel}"/>
            </Grid>
            <Border x:Name="ConnectSimulationSeparator" Grid.Column="7" Style="{StaticResource RibbonSectionSeparator}"/>

            <controls:MainToolbarSimulationContent Grid.Column="8" DataContext="{Binding}"/>
            <controls:MainToolbarEtcContent Grid.Column="11" Grid.ColumnSpan="2" DataContext="{Binding}"/>
        </Grid>
    </Border>
</UserControl>
