<UserControl x:Class="Promaker.Controls.MainToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="ThisControl">
    <Border Background="{DynamicResource TertiaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Height="58">
        <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Disabled"
                      Focusable="False">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Stretch"
                        Margin="4,0">

                <!-- 그룹1: File — 범용 버튼, 아이콘만 표시 / 툴팁으로 설명 -->
                <Button Style="{StaticResource SlimToolbarButton}" Command="{Binding NewProjectCommand}"
                        ToolTip="새 파일 (Ctrl+N)">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="새 파일" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SlimToolbarButton}" Command="{Binding OpenFileCommand}"
                        ToolTip="불러오기 (Ctrl+O)">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <Canvas Width="18" Height="16" HorizontalAlignment="Center">
                            <!-- 폴더 뒷면 (탭 + 우측 세로선만, y=7에서 끊음) -->
                            <Path Data="M 0,15 L 0,1 L 7,1 L 9,4 L 17,4 L 17,7" Fill="Transparent"
                                  Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.2"/>
                            <!-- 폴더 앞면 (평행사변형, 채움 없음) -->
                            <Path Data="M 0,15 L 4,7 L 21,7 L 17,15 Z"
                                  Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.2"/>
                        </Canvas>
                        <TextBlock Text="불러오기" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>
                <Grid VerticalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource SlimToolbarButton}" Command="{Binding SaveFileCommand}"
                            ToolTip="저장 (Ctrl+S)" Padding="8,2,2,2">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="저장" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                    <ToggleButton x:Name="SaveMenuToggle" Grid.Column="1"
                                  Style="{StaticResource SlimToggleButton}"
                                  ToolTip="다른 이름으로 저장"
                                  Padding="2,0" MinWidth="14" Width="14">
                        <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="8"
                                   VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                    </ToggleButton>
                    <Popup IsOpen="{Binding IsChecked, ElementName=SaveMenuToggle, Mode=TwoWay}"
                           StaysOpen="False"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=SaveMenuToggle}"
                           DataContext="{Binding DataContext, ElementName=ThisControl}">
                        <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="4"
                                MinWidth="160">
                            <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding SaveFileAsCommand}" Click="CloseSavePopup">
                                <TextBlock Text="다른 이름으로 저장..." VerticalAlignment="Center"/>
                            </Button>
                        </Border>
                    </Popup>
                </Grid>

                <!-- ① 구분선 좌우 Margin 6,0 (기존 4,0 대비 1.5배) -->
                <Border Width="1" Height="36" Margin="6,0" Background="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>

                <!-- 그룹2: Edit — 범용 버튼, 아이콘만 표시 / 툴팁으로 설명 -->
                <Button Style="{StaticResource SlimToolbarButton}" Command="{Binding UndoCommand}"
                        ToolTip="실행취소 (Ctrl+Z)">
                    <TextBlock Text="&#xE7A7;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                </Button>
                <Button Style="{StaticResource SlimToolbarButton}" Command="{Binding RedoCommand}"
                        ToolTip="다시실행 (Ctrl+Y)">
                    <TextBlock Text="&#xE7A6;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                </Button>


                <!-- 그룹3: Add 드롭다운 -->
                <Grid VerticalAlignment="Stretch">
                    <ToggleButton x:Name="AddToggleBtn" Style="{StaticResource SlimToggleButton}" ToolTip="Add">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <TextBlock Text="&#xE109;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center"/>
                            <TextBlock Text="추가" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </ToggleButton>
                    <Popup IsOpen="{Binding IsChecked, ElementName=AddToggleBtn, Mode=TwoWay}"
                           StaysOpen="False"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=AddToggleBtn}"
                           DataContext="{Binding DataContext, ElementName=ThisControl}">
                        <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="4"
                                MinWidth="130">
                            <StackPanel Orientation="Vertical">
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding AddSystemCommand}" Click="CloseAddPopup">
                                    <TextBlock Text="System" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding AddFlowCommand}" Click="CloseAddPopup">
                                    <TextBlock Text="Flow" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding AddWorkCommand}" Click="CloseAddPopup">
                                    <TextBlock Text="Work" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding AddCallCommand}" Click="CloseAddPopup">
                                    <TextBlock Text="Call" VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

                <Button Style="{StaticResource SlimToolbarButton}" Command="{Binding AutoLayoutCommand}"
                        ToolTip="자동 재배치 (Ctrl+L)">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="&#xF0E2;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="재배치" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>

                <Border Width="1" Height="36" Margin="6,0" Background="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>

                <!-- 그룹4: Delete -->
                <Button Style="{StaticResource SlimToolbarButton}" Command="{Binding DeleteSelectedCommand}"
                        ToolTip="삭제">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource RedAccentBrush}"/>
                        <TextBlock Text="삭제" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"
                                   Foreground="{DynamicResource RedAccentBrush}"/>
                    </StackPanel>
                </Button>

                <Border Width="1" Height="36" Margin="6,0" Background="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>

                <StackPanel x:Name="SimulationTools"
                            Orientation="Horizontal"
                            VerticalAlignment="Stretch"
                            DataContext="{Binding Simulation}">

                <!-- 그룹5: Simulation
                     ④ '실행' 버튼: PrimaryActionButton 스타일 + 아이콘 20px(약 11% 확대) + 채도 낮은 초록 배경 -->
                <Button Style="{StaticResource PrimaryActionButton}" Command="{Binding StartSimulationCommand}"
                        ToolTip="시뮬레이션 실행" Margin="0,3">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="실행" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SlimToolbarButton}" Command="{Binding PauseSimulationCommand}" ToolTip="일시정지">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE769;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="일시정지" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SlimToolbarButton}" Command="{Binding StopSimulationCommand}" ToolTip="정지">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource RedAccentBrush}"/>
                        <TextBlock Text="정지" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"
                                   Foreground="{DynamicResource RedAccentBrush}"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SlimToolbarButton}" Command="{Binding ResetSimulationCommand}" ToolTip="초기화">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="초기화" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>

                <Border Width="1" Height="36" Margin="6,0" Background="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>

                <!-- 그룹6: Sim Controls -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="4,0">
                    <TextBlock Text="속도" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <ComboBox SelectedValue="{Binding SimSpeed}" SelectedValuePath="Tag"
                              Width="60" FontSize="11">
                        <ComboBoxItem Content="0.5x" Tag="0.5"/>
                        <ComboBoxItem Content="1x"   Tag="1.0" IsSelected="True"/>
                        <ComboBoxItem Content="2x"   Tag="2.0"/>
                        <ComboBoxItem Content="5x"   Tag="5.0"/>
                        <ComboBoxItem Content="10x"  Tag="10.0"/>
                    </ComboBox>
                </StackPanel>

                <ToggleButton Style="{StaticResource SlimToggleButton}"
                              IsChecked="{Binding SimTimeIgnore}" ToolTip="시간 무시" Margin="2,0">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="시간무시" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </ToggleButton>

                <Border Width="1" Height="36" Margin="6,0" Background="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>

                <!-- 그룹7: Work 강제 제어 -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="4,0">
                    <TextBlock Text="Work" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <ComboBox ItemsSource="{Binding SimWorkItems}" SelectedItem="{Binding SelectedSimWork}"
                              Width="140" FontSize="11"/>
                </StackPanel>

                <Button Style="{StaticResource SlimToolbarButton}" Command="{Binding ForceWorkStartCommand}" ToolTip="Work 강제 실행">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center" Foreground="#32CD32"/>
                        <TextBlock Text="Work 실행" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0" Foreground="#32CD32"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SlimToolbarButton}" Command="{Binding ForceWorkResetCommand}" ToolTip="Work 강제 초기화">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource OrangeAccentBrush}"/>
                        <TextBlock Text="Work 초기화" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"
                                   Foreground="{DynamicResource OrangeAccentBrush}"/>
                    </StackPanel>
                </Button>

                <Border Width="1" Height="36" Margin="6,0" Background="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>

                <!-- 그룹8: Report 내보내기 드롭다운 -->
                <Grid VerticalAlignment="Stretch">
                    <ToggleButton x:Name="ReportToggleBtn"
                                  Style="{StaticResource SlimToggleButton}"
                                  ToolTip="리포트 내보내기"
                                  IsEnabled="{Binding HasReportData}">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <Canvas Width="18" Height="18" HorizontalAlignment="Center">
                                <!-- 문서 본체 (투명 배경, 테마 테두리) -->
                                <Path Data="M 2,0 L 12,0 L 16,4 L 16,18 L 2,18 Z" Fill="Transparent"
                                      Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.2"/>
                                <!-- 접힌 모서리 (삼각형 채움) -->
                                <Path Data="M 12,0 L 12,4 L 16,4 Z" Fill="{DynamicResource TertiaryBackgroundBrush}"
                                      Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.0"/>
                                <!-- 막대 그래프 3개 -->
                                <Rectangle Canvas.Left="4.5" Canvas.Top="10" Width="2.5" Height="5.5"
                                           Fill="#E85050" RadiusX="0.5" RadiusY="0.5"/>
                                <Rectangle Canvas.Left="7.8" Canvas.Top="7" Width="2.5" Height="8.5"
                                           Fill="#F0A030" RadiusX="0.5" RadiusY="0.5"/>
                                <Rectangle Canvas.Left="11.1" Canvas.Top="8.5" Width="2.5" Height="7"
                                           Fill="#40C060" RadiusX="0.5" RadiusY="0.5"/>
                            </Canvas>
                            <TextBlock Text="리포트" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </ToggleButton>
                    <Popup IsOpen="{Binding IsChecked, ElementName=ReportToggleBtn, Mode=TwoWay}"
                           StaysOpen="False"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=ReportToggleBtn}"
                           DataContext="{Binding DataContext, ElementName=SimulationTools}">
                        <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="4"
                                MinWidth="130">
                            <StackPanel Orientation="Vertical">
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding ExportReportCsvCommand}" Click="CloseReportPopup">
                                    <TextBlock Text="CSV (.csv)" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding ExportReportXlsxCommand}" Click="CloseReportPopup">
                                    <TextBlock Text="Excel (.xlsx)" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding ExportReportHtmlCommand}" Click="CloseReportPopup">
                                    <TextBlock Text="HTML (.html)" VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

                <Border Width="1" Height="36" Margin="6,0" Background="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>

                <!-- 그룹9: 설정 -->
                <Button Style="{StaticResource SlimToolbarButton}"
                        Command="{Binding DataContext.ShowProjectSettingsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        ToolTip="프로젝트 속성">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center"/>
                        <TextBlock Text="설정" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
