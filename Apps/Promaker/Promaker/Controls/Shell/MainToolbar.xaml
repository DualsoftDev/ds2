<UserControl x:Class="Promaker.Controls.MainToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:res="clr-namespace:Promaker.Resources"
             x:Name="ThisControl">
    <UserControl.Resources>
        <Style x:Key="RibbonSectionSeparator" TargetType="Border">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Margin" Value="14,10"/>
            <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
        </Style>
        <Style x:Key="RibbonSectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>
        <Style x:Key="RibbonIconLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
        <Style x:Key="RibbonFlatButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,8"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="58"/>
            <Setter Property="MinHeight" Value="66"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RibbonFlatToggleButton" TargetType="ToggleButton" BasedOn="{StaticResource SlimToggleButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,8"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="MinWidth" Value="58"/>
            <Setter Property="MinHeight" Value="66"/>
        </Style>
        <Style x:Key="ConnectArrowOptionRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="OptionBorder"
                                Background="{DynamicResource TertiaryBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="3" Padding="8,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Width="14" Height="14" VerticalAlignment="Top" Margin="0,2,0,0">
                                    <Ellipse Stroke="{DynamicResource AccentBrush}" StrokeThickness="2"/>
                                    <Ellipse x:Name="Dot" Width="7" Height="7"
                                             Fill="{DynamicResource AccentBrush}" Visibility="Collapsed"/>
                                </Grid>
                                <ContentPresenter Grid.Column="1"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Dot" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="OptionBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="OptionBorder" Property="Background" Value="{DynamicResource SelectedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OptionBorder" Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ConnectPinToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTip" Value="우클릭 메뉴에 표시"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Padding="2">
                            <Grid>
                                <Path x:Name="UnpinnedIcon"
                                      Data="M12,2 L14,8 L20,9 L15.5,13 L17,19 L12,16 L7,19 L8.5,13 L4,9 L10,8 Z"
                                      Stroke="{DynamicResource SecondaryTextBrush}" StrokeThickness="1.2"
                                      Fill="Transparent" Stretch="Uniform" Width="14" Height="14"/>
                                <Path x:Name="PinnedIcon"
                                      Data="M12,2 L14,8 L20,9 L15.5,13 L17,19 L12,16 L7,19 L8.5,13 L4,9 L10,8 Z"
                                      Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.2"
                                      Fill="{DynamicResource AccentBrush}" Stretch="Uniform"
                                      Width="14" Height="14" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="UnpinnedIcon" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="PinnedIcon" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource ToolbarShellBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="10,6,10,8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/> <!-- 0: File -->
                <ColumnDefinition Width="Auto"/> <!-- 1: sep -->
                <ColumnDefinition Width="Auto"/> <!-- 2: Edit -->
                <ColumnDefinition Width="Auto"/> <!-- 3: sep -->
                <ColumnDefinition Width="Auto"/> <!-- 4: Connect -->
                <ColumnDefinition Width="Auto"/> <!-- 5: sep -->
                <ColumnDefinition Width="Auto"/> <!-- 6: Simulation -->
                <ColumnDefinition Width="Auto"/> <!-- 7: sep -->
                <ColumnDefinition Width="*"/>    <!-- 8: spacer -->
                <ColumnDefinition Width="Auto"/> <!-- 9: Util -->
                <ColumnDefinition Width="Auto"/> <!-- 10: Settings -->
            </Grid.ColumnDefinitions>

            <!-- File Section -->
            <Grid x:Name="ProjectQuickAccessSection" Grid.Column="0">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <WrapPanel Orientation="Horizontal">
                    <Button x:Name="NewProjectQuickButton" Style="{StaticResource RibbonFlatButton}" Command="{Binding NewProjectCommand}" ToolTip="{x:Static res:Strings.NewFileTooltip}">
                        <StackPanel Orientation="Vertical"><Path Width="18" Height="18" Stretch="Uniform" Data="{StaticResource IconNewFile}" Fill="{DynamicResource IconGrayBrush}"/><TextBlock Text="{x:Static res:Strings.NewFile}" Style="{StaticResource RibbonIconLabel}"/></StackPanel>
                    </Button>
                    <Button x:Name="OpenFileQuickButton" Style="{StaticResource RibbonFlatButton}" Command="{Binding OpenFileCommand}" ToolTip="{x:Static res:Strings.LoadTooltip}">
                        <StackPanel Orientation="Vertical"><Path Width="18" Height="18" Stretch="Uniform" Data="M19,20H4C2.89,20 2,19.1 2,18V6C2,4.89 2.89,4 4,4H10L12,6H19A2,2 0 0,1 21,8H21L4,8V18L6.14,10H23.21L20.93,18.5C20.7,19.37 19.92,20 19,20Z" Fill="{DynamicResource IconGrayBrush}"/><TextBlock Text="{x:Static res:Strings.Load}" Style="{StaticResource RibbonIconLabel}"/></StackPanel>
                    </Button>
                    <Grid>
                        <ToggleButton x:Name="SaveMenuToggle" Style="{StaticResource RibbonFlatToggleButton}" ToolTip="{x:Static res:Strings.SaveTooltip}" IsEnabled="{Binding HasProject}">
                            <StackPanel Orientation="Vertical"><Path Width="18" Height="18" Stretch="Uniform" Data="M17 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V7l-4-4zm-5 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3zm3-10H5V5h10v4z" Fill="{DynamicResource IconGrayBrush}"/><TextBlock Text="{x:Static res:Strings.Save}" Style="{StaticResource RibbonIconLabel}"/></StackPanel>
                        </ToggleButton>
                        <Popup IsOpen="{Binding IsChecked, ElementName=SaveMenuToggle, Mode=TwoWay}" StaysOpen="False" Placement="Bottom" PlacementTarget="{Binding ElementName=SaveMenuToggle}" DataContext="{Binding DataContext, ElementName=ThisControl}">
                            <Border Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="4" MinWidth="160">
                                <StackPanel>
                                    <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding SaveFileCommand}" Click="CloseSavePopup"><TextBlock Text="{x:Static res:Strings.Save}"/></Button>
                                    <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding SaveFileAsCommand}" Click="CloseSavePopup"><TextBlock Text="{x:Static res:Strings.SaveAs}"/></Button>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </WrapPanel>
                <TextBlock Grid.Row="1" Text="파일" Style="{StaticResource RibbonSectionLabel}"/>
            </Grid>

            <Border x:Name="ProjectEditSeparator" Grid.Column="1" Style="{StaticResource RibbonSectionSeparator}"/>

            <!-- Edit Section (dropdown) -->
            <Grid x:Name="EditSection" Grid.Column="2">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid x:Name="EditRibbonContentPanel">
                    <ToggleButton x:Name="EditMenuToggle" Style="{StaticResource RibbonFlatToggleButton}" ToolTip="편집 메뉴" IsEnabled="{Binding HasProject}">
                        <StackPanel Orientation="Vertical">
                            <Path Width="18" Height="18" Stretch="Uniform" Data="M3 10h11v2H3v-2zm0-2h11V6H3v2zm0 8h7v-2H3v2zm15.01-3.13l1.41-1.41c.2-.2.51-.2.71 0l1.41 1.41c.2.2.2.51 0 .71l-1.41 1.41-2.12-2.12zm-.71.71l-5.3 5.3V21h2.12l5.3-5.3-2.12-2.12z" Fill="{DynamicResource IconGrayBrush}"/>
                            <TextBlock Text="편집" Style="{StaticResource RibbonIconLabel}"/>
                        </StackPanel>
                    </ToggleButton>
                    <Popup IsOpen="{Binding IsChecked, ElementName=EditMenuToggle, Mode=TwoWay}"
                           StaysOpen="False"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=EditMenuToggle}"
                           DataContext="{Binding DataContext, ElementName=ThisControl}">
                        <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="4"
                                MinWidth="180">
                            <StackPanel>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding UndoCommand}" Click="CloseEditPopup"><TextBlock Text="실행 취소"/></Button>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding RedoCommand}" Click="CloseEditPopup"><TextBlock Text="다시 실행"/></Button>
                                <Separator Margin="4,4"/>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding AddSystemCommand}" Click="CloseEditPopup"><TextBlock Text="System 추가"/></Button>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding AddFlowCommand}" Click="CloseEditPopup"><TextBlock Text="Flow 추가"/></Button>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding AddWorkCommand}" Click="CloseEditPopup"><TextBlock Text="Work 추가"/></Button>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding AddCallCommand}" Click="CloseEditPopup"><TextBlock Text="Call 추가"/></Button>
                                <Separator Margin="4,4"/>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding AutoLayoutCommand}" Click="CloseEditPopup"><TextBlock Text="자동 배치"/></Button>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
                <TextBlock Grid.Row="1" Text="편집" Style="{StaticResource RibbonSectionLabel}"/>
            </Grid>
            <Border x:Name="EditConnectSeparator" Grid.Column="3" Style="{StaticResource RibbonSectionSeparator}"/>

            <!-- Connect Section (dropdown with arrow type selection) -->
            <Grid x:Name="ConnectSection" Grid.Column="4">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <WrapPanel Orientation="Horizontal">
                    <Button x:Name="ConnectExecuteButton" Style="{StaticResource RibbonFlatButton}"
                            Command="{Binding ConnectSelectedNodesCommand}"
                            ToolTip="선택된 노드를 연결" Margin="2,0,0,0" Padding="8,8,2,8">
                        <StackPanel Orientation="Vertical">
                            <Path Width="18" Height="18" Stretch="Uniform" Fill="{DynamicResource IconGrayBrush}"
                                  Data="M6 3C4.34 3 3 4.34 3 6s1.34 3 3 3c.55 0 1.07-.15 1.52-.42L9.4 10.46C9.15 10.93 9 11.45 9 12s.15 1.07.4 1.54l-1.88 1.88C7.07 15.15 6.55 15 6 15c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3c0-.55-.15-1.07-.42-1.52l1.88-1.88c.47.27.99.4 1.54.4s1.07-.13 1.54-.4l1.88 1.88C15.15 16.93 15 17.45 15 18c0 1.66 1.34 3 3 3s3-1.34 3-3-1.34-3-3-3c-.55 0-1.07.15-1.52.42l-1.88-1.88c.27-.47.4-.99.4-1.54s-.13-1.07-.4-1.54l1.88-1.88C16.93 8.85 17.45 9 18 9c1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .55.15 1.07.42 1.52l-1.88 1.88C13.07 9.15 12.55 9 12 9s-1.07.15-1.54.42L8.58 7.54C8.85 7.07 9 6.55 9 6c0-1.66-1.34-3-3-3z"/>
                            <TextBlock Text="연결" Style="{StaticResource RibbonIconLabel}"/>
                        </StackPanel>
                    </Button>
                    <Grid>
                        <ToggleButton x:Name="ConnectTypeToggle" Style="{StaticResource RibbonFlatToggleButton}"
                                      IsEnabled="{Binding HasProject}" ToolTip="연결 타입 선택"
                                      MinWidth="20" Margin="0" Padding="0,8">
                            <Path Width="10" Height="6" Stretch="Uniform" Data="M0,0 L5,5 L10,0" Fill="{DynamicResource IconGrayBrush}"/>
                        </ToggleButton>
                        <Popup IsOpen="{Binding IsChecked, ElementName=ConnectTypeToggle, Mode=TwoWay}"
                               StaysOpen="False" Placement="Bottom"
                               PlacementTarget="{Binding ElementName=ConnectTypeToggle}"
                               DataContext="{Binding DataContext, ElementName=ThisControl}"
                               Opened="ConnectTypePopup_Opened">
                            <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4" Padding="8" MinWidth="300">
                                <StackPanel x:Name="ConnectTypeList">
                                    <TextBlock Text="연결 형식:" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>

                                    <RadioButton x:Name="ConnStartRadio" GroupName="ConnectType" Tag="Start" IsChecked="True"
                                                 Style="{StaticResource ConnectArrowOptionRadio}" Click="ConnectType_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Canvas Width="40" Height="14" Margin="0,0,8,0">
                                                        <Border Canvas.Left="0" Canvas.Top="5.5" Width="30" Height="3" Background="{DynamicResource GreenAccentBrush}" CornerRadius="1"/>
                                                        <Path Canvas.Left="30" Canvas.Top="0" Data="M0,2 L8,7 L0,12" Stroke="{DynamicResource GreenAccentBrush}" StrokeThickness="2" Fill="Transparent" StrokeLineJoin="Miter"/>
                                                    </Canvas>
                                                    <TextBlock Text="시작 인과" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12"/>
                                                </StackPanel>
                                                <TextBlock Text="A작업이 끝난 후 B작업 시작" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="10" Margin="48,2,0,0"/>
                                            </StackPanel>
                                            <ToggleButton x:Name="ConnStartPin" Grid.Column="1" Style="{StaticResource ConnectPinToggleStyle}"
                                                          VerticalAlignment="Top" Margin="6,0,0,0" Click="ConnectPin_Click" Tag="Start"/>
                                        </Grid>
                                    </RadioButton>

                                    <RadioButton x:Name="ConnResetRadio" GroupName="ConnectType" Tag="Reset"
                                                 Style="{StaticResource ConnectArrowOptionRadio}" Click="ConnectType_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Canvas Width="40" Height="14" Margin="0,0,8,0">
                                                        <Line X1="0" Y1="7" X2="30" Y2="7" Stroke="{DynamicResource OrangeAccentBrush}" StrokeThickness="3" StrokeDashArray="2,1"/>
                                                        <Path Canvas.Left="30" Canvas.Top="0" Data="M0,2 L8,7 L0,12" Stroke="{DynamicResource OrangeAccentBrush}" StrokeThickness="2" Fill="Transparent" StrokeLineJoin="Miter"/>
                                                    </Canvas>
                                                    <TextBlock Text="리셋 인과" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12"/>
                                                </StackPanel>
                                                <TextBlock Text="A작업 시작과 동시에 B작업이 리셋" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="10" Margin="48,2,0,0"/>
                                            </StackPanel>
                                            <ToggleButton x:Name="ConnResetPin" Grid.Column="1" Style="{StaticResource ConnectPinToggleStyle}"
                                                          VerticalAlignment="Top" Margin="6,0,0,0" Click="ConnectPin_Click" Tag="Reset"/>
                                        </Grid>
                                    </RadioButton>

                                    <RadioButton x:Name="ConnStartResetRadio" GroupName="ConnectType" Tag="StartReset"
                                                 Style="{StaticResource ConnectArrowOptionRadio}" Click="ConnectType_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Canvas Width="40" Height="14" Margin="0,0,8,0">
                                                        <Rectangle Canvas.Left="0" Canvas.Top="3" Width="7" Height="8" Fill="{DynamicResource RedAccentBrush}"/>
                                                        <Border Canvas.Left="7" Canvas.Top="5.5" Width="23" Height="3" Background="{DynamicResource RedAccentBrush}" CornerRadius="1"/>
                                                        <Path Canvas.Left="30" Canvas.Top="0" Data="M0,2 L8,7 L0,12" Stroke="{DynamicResource RedAccentBrush}" StrokeThickness="2" Fill="Transparent" StrokeLineJoin="Miter"/>
                                                    </Canvas>
                                                    <TextBlock Text="시작리셋 인과" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12"/>
                                                </StackPanel>
                                                <TextBlock Text="A가 끝나면 B시작과 동시에 A가 리셋" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="10" Margin="48,2,0,0"/>
                                            </StackPanel>
                                            <ToggleButton x:Name="ConnStartResetPin" Grid.Column="1" Style="{StaticResource ConnectPinToggleStyle}"
                                                          VerticalAlignment="Top" Margin="6,0,0,0" Click="ConnectPin_Click" Tag="StartReset"/>
                                        </Grid>
                                    </RadioButton>

                                    <RadioButton x:Name="ConnResetResetRadio" GroupName="ConnectType" Tag="ResetReset"
                                                 Style="{StaticResource ConnectArrowOptionRadio}" Click="ConnectType_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Canvas Width="40" Height="14" Margin="0,0,8,0">
                                                        <Path Canvas.Left="0" Canvas.Top="0" Data="M8,2 L0,7 L8,12" Stroke="{DynamicResource OrangeAccentBrush}" StrokeThickness="2" Fill="Transparent" StrokeLineJoin="Miter"/>
                                                        <Line X1="8" Y1="7" X2="30" Y2="7" Stroke="{DynamicResource OrangeAccentBrush}" StrokeThickness="3" StrokeDashArray="2,1"/>
                                                        <Path Canvas.Left="30" Canvas.Top="0" Data="M0,2 L8,7 L0,12" Stroke="{DynamicResource OrangeAccentBrush}" StrokeThickness="2" Fill="Transparent" StrokeLineJoin="Miter"/>
                                                    </Canvas>
                                                    <TextBlock Text="상호리셋 인과" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12"/>
                                                </StackPanel>
                                                <TextBlock Text="A와 B가 서로 리셋" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="10" Margin="48,2,0,0"/>
                                            </StackPanel>
                                            <ToggleButton x:Name="ConnResetResetPin" Grid.Column="1" Style="{StaticResource ConnectPinToggleStyle}"
                                                          VerticalAlignment="Top" Margin="6,0,0,0" Click="ConnectPin_Click" Tag="ResetReset"/>
                                        </Grid>
                                    </RadioButton>

                                    <RadioButton x:Name="ConnGroupRadio" GroupName="ConnectType" Tag="Group"
                                                 Style="{StaticResource ConnectArrowOptionRadio}" Click="ConnectType_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Canvas Width="40" Height="14" Margin="0,0,8,0">
                                                        <Border Canvas.Left="0" Canvas.Top="5.5" Width="40" Height="3" Background="{DynamicResource AccentBrush}" CornerRadius="1"/>
                                                    </Canvas>
                                                    <TextBlock Text="그룹연결" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12"/>
                                                </StackPanel>
                                                <TextBlock Text="그룹 간 연결 (직선)" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="10" Margin="48,2,0,0"/>
                                            </StackPanel>
                                            <ToggleButton x:Name="ConnGroupPin" Grid.Column="1" Style="{StaticResource ConnectPinToggleStyle}"
                                                          VerticalAlignment="Top" Margin="6,0,0,0" Click="ConnectPin_Click" Tag="Group"/>
                                        </Grid>
                                    </RadioButton>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </WrapPanel>
                <TextBlock Grid.Row="1" Text="연결" Style="{StaticResource RibbonSectionLabel}"/>
            </Grid>
            <Border x:Name="ConnectSimulationSeparator" Grid.Column="5" Style="{StaticResource RibbonSectionSeparator}"/>

            <!-- Simulation Section (inline) -->
            <Grid x:Name="SimulationSection" Grid.Column="6" DataContext="{Binding Simulation}" HorizontalAlignment="Left">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <WrapPanel x:Name="SimulationRibbonContentPanel" Orientation="Horizontal">
                    <Button x:Name="SimulationStartStopButton" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RibbonFlatButton}">
                                <Setter Property="Command" Value="{Binding StartSimulationCommand}"/>
                                <Setter Property="ToolTip" Value="{x:Static res:Strings.StartSimulationTooltip}"/>
                                <Setter Property="Foreground" Value="{DynamicResource IconGreenBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSimulating}" Value="True"><Setter Property="Command" Value="{Binding StopSimulationCommand}"/><Setter Property="ToolTip" Value="{x:Static res:Strings.StopSimulationTooltip}"/><Setter Property="Foreground" Value="{DynamicResource IconRedBrush}"/></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Vertical">
                            <Path Width="18" Height="18" Stretch="Fill" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Data" Value="M 4,2 L 16,9 L 4,16 Z"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSimulating}" Value="True">
                                                <Setter Property="Data" Value="M 3,3 L 15,3 L 15,15 L 3,15 Z"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                            <TextBlock x:Name="SimulationStartStopText" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource RibbonIconLabel}">
                                        <Setter Property="Text" Value="PLAY"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSimulating}" Value="True">
                                                <Setter Property="Text" Value="STOP"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource RibbonFlatButton}" Command="{Binding PauseSimulationCommand}" ToolTip="{x:Static res:Strings.PauseSimulationTooltip}" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}"><StackPanel Orientation="Vertical"><Canvas Width="18" Height="18" HorizontalAlignment="Center"><Rectangle Canvas.Left="4" Canvas.Top="2.5" Width="3.8" Height="13" Fill="{DynamicResource IconGrayBrush}" RadiusX="1" RadiusY="1"/><Rectangle Canvas.Left="10.2" Canvas.Top="2.5" Width="3.8" Height="13" Fill="{DynamicResource IconGrayBrush}" RadiusX="1" RadiusY="1"/></Canvas><TextBlock Text="PAUSE" Style="{StaticResource RibbonIconLabel}"/></StackPanel></Button>
                    <Button Style="{StaticResource RibbonFlatButton}" Command="{Binding ResetSimulationCommand}" ToolTip="{x:Static res:Strings.ResetSimulationTooltip}" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}" Foreground="{DynamicResource IconOrangeBrush}"><StackPanel Orientation="Vertical"><Path Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Center" Data="M12,4V1L8,5L12,9V6A6,6 0 0,1 18,12A6,6 0 0,1 12,18A6,6 0 0,1 6,12H4A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/><TextBlock Text="REVERT" Style="{StaticResource RibbonIconLabel}" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/></StackPanel></Button>
                    <StackPanel Orientation="Vertical" Margin="8,0,0,0" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}">
                        <TextBlock Text="Work" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <ComboBox x:Name="SimWorkComboBox" ItemsSource="{Binding SimWorkItems}" SelectedItem="{Binding SelectedSimWork}" Width="130" FontSize="11"/>
                        <UniformGrid Columns="2" Margin="0,6,0,0">
                            <Button x:Name="ForceWorkStartButton" Command="{Binding ForceWorkStartCommand}" ToolTip="{x:Static res:Strings.ForceWorkStartTooltip}" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}" Margin="0,0,4,0">
                                <Button.Style><Style TargetType="Button" BasedOn="{StaticResource RibbonFlatButton}"><Setter Property="Foreground" Value="{DynamicResource IconGreenBrush}"/><Setter Property="MinWidth" Value="0"/><Setter Property="MinHeight" Value="0"/><Setter Property="Padding" Value="8,4"/></Style></Button.Style>
                                <TextBlock Text="START" VerticalAlignment="Center" FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" HorizontalAlignment="Center"/>
                            </Button>
                            <Button x:Name="ForceWorkResetButton" Command="{Binding ForceWorkResetCommand}" ToolTip="{x:Static res:Strings.ForceWorkResetTooltip}" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}" Margin="4,0,0,0">
                                <Button.Style><Style TargetType="Button" BasedOn="{StaticResource RibbonFlatButton}"><Setter Property="Foreground" Value="{DynamicResource IconOrangeBrush}"/><Setter Property="MinWidth" Value="0"/><Setter Property="MinHeight" Value="0"/><Setter Property="Padding" Value="8,4"/></Style></Button.Style>
                                <TextBlock Text="RESET" VerticalAlignment="Center" FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" HorizontalAlignment="Center"/>
                            </Button>
                        </UniformGrid>
                    </StackPanel>
                    <StackPanel Orientation="Vertical" Margin="8,0,0,0" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}">
                        <TextBlock Text="{x:Static res:Strings.Speed}" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <ComboBox x:Name="SimSpeedComboBox" SelectedValue="{Binding SimSpeed}" SelectedValuePath="Tag" Width="72" FontSize="11">
                            <ComboBoxItem Content="0.5x"><ComboBoxItem.Tag><sys:Double>0.5</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                            <ComboBoxItem Content="1x"><ComboBoxItem.Tag><sys:Double>1.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                            <ComboBoxItem Content="2x"><ComboBoxItem.Tag><sys:Double>2.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                            <ComboBoxItem Content="5x"><ComboBoxItem.Tag><sys:Double>5.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                            <ComboBoxItem Content="10x"><ComboBoxItem.Tag><sys:Double>10.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                            <ComboBoxItem Content="{x:Static res:Strings.IgnoreTime}"><ComboBoxItem.Tag><sys:Double>0.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                    <Button Style="{StaticResource RibbonFlatButton}" Command="{Binding DataContext.OpenTokenSpecDialogCommand, ElementName=ThisControl}" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}" ToolTip="TokenSpec 편집">
                        <StackPanel Orientation="Vertical">
                            <Path Width="18" Height="18" Stretch="Uniform" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" Fill="{DynamicResource IconGrayBrush}"/>
                            <TextBlock Text="Token" Style="{StaticResource RibbonIconLabel}"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
                <TextBlock Grid.Row="1" Text="시뮬레이션" Style="{StaticResource RibbonSectionLabel}"/>
            </Grid>

            <!-- Util Section (dropdown, right-aligned) -->
            <Grid x:Name="UtilSection" Grid.Column="9">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid>
                    <ToggleButton x:Name="UtilMenuToggle" Style="{StaticResource RibbonFlatToggleButton}" ToolTip="유틸리티" IsEnabled="{Binding HasProject}">
                        <StackPanel Orientation="Vertical">
                            <Path Width="18" Height="18" Stretch="Uniform" Data="M3 3h8v2H3V3zm0 4h12v2H3V7zm0 4h8v2H3v-2zm0 4h12v2H3v-2zm0 4h8v2H3v-2z" Fill="{DynamicResource IconGrayBrush}"/>
                            <TextBlock Text="유틸" Style="{StaticResource RibbonIconLabel}"/>
                        </StackPanel>
                    </ToggleButton>
                    <Popup IsOpen="{Binding IsChecked, ElementName=UtilMenuToggle, Mode=TwoWay}"
                           StaysOpen="False" Placement="Bottom"
                           PlacementTarget="{Binding ElementName=UtilMenuToggle}"
                           DataContext="{Binding DataContext, ElementName=ThisControl}">
                        <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="4" MinWidth="180">
                            <StackPanel>
                                <TextBlock Text="편집" FontSize="11" FontWeight="SemiBold" Margin="8,4,8,4" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding OpenIoBatchDialogCommand}" Click="CloseUtilPopup"><TextBlock Text="I/O 편집"/></Button>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding OpenDurationBatchDialogCommand}" Click="CloseUtilPopup"><TextBlock Text="Duration 편집"/></Button>
                                <Separator Margin="4,4"/>
                                <TextBlock Text="리포트" FontSize="11" FontWeight="SemiBold" Margin="8,4,8,4" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding Simulation.ExportReportCsvCommand}" Click="CloseUtilPopup"><TextBlock Text="리포트 CSV"/></Button>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding Simulation.ExportReportXlsxCommand}" Click="CloseUtilPopup"><TextBlock Text="리포트 Excel"/></Button>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding Simulation.ExportReportHtmlCommand}" Click="CloseUtilPopup"><TextBlock Text="리포트 HTML"/></Button>
                                <Separator Margin="4,4"/>
                                <TextBlock Text="CSV" FontSize="11" FontWeight="SemiBold" Margin="8,4,8,4" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding ImportCsvCommand}" Click="CloseUtilPopup"><TextBlock Text="CSV 불러오기"/></Button>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding ExportCsvCommand}" Click="CloseUtilPopup"><TextBlock Text="CSV 내보내기"/></Button>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
                <TextBlock Grid.Row="1" Text="유틸" Style="{StaticResource RibbonSectionLabel}"/>
            </Grid>

            <!-- Settings Section -->
            <Grid x:Name="SettingsSection" Grid.Column="10">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid x:Name="SettingsRibbonContentPanel">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="ThemeButton" Grid.Column="0" Style="{StaticResource RibbonFlatButton}" Command="{Binding ToggleThemeCommand}" ToolTip="{Binding ThemeButtonToolTip}">
                        <StackPanel Orientation="Vertical">
                            <Path x:Name="ThemeSunIcon"
                                  Width="18"
                                  Height="18"
                                  Stretch="Uniform"
                                  Fill="{DynamicResource IconGrayBrush}"
                                  Margin="0,0,0,2"
                                  Data="M6.76,4.84 l-1.8,-1.79 l-1.41,1.41 l1.79,1.79 l1.42,-1.41 z M4,10.5 H1 v2 h3 v-2 z M13,0.55 h-2 V3.5 h2 V0.55 z M20.45,4.46 l-1.41,-1.41 l-1.79,1.79 l1.41,1.41 l1.79,-1.79 z M17.24,18.15 l1.79,1.8 l1.41,-1.41 l-1.8,-1.79 l-1.4,1.4 z M20,10.5 v2 h3 v-2 h-3 z M12,5.5 c-3.31,0 -6,2.69 -6,6 s2.69,6 6,6 s6,-2.69 6,-6 s-2.69,-6 -6,-6 z M11,19.5 h2 v2.95 h-2 v-2.95 z M3.55,18.54 l1.41,1.41 l1.79,-1.8 l-1.41,-1.41 l-1.79,1.8 z"/>
                            <TextBlock Text="{Binding ThemeButtonText}" Style="{StaticResource RibbonIconLabel}"/>
                        </StackPanel>
                    </Button>
                    <Border x:Name="ThemeSettingsSeparator" Grid.Column="1" Style="{StaticResource RibbonSectionSeparator}" Margin="10,10"/>
                    <Button x:Name="SettingsButton" Grid.Column="2" Style="{StaticResource RibbonFlatButton}" Command="{Binding ShowProjectSettingsCommand}" ToolTip="{x:Static res:Strings.Settings}">
                        <StackPanel Orientation="Vertical"><Path Width="18" Height="18" Stretch="Uniform" Data="M19.43 12.98c.04-.32.07-.64.07-.98s-.03-.66-.07-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.39-.3-.61-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98l-2.49-1c-.23-.09-.49 0-.61.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.32-.07.65-.07.98s.03.66.07.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.39.3.61.22l2.49-1c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.59 1.69-.98l2.49 1c.23.09.49 0 .61-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.11-1.65zM12 15.5c-1.93 0-3.5-1.57-3.5-3.5s1.57-3.5 3.5-3.5 3.5 1.57 3.5 3.5-1.57 3.5-3.5 3.5z" Fill="{DynamicResource IconGrayBrush}"/><TextBlock Text="{x:Static res:Strings.Settings}" Style="{StaticResource RibbonIconLabel}"/></StackPanel>
                    </Button>
                    <Border Grid.Column="3" Style="{StaticResource RibbonSectionSeparator}" Margin="10,10"/>
                    <Button x:Name="AboutButton" Grid.Column="4" Style="{StaticResource RibbonFlatButton}" Click="AboutButton_Click" ToolTip="프로그램 정보">
                        <StackPanel Orientation="Vertical">
                            <Grid Width="18" Height="18">
                                <Ellipse Fill="{DynamicResource IconGrayBrush}"/>
                                <TextBlock Text="i" FontSize="13" FontWeight="Bold"
                                           Foreground="{DynamicResource ToolbarShellBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Margin="0,-1,0,0"/>
                            </Grid>
                            <TextBlock Text="정보" Style="{StaticResource RibbonIconLabel}"/>
                        </StackPanel>
                    </Button>
                </Grid>
                <TextBlock Grid.Row="1" Text="설정" Style="{StaticResource RibbonSectionLabel}"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
