<UserControl x:Class="Promaker.Controls.MainToolbarSimulationContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:res="clr-namespace:Promaker.Resources"
             x:Name="ThisControl">
    <WrapPanel x:Name="SimulationRibbonContentPanel"
               Orientation="Horizontal"
               VerticalAlignment="Center"
               DataContext="{Binding Simulation}">
        <WrapPanel.Style>
            <Style TargetType="WrapPanel">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding DataContext.SelectedRibbonGroup, ElementName=ThisControl}" Value="Simulation">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </WrapPanel.Style>

        <Button IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource SlimToolbarButton}">
                    <Setter Property="Command" Value="{Binding StartSimulationCommand}"/>
                    <Setter Property="ToolTip" Value="{x:Static res:Strings.StartSimulationTooltip}"/>
                    <Setter Property="Foreground" Value="{DynamicResource IconGreenBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSimulating}" Value="True">
                            <Setter Property="Command" Value="{Binding StopSimulationCommand}"/>
                            <Setter Property="ToolTip" Value="{x:Static res:Strings.StopSimulationTooltip}"/>
                            <Setter Property="Foreground" Value="{DynamicResource IconRedBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <Path Width="18"
                      Height="18"
                      Stretch="Uniform"
                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                    <Path.Style>
                        <Style TargetType="Path">
                            <Setter Property="Data" Value="{StaticResource IconPlay}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSimulating}" Value="True">
                                    <Setter Property="Data" Value="{StaticResource IconStop}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                </Path>
                <TextBlock FontSize="9"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,0"
                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="{x:Static res:Strings.Start}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSimulating}" Value="True">
                                    <Setter Property="Text" Value="{x:Static res:Strings.Stop}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Button>

        <Button Style="{StaticResource SlimToolbarButton}" Command="{Binding PauseSimulationCommand}" ToolTip="{x:Static res:Strings.PauseSimulationTooltip}" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <Path Width="18" Height="18" Stretch="Uniform" Data="{StaticResource IconPause}" Fill="{DynamicResource IconGrayBrush}"/>
                <TextBlock Text="{x:Static res:Strings.Pause}" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
        </Button>

        <Button Style="{StaticResource SlimToolbarButton}"
                Command="{Binding ResetSimulationCommand}"
                ToolTip="{x:Static res:Strings.ResetSimulationTooltip}"
                IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}"
                Foreground="{DynamicResource IconOrangeBrush}">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <Path Width="18"
                      Height="18"
                      Stretch="Uniform"
                      Data="{StaticResource IconRefresh}"
                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                <TextBlock Text="{x:Static res:Strings.Reset}"
                           FontSize="9"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,0"
                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
            </StackPanel>
        </Button>

        <Border Style="{StaticResource RibbonContentSeparator}"/>

        <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,6,0" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}">
            <TextBlock Text="공정" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,2"/>
            <ComboBox x:Name="SimWorkComboBox"
                      ItemsSource="{Binding SimWorkItems}"
                      SelectedItem="{Binding SelectedSimWork}"
                      Width="130"
                      FontSize="11"/>
            <UniformGrid Columns="2" Margin="0,6,0,0">
                <Button x:Name="ForceWorkStartButton"
                        Command="{Binding ForceWorkStartCommand}"
                        ToolTip="{x:Static res:Strings.ForceWorkStartTooltip}"
                        IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}"
                        Margin="0,0,4,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SlimToolbarButton}">
                            <Setter Property="Foreground" Value="{DynamicResource IconGreenBrush}"/>
                            <Setter Property="MinWidth" Value="0"/>
                            <Setter Property="MinHeight" Value="0"/>
                            <Setter Property="Padding" Value="8,4"/>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <Path Width="10"
                              Height="10"
                              Stretch="Uniform"
                              Data="{StaticResource IconPlay}"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Margin="0,0,4,0"/>
                        <TextBlock Text="{x:Static res:Strings.Start}"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </StackPanel>
                </Button>

                <Button x:Name="ForceWorkResetButton"
                        Command="{Binding ForceWorkResetCommand}"
                        ToolTip="{x:Static res:Strings.ForceWorkResetTooltip}"
                        IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}"
                        Margin="4,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SlimToolbarButton}">
                            <Setter Property="Foreground" Value="{DynamicResource IconOrangeBrush}"/>
                            <Setter Property="MinWidth" Value="0"/>
                            <Setter Property="MinHeight" Value="0"/>
                            <Setter Property="Padding" Value="8,4"/>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <Path Width="10"
                              Height="10"
                              Stretch="Uniform"
                              Data="{StaticResource IconRefresh}"
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Margin="0,0,4,0"/>
                        <TextBlock Text="{x:Static res:Strings.Reset}"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </StackPanel>
                </Button>
            </UniformGrid>
        </StackPanel>

        <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,4,0" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}">
            <TextBlock Text="{x:Static res:Strings.Speed}" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,2"/>
            <ComboBox x:Name="SimSpeedComboBox" SelectedValue="{Binding SimSpeed}" SelectedValuePath="Tag" Width="72" FontSize="11">
                <ComboBoxItem Content="0.5x">
                    <ComboBoxItem.Tag>
                        <sys:Double>0.5</sys:Double>
                    </ComboBoxItem.Tag>
                </ComboBoxItem>
                <ComboBoxItem Content="1x">
                    <ComboBoxItem.Tag>
                        <sys:Double>1.0</sys:Double>
                    </ComboBoxItem.Tag>
                </ComboBoxItem>
                <ComboBoxItem Content="2x">
                    <ComboBoxItem.Tag>
                        <sys:Double>2.0</sys:Double>
                    </ComboBoxItem.Tag>
                </ComboBoxItem>
                <ComboBoxItem Content="5x">
                    <ComboBoxItem.Tag>
                        <sys:Double>5.0</sys:Double>
                    </ComboBoxItem.Tag>
                </ComboBoxItem>
                <ComboBoxItem Content="10x">
                    <ComboBoxItem.Tag>
                        <sys:Double>10.0</sys:Double>
                    </ComboBoxItem.Tag>
                </ComboBoxItem>
                <ComboBoxItem Content="{x:Static res:Strings.IgnoreTime}">
                    <ComboBoxItem.Tag>
                        <sys:Double>0</sys:Double>
                    </ComboBoxItem.Tag>
                </ComboBoxItem>
            </ComboBox>
        </StackPanel>
    </WrapPanel>
</UserControl>
