<UserControl x:Class="Promaker.Controls.MainToolbarSimulationContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:core="clr-namespace:Ds2.Core;assembly=Ds2.Core"
             xmlns:conv="clr-namespace:Promaker.Presentation"
             xmlns:res="clr-namespace:Promaker.Resources">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="MainToolbarResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="SimulationSection" HorizontalAlignment="Left">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 시뮬레이션 controls (PLAY/PAUSE + Work + 속도) -->
        <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal">
            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="SimulationStartStopButton"
                            IsEnabled="{Binding HasProject}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RibbonFlatButton}">
                                <Setter Property="Command" Value="{Binding Simulation.StartSimulationCommand}"/>
                                <Setter Property="ToolTip" Value="{x:Static res:Strings.StartSimulationTooltip}"/>
                                <Setter Property="Foreground" Value="{DynamicResource IconGreenBrush}"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Simulation.IsSimulating}" Value="True"/>
                                            <Condition Binding="{Binding Simulation.IsSimPaused}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Command" Value="{Binding Simulation.StopSimulationCommand}"/>
                                        <Setter Property="ToolTip" Value="{x:Static res:Strings.StopSimulationTooltip}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource IconRedBrush}"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Vertical">
                            <Grid Width="18" Height="18">
                                <iconPacks:PackIconMaterial Kind="Play"
                                                            Width="18"
                                                            Height="18"
                                                            HorizontalAlignment="Center"
                                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                    <iconPacks:PackIconMaterial.Style>
                                        <Style TargetType="iconPacks:PackIconMaterial">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Simulation.IsSimulating}" Value="True"/>
                                                        <Condition Binding="{Binding Simulation.IsSimPaused}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </iconPacks:PackIconMaterial.Style>
                                </iconPacks:PackIconMaterial>
                                <iconPacks:PackIconMaterial Kind="Stop"
                                                            Width="18"
                                                            Height="18"
                                                            HorizontalAlignment="Center"
                                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                    <iconPacks:PackIconMaterial.Style>
                                        <Style TargetType="iconPacks:PackIconMaterial">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Simulation.IsSimulating}" Value="True"/>
                                                        <Condition Binding="{Binding Simulation.IsSimPaused}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </iconPacks:PackIconMaterial.Style>
                                </iconPacks:PackIconMaterial>
                            </Grid>
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource RibbonIconLabel}">
                                        <Setter Property="Text" Value="PLAY"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Simulation.IsSimulating}" Value="True"/>
                                                    <Condition Binding="{Binding Simulation.IsSimPaused}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Text" Value="STOP"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                    <Button x:Name="SimulationPauseStepButton"
                            IsEnabled="{Binding HasProject}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RibbonFlatButton}">
                                <Setter Property="Command" Value="{Binding Simulation.PauseSimulationCommand}"/>
                                <Setter Property="ToolTip" Value="{x:Static res:Strings.PauseSimulationTooltip}"/>
                                <Setter Property="Foreground" Value="{DynamicResource IconOrangeBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Simulation.IsSimPaused}" Value="True">
                                        <Setter Property="Command" Value="{Binding Simulation.StepSimulationCommand}"/>
                                        <Setter Property="ToolTip" Value="한 단계 실행"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Vertical">
                            <Grid Width="18" Height="18">
                                <iconPacks:PackIconMaterial Kind="Pause"
                                                            Width="18"
                                                            Height="18"
                                                            HorizontalAlignment="Center"
                                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                    <iconPacks:PackIconMaterial.Style>
                                        <Style TargetType="iconPacks:PackIconMaterial">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Simulation.IsSimPaused}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </iconPacks:PackIconMaterial.Style>
                                </iconPacks:PackIconMaterial>
                                <iconPacks:PackIconMaterial Kind="SkipNext"
                                                            Width="18"
                                                            Height="18"
                                                            HorizontalAlignment="Center"
                                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                    <iconPacks:PackIconMaterial.Style>
                                        <Style TargetType="iconPacks:PackIconMaterial">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Simulation.IsSimPaused}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </iconPacks:PackIconMaterial.Style>
                                </iconPacks:PackIconMaterial>
                            </Grid>
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource RibbonIconLabel}">
                                        <Setter Property="Text" Value="PAUSE"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Simulation.IsSimPaused}" Value="True">
                                                <Setter Property="Text" Value="STEP"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                    <!-- 원위치(Homing) — Control 모드 + 실 PLC 연결 시에만 가시. Push-button: 누르고 있는 동안만 진행, 떼면 즉시 종료(deadman switch). -->
                    <Button x:Name="SimulationHomingButton"
                            ToolTip="{x:Static res:Strings.HomingTooltip}"
                            Visibility="{Binding Simulation.IsHomingButtonVisible, Converter={StaticResource BoolToVis}}"
                            IsEnabled="{Binding Simulation.IsHomingButtonHotEnabled}"
                            PreviewMouseLeftButtonDown="HomingButton_MouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="HomingButton_Release"
                            LostMouseCapture="HomingButton_Release">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RibbonFlatButton}">
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                <Style.Triggers>
                                    <!-- 누름 상태: 빨간 강조 + 굵은 테두리 (deadman switch 임을 시각적으로 강조) -->
                                    <DataTrigger Binding="{Binding Simulation.IsHomingPressed}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource IconRedBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource IconRedBrush}"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Vertical">
                            <iconPacks:PackIconMaterial Kind="HomeImportOutline"
                                                        Width="18" Height="18"
                                                        HorizontalAlignment="Center"
                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource RibbonIconLabel}">
                                        <Setter Property="Text" Value="원위치(Hold)"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Simulation.IsHomingPressed}" Value="True">
                                                <Setter Property="Text" Value="진행중..."/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                    <!-- 수동 컨트롤러 — Control + 실 PLC 연결 시에만 가시. 클릭하면 modeless 다이얼로그가 열려 디바이스별로 직접 ON/OFF 제어. -->
                    <Button x:Name="SimulationManualControlButton"
                            Click="ManualControlButton_Click"
                            ToolTip="{x:Static res:Strings.ManualControlTooltip}"
                            Visibility="{Binding Simulation.IsManualControlButtonVisible, Converter={StaticResource BoolToVis}}"
                            IsEnabled="{Binding Simulation.IsManualControlButtonHotEnabled}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RibbonFlatButton}">
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Simulation.IsManualControlActive}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource IconRedBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource IconRedBrush}"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Vertical">
                            <iconPacks:PackIconMaterial Kind="GestureTapButton"
                                                        Width="18" Height="18"
                                                        HorizontalAlignment="Center"
                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource RibbonIconLabel}">
                                        <Setter Property="Text" Value="수동"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Simulation.IsManualControlActive}" Value="True">
                                                <Setter Property="Text" Value="활성"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,0">
                    <iconPacks:PackIconMaterial Kind="Autorenew"
                                                Width="12" Height="12"
                                                VerticalAlignment="Center"
                                                Margin="0,0,4,0"
                                                SpinDuration="1.5"
                                                Foreground="{DynamicResource IconOrangeBrush}">
                        <iconPacks:PackIconMaterial.Style>
                            <Style TargetType="iconPacks:PackIconMaterial">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Spin" Value="False"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Simulation.IsHomingPhase}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Spin" Value="True"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </iconPacks:PackIconMaterial.Style>
                    </iconPacks:PackIconMaterial>
                    <TextBlock Text="{Binding Simulation.SimStatusText}"
                               FontSize="9"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource IconRedBrush}"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Simulation.IsSimulating}" Value="True"/>
                                            <Condition Binding="{Binding Simulation.IsSimPaused}" Value="False"/>
                                            <Condition Binding="{Binding Simulation.IsHomingPhase}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Foreground" Value="{DynamicResource IconGreenBrush}"/>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Simulation.IsSimulating}" Value="True"/>
                                            <Condition Binding="{Binding Simulation.IsSimPaused}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Foreground" Value="{DynamicResource IconOrangeBrush}"/>
                                    </MultiDataTrigger>
                                    <DataTrigger Binding="{Binding Simulation.SimStatusText}" Value="시뮬레이션 단계 제어 중">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Simulation.IsHomingPhase}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource IconOrangeBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard Name="PulseStoryboard">
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True" FillBehavior="Stop">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1.0" To="0.55" Duration="0:0:0.9"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="PulseStoryboard"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <!-- Work / 속도 / 연속투입 통합 grid: 같은 grid 의 row 라서 라벨/콤보가 자동으로 같은 가로선에 정렬됨 -->
            <Grid Margin="22,0,0,0"
                  VerticalAlignment="Center"
                  IsEnabled="{Binding HasProject}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Work 칸 -->
                <TextBlock Grid.Column="0" Grid.Row="0" Text="Work" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,1"/>
                <ComboBox Grid.Column="0" Grid.Row="1"
                          x:Name="SimWorkComboBox"
                          ItemsSource="{Binding Simulation.SimWorkItems}"
                          SelectedItem="{Binding Simulation.SelectedSimWork}"
                          Width="130"
                          MinHeight="24"
                          FontSize="11"/>
                <UniformGrid Grid.Column="0" Grid.Row="2" Columns="2" Margin="0,1,0,0">
                    <Button x:Name="ForceWorkStartButton"
                            Command="{Binding Simulation.ForceWorkStartCommand}"
                            ToolTip="{x:Static res:Strings.ForceWorkStartTooltip}"
                            IsEnabled="{Binding HasProject}"
                            Margin="0,0,2,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RibbonFlatButton}">
                                <Setter Property="Foreground" Value="{DynamicResource IconGreenBrush}"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                                <Setter Property="Padding" Value="6,2"/>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="START"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   HorizontalAlignment="Center"/>
                    </Button>
                    <Button x:Name="ForceWorkResetButton"
                            Command="{Binding Simulation.ForceWorkResetCommand}"
                            ToolTip="{x:Static res:Strings.ForceWorkResetTooltip}"
                            IsEnabled="{Binding HasProject}"
                            Margin="2,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RibbonFlatButton}">
                                <Setter Property="Foreground" Value="{DynamicResource IconOrangeBrush}"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                                <Setter Property="Padding" Value="6,2"/>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="RESET"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   HorizontalAlignment="Center"/>
                    </Button>
                </UniformGrid>

                <!-- 속도 칸 (좌측 22px 간격은 column 1 자식들의 좌측 Margin 으로 부여) -->
                <TextBlock Grid.Column="1" Grid.Row="0" Text="{x:Static res:Strings.Speed}" FontSize="9" HorizontalAlignment="Center" Margin="22,0,0,1"/>
                <ComboBox Grid.Column="1" Grid.Row="1"
                          x:Name="SimSpeedComboBox"
                          SelectedValue="{Binding Simulation.SimSpeed}"
                          SelectedValuePath="Tag"
                          Width="110"
                          MinHeight="24"
                          FontSize="11"
                          HorizontalContentAlignment="Center"
                          Margin="22,0,0,0">
                    <ComboBoxItem Content="0.5x"><ComboBoxItem.Tag><sys:Double>0.5</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="1x"><ComboBoxItem.Tag><sys:Double>1.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="2x"><ComboBoxItem.Tag><sys:Double>2.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="5x"><ComboBoxItem.Tag><sys:Double>5.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="10x"><ComboBoxItem.Tag><sys:Double>10.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                </ComboBox>
                <!-- Token + 연속투입 — 같은 StackPanel 에 묶어 baseline/padding 일관 정렬 (column 1+2 RowSpan 방식) -->
                <StackPanel Grid.Column="1" Grid.Row="2" Grid.ColumnSpan="2"
                            Orientation="Horizontal" HorizontalAlignment="Center" Margin="22,1,0,0">
                    <Button x:Name="OpenTokenSpecButton"
                            Command="{Binding OpenTokenSpecDialogCommand}"
                            IsEnabled="{Binding HasProject}"
                            ToolTip="TokenSpec 편집"
                            VerticalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RibbonFlatButton}">
                                <Setter Property="Foreground" Value="{DynamicResource IconGrayBrush}"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                                <Setter Property="Padding" Value="6,2"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="CheckCircle" Width="11" Height="11"
                                                        VerticalAlignment="Center" Margin="0,0,3,0"
                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            <TextBlock Text="Token" FontSize="11" VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </StackPanel>
                    </Button>
                    <!-- 연속투입: Token 과 같은 padding/외곽선/baseline. IsChecked=True 일 때 AccentBrush 배경 + 흰글씨로 "눌린 이펙트". -->
                    <ToggleButton x:Name="ContinuousInjectionToggle"
                                  IsChecked="{Binding Simulation.IsContinuousInjectionEnabled}"
                                  IsEnabled="{Binding HasProject}"
                                  Margin="6,0,0,0"
                                  ToolTip="Source START 후 Ready 복귀 시 다음 토큰을 자동으로 다시 투입합니다.">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{DynamicResource IconGrayBrush}"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="4,2"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="3"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}"/>
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Repeat" Width="10" Height="10"
                                                        VerticalAlignment="Center" Margin="0,0,3,0"
                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                            <TextBlock Text="연속투입" FontSize="11" VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"/>
                        </StackPanel>
                    </ToggleButton>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- 시뮬레이션 / 런타임 구분선 — 다른 ribbon 섹션과 동일 스타일/길이 (라벨 row 까지 RowSpan=2) -->
        <Border Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                Style="{StaticResource RibbonSectionSeparator}"/>

        <!-- 런타임 controls (Runtime 버튼 + 모드/Hub 입력) -->
        <StackPanel Grid.Column="2" Grid.Row="0" Orientation="Horizontal">
            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                <Button x:Name="RuntimeSettingButton"
                        Command="{Binding ShowRuntimeSettingsCommand}"
                        IsEnabled="{Binding HasProject}"
                        ToolTip="런타임 설정 (Runtime Mode · Variant · Theme)">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource RibbonFlatButton}">
                            <Setter Property="Foreground" Value="{DynamicResource IconGrayBrush}"/>
                            <Setter Property="MinWidth" Value="56"/>
                            <Setter Property="MinHeight" Value="0"/>
                            <Setter Property="Padding" Value="8,6"/>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial Kind="Cog" Width="18" Height="18"
                                                    HorizontalAlignment="Center"
                                                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        <TextBlock Text="Runtime" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Vertical"
                        Margin="12,0,0,0"
                        MinWidth="130"
                        VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Simulation.SelectedRuntimeMode}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               VerticalAlignment="Center"/>
                    <Ellipse Width="8" Height="8" Margin="6,0,0,0"
                             VerticalAlignment="Center"
                             Visibility="{Binding Simulation.NeedsHubConnection, Converter={StaticResource BoolToVis}}"
                             ToolTip="{Binding Simulation.HubStatusText}">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource IconRedBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Simulation.IsHubReconnecting}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource IconOrangeBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Simulation.IsHubConnected}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource IconGreenBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </StackPanel>
                <TextBox Text="{Binding Simulation.HubAddress, UpdateSourceTrigger=PropertyChanged}"
                         Width="130" MinHeight="24" FontSize="11"
                         Margin="0,3,0,0"
                         Padding="6,2"
                         VerticalContentAlignment="Center"
                         IsEnabled="{Binding Simulation.CanChangeMode}"
                         ToolTip="Hub 주소 (host:port) — Sim 외 모드에서 입력"
                         Visibility="{Binding Simulation.NeedsHubConnection, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </StackPanel>

        <!-- 섹션 라벨: 시뮬레이션 / 런타임 (각자 칸 중앙 정렬) -->
        <TextBlock Grid.Column="0" Grid.Row="1" Text="시뮬레이션" Style="{StaticResource RibbonSectionLabel}"/>
        <TextBlock Grid.Column="2" Grid.Row="1" Text="런타임" Style="{StaticResource RibbonSectionLabel}"/>
    </Grid>
</UserControl>
