<UserControl x:Class="Promaker.Controls.MainToolbarSimulationContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:res="clr-namespace:Promaker.Resources">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="MainToolbarResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="SimulationSection" HorizontalAlignment="Left">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <WrapPanel x:Name="SimulationRibbonContentPanel" Orientation="Horizontal">
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="SimulationStartStopButton"
                            IsEnabled="{Binding HasProject}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RibbonFlatButton}">
                                <Setter Property="Command" Value="{Binding Simulation.StartSimulationCommand}"/>
                                <Setter Property="ToolTip" Value="{x:Static res:Strings.StartSimulationTooltip}"/>
                                <Setter Property="Foreground" Value="{DynamicResource IconGreenBrush}"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Simulation.IsSimulating}" Value="True"/>
                                            <Condition Binding="{Binding Simulation.IsSimPaused}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Command" Value="{Binding Simulation.StopSimulationCommand}"/>
                                        <Setter Property="ToolTip" Value="{x:Static res:Strings.StopSimulationTooltip}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource IconRedBrush}"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Vertical">
                            <Grid Width="18" Height="18">
                                <iconPacks:PackIconMaterial Kind="Play"
                                                            Width="18"
                                                            Height="18"
                                                            HorizontalAlignment="Center"
                                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                    <iconPacks:PackIconMaterial.Style>
                                        <Style TargetType="iconPacks:PackIconMaterial">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Simulation.IsSimulating}" Value="True"/>
                                                        <Condition Binding="{Binding Simulation.IsSimPaused}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </iconPacks:PackIconMaterial.Style>
                                </iconPacks:PackIconMaterial>
                                <iconPacks:PackIconMaterial Kind="Stop"
                                                            Width="18"
                                                            Height="18"
                                                            HorizontalAlignment="Center"
                                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                    <iconPacks:PackIconMaterial.Style>
                                        <Style TargetType="iconPacks:PackIconMaterial">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Simulation.IsSimulating}" Value="True"/>
                                                        <Condition Binding="{Binding Simulation.IsSimPaused}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </iconPacks:PackIconMaterial.Style>
                                </iconPacks:PackIconMaterial>
                            </Grid>
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource RibbonIconLabel}">
                                        <Setter Property="Text" Value="PLAY"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Simulation.IsSimulating}" Value="True"/>
                                                    <Condition Binding="{Binding Simulation.IsSimPaused}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Text" Value="STOP"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                    <Button x:Name="SimulationPauseStepButton"
                            IsEnabled="{Binding HasProject}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RibbonFlatButton}">
                                <Setter Property="Command" Value="{Binding Simulation.PauseSimulationCommand}"/>
                                <Setter Property="ToolTip" Value="{x:Static res:Strings.PauseSimulationTooltip}"/>
                                <Setter Property="Foreground" Value="{DynamicResource IconOrangeBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Simulation.IsSimPaused}" Value="True">
                                        <Setter Property="Command" Value="{Binding Simulation.StepSimulationCommand}"/>
                                        <Setter Property="ToolTip" Value="한 단계 실행"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Vertical">
                            <Grid Width="18" Height="18">
                                <iconPacks:PackIconMaterial Kind="Pause"
                                                            Width="18"
                                                            Height="18"
                                                            HorizontalAlignment="Center"
                                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                    <iconPacks:PackIconMaterial.Style>
                                        <Style TargetType="iconPacks:PackIconMaterial">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Simulation.IsSimPaused}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </iconPacks:PackIconMaterial.Style>
                                </iconPacks:PackIconMaterial>
                                <iconPacks:PackIconMaterial Kind="SkipNext"
                                                            Width="18"
                                                            Height="18"
                                                            HorizontalAlignment="Center"
                                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                    <iconPacks:PackIconMaterial.Style>
                                        <Style TargetType="iconPacks:PackIconMaterial">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Simulation.IsSimPaused}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </iconPacks:PackIconMaterial.Style>
                                </iconPacks:PackIconMaterial>
                            </Grid>
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource RibbonIconLabel}">
                                        <Setter Property="Text" Value="PAUSE"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Simulation.IsSimPaused}" Value="True">
                                                <Setter Property="Text" Value="STEP"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,0">
                    <iconPacks:PackIconMaterial Kind="Autorenew"
                                                Width="12" Height="12"
                                                VerticalAlignment="Center"
                                                Margin="0,0,4,0"
                                                SpinDuration="1.5"
                                                Foreground="{DynamicResource IconOrangeBrush}">
                        <iconPacks:PackIconMaterial.Style>
                            <Style TargetType="iconPacks:PackIconMaterial">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Spin" Value="False"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Simulation.IsHomingPhase}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="Spin" Value="True"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </iconPacks:PackIconMaterial.Style>
                    </iconPacks:PackIconMaterial>
                    <TextBlock Text="{Binding Simulation.SimStatusText}"
                               FontSize="9"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource IconRedBrush}"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Simulation.IsSimulating}" Value="True"/>
                                            <Condition Binding="{Binding Simulation.IsSimPaused}" Value="False"/>
                                            <Condition Binding="{Binding Simulation.IsHomingPhase}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Foreground" Value="{DynamicResource IconGreenBrush}"/>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Simulation.IsSimulating}" Value="True"/>
                                            <Condition Binding="{Binding Simulation.IsSimPaused}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Foreground" Value="{DynamicResource IconOrangeBrush}"/>
                                    </MultiDataTrigger>
                                    <DataTrigger Binding="{Binding Simulation.SimStatusText}" Value="시뮬레이션 단계 제어 중">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Simulation.IsHomingPhase}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource IconOrangeBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard Name="PulseStoryboard">
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True" FillBehavior="Stop">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1.0" To="0.55" Duration="0:0:0.9"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="PulseStoryboard"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
            <StackPanel Orientation="Vertical"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        IsEnabled="{Binding HasProject}">
                <TextBlock Text="Work" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,1"/>
                <ComboBox x:Name="SimWorkComboBox"
                          ItemsSource="{Binding Simulation.SimWorkItems}"
                          SelectedItem="{Binding Simulation.SelectedSimWork}"
                          Width="130"
                          MinHeight="24"
                          FontSize="11"/>
                <UniformGrid Columns="2" Margin="0,1,0,0">
                    <Button x:Name="ForceWorkStartButton"
                            Command="{Binding Simulation.ForceWorkStartCommand}"
                            ToolTip="{x:Static res:Strings.ForceWorkStartTooltip}"
                            IsEnabled="{Binding HasProject}"
                            Margin="0,0,2,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RibbonFlatButton}">
                                <Setter Property="Foreground" Value="{DynamicResource IconGreenBrush}"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                                <Setter Property="Padding" Value="6,2"/>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="START"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   HorizontalAlignment="Center"/>
                    </Button>
                    <Button x:Name="ForceWorkResetButton"
                            Command="{Binding Simulation.ForceWorkResetCommand}"
                            ToolTip="{x:Static res:Strings.ForceWorkResetTooltip}"
                            IsEnabled="{Binding HasProject}"
                            Margin="2,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RibbonFlatButton}">
                                <Setter Property="Foreground" Value="{DynamicResource IconOrangeBrush}"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                                <Setter Property="Padding" Value="6,2"/>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="RESET"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   HorizontalAlignment="Center"/>
                    </Button>
                </UniformGrid>
            </StackPanel>
            <StackPanel Orientation="Vertical"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        IsEnabled="{Binding HasProject}">
                <TextBlock Text="{x:Static res:Strings.Speed}" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,1"/>
                <ComboBox x:Name="SimSpeedComboBox"
                          SelectedValue="{Binding Simulation.SimSpeed}"
                          SelectedValuePath="Tag"
                          Width="72"
                          MinHeight="24"
                          FontSize="11">
                    <ComboBoxItem Content="0.5x"><ComboBoxItem.Tag><sys:Double>0.5</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="1x"><ComboBoxItem.Tag><sys:Double>1.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="2x"><ComboBoxItem.Tag><sys:Double>2.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="5x"><ComboBoxItem.Tag><sys:Double>5.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="10x"><ComboBoxItem.Tag><sys:Double>10.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="{x:Static res:Strings.IgnoreTime}"><ComboBoxItem.Tag><sys:Double>0.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                </ComboBox>
            </StackPanel>
            <Button x:Name="OpenTokenSpecButton"
                    Style="{StaticResource RibbonFlatButton}"
                    Command="{Binding OpenTokenSpecDialogCommand}"
                    IsEnabled="{Binding HasProject}"
                    ToolTip="TokenSpec 편집">
                <StackPanel Orientation="Vertical">
                    <iconPacks:PackIconMaterial Kind="CheckCircle" Width="18" Height="18" HorizontalAlignment="Center" Foreground="{DynamicResource IconGrayBrush}"/>
                    <TextBlock Text="Token" Style="{StaticResource RibbonIconLabel}"/>
                </StackPanel>
            </Button>
            <Button x:Name="CheckModelButton"
                    Style="{StaticResource RibbonFlatButton}"
                    Command="{Binding Simulation.CheckModelCommand}"
                    IsEnabled="{Binding HasProject}"
                    ToolTip="모델 검증 (그래프 경고 확인)">
                <StackPanel Orientation="Vertical">
                    <iconPacks:PackIconMaterial Kind="ShieldCheck" Width="18" Height="18" HorizontalAlignment="Center" Foreground="{DynamicResource IconGrayBrush}"/>
                    <TextBlock Text="Check" Style="{StaticResource RibbonIconLabel}"/>
                </StackPanel>
            </Button>
        </WrapPanel>
        <TextBlock Grid.Row="1" Text="시뮬레이션" Style="{StaticResource RibbonSectionLabel}"/>
    </Grid>
</UserControl>
