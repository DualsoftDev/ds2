<UserControl x:Class="Promaker.Controls.MainToolbarSimulationContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:res="clr-namespace:Promaker.Resources"
             x:Name="ThisControl"
             DataContext="{Binding Simulation}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="MainToolbarResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="SimulationSection" HorizontalAlignment="Left">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <WrapPanel x:Name="SimulationRibbonContentPanel" Orientation="Horizontal">
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="SimulationStartStopButton" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RibbonFlatButton}">
                                <Setter Property="Command" Value="{Binding StartSimulationCommand}"/>
                                <Setter Property="ToolTip" Value="{x:Static res:Strings.StartSimulationTooltip}"/>
                                <Setter Property="Foreground" Value="{DynamicResource IconGreenBrush}"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsSimulating}" Value="True"/>
                                            <Condition Binding="{Binding IsSimPaused}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Command" Value="{Binding StopSimulationCommand}"/>
                                        <Setter Property="ToolTip" Value="{x:Static res:Strings.StopSimulationTooltip}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource IconRedBrush}"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Vertical">
                            <Grid Width="18" Height="18">
                                <iconPacks:PackIconMaterial Kind="Play" Width="18" Height="18" HorizontalAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                    <iconPacks:PackIconMaterial.Style>
                                        <Style TargetType="iconPacks:PackIconMaterial">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsSimulating}" Value="True"/>
                                                        <Condition Binding="{Binding IsSimPaused}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </iconPacks:PackIconMaterial.Style>
                                </iconPacks:PackIconMaterial>
                                <iconPacks:PackIconMaterial Kind="Stop" Width="18" Height="18" HorizontalAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                    <iconPacks:PackIconMaterial.Style>
                                        <Style TargetType="iconPacks:PackIconMaterial">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsSimulating}" Value="True"/>
                                                        <Condition Binding="{Binding IsSimPaused}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </iconPacks:PackIconMaterial.Style>
                                </iconPacks:PackIconMaterial>
                            </Grid>
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource RibbonIconLabel}">
                                        <Setter Property="Text" Value="PLAY"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsSimulating}" Value="True"/>
                                                    <Condition Binding="{Binding IsSimPaused}" Value="False"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Text" Value="STOP"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                    <Button>
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RibbonFlatButton}">
                                <Setter Property="Command" Value="{Binding PauseSimulationCommand}"/>
                                <Setter Property="ToolTip" Value="{x:Static res:Strings.PauseSimulationTooltip}"/>
                                <Setter Property="Foreground" Value="{DynamicResource IconOrangeBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSimPaused}" Value="True">
                                        <Setter Property="Command" Value="{Binding StepSimulationCommand}"/>
                                        <Setter Property="ToolTip" Value="한 단계 실행"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Vertical">
                            <Grid Width="18" Height="18">
                                <iconPacks:PackIconMaterial Kind="Pause" Width="18" Height="18" HorizontalAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                    <iconPacks:PackIconMaterial.Style>
                                        <Style TargetType="iconPacks:PackIconMaterial">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSimPaused}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </iconPacks:PackIconMaterial.Style>
                                </iconPacks:PackIconMaterial>
                                <iconPacks:PackIconMaterial Kind="SkipNext" Width="18" Height="18" HorizontalAlignment="Center" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                    <iconPacks:PackIconMaterial.Style>
                                        <Style TargetType="iconPacks:PackIconMaterial">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSimPaused}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </iconPacks:PackIconMaterial.Style>
                                </iconPacks:PackIconMaterial>
                            </Grid>
                            <TextBlock Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource RibbonIconLabel}">
                                        <Setter Property="Text" Value="PAUSE"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSimPaused}" Value="True">
                                                <Setter Property="Text" Value="STEP"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock Text="{Binding SimStatusText}" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource IconRedBrush}"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsSimulating}" Value="True"/>
                                        <Condition Binding="{Binding IsSimPaused}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Foreground" Value="{DynamicResource IconGreenBrush}"/>
                                </MultiDataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsSimulating}" Value="True"/>
                                        <Condition Binding="{Binding IsSimPaused}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Foreground" Value="{DynamicResource IconOrangeBrush}"/>
                                </MultiDataTrigger>
                                <DataTrigger Binding="{Binding SimStatusText}" Value="단계 제어 중">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="8,0,0,0" VerticalAlignment="Center" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}">
                <TextBlock Text="Work" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,1"/>
                <ComboBox x:Name="SimWorkComboBox" ItemsSource="{Binding SimWorkItems}" SelectedItem="{Binding SelectedSimWork}" Width="130" FontSize="11"/>
                <UniformGrid Columns="2" Margin="0,1,0,0">
                    <Button x:Name="ForceWorkStartButton" Command="{Binding ForceWorkStartCommand}" ToolTip="{x:Static res:Strings.ForceWorkStartTooltip}" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}" Margin="0,0,2,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RibbonFlatButton}">
                                <Setter Property="Foreground" Value="{DynamicResource IconGreenBrush}"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                                <Setter Property="Padding" Value="6,2"/>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="START" VerticalAlignment="Center" FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" HorizontalAlignment="Center"/>
                    </Button>
                    <Button x:Name="ForceWorkResetButton" Command="{Binding ForceWorkResetCommand}" ToolTip="{x:Static res:Strings.ForceWorkResetTooltip}" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}" Margin="2,0,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource RibbonFlatButton}">
                                <Setter Property="Foreground" Value="{DynamicResource IconOrangeBrush}"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                                <Setter Property="Padding" Value="6,2"/>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="RESET" VerticalAlignment="Center" FontSize="11" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" HorizontalAlignment="Center"/>
                    </Button>
                </UniformGrid>
            </StackPanel>
            <StackPanel Orientation="Vertical" Margin="8,0,0,0" VerticalAlignment="Center" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}">
                <TextBlock Text="{x:Static res:Strings.Speed}" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,1"/>
                <ComboBox x:Name="SimSpeedComboBox" SelectedValue="{Binding SimSpeed}" SelectedValuePath="Tag" Width="72" FontSize="11">
                    <ComboBoxItem Content="0.5x"><ComboBoxItem.Tag><sys:Double>0.5</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="1x"><ComboBoxItem.Tag><sys:Double>1.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="2x"><ComboBoxItem.Tag><sys:Double>2.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="5x"><ComboBoxItem.Tag><sys:Double>5.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="10x"><ComboBoxItem.Tag><sys:Double>10.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                    <ComboBoxItem Content="{x:Static res:Strings.IgnoreTime}"><ComboBoxItem.Tag><sys:Double>0.0</sys:Double></ComboBoxItem.Tag></ComboBoxItem>
                </ComboBox>
            </StackPanel>
            <Button Style="{StaticResource RibbonFlatButton}" Command="{Binding DataContext.OpenTokenSpecDialogCommand, ElementName=ThisControl}" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}" ToolTip="TokenSpec 편집">
                <StackPanel Orientation="Vertical">
                    <iconPacks:PackIconMaterial Kind="CheckCircle" Width="18" Height="18" HorizontalAlignment="Center" Foreground="{DynamicResource IconGrayBrush}"/>
                    <TextBlock Text="Token" Style="{StaticResource RibbonIconLabel}"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource RibbonFlatButton}" Command="{Binding CheckModelCommand}" IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}" ToolTip="모델 검증 (그래프 경고 확인)">
                <StackPanel Orientation="Vertical">
                    <iconPacks:PackIconMaterial Kind="ShieldCheck" Width="18" Height="18" HorizontalAlignment="Center" Foreground="{DynamicResource IconGrayBrush}"/>
                    <TextBlock Text="Check" Style="{StaticResource RibbonIconLabel}"/>
                </StackPanel>
            </Button>
        </WrapPanel>
        <TextBlock Grid.Row="1" Text="시뮬레이션" Style="{StaticResource RibbonSectionLabel}"/>
    </Grid>
</UserControl>
