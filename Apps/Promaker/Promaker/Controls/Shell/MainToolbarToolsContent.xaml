<UserControl x:Class="Promaker.Controls.MainToolbarToolsContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:Promaker.Resources"
             x:Name="ThisControl">
    <WrapPanel x:Name="ToolsRibbonContentPanel"
               Orientation="Horizontal"
               VerticalAlignment="Center">
        <WrapPanel.Style>
            <Style TargetType="WrapPanel">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SelectedRibbonGroup}" Value="Tools">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </WrapPanel.Style>

        <Button Style="{StaticResource SlimToolbarButton}"
                Command="{Binding OpenIoBatchDialogCommand}"
                IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}"
                ToolTip="I/O 일괄 편집">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <Path Width="18"
                      Height="18"
                      Stretch="Uniform"
                      Data="M3 3h18v2H3V3zm0 4h12v2H3V7zm0 4h18v2H3v-2zm0 4h12v2H3v-2zm0 4h18v2H3v-2z"
                      Fill="{DynamicResource IconGrayBrush}"/>
                <TextBlock Text="I/O편집" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
        </Button>

        <Button Style="{StaticResource SlimToolbarButton}"
                Command="{Binding OpenDurationBatchDialogCommand}"
                IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}"
                ToolTip="Duration 일괄 편집">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <Path Width="18" Height="18" Stretch="Uniform"
                      Data="{StaticResource IconClock}"
                      Fill="{DynamicResource IconGrayBrush}"/>
                <TextBlock Text="시간편집" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
        </Button>

        <Button x:Name="ThemeToggleButton"
                Style="{StaticResource SlimToolbarButton}"
                Command="{Binding ToggleThemeCommand}"
                ToolTip="{Binding ThemeButtonToolTip}">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <Path Width="18"
                      Height="18"
                      Stretch="Uniform"
                      Data="M12 3a1 1 0 0 1 .98 1.2A7 7 0 0 0 20.8 12a1 1 0 0 1 1.2.98A10 10 0 1 1 12 3z"
                      Fill="{DynamicResource IconGrayBrush}"/>
                <TextBlock Text="{Binding ThemeButtonText}" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
        </Button>

        <Grid VerticalAlignment="Stretch">
            <ToggleButton x:Name="DataToggleBtn"
                          Style="{StaticResource SlimToggleButton}"
                          ToolTip="{x:Static res:Strings.Data}">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <Path Width="18"
                          Height="18"
                          Stretch="Uniform"
                          Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"
                          Fill="{DynamicResource IconGrayBrush}"/>
                    <TextBlock Text="{x:Static res:Strings.Data}" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </ToggleButton>
            <Popup IsOpen="{Binding IsChecked, ElementName=DataToggleBtn, Mode=TwoWay}"
                   StaysOpen="False"
                   Placement="Bottom"
                   PlacementTarget="{Binding ElementName=DataToggleBtn}"
                   DataContext="{Binding DataContext, ElementName=ThisControl}">
                <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="4"
                        MinWidth="160">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="{x:Static res:Strings.Report}" FontSize="11" FontWeight="SemiBold" Margin="8,4,8,4" Foreground="{DynamicResource ForegroundBrush}"/>
                        <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding Simulation.ExportReportCsvCommand}" Click="CloseDataPopup" IsEnabled="{Binding Simulation.HasReportData}"><TextBlock Text="CSV (.csv)"/></Button>
                        <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding Simulation.ExportReportXlsxCommand}" Click="CloseDataPopup" IsEnabled="{Binding Simulation.HasReportData}"><TextBlock Text="Excel (.xlsx)"/></Button>
                        <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding Simulation.ExportReportHtmlCommand}" Click="CloseDataPopup" IsEnabled="{Binding Simulation.HasReportData}"><TextBlock Text="HTML (.html)"/></Button>
                        <Separator Margin="4,4"/>
                        <TextBlock Text="CSV" FontSize="11" FontWeight="SemiBold" Margin="8,4,8,4" Foreground="{DynamicResource ForegroundBrush}"/>
                        <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding ImportCsvCommand}" Click="CloseDataPopup"><TextBlock Text="{x:Static res:Strings.LoadCsv}"/></Button>
                        <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding ExportCsvCommand}" Click="CloseDataPopup"><TextBlock Text="{x:Static res:Strings.ExportCsv}"/></Button>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>

        <Button Style="{StaticResource SlimToolbarButton}"
                Command="{Binding ShowProjectSettingsCommand}"
                IsEnabled="{Binding DataContext.HasProject, ElementName=ThisControl}"
                ToolTip="{x:Static res:Strings.Settings}">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <Path Width="18"
                      Height="18"
                      Stretch="Uniform"
                      Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.06-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.73,8.87 C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.06,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.49-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z"
                      Fill="{DynamicResource IconGrayBrush}"/>
                <TextBlock Text="{x:Static res:Strings.Settings}" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
        </Button>
    </WrapPanel>
</UserControl>
