<UserControl x:Class="Promaker.Controls.ExplorerPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Promaker.ViewModels"
             xmlns:conv="clr-namespace:Promaker.Presentation"
             xmlns:help="clr-namespace:Promaker.Help">
    <UserControl.Resources>
        <conv:EntityTypeToIconConverter x:Key="TypeToIcon"/>
        <conv:EntityTypeToBrushConverter x:Key="TypeToBrush"/>
        <conv:EntityTypeToForegroundConverter x:Key="TypeToForeground"/>
        <conv:PositiveIntToVisibilityConverter x:Key="PositiveIntToVis"/>
        <conv:BindingProxy x:Key="Proxy" Data="{Binding}"/>

        <Style x:Key="TreePaneToggleStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource SelectedBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TreeViewItemBaseStyle" TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <EventSetter Event="MouseDoubleClick" Handler="TreeViewItem_MouseDoubleClick"/>
        </Style>

        <Style x:Key="TreeViewItemInteractiveStyle" TargetType="TreeViewItem" BasedOn="{StaticResource TreeViewItemBaseStyle}">
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TreeViewItem_PreviewMouseLeftButtonDown"/>
            <EventSetter Event="PreviewMouseLeftButtonUp" Handler="TreeViewItem_PreviewMouseLeftButtonUp"/>
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="TreeViewItem_PreviewMouseRightButtonDown"/>
            <EventSetter Event="PreviewMouseMove" Handler="TreeViewItem_PreviewMouseMove_Drag"/>
        </Style>

        <HierarchicalDataTemplate x:Key="EntityTreeItemTemplate"
                                  DataType="{x:Type vm:EntityNode}"
                                  ItemsSource="{Binding Children}">
            <Border x:Name="TreeItemBorder" CornerRadius="3" Padding="2,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="18" Height="18" CornerRadius="3" Margin="0,0,6,0"
                            Background="{Binding EntityType, Converter={StaticResource TypeToBrush}}">
                        <TextBlock Text="{Binding EntityType, Converter={StaticResource TypeToIcon}}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{Binding EntityType, Converter={StaticResource TypeToForeground}}"/>
                    </Border>
                    <TextBlock x:Name="TreeNodeName" Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" FontSize="13"/>
                    <Border Grid.Column="2"
                            Margin="6,0,0,0"
                            Padding="5,0"
                            CornerRadius="8"
                            MinWidth="16"
                            HorizontalAlignment="Right"
                            Background="{DynamicResource AccentBrush}"
                            Visibility="{Binding SelectionOrder, Converter={StaticResource PositiveIntToVis}}">
                        <TextBlock Text="{Binding SelectionOrder}"
                                   Foreground="{DynamicResource AccentTextBrush}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsWarning}" Value="True">
                    <Setter TargetName="TreeNodeName" Property="Foreground" Value="{DynamicResource IconRedBrush}"/>
                    <Setter TargetName="TreeNodeName" Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsTreeSelected}" Value="True">
                    <Setter TargetName="TreeItemBorder" Property="Background" Value="{DynamicResource SelectedBrush}"/>
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>

        <ContextMenu x:Key="EntityTreeContextMenu"
                     x:Shared="False"
                     DataContext="{Binding Data, Source={StaticResource Proxy}}">
            <MenuItem Tag="AddSystem" Header="System 추가" Command="{Binding AddSystemCommand}"/>
            <MenuItem Tag="AddFlow" Header="Flow 추가" Command="{Binding AddFlowCommand}"/>
            <MenuItem Tag="AddWork" Header="Work 추가" Command="{Binding AddWorkCommand}"/>
            <MenuItem Tag="AddCall" Header="Call 추가" Command="{Binding AddCallCommand}"/>
            <Separator Tag="SepAdd"/>
            <MenuItem Tag="ImportMermaid" Header="Mermaid 불러오기..." Command="{Binding ImportMermaidCommand}"/>
            <MenuItem Tag="ExportCsv" Header="CSV 내보내기..." Command="{Binding ExportCsvCommand}"/>
            <Separator Tag="SepImport"/>
            <MenuItem Tag="Copy" Header="복사" Command="{Binding CopySelectedCommand}"/>
            <MenuItem Tag="Paste" Header="붙여넣기" Command="{Binding PasteCopiedCommand}"/>
            <Separator Tag="SepEdit"/>
            <MenuItem Tag="MoveUp" Header="위로 이동" Command="{Binding MoveWorkUpCommand}"/>
            <MenuItem Tag="MoveDown" Header="아래로 이동" Command="{Binding MoveWorkDownCommand}"/>
            <Separator Tag="SepMove"/>
            <MenuItem Tag="FocusCanvas" Header="캔버스에서 보기" Command="{Binding Canvas.FocusSelectedInCanvasCommand}"/>
            <MenuItem Tag="Rename" Header="이름 바꾸기..." Command="{Binding FocusNameEditorCommand}"/>
            <MenuItem Tag="Delete" Header="삭제" Command="{Binding DeleteSelectedCommand}" Foreground="{DynamicResource RedAccentBrush}"/>
            <Separator Tag="SepExpandCollapse"/>
            <MenuItem Tag="ExpandAll" Header="전체 펼치기" Click="ExpandAll_Click"/>
            <MenuItem Tag="CollapseAll" Header="전체 접기" Click="CollapseAll_Click"/>
        </ContextMenu>
    </UserControl.Resources>

    <Border Style="{StaticResource PanelContainer}">
            <Grid x:Name="ExplorerLayoutRoot">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
            <Border Style="{StaticResource PanelHeader}">
                <Grid>
                    <TextBlock Text="Explorer" FontWeight="SemiBold" FontSize="12"/>
                    <Button Style="{StaticResource HelpButton}" HorizontalAlignment="Right"
                            Command="{x:Static help:HelpNavigator.NavigateCommand}"
                            CommandParameter="explorer"/>
                    </Grid>
            </Border>

            <Border Grid.Row="1" Padding="8,8,8,6" BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource BorderBrush}">
                <TextBox x:Name="SearchBox"
                         Padding="6,4"
                         VerticalContentAlignment="Center"
                         ToolTip="이름으로 Explorer 항목 검색"
                         TextChanged="SearchBox_TextChanged"
                         PreviewKeyDown="SearchBox_PreviewKeyDown"/>
            </Border>

            <Grid x:Name="UpperPanelsHost" Grid.Row="2">
                <TreeView x:Name="ControlTree"
                          AllowDrop="True"
                          DragOver="ControlTree_DragOver"
                          DragLeave="ControlTree_DragLeave"
                          Drop="ControlTree_Drop"
                          ItemsSource="{Binding ControlTreeRoots}"
                          SelectedItemChanged="Tree_SelectedItemChanged"
                          PreviewMouseDown="Tree_PreviewMouseDown"
                          PreviewKeyDown="Tree_PreviewKeyDown"
                          ContextMenuOpening="Tree_ContextMenuOpening">
                    <TreeView.ItemContainerStyle>
                        <StaticResource ResourceKey="TreeViewItemInteractiveStyle"/>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <StaticResource ResourceKey="EntityTreeItemTemplate"/>
                    </TreeView.ItemTemplate>
                    <TreeView.ContextMenu>
                        <StaticResource ResourceKey="EntityTreeContextMenu"/>
                    </TreeView.ContextMenu>
                </TreeView>

                <TreeView x:Name="DeviceTree"
                          Visibility="Collapsed"
                          ItemsSource="{Binding DeviceTreeRoots}"
                          SelectedItemChanged="Tree_SelectedItemChanged"
                          PreviewMouseDown="Tree_PreviewMouseDown"
                          PreviewKeyDown="Tree_PreviewKeyDown"
                          ContextMenuOpening="Tree_ContextMenuOpening">
                    <TreeView.ItemContainerStyle>
                        <StaticResource ResourceKey="TreeViewItemInteractiveStyle"/>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <StaticResource ResourceKey="EntityTreeItemTemplate"/>
                    </TreeView.ItemTemplate>
                    <TreeView.ContextMenu>
                        <StaticResource ResourceKey="EntityTreeContextMenu"/>
                    </TreeView.ContextMenu>
                </TreeView>
            </Grid>

            <Border Grid.Row="3" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}">
                <UniformGrid Columns="2">
                    <ToggleButton x:Name="ControlTreeButton"
                                  Style="{StaticResource TreePaneToggleStyle}"
                                  Content="Control"
                                  IsChecked="True"
                                  Click="ControlTreeButton_Click"/>
                    <ToggleButton x:Name="DeviceTreeButton"
                                  Style="{StaticResource TreePaneToggleStyle}"
                                  Content="Device"
                                  Click="DeviceTreeButton_Click"/>
                </UniformGrid>
            </Border>
        </Grid>
    </Border>
</UserControl>
