<UserControl x:Class="Promaker.Controls.MainToolbarEtcContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:res="clr-namespace:Promaker.Resources"
             x:Name="ThisControl">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="MainToolbarResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="EtcSection">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <WrapPanel Orientation="Horizontal">
            <Grid>
                <ToggleButton x:Name="UtilMenuToggle" Style="{StaticResource RibbonFlatToggleButton}" ToolTip="유틸리티">
                    <StackPanel Orientation="Vertical">
                        <iconPacks:PackIconMaterial Kind="Wrench" Width="18" Height="18" HorizontalAlignment="Center" Foreground="{DynamicResource IconGrayBrush}"/>
                        <TextBlock Text="유틸" Style="{StaticResource RibbonIconLabel}"/>
                    </StackPanel>
                </ToggleButton>
                <Popup IsOpen="{Binding IsChecked, ElementName=UtilMenuToggle, Mode=TwoWay}"
                       StaysOpen="False"
                       Placement="Bottom"
                       PlacementTarget="{Binding ElementName=UtilMenuToggle}"
                       DataContext="{Binding DataContext, ElementName=ThisControl}">
                    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="4"
                            MinWidth="180">
                        <StackPanel>
                            <TextBlock Text="편집" FontSize="11" FontWeight="SemiBold" Margin="8,4,8,4" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding OpenDurationBatchDialogCommand}" Click="CloseUtilPopup"><TextBlock Text="Duration 편집"/></Button>
                            <Separator Margin="4,4"/>
                            <TextBlock Text="시뮬레이션" FontSize="11" FontWeight="SemiBold" Margin="8,4,8,4" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding Simulation.ExportReportCommand}" Click="CloseUtilPopup"><TextBlock Text="시뮬레이션 출력"/></Button>
                            <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding ShowSimulationScenariosCommand}" Click="CloseUtilPopup"><TextBlock Text="시뮬레이션 결과 보기"/></Button>
                            <Separator Margin="4,4"/>
                            <TextBlock Text="CSV" FontSize="11" FontWeight="SemiBold" Margin="8,4,8,4" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding ImportCsvCommand}" Click="CloseUtilPopup"><TextBlock Text="CSV 불러오기"/></Button>
                            <Separator Margin="4,4"/>
                            <TextBlock Text="PLC" FontSize="11" FontWeight="SemiBold" Margin="8,4,8,4" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding OpenTagWizardCommand}" Click="CloseUtilPopup"><TextBlock Text="IO 생성"/></Button>
                            <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding OpenTagInspectorCommand}" Click="CloseUtilPopup"><TextBlock Text="IO·태그 확인"/></Button>
                            <Button Style="{StaticResource AddMenuItemButton}"
                                    Command="{Binding OpenPlcXmlGeneratorCommand}"
                                    Click="CloseUtilPopup">
                                <TextBlock Text="PLC 생성"/>
                            </Button>
                            <Separator Margin="4,4"/>
                            <TextBlock Text="뷰" FontSize="11" FontWeight="SemiBold" Margin="8,4,8,4" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding Open3DViewCommand}" Click="CloseUtilPopup"><TextBlock Text="3D 배치 뷰"/></Button>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
            <!-- B-1 (`Apps/Promaker/Docs/todo-dock-layout.md` §3.1 Q2) — 닫힌 anchor 복원 UI. 4 anchor 의 IsVisible 양방향 토글.
                 닫힌 항목도 자연스럽게 unchecked 로 표시되어 ▼ 드롭다운 + 보기 메뉴 분리 안 대신 단일 popup 통합.
                 LlmChat 은 IsLlmChatVisible SSOT 별도 + 별도 LLM toolbar 버튼 이미 존재 → 본 메뉴 제외. -->
            <Grid>
                <ToggleButton x:Name="ViewMenuToggle" Style="{StaticResource RibbonFlatToggleButton}" ToolTip="패널 보기">
                    <StackPanel Orientation="Vertical">
                        <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="18" Height="18" HorizontalAlignment="Center" Foreground="{DynamicResource IconGrayBrush}"/>
                        <TextBlock Text="보기" Style="{StaticResource RibbonIconLabel}"/>
                    </StackPanel>
                </ToggleButton>
                <Popup IsOpen="{Binding IsChecked, ElementName=ViewMenuToggle, Mode=TwoWay}"
                       StaysOpen="False"
                       Placement="Bottom"
                       PlacementTarget="{Binding ElementName=ViewMenuToggle}"
                       DataContext="{Binding DataContext, ElementName=ThisControl}">
                    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="4"
                            MinWidth="200">
                        <StackPanel>
                            <TextBlock Text="패널 보기/숨김" FontSize="11" FontWeight="SemiBold" Margin="8,4,8,6" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <CheckBox Content="Explorer"   IsChecked="{Binding ExplorerAnchor.IsVisible,   Mode=TwoWay}" IsEnabled="{Binding HasProject}" Margin="8,4"/>
                            <CheckBox Content="Properties" IsChecked="{Binding PropertyAnchor.IsVisible,   Mode=TwoWay}" IsEnabled="{Binding HasProject}" Margin="8,4"/>
                            <CheckBox Content="History"    IsChecked="{Binding HistoryAnchor.IsVisible,    Mode=TwoWay}" IsEnabled="{Binding HasProject}" Margin="8,4"/>
                            <CheckBox Content="Simulation" IsChecked="{Binding SimulationAnchor.IsVisible, Mode=TwoWay}" IsEnabled="{Binding HasProject}" Margin="8,4"/>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
            <Button x:Name="ThemeButton" Style="{StaticResource RibbonFlatButton}" Command="{Binding ToggleThemeCommand}" ToolTip="{Binding ThemeButtonToolTip}">
                <StackPanel Orientation="Vertical">
                    <Grid Width="18" Height="18" HorizontalAlignment="Center" Margin="0,0,0,2">
                        <iconPacks:PackIconMaterial Kind="WhiteBalanceSunny" Width="18" Height="18" Foreground="{DynamicResource IconGrayBrush}">
                            <iconPacks:PackIconMaterial.Style>
                                <Style TargetType="iconPacks:PackIconMaterial">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </iconPacks:PackIconMaterial.Style>
                        </iconPacks:PackIconMaterial>
                        <iconPacks:PackIconMaterial Kind="WeatherNight" Width="18" Height="18" Foreground="{DynamicResource IconGrayBrush}">
                            <iconPacks:PackIconMaterial.Style>
                                <Style TargetType="iconPacks:PackIconMaterial">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </iconPacks:PackIconMaterial.Style>
                        </iconPacks:PackIconMaterial>
                    </Grid>
                    <TextBlock Text="{Binding ThemeButtonText}" Style="{StaticResource RibbonIconLabel}"/>
                </StackPanel>
            </Button>
            <!-- LLM 토글 (Phase 2 PR-C) — 라이트 버튼 패턴 (Command + DataTrigger 로 active 시 아이콘 색 강조).
                 Click 시 ToggleLlmChatCommand 가 lazy 생성 + consent 검사 + IsLlmChatVisible 토글. -->
            <Button Style="{StaticResource RibbonFlatButton}"
                    Command="{Binding ToggleLlmChatCommand}"
                    ToolTip="LLM Chat 패널 토글">
                <StackPanel Orientation="Vertical">
                    <iconPacks:PackIconMaterial Kind="Robot" Width="18" Height="18" HorizontalAlignment="Center">
                        <iconPacks:PackIconMaterial.Style>
                            <Style TargetType="iconPacks:PackIconMaterial">
                                <Setter Property="Foreground" Value="{DynamicResource IconGrayBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLlmChatVisible}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </iconPacks:PackIconMaterial.Style>
                    </iconPacks:PackIconMaterial>
                    <TextBlock Text="LLM" Style="{StaticResource RibbonIconLabel}"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource RibbonFlatButton}" Command="{Binding ShowApplicationSettingsCommand}" ToolTip="환경 설정 (AASX/PLC/LLM/프리셋)">
                <StackPanel Orientation="Vertical">
                    <iconPacks:PackIconMaterial Kind="Cog" Width="18" Height="18" HorizontalAlignment="Center" Foreground="{DynamicResource IconGrayBrush}"/>
                    <TextBlock Text="{x:Static res:Strings.Settings}" Style="{StaticResource RibbonIconLabel}"/>
                </StackPanel>
            </Button>
            <Button x:Name="AboutButton" Style="{StaticResource RibbonFlatButton}" Click="AboutButton_Click" ToolTip="프로그램 정보">
                <StackPanel Orientation="Vertical">
                    <iconPacks:PackIconMaterial Kind="Information" Width="18" Height="18" HorizontalAlignment="Center" Foreground="{DynamicResource IconGrayBrush}"/>
                    <TextBlock Text="정보" Style="{StaticResource RibbonIconLabel}"/>
                </StackPanel>
            </Button>
        </WrapPanel>
        <TextBlock Grid.Row="1" Text="기타" Style="{StaticResource RibbonSectionLabel}"/>
    </Grid>
</UserControl>
