<UserControl x:Class="Promaker.Controls.MainToolbarEtcContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:res="clr-namespace:Promaker.Resources"
             x:Name="ThisControl">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="MainToolbarResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="EtcSection">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <WrapPanel Orientation="Horizontal">
            <Grid>
                <ToggleButton x:Name="UtilMenuToggle" Style="{StaticResource RibbonFlatToggleButton}" ToolTip="유틸리티" Checked="UtilMenuToggle_Checked">
                    <StackPanel Orientation="Vertical">
                        <iconPacks:PackIconMaterial Kind="Wrench" Width="18" Height="18" HorizontalAlignment="Center" Foreground="{DynamicResource IconGrayBrush}"/>
                        <TextBlock Text="유틸" Style="{StaticResource RibbonIconLabel}"/>
                    </StackPanel>
                </ToggleButton>
                <Popup IsOpen="{Binding IsChecked, ElementName=UtilMenuToggle, Mode=TwoWay}"
                       StaysOpen="False"
                       Placement="Bottom"
                       PlacementTarget="{Binding ElementName=UtilMenuToggle}"
                       DataContext="{Binding DataContext, ElementName=ThisControl}">
                    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="4"
                            MinWidth="180">
                        <StackPanel>
                            <TextBlock Text="편집" FontSize="11" FontWeight="SemiBold" Margin="8,4,8,4" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding OpenDurationBatchDialogCommand}" Click="CloseUtilPopup"><TextBlock Text="Duration 편집"/></Button>
                            <Separator Margin="4,4"/>
                            <TextBlock Text="시뮬레이션" FontSize="11" FontWeight="SemiBold" Margin="8,4,8,4" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding Simulation.ExportReportCommand}" Click="CloseUtilPopup"><TextBlock Text="시뮬레이션 출력"/></Button>
                            <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding ShowSimulationScenariosCommand}" Click="CloseUtilPopup"><TextBlock Text="시뮬레이션 결과 보기"/></Button>
                            <Separator Margin="4,4"/>
                            <TextBlock Text="CSV" FontSize="11" FontWeight="SemiBold" Margin="8,4,8,4" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding ImportCsvCommand}" Click="CloseUtilPopup"><TextBlock Text="CSV 불러오기"/></Button>
                            <Separator Margin="4,4"/>
                            <TextBlock Text="PLC" FontSize="11" FontWeight="SemiBold" Margin="8,4,8,4" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding OpenTagWizardCommand}" Click="CloseUtilPopup"><TextBlock Text="IO 생성"/></Button>
                            <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding OpenIoBatchDialogCommand}" Click="CloseUtilPopup"><TextBlock Text="IO 조회"/></Button>
                            <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding OpenPlcXmlGeneratorCommand}" Click="CloseUtilPopup"><TextBlock Text="PLC 생성"/></Button>
                            <StackPanel Visibility="{Binding Is3DViewEnabled, Converter={StaticResource BoolToVis}}">
                                <Separator Margin="4,4"/>
                                <TextBlock Text="뷰" FontSize="11" FontWeight="SemiBold" Margin="8,4,8,4" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <Button Style="{StaticResource AddMenuItemButton}" Command="{Binding Open3DViewCommand}" Click="CloseUtilPopup"><TextBlock Text="3D 배치 뷰"/></Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
<Button x:Name="ThemeButton" Style="{StaticResource RibbonFlatButton}" Command="{Binding ToggleThemeCommand}" ToolTip="{Binding ThemeButtonToolTip}">
                <StackPanel Orientation="Vertical">
                    <Grid Width="18" Height="18" HorizontalAlignment="Center" Margin="0,0,0,2">
                        <iconPacks:PackIconMaterial Kind="WhiteBalanceSunny" Width="18" Height="18" Foreground="{DynamicResource IconGrayBrush}">
                            <iconPacks:PackIconMaterial.Style>
                                <Style TargetType="iconPacks:PackIconMaterial">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </iconPacks:PackIconMaterial.Style>
                        </iconPacks:PackIconMaterial>
                        <iconPacks:PackIconMaterial Kind="WeatherNight" Width="18" Height="18" Foreground="{DynamicResource IconGrayBrush}">
                            <iconPacks:PackIconMaterial.Style>
                                <Style TargetType="iconPacks:PackIconMaterial">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </iconPacks:PackIconMaterial.Style>
                        </iconPacks:PackIconMaterial>
                    </Grid>
                    <TextBlock Text="{Binding ThemeButtonText}" Style="{StaticResource RibbonIconLabel}"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource RibbonFlatButton}" Command="{Binding ShowProjectSettingsCommand}" ToolTip="프로젝트 속성">
                <StackPanel Orientation="Vertical">
                    <iconPacks:PackIconMaterial Kind="Cog" Width="18" Height="18" HorizontalAlignment="Center" Foreground="{DynamicResource IconGrayBrush}"/>
                    <TextBlock Text="{x:Static res:Strings.Settings}" Style="{StaticResource RibbonIconLabel}"/>
                </StackPanel>
            </Button>
            <Button x:Name="AboutButton" Style="{StaticResource RibbonFlatButton}" Click="AboutButton_Click" ToolTip="프로그램 정보">
                <StackPanel Orientation="Vertical">
                    <iconPacks:PackIconMaterial Kind="Information" Width="18" Height="18" HorizontalAlignment="Center" Foreground="{DynamicResource IconGrayBrush}"/>
                    <TextBlock Text="정보" Style="{StaticResource RibbonIconLabel}"/>
                </StackPanel>
            </Button>
        </WrapPanel>
        <TextBlock Grid.Row="1" Text="기타" Style="{StaticResource RibbonSectionLabel}"/>
    </Grid>
</UserControl>
