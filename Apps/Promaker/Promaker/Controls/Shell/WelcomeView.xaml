<UserControl x:Class="Promaker.Controls.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks">
    <Border Background="{DynamicResource PrimaryBackgroundBrush}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <Ellipse Width="70" Height="70" Opacity="0.4" Margin="0,0,0,20"
                     HorizontalAlignment="Center">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="{DynamicResource AccentColor}" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <iconPacks:PackIconMaterial Kind="FolderOpen" Width="48" Height="48" Margin="0,-72,0,40"
                  HorizontalAlignment="Center"
                  Foreground="{DynamicResource AccentBrush}"/>
            <TextBlock Text="기존 프로젝트 파일을 불러오세요"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="프로젝트를 시작하려면 새로 만들거나 파일을 열어주세요"
                       FontSize="13"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,24"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding NewProjectCommand}"
                        Padding="16,10" Margin="0,0,12,0"
                        FontSize="13" Cursor="Hand"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White" BorderThickness="0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="FileDocumentPlus" Width="16" Height="16" Margin="0,0,6,0"
                              Foreground="White"/>
                        <TextBlock Text="새로 만들기" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenFileCommand}"
                        Padding="16,10"
                        FontSize="13" Cursor="Hand"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White" BorderThickness="0">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="FolderOpen" Width="16" Height="16" Margin="0,0,6,0"
                              Foreground="White"/>
                        <TextBlock Text="프로젝트 열기" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
