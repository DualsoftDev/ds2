<UserControl x:Class="Promaker.Controls.MainToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ToolBarTray>
        <ToolBar>
            <Button Content="New" Style="{StaticResource RibbonButton}" Command="{Binding NewProjectCommand}" ToolTip="New Project (Ctrl+N)"/>
            <Button Content="Open" Style="{StaticResource RibbonButton}" Command="{Binding OpenFileCommand}" ToolTip="Open File (Ctrl+O)"/>
            <Button Content="Save" Style="{StaticResource RibbonButton}" Command="{Binding SaveFileCommand}" ToolTip="Save (Ctrl+S)"/>
            <Separator/>
            <Button Content="Undo" Style="{StaticResource RibbonButton}" Command="{Binding UndoCommand}" ToolTip="Undo (Ctrl+Z)"/>
            <Button Content="Redo" Style="{StaticResource RibbonButton}" Command="{Binding RedoCommand}" ToolTip="Redo (Ctrl+Y)"/>
            <Separator/>
            <Button Content="+ Project" Style="{StaticResource RibbonButton}" Command="{Binding AddProjectCommand}"/>
            <Button Content="+ System" Style="{StaticResource RibbonButton}" Command="{Binding AddSystemCommand}"/>
            <Button Content="+ Flow" Style="{StaticResource RibbonButton}" Command="{Binding AddFlowCommand}"/>
            <Button Content="+ Work" Style="{StaticResource RibbonButton}" Command="{Binding AddWorkCommand}"/>
            <Button Content="+ Call" Style="{StaticResource RibbonButton}" Command="{Binding AddCallCommand}"/>
            <Separator/>
            <Button Content="Delete" Style="{StaticResource RibbonButton}" Command="{Binding DeleteSelectedCommand}" Foreground="{DynamicResource RedAccentBrush}"/>
            <Separator/>
            <Button Content="Simulate" Style="{StaticResource RibbonButton}" Command="{Binding StartSimulationCommand}" Foreground="#32CD32"/>
            <Button Content="Pause" Style="{StaticResource RibbonButton}" Command="{Binding PauseSimulationCommand}"/>
            <Button Content="Stop" Style="{StaticResource RibbonButton}" Command="{Binding StopSimulationCommand}" Foreground="{DynamicResource RedAccentBrush}"/>
            <Button Content="Reset" Style="{StaticResource RibbonButton}" Command="{Binding ResetSimulationCommand}"/>
            <Separator/>
            <TextBlock Text="Speed:" VerticalAlignment="Center" Margin="4,0"/>
            <ComboBox SelectedValue="{Binding SimSpeed}" SelectedValuePath="Tag" Width="60" VerticalAlignment="Center">
                <ComboBoxItem Content="0.5x" Tag="0.5"/>
                <ComboBoxItem Content="1x" Tag="1.0" IsSelected="True"/>
                <ComboBoxItem Content="2x" Tag="2.0"/>
                <ComboBoxItem Content="5x" Tag="5.0"/>
                <ComboBoxItem Content="10x" Tag="10.0"/>
            </ComboBox>
            <CheckBox Content="TimeIgnore" IsChecked="{Binding SimTimeIgnore}" VerticalAlignment="Center" Margin="8,0"/>
            <Separator/>
            <TextBlock Text="Work:" VerticalAlignment="Center" Margin="4,0"/>
            <ComboBox ItemsSource="{Binding SimWorkItems}" SelectedItem="{Binding SelectedSimWork}"
                      Width="150" VerticalAlignment="Center"/>
            <Button Content="Work Start" Style="{StaticResource RibbonButton}" Command="{Binding ForceWorkStartCommand}" Foreground="#32CD32"/>
            <Button Content="Work Reset" Style="{StaticResource RibbonButton}" Command="{Binding ForceWorkResetCommand}" Foreground="{DynamicResource OrangeAccentBrush}"/>
        </ToolBar>
    </ToolBarTray>
</UserControl>
