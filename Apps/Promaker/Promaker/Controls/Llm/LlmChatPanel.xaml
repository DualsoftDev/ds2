<UserControl x:Class="Promaker.Controls.Llm.LlmChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Promaker.Controls.Llm"
             xmlns:b="clr-namespace:Promaker.Behaviors"
             AllowDrop="True"
             PreviewDragEnter="Panel_PreviewDragEnter"
             PreviewDragLeave="Panel_PreviewDragLeave"
             PreviewDragOver="Panel_PreviewDragOver"
             PreviewDrop="Panel_PreviewDrop"
             Background="{DynamicResource PrimaryBackgroundBrush}"
             Foreground="{DynamicResource PrimaryTextBrush}">
    <UserControl.Resources>
        <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- LLM 에러 표시 색상 SSOT — Border / Foreground 양쪽에서 참조. 향후 테마 변경 시 본 한 줄만 수정. -->
        <SolidColorBrush x:Key="LlmErrorBrush" Color="DarkOrange"/>

        <!-- 다크 테마 친화 ChatTurn template (1d-4 D — 별도 Window 에서 dock 으로 이전) -->
        <Style x:Key="TurnListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource PrimaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style x:Key="TurnContainerStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Role}" Value="user">
                    <Setter Property="HorizontalContentAlignment" Value="Right"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Role}" Value="assistant">
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Role}" Value="system">
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Role}" Value="tool">
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Role}" Value="thinking">
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Role}" Value="error">
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ChatBubbleBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="2"/>
            <!-- YAML multi-line 본문 가독성 위해 520 → 720 (assistant 응답이 YAML 포함 시 wrap 빈도 감소). -->
            <Setter Property="MaxWidth" Value="720"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Role}" Value="user">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Role}" Value="system">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="MaxWidth" Value="720"/>
                </DataTrigger>
                <!-- Tool: 회색 배경 없는 인라인 메모 형태 (system 과 유사하나 좌측 정렬). -->
                <DataTrigger Binding="{Binding Role}" Value="tool">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Padding" Value="2,0"/>
                    <Setter Property="MaxWidth" Value="720"/>
                </DataTrigger>
                <!-- Thinking: 외형은 normal (텍스트 스타일 그대로) + 좌측 2px accent 색띠 (옵션 b). HistoryPanel IsLlmTurn 패턴 재활용. -->
                <DataTrigger Binding="{Binding Role}" Value="thinking">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="BorderThickness" Value="2,0,0,0"/>
                    <Setter Property="CornerRadius" Value="0"/>
                    <Setter Property="Padding" Value="8,4"/>
                </DataTrigger>
                <!-- Error: dark orange 외곽선 + 동일 색 텍스트 (사용자 지정). [ERROR] / [provider error] / [ApplyImportPlan ERROR]. -->
                <DataTrigger Binding="{Binding Role}" Value="error">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="{StaticResource LlmErrorBrush}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="CornerRadius" Value="3"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- PR-E (2): 부분 텍스트 selection 위해 read-only TextBox 사용 (WPF TextBlock 은 native selection 미지원).
             Background/Border 제거로 시각적으로 TextBlock 과 동일. Cursor=IBeam 으로 선택 가능 시각 단서. -->
        <Style x:Key="ChatBubbleTextStyle" TargetType="TextBox">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="IsReadOnlyCaretVisible" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="IBeam"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Role}" Value="user">
                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Role}" Value="system">
                    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="FontStyle" Value="Italic"/>
                </DataTrigger>
                <!-- Tool: gray + italic + 작은 글자 (사용자 요구 = "tool 관련 : gray"). -->
                <DataTrigger Binding="{Binding Role}" Value="tool">
                    <Setter Property="Foreground" Value="Gray"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="FontStyle" Value="Italic"/>
                </DataTrigger>
                <!-- Assistant: YAML 등 schema-doc 응답 등폭 정렬 위해 monospace. 자연어 부분도 mono 라 약간 어색하나
                     fenced code block 부분 mono (RichTextBox + markdown 파서) 는 본 PoC scope 외 — 전체 mono 로 타협. -->
                <DataTrigger Binding="{Binding Role}" Value="assistant">
                    <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New, monospace"/>
                </DataTrigger>
                <!-- Thinking: 기본 PrimaryTextBrush 유지 (사용자 요구 = "normal"). 시각 구분은 Border 좌측 색띠로 처리. -->
                <!-- Error: dark orange 강조 + SemiBold. -->
                <DataTrigger Binding="{Binding Role}" Value="error">
                    <Setter Property="Foreground" Value="{StaticResource LlmErrorBrush}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ChatInputBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}"/>
        </Style>

        <Style x:Key="ChatButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SendButtonStyle" TargetType="Button" BasedOn="{StaticResource ChatButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <!-- commit-5: drag-over visual cue — Panel_PreviewDragEnter/Leave/Drop 가 BorderBrush 토글. -->
    <Border x:Name="DragHighlightBorder"
            BorderBrush="Transparent"
            BorderThickness="2"
            CornerRadius="3"
            Padding="6">
    <Grid b:CtrlWheelZoom.IsEnabled="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <!-- Streaming/progress dots — IsSending 시 ListBox 바로 아래 좌측에 표시 (마지막 turn 시선과 인접). -->
            <RowDefinition Height="Auto"/>
            <!-- chip 영역 1줄 안내 (정책 8/9/MI-5) — AttachmentNotice 비어있으면 Collapsed -->
            <RowDefinition Height="Auto"/>
            <!-- 첨부 chip ItemsControl (정책 4) — Attachments.Count==0 이면 Collapsed -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header — title 좌측 + provider ComboBox 우측 (Phase 2 Claude/Codex dispatch) -->
        <Grid Grid.Row="0" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="LLM Chat" FontWeight="SemiBold" FontSize="12"
                       VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding AvailableProviders}"
                      SelectedItem="{Binding SelectedProvider}"
                      IsEnabled="{Binding IsSending, Converter={StaticResource InverseBoolConverter}}"
                      MinWidth="80"
                      ToolTip="LLM provider 선택. 변경 시 새 CLI 검출 + 세션 초기화."/>
        </Grid>

        <!-- Status + Thinking indicator (PR-F). Ev2.Oracle 의 3-dot blink 패턴 — IsSending 시 우측에 표시.
             Storyboard 는 Loaded 시점부터 항상 도는데 컨테이너 Visibility 로 ON/OFF (CPU 비용 무시 수준). -->
        <DockPanel Grid.Row="1" Margin="0,0,0,6" LastChildFill="True">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="6,0,0,0"
                        Visibility="{Binding IsSending, Converter={StaticResource BoolToVis}}">
                <Ellipse Width="6" Height="6" Margin="2,0"
                         Fill="{DynamicResource AccentBrush}" Opacity="0.3">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.3" To="1.0" Duration="0:0:0.6"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                <Ellipse Width="6" Height="6" Margin="2,0"
                         Fill="{DynamicResource AccentBrush}" Opacity="0.3">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True" BeginTime="0:0:0.2">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.3" To="1.0" Duration="0:0:0.6"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                <Ellipse Width="6" Height="6" Margin="2,0"
                         Fill="{DynamicResource AccentBrush}" Opacity="0.3">
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True" BeginTime="0:0:0.4">
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.3" To="1.0" Duration="0:0:0.6"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
            </StackPanel>
            <TextBlock Text="{Binding StatusText}"
                       FontSize="11"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Turns. PR-E (1): VirtualizingPanel.ScrollUnit=Pixel 로 부드러운 scroll. -->
        <ListBox x:Name="TurnsListBox" Grid.Row="2"
                 Style="{StaticResource TurnListBoxStyle}"
                 ItemContainerStyle="{StaticResource TurnContainerStyle}"
                 ItemsSource="{Binding Turns}"
                 VirtualizingPanel.ScrollUnit="Pixel"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <!-- PR-E (2): ListBox 자체 ContextMenu — 전체 대화 복사 / Markdown 내보내기 -->
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="전체 대화 복사" Command="{Binding CopyAllCommand}"/>
                    <MenuItem Header="대화 내보내기 (.md)…" Command="{Binding ExportCommand}"/>
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource ChatBubbleBorderStyle}">
                        <!-- 부분 복사: read-only TextBox 의 selection + Ctrl+C. 전체 복사 / export 는 ListBox 의 ContextMenu.
                             review #2 fix: TextBox 의 기본 ContextMenu (잘라내기/복사/붙여넣기) 를 비활성화해
                             우클릭 시 visual tree 상위 ListBox.ContextMenu (전체 복사 / export) 가 표시되도록. -->
                        <TextBox Text="{Binding Text, Mode=OneWay}" Style="{StaticResource ChatBubbleTextStyle}">
                            <TextBox.ContextMenu>
                                <x:Null/>
                            </TextBox.ContextMenu>
                        </TextBox>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Progress dots (B 옵션) — ListBox 바로 아래 좌측. 송신 시점부터 SessionEnd 까지 (= IsSending) 표시.
             기존 상단 status 의 3-dot 과 동일 storyboard 패턴, 크기만 6→12 로 확대 + 좌측 정렬 (마지막 turn 시선 근접).
             phase 1 (응답 대기) / phase 2 (streaming) / phase 3 (tool 사이클) 모두 동일 invariant — IsSending 만으로 ON/OFF. -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="12,4,0,0"
                    Visibility="{Binding IsSending, Converter={StaticResource BoolToVis}}">
            <Ellipse Width="10" Height="10" Margin="3,0"
                     Fill="{DynamicResource AccentBrush}" Opacity="0.3">
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0.3" To="1.0" Duration="0:0:0.6"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>
            <Ellipse Width="10" Height="10" Margin="3,0"
                     Fill="{DynamicResource AccentBrush}" Opacity="0.3">
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True" BeginTime="0:0:0.2">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0.3" To="1.0" Duration="0:0:0.6"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>
            <Ellipse Width="10" Height="10" Margin="3,0"
                     Fill="{DynamicResource AccentBrush}" Opacity="0.3">
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True" BeginTime="0:0:0.4">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0.3" To="1.0" Duration="0:0:0.6"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>
        </StackPanel>

        <!-- 첨부 안내 1줄 (정책 8/9/MI-5) — 거부 / cap 초과 / provider 전환 단일화. 비어있으면 hide. -->
        <TextBlock Grid.Row="4"
                   Text="{Binding AttachmentNotice}"
                   Margin="0,6,0,0"
                   FontSize="11"
                   Foreground="{StaticResource LlmErrorBrush}"
                   TextWrapping="Wrap">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding AttachmentNotice}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- 첨부 chip ItemsControl (정책 4) — filename + size + ≈token + ×제거. Attachments 비어있으면 Collapsed.
             chip focusable + Delete 키 제거 (MI-4 접근성). -->
        <ItemsControl Grid.Row="5"
                      ItemsSource="{Binding Attachments}"
                      Margin="0,4,0,0"
                      Visibility="{Binding HasAttachments, Converter={StaticResource BoolToVis}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,2,4,2"
                            Padding="6,2"
                            CornerRadius="3"
                            Focusable="True"
                            Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1">
                        <Border.InputBindings>
                            <KeyBinding Key="Delete"
                                        Command="{Binding DataContext.RemoveAttachmentCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                        </Border.InputBindings>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding FileName}"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       MaxWidth="220"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding FileName}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="{Binding SizeLabel}"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="10"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Text="{Binding TokensLabel}"
                                       Margin="6,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="10"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <Button Command="{Binding DataContext.RemoveAttachmentCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Margin="6,0,0,0"
                                    Padding="4,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{DynamicResource SecondaryTextBrush}"
                                    Cursor="Hand"
                                    ToolTip="제거 (Delete)"
                                    Content="&#x2715;"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Input. Enter=전송 / Shift+Enter=줄바꿈 / Alt+J=줄바꿈. commit-5: Ctrl+V hook (DataObject.AddPastingHandler). -->
        <TextBox x:Name="InputBox"
                 Grid.Row="6"
                 Style="{StaticResource ChatInputBoxStyle}"
                 Margin="0,8,0,0"
                 MinHeight="64"
                 MaxHeight="160"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}"
                 IsEnabled="{Binding IsSending, Converter={StaticResource InverseBoolConverter}}"
                 PreviewKeyDown="InputBox_PreviewKeyDown"/>

        <!-- Buttons. PR-E (3): 단일 버튼이 IsSending 에 따라 "전송 (Enter)" ↔ "취소" 로 토글. 별도 취소 버튼 삭제.
             Icon: Segoe MDL2 Assets — Refresh(E72C) / Send(E724) / Cancel(E711). DurationBatchDialog 기존 관례 재사용. -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Command="{Binding ResetCommand}"
                    Style="{StaticResource ChatButtonStyle}"
                    Width="80" Margin="0,0,6,0"
                    ToolTip="대화 초기화 (세션 종료 + Turns 비우기)">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                               FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="초기화" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Width="128">
                <Button.Resources>
                    <Style x:Key="SendIconStyle" TargetType="TextBlock">
                        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Margin" Value="0,0,6,0"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Text" Value="&#xE724;"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSending}" Value="True">
                                <Setter Property="Text" Value="&#xE711;"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                    <Style x:Key="SendLabelStyle" TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Text" Value="전송 (Enter)"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSending}" Value="True">
                                <Setter Property="Text" Value="취소"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SendButtonStyle}">
                        <Setter Property="Command" Value="{Binding SendCommand}"/>
                        <Style.Triggers>
                            <!-- A 옵션: IsSending=True 시 취소 버튼 breathing (Opacity 0.7↔1.0, 0.8s).
                                 hit-target 흔들리지 않도록 진폭 좁게 + Background/Border 색은 유지.
                                 ExitActions 의 StopStoryboard 가 Opacity=1.0 으로 원복 (animation hold value 제거). -->
                            <DataTrigger Binding="{Binding IsSending}" Value="True">
                                <Setter Property="Command" Value="{Binding CancelCommand}"/>
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="CancelBreathBeginStoryboard">
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.7" To="1.0" Duration="0:0:0.8"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="CancelBreathBeginStoryboard"/>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{StaticResource SendIconStyle}"/>
                    <TextBlock Style="{StaticResource SendLabelStyle}"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
    </Border>
</UserControl>
