<Window x:Class="Promaker.Controls.ExpressionEditor.Views.ExpressionEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Promaker.Controls.ExpressionEditor.Views"
        Title="식 편집기"
        Width="1350" Height="930"
        MinWidth="960" MinHeight="630"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SecondaryBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <views:ExpressionEditorView x:Name="EditorView" Grid.Row="0"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="확인"  Padding="14,6" Margin="0,0,6,0" IsDefault="True"
                    Style="{DynamicResource DarkButton}"
                    Click="Ok_Click"/>
            <Button Content="취소"  Padding="14,6" IsCancel="True"
                    Style="{DynamicResource SecondaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
