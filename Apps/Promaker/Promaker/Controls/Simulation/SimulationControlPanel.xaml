<UserControl x:Class="Promaker.Controls.SimulationControlPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <Border Width="324"
            Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="1"
            CornerRadius="18"
            Padding="14">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="DragHandle"
                    Grid.Row="0"
                    Background="Transparent"
                    Cursor="SizeAll"
                    Padding="0,0,0,10"
                    MouseLeftButtonDown="DragHandle_OnMouseLeftButtonDown"
                    MouseMove="DragHandle_OnMouseMove"
                    MouseLeftButtonUp="DragHandle_OnMouseLeftButtonUp">
                <DockPanel LastChildFill="False">
                    <TextBlock Text="Simulation Control"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Drag"
                               DockPanel.Dock="Right"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="10"
                               VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12">
                <Button Style="{StaticResource SlimToolbarButton}"
                        Command="{Binding StartSimulationCommand}"
                        ToolTip="Start">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <Path Width="18" Height="18" Stretch="Fill" Data="M 4,2 L 16,9 L 4,16 Z" Fill="{DynamicResource IconGreenBrush}"/>
                        <TextBlock Text="Start" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SlimToolbarButton}"
                        Command="{Binding PauseSimulationCommand}"
                        ToolTip="Pause">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <Canvas Width="18" Height="18" HorizontalAlignment="Center">
                            <Rectangle Canvas.Left="4" Canvas.Top="2.5" Width="3.8" Height="13" Fill="{DynamicResource IconGrayBrush}" RadiusX="1" RadiusY="1"/>
                            <Rectangle Canvas.Left="10.2" Canvas.Top="2.5" Width="3.8" Height="13" Fill="{DynamicResource IconGrayBrush}" RadiusX="1" RadiusY="1"/>
                        </Canvas>
                        <TextBlock Text="Pause" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SlimToolbarButton}"
                        Command="{Binding StopSimulationCommand}"
                        ToolTip="Stop">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2" Fill="{DynamicResource IconRedBrush}"/>
                        <TextBlock Text="Stop" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SlimToolbarButton}"
                        Command="{Binding ResetSimulationCommand}"
                        ToolTip="Reset">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <Canvas Width="18" Height="18" HorizontalAlignment="Center">
                            <Path Data="M12,4V1L8,5L12,9V6A6,6 0 0,1 18,12A6,6 0 0,1 12,18A6,6 0 0,1 6,12H4A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4Z"
                                  Fill="{DynamicResource IconOrangeBrush}"/>
                        </Canvas>
                        <TextBlock Text="Reset" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Speed"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1"
                          SelectedValue="{Binding SimSpeed}"
                          SelectedValuePath="Tag"
                          Width="76"
                          FontSize="11"
                          HorizontalAlignment="Left">
                    <ComboBoxItem Content="0.5x" Tag="0.5"/>
                    <ComboBoxItem Content="1x" Tag="1.0" IsSelected="True"/>
                    <ComboBoxItem Content="2x" Tag="2.0"/>
                    <ComboBoxItem Content="5x" Tag="5.0"/>
                    <ComboBoxItem Content="10x" Tag="10.0"/>
                </ComboBox>

                <CheckBox Grid.Column="2"
                          Content="Ignore Time"
                          IsChecked="{Binding SimTimeIgnore}"
                          Margin="14,0,8,0"
                          VerticalAlignment="Center"/>

                <TextBlock Grid.Column="3"
                           Text="{Binding SimClock}"
                           Foreground="{DynamicResource IconBlueBrush}"
                           FontFamily="Consolas"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </Grid>

            <Grid Grid.Row="3" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Work"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding SimWorkItems}"
                          SelectedItem="{Binding SelectedSimWork}"
                          FontSize="11"/>
            </Grid>

            <UniformGrid Grid.Row="4" Columns="2">
                <Button Style="{StaticResource SlimToolbarButton}"
                        Command="{Binding ForceWorkStartCommand}"
                        ToolTip="Execute Work">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <Path Width="18" Height="18" Stretch="Fill" Data="M 4,2 L 16,9 L 4,16 Z" Fill="{DynamicResource IconGreenBrush}"/>
                        <TextBlock Text="Execute" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SlimToolbarButton}"
                        Command="{Binding ForceWorkResetCommand}"
                        ToolTip="Reset Work">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <Canvas Width="18" Height="18" HorizontalAlignment="Center">
                            <Path Data="M12,4V1L8,5L12,9V6A6,6 0 0,1 18,12A6,6 0 0,1 12,18A6,6 0 0,1 6,12H4A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4Z"
                                  Fill="{DynamicResource IconOrangeBrush}"/>
                        </Canvas>
                        <TextBlock Text="Work Reset" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Button>
            </UniformGrid>
        </Grid>
    </Border>
</UserControl>
