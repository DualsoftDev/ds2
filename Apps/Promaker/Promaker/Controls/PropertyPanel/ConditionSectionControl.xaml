<UserControl x:Class="Promaker.Controls.ConditionSectionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:help="clr-namespace:Promaker.Help"
             xmlns:conv="clr-namespace:Promaker.Presentation"
             x:Name="Root">
    <UserControl.Resources>
        <conv:MatchStateToBrushConverter x:Key="MatchToBrush"/>
    </UserControl.Resources>
    <Border BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Margin="0,2,0,4"
            Background="{DynamicResource TertiaryBackgroundBrush}"
            AllowDrop="True"
            DragEnter="Border_DragEnter"
            DragLeave="Border_DragLeave"
            DragOver="Border_DragOver"
            Drop="Border_Drop">
        <StackPanel>
            <!-- Header -->
            <Border Background="{DynamicResource SecondaryBackgroundBrush}" Padding="4,3">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding HeaderText, ElementName=Root}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <Button Style="{DynamicResource HelpButton}"
                                Command="{x:Static help:HelpNavigator.NavigateCommand}"
                                CommandParameter="{Binding HelpTopic, ElementName=Root}"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="&#x270E;"
                            ToolTip="일괄 편집"
                            Style="{DynamicResource InlineListButton}"
                            Command="{Binding EditConditionsCommand, ElementName=Root}"
                            CommandParameter="{Binding EditConditionsParameter, ElementName=Root}"/>
                    <Button Grid.Column="2"
                            Content="+"
                            ToolTip="{Binding AddToolTip, ElementName=Root}"
                            Style="{DynamicResource InlineListButton}"
                            Command="{Binding AddCommand, ElementName=Root}"
                            CommandParameter="{Binding AddCommandParameter, ElementName=Root}"/>
                </Grid>
            </Border>

            <!-- Condition formula list -->
            <ItemsControl ItemsSource="{Binding ItemsSource, ElementName=Root}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border AllowDrop="True"
                                Background="Transparent"
                                DragEnter="ConditionItem_DragEnter"
                                DragLeave="ConditionItem_DragLeave"
                                DragOver="ConditionItem_DragOver"
                                Drop="ConditionItem_Drop"
                                Tag="{Binding}">
                            <Grid Margin="4,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Content="x"
                                        Style="{DynamicResource InlineListButton}"
                                        Command="{Binding RemoveConditionCommand, ElementName=Root}"
                                        CommandParameter="{Binding}"/>
                                <StackPanel Grid.Column="1" Margin="4,0">
                                    <TextBlock FontSize="10"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding FormulaText}"
                                               Loaded="FormulaBlock_Loaded"
                                               DataContextChanged="FormulaBlock_DataContextChanged"/>
                                    <!-- 시뮬 동작 중 leaf 별 [현재:X / 기대:Y] 표시 — RuntimeText 가 비어있는 row 는 자동 숨김. -->
                                    <ItemsControl ItemsSource="{Binding AllLeafRows}" Margin="12,0,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding RuntimeText}"
                                                           FontSize="9"
                                                           FontStyle="Italic"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{Binding IsMatched, Converter={StaticResource MatchToBrush}}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RuntimeText}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Drop hint (shown when empty) -->
            <TextBlock x:Name="DropHint"
                       Text="Call을 여기로 드래그하세요"
                       FontSize="10"
                       FontStyle="Italic"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,6"
                       Visibility="Collapsed"/>
        </StackPanel>
    </Border>
</UserControl>
