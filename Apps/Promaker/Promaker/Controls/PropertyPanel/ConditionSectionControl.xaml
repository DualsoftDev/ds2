<UserControl x:Class="Promaker.Controls.ConditionSectionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:help="clr-namespace:Promaker.Help"
             x:Name="Root">
    <Border BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Margin="0,2,0,4"
            Background="{DynamicResource TertiaryBackgroundBrush}"
            AllowDrop="True"
            DragEnter="Border_DragEnter"
            DragLeave="Border_DragLeave"
            DragOver="Border_DragOver"
            Drop="Border_Drop">
        <StackPanel>
            <!-- Header -->
            <Border Background="{DynamicResource SecondaryBackgroundBrush}" Padding="4,3">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding HeaderText, ElementName=Root}"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <Button Style="{DynamicResource HelpButton}"
                                Command="{x:Static help:HelpNavigator.NavigateCommand}"
                                CommandParameter="{Binding HelpTopic, ElementName=Root}"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="&#x270E;"
                            ToolTip="일괄 편집"
                            Style="{DynamicResource InlineListButton}"
                            Command="{Binding EditConditionsCommand, ElementName=Root}"
                            CommandParameter="{Binding EditConditionsParameter, ElementName=Root}"/>
                    <Button Grid.Column="2"
                            Content="+"
                            ToolTip="{Binding AddToolTip, ElementName=Root}"
                            Style="{DynamicResource InlineListButton}"
                            Command="{Binding AddCommand, ElementName=Root}"
                            CommandParameter="{Binding AddCommandParameter, ElementName=Root}"/>
                </Grid>
            </Border>

            <!-- Condition group list — 각 그룹은 헤더(remove 버튼) + 신호 행들 -->
            <ItemsControl ItemsSource="{Binding ItemsSource, ElementName=Root}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border AllowDrop="True"
                                Background="Transparent"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                DragEnter="ConditionItem_DragEnter"
                                DragLeave="ConditionItem_DragLeave"
                                DragOver="ConditionItem_DragOver"
                                Drop="ConditionItem_Drop"
                                Tag="{Binding}">
                            <StackPanel Margin="4,2">
                                <!-- 그룹 헤더: 그룹 전체 삭제 버튼만 (AND/OR 의미 없음 — 단순 리스트). -->
                                <Button Content="x"
                                        HorizontalAlignment="Left"
                                        Style="{DynamicResource InlineListButton}"
                                        ToolTip="조건 그룹 삭제"
                                        Margin="0,0,0,2"
                                        Command="{Binding RemoveConditionCommand, ElementName=Root}"
                                        CommandParameter="{Binding}"/>

                                <!-- 그룹 안의 ApiCall 신호 리스트 — 각 행: 이름 + ValueSpec + 편집/삭제 버튼 -->
                                <ItemsControl ItemsSource="{Binding Items}" Margin="14,0,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0"
                                                        Content="x"
                                                        Style="{DynamicResource InlineListButton}"
                                                        ToolTip="이 ApiCall 제거"
                                                        Command="{Binding RemoveConditionApiCallCommand, ElementName=Root}"
                                                        CommandParameter="{Binding}"/>
                                                <TextBlock Grid.Column="1"
                                                           FontSize="10"
                                                           VerticalAlignment="Center"
                                                           Margin="4,0"
                                                           Text="{Binding ApiDefDisplayName}"
                                                           ToolTip="{Binding ApiDefDisplayName}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="2"
                                                           FontSize="10"
                                                           VerticalAlignment="Center"
                                                           Margin="4,0"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           Text="{Binding OutputSpecText}"/>
                                                <Button Grid.Column="3"
                                                        Content="ValueSpec"
                                                        Style="{DynamicResource InlineListButton}"
                                                        ToolTip="OutputSpec / InputSpec 편집"
                                                        Command="{Binding EditConditionApiCallSpecCommand, ElementName=Root}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Drop hint (shown when empty) -->
            <TextBlock x:Name="DropHint"
                       Text="Call을 여기로 드래그하세요"
                       FontSize="10"
                       FontStyle="Italic"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,6"
                       Visibility="Collapsed"/>
        </StackPanel>
    </Border>
</UserControl>
