<Window x:Class="Promaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:ctrl="clr-namespace:Promaker.Controls"
        xmlns:conv="clr-namespace:Promaker.Presentation"
        xmlns:help="clr-namespace:Promaker.Help"
        Title="{Binding Title}" Width="1688" Height="800"
        MinWidth="880" MinHeight="600"
        Icon="/Promaker;component/Assets/Promaker.ico"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        DragOver="Window_DragOver"
        DragLeave="Window_DragLeave"
        Drop="Window_Drop">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}"/>
        <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}"/>
        <KeyBinding Gesture="Ctrl+C" Command="{Binding CopySelectedCommand}"/>
        <KeyBinding Gesture="Ctrl+V" Command="{Binding PasteCopiedCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveFileCommand}"/>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewProjectCommand}"/>
        <KeyBinding Gesture="Delete" Command="{Binding DeleteSelectedCommand}"/>
        <KeyBinding Key="F2" Command="{Binding FocusNameEditorCommand}"/>
        <KeyBinding Gesture="Ctrl+W" Command="{Binding Canvas.CloseActiveTabCommand}"/>
        <KeyBinding Key="F1" Command="{x:Static help:HelpNavigator.NavigateCommand}" CommandParameter="general"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ctrl:MainToolbar Grid.Row="0"/>

        <!-- Main content area with columns -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="150"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="280" MinWidth="150"/>
            </Grid.ColumnDefinitions>

            <ctrl:ExplorerPane Grid.Column="0"/>
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="200" MinHeight="80"/>
                </Grid.RowDefinitions>

                <ctrl:SplitCanvasContainer x:Name="WorkspacePane" Grid.Row="0"/>

                <GridSplitter Grid.Row="1"
                              Height="4"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"/>

                <ctrl:SimulationPanel x:Name="SimulationPanelHost"
                                      Grid.Row="2"
                                      DataContext="{Binding Simulation}"/>
            </Grid>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"/>

            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="220" MinHeight="60"/>
                </Grid.RowDefinitions>

                <ctrl:PropertyPanel x:Name="PropertyPane" Grid.Row="0" DataContext="{Binding PropertyPanel}"/>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>

                <Border Grid.Row="2" Style="{StaticResource PanelContainer}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelHeader}">
                            <Grid>
                                <TextBlock Text="History" FontWeight="SemiBold" FontSize="12"/>
                                <Button Style="{StaticResource HelpButton}" HorizontalAlignment="Right"
                                        Command="{x:Static help:HelpNavigator.NavigateCommand}"
                                        CommandParameter="history"/>
                            </Grid>
                        </Border>
                        <ctrl:HistoryPanel Grid.Row="1"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Welcome screen when no project is open -->
            <Border x:Name="WelcomeOverlay" Grid.ColumnSpan="5"
                    Background="{DynamicResource PrimaryBackgroundBrush}" Panel.ZIndex="10"
                    AllowDrop="True"
                    DragEnter="Window_DragEnter"
                    DragOver="Window_DragOver"
                    DragLeave="Window_DragLeave"
                    Drop="Window_Drop">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasProject}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Ellipse Width="70" Height="70" Opacity="0.4" Margin="0,0,0,20"
                             HorizontalAlignment="Center">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="{DynamicResource AccentColor}" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <iconPacks:PackIconMaterial Kind="FolderOpen" Width="48" Height="48" Margin="0,-72,0,40"
                          HorizontalAlignment="Center"
                          Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="기존 프로젝트 파일을 불러오세요"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="프로젝트를 시작하려면 새로 만들거나 파일을 열어주세요"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,24"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Command="{Binding NewProjectCommand}"
                                Padding="16,10" Margin="0,0,12,0"
                                FontSize="13" Cursor="Hand"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="White" BorderThickness="0">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="FileDocumentPlus" Width="16" Height="16" Margin="0,0,6,0"
                                      Foreground="White"/>
                                <TextBlock Text="새로 만들기" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OpenFileCommand}"
                                Padding="16,10"
                                FontSize="13" Cursor="Hand"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="White" BorderThickness="0">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="FolderOpen" Width="16" Height="16" Margin="0,0,6,0"
                                      Foreground="White"/>
                                <TextBlock Text="프로젝트 열기" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- File drag overlay -->
        <Grid x:Name="FileDragOverlay" Grid.RowSpan="3" Visibility="Collapsed" IsHitTestVisible="False" Panel.ZIndex="100">
            <!-- Semi-transparent background with accent color -->
            <Rectangle x:Name="DragDropBackground" Fill="{DynamicResource AccentBrush}" Opacity="0.15"/>

            <!-- Dashed border -->
            <Rectangle x:Name="DragDropBorder" Stroke="{DynamicResource AccentBrush}"
                       StrokeThickness="4"
                       StrokeDashArray="10,5"
                       Margin="20"/>

            <!-- Drop instruction -->
            <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="60,50"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.4" BlurRadius="20" ShadowDepth="5"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <!-- SDF Icon (shown for .sdf files) -->
                    <Image x:Name="DragDropSdfIcon" Source="Assets/SdfFile.ico"
                           Width="100" Height="100" Margin="0,0,0,20"
                           HorizontalAlignment="Center" Stretch="Uniform" Visibility="Collapsed"/>

                    <!-- JSON Icon (shown for .json files) -->
                    <Grid x:Name="DragDropJsonIcon" Width="100" Height="100" Margin="0,0,0,20"
                          HorizontalAlignment="Center" Visibility="Collapsed">
                        <Rectangle Fill="#FF2196F3" RadiusX="12" RadiusY="12"/>
                        <TextBlock Text="JSON" FontSize="24" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- AASX Icon (shown for .aasx files) -->
                    <Image x:Name="DragDropAasxIcon" Source="Resources/Icons/aas.png"
                           Width="100" Height="100" Margin="0,0,0,20"
                           HorizontalAlignment="Center" Stretch="Uniform" Visibility="Collapsed"/>

                    <!-- Mermaid Icon (shown for .md files) -->
                    <iconPacks:PackIconMaterial x:Name="DragDropMermaidIcon" Kind="FileChart"
                             Width="100" Height="100" Margin="0,0,0,20"
                             HorizontalAlignment="Center" Visibility="Collapsed"
                             Foreground="{DynamicResource AccentBrush}"/>

                    <!-- Dynamic message text -->
                    <TextBlock x:Name="DragDropMessage" Text="프로젝트 파일을 여기에 놓으세요"
                               FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock x:Name="DragDropSubMessage" Text="지원 형식: SDF, AASX, Mermaid"
                               FontSize="12" Margin="0,10,0,0" HorizontalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
