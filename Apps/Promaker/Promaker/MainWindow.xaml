<Window x:Class="Promaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:Promaker.Controls"
        xmlns:conv="clr-namespace:Promaker.Presentation"
        xmlns:help="clr-namespace:Promaker.Help"
        Title="{Binding Title}" Width="1540" Height="800"
        MinWidth="880" MinHeight="600"
        Icon="pack://application:,,,/Assets/Promaker.ico"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}"/>
        <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}"/>
        <KeyBinding Gesture="Ctrl+C" Command="{Binding CopySelectedCommand}"/>
        <KeyBinding Gesture="Ctrl+V" Command="{Binding PasteCopiedCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveFileCommand}"/>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewProjectCommand}"/>
        <KeyBinding Gesture="Delete" Command="{Binding DeleteSelectedCommand}"/>
        <KeyBinding Key="F2" Command="{Binding FocusNameEditorCommand}"/>
        <KeyBinding Key="F1" Command="{x:Static help:HelpNavigator.NavigateCommand}" CommandParameter="general"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ctrl:MainToolbar Grid.Row="0"/>

        <!-- Main content area with columns -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="150"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="280" MinWidth="150"/>
            </Grid.ColumnDefinitions>

            <ctrl:ExplorerPane Grid.Column="0"/>
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="200" MinHeight="80"/>
                </Grid.RowDefinitions>

                <ctrl:SplitCanvasContainer x:Name="WorkspacePane" Grid.Row="0"/>

                <GridSplitter Grid.Row="1"
                              Height="4"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"/>

                <ctrl:SimulationPanel Grid.Row="2"
                                      DataContext="{Binding Simulation}"/>
            </Grid>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"/>

            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="220" MinHeight="60"/>
                </Grid.RowDefinitions>

                <ctrl:PropertyPanel x:Name="PropertyPane" Grid.Row="0" DataContext="{Binding PropertyPanel}"/>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>

                <Border Grid.Row="2" Style="{StaticResource PanelContainer}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelHeader}">
                            <Grid>
                                <TextBlock Text="History" FontWeight="SemiBold" FontSize="12"/>
                                <Button Style="{StaticResource HelpButton}" HorizontalAlignment="Right"
                                        Command="{x:Static help:HelpNavigator.NavigateCommand}"
                                        CommandParameter="history"/>
                            </Grid>
                        </Border>
                        <ctrl:HistoryPanel Grid.Row="1"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
