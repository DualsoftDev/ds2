<Window x:Class="Promaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:ad="https://github.com/Dirkster99/AvalonDock"
        xmlns:adc="clr-namespace:AvalonDock.Controls;assembly=AvalonDock"
        xmlns:adThemes="clr-namespace:AvalonDock.Themes;assembly=AvalonDock.Themes.Metro"
        xmlns:ctrl="clr-namespace:Promaker.Controls"
        xmlns:llm="clr-namespace:Promaker.Controls.Llm"
        xmlns:vm="clr-namespace:Promaker.ViewModels"
        xmlns:conv="clr-namespace:Promaker.Presentation"
        xmlns:help="clr-namespace:Promaker.Help"
        Title="{Binding Title}" Width="1688" Height="800"
        MinWidth="880" MinHeight="600"
        Icon="/Promaker;component/Assets/Promaker.ico"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource PrimaryBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}"
        Closing="Window_Closing"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        DragOver="Window_DragOver"
        DragLeave="Window_DragLeave"
        Drop="Window_Drop">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- 1d-4 D — LlmChatViewModel 을 LlmChatPanel 로 자동 매핑 (DataTemplate). -->
        <DataTemplate DataType="{x:Type vm:LlmChatViewModel}">
            <llm:LlmChatPanel/>
        </DataTemplate>

        <!-- v17 — AvalonDock Metro DocumentPaneControlStyle 은 ContentPanel Padding="0,1,0,2" 와
             PART_SelectedContentHost Margin="0,2,0,2" 를 하드코딩해 Welcome/Canvas 상하단 흰 줄을 만든다.
             Promaker workspace 는 내부 tab/canvas 가 자체 chrome 을 가지므로 document pane chrome 을 제거한다. -->
        <Style x:Key="PromakerDocumentPaneControlStyle" TargetType="{x:Type adc:LayoutDocumentPaneControl}">
            <Setter Property="Background" Value="{DynamicResource PrimaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type adc:LayoutDocumentPaneControl}">
                        <Grid ClipToBounds="True"
                              KeyboardNavigation.TabNavigation="Local"
                              SnapsToDevicePixels="True"
                              Background="{TemplateBinding Background}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.RowSpan="2" Background="Transparent"/>
                            <adc:DocumentPaneTabPanel x:Name="HeaderPanel"
                                                      Grid.Row="0"
                                                      IsItemsHost="True"
                                                      KeyboardNavigation.TabIndex="1"
                                                      Visibility="{Binding Model.ShowHeader, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVis}}"/>
                            <Border x:Name="ContentPanel"
                                    Grid.Row="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    KeyboardNavigation.DirectionalNavigation="Contained"
                                    KeyboardNavigation.TabIndex="2"
                                    KeyboardNavigation.TabNavigation="Cycle">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  Content="{Binding Model.SelectedContent.Content, RelativeSource={RelativeSource TemplatedParent}}"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="{x:Type TabItem}">
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                        <Setter Property="ToolTip" Value="{Binding ToolTip}"/>
                        <Setter Property="Padding" Value="4"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type TabItem}">
                                    <Border Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="0,1,0,0">
                                        <ContentPresenter ContentSource="Header"
                                                          RecognizesAccessKey="True"
                                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="Selector.IsSelected" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <adc:LayoutDocumentTabItem Model="{Binding}"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <adc:LayoutDocumentControl Model="{Binding}"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}"/>
        <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}"/>
        <KeyBinding Gesture="Ctrl+C" Command="{Binding CopySelectedCommand}"/>
        <KeyBinding Gesture="Ctrl+V" Command="{Binding PasteCopiedCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveFileCommand}"/>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewProjectCommand}"/>
        <KeyBinding Gesture="Delete" Command="{Binding DeleteSelectedCommand}"/>
        <KeyBinding Key="F2" Command="{Binding FocusNameEditorCommand}"/>
        <KeyBinding Gesture="Ctrl+W" Command="{Binding Canvas.CloseActiveTabCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+W" Command="{Binding CloseFileCommand}"/>
        <KeyBinding Key="F1" Command="{x:Static help:HelpNavigator.NavigateCommand}" CommandParameter="general"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ctrl:MainToolbar Grid.Row="0"/>

        <!-- v7 PR-2a — AvalonDock DockingManager 로 외곽 layout 교체.
             Welcome/Canvas 통합 안 A: welcomeDoc/canvasDoc 의 IsVisible 을 HasProject 에 동기화.
             모든 anchor 에 CanClose=False CanHide=True 일괄 (v7 spike 회귀 회피 — 기본값 CanClose=true 면 X = 영구 제거).
             ContentId 모든 항목 필수 (serialize/deserialize key). LlmChat 은 IsVisible=False 기본. -->
        <!-- dockManager x:Name 은 `Apps/Promaker/Docs/todo-dock-layout.md` §4 의 PR-3 (XmlLayoutSerializer Save/Restore) 진입 시 사용 예정 — 현재는 placeholder. -->
        <ad:DockingManager x:Name="dockManager" Grid.Row="1"
                           AllowMixedOrientation="True"
                           Background="{DynamicResource PrimaryBackgroundBrush}"
                           BorderThickness="0"
                           DocumentPaneControlStyle="{StaticResource PromakerDocumentPaneControlStyle}">
            <!-- 다크 테마 hotfix — Promaker 자체 ThemeManager 와 별개로 AvalonDock 의 caption/탭/auto-hide brush 적용.
                 PR-4 진입 시 `Apps/Promaker/Promaker/Themes/Theme.Controls.Dock.xaml` 자체 매핑으로 교체 예정.
                 v10 추가 — Background/BorderThickness 명시: AvalonDock.Themes.Metro 가 Application.Resources 에 merge 되며
                 default Window/dockManager 의 light gray background 가 노출되는 회귀 (image 4/5) 차단. -->
            <ad:DockingManager.Theme>
                <adThemes:MetroTheme/>
            </ad:DockingManager.Theme>
            <!-- v14 — floating window 관련 모든 setter (Topmost / OwnedByDockingManagerWindow / ResizeBorderThickness /
                 Background) 는 `MainWindow.xaml.cs` 의 OnFloatingWindowCreated 핸들러로 이전.
                 사유: floating window 가 별도 Window 인스턴스라 dockManager logical/resource tree 와 분리되어
                 DockingManager.Resources 의 implicit Style 이 도달 안 함 (v12/v13 미적용 회귀 사용자 보고).
                 추가로 LayoutFloatingWindowControl.ResizeBorderThickness DP 직접 set 은 frozen WindowChrome 에 set
                 시도하다 "읽기 전용 상태" 예외 발생 → code-behind 에서 WindowChrome clone 후 SetWindowChrome.
                 LayoutGridResizerControl 은 dockManager logical child 라 implicit Style 정상 적용. -->
            <ad:DockingManager.Resources>
                <!-- v14 — Workspace ↔ Simulation 사이 horizontal splitter 의 white line 제거.
                     Metro theme 의 LayoutGridResizerControl Background 기본값 = AvalonDock_ThemeMetro_BaseColor7 (#EEEEEE)
                     로 다크 배경에서 부조화. -->
                <Style TargetType="{x:Type adc:LayoutGridResizerControl}">
                    <Setter Property="Background" Value="{DynamicResource PrimaryBackgroundBrush}"/>
                </Style>
                <!-- v14.3 — v14.2 의 LayoutDocumentPaneControl Style 은 Window.Resources 로 이동
                     (DockingManager.Resources scope 에서 Metro theme DefaultStyleKey lookup 보다 약해 미적용 의심). -->
            </ad:DockingManager.Resources>
            <ad:LayoutRoot>
                <ad:LayoutPanel Orientation="Horizontal">

                    <ad:LayoutAnchorablePane x:Name="explorerPane" DockWidth="320">
                        <ad:LayoutAnchorable x:Name="explorerAnchor"
                                             ContentId="explorer" Title="Explorer"
                                             CanClose="False" CanHide="True"
                                             CanFloat="True" CanAutoHide="True">
                            <ctrl:ExplorerPane/>
                        </ad:LayoutAnchorable>
                    </ad:LayoutAnchorablePane>

                    <ad:LayoutPanel Orientation="Vertical">
                        <!-- v7 PR-2a — Welcome/Canvas 통합 안 A. LayoutDocument.IsVisible 은 read-only 라
                             XAML setter 불가. SyncWelcomeCanvasVisibility() 가 HasProject 에 따라
                             workspaceDocs.Children 에 welcomeDoc / canvasDoc 중 하나만 attach. -->
                        <ad:LayoutDocumentPane x:Name="workspaceDocs" ShowHeader="False">
                            <ad:LayoutDocument x:Name="welcomeDoc"
                                               ContentId="welcome" Title="Welcome"
                                               CanClose="False" CanFloat="False">
                                <ctrl:WelcomeView/>
                            </ad:LayoutDocument>
                            <ad:LayoutDocument x:Name="canvasDoc"
                                               ContentId="canvas" Title="Workspace"
                                               CanClose="False" CanFloat="False">
                                <ctrl:SplitCanvasContainer x:Name="WorkspacePane" MinHeight="120"/>
                            </ad:LayoutDocument>
                        </ad:LayoutDocumentPane>
                        <ad:LayoutAnchorablePane x:Name="simulationPane" DockHeight="200">
                            <ad:LayoutAnchorable x:Name="simulationAnchor"
                                                 ContentId="simulation" Title="Simulation"
                                                 CanClose="False" CanHide="True"
                                                 CanFloat="True" CanAutoHide="True">
                                <ctrl:SimulationPanel x:Name="SimulationPanelHost"
                                                      DataContext="{Binding Simulation}"/>
                            </ad:LayoutAnchorable>
                        </ad:LayoutAnchorablePane>
                    </ad:LayoutPanel>

                    <ad:LayoutPanel x:Name="rightPanel" Orientation="Vertical" DockWidth="280">
                        <!-- v10 hotfix — fill pane 2개 (propertyPane / llmChatPane) 는 명시적 DockHeight="*" 로 C# 의
                             `OnAnchorIsVisibleChanged` 의 StarLength toggle 과 SSOT 일치. 빈 pane 잔존 시 0 으로 toggle. -->
                        <ad:LayoutAnchorablePane x:Name="propertyPane" DockHeight="*">
                            <ad:LayoutAnchorable x:Name="propertyAnchor"
                                                 ContentId="properties" Title="Properties"
                                                 CanClose="False" CanHide="True"
                                                 CanFloat="True" CanAutoHide="True">
                                <ctrl:PropertyPanel x:Name="PropertyPane"
                                                    DataContext="{Binding PropertyPanel}"/>
                            </ad:LayoutAnchorable>
                        </ad:LayoutAnchorablePane>
                        <ad:LayoutAnchorablePane x:Name="historyPane" DockHeight="220">
                            <ad:LayoutAnchorable x:Name="historyAnchor"
                                                 ContentId="history" Title="History"
                                                 CanClose="False" CanHide="True"
                                                 CanFloat="True" CanAutoHide="True">
                                <Border Style="{StaticResource PanelContainer}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Style="{StaticResource PanelHeader}">
                                            <Grid>
                                                <TextBlock Text="History" FontWeight="SemiBold" FontSize="12"/>
                                                <Button Style="{StaticResource HelpButton}" HorizontalAlignment="Right"
                                                        Command="{x:Static help:HelpNavigator.NavigateCommand}"
                                                        CommandParameter="history"/>
                                            </Grid>
                                        </Border>
                                        <ctrl:HistoryPanel Grid.Row="1"/>
                                    </Grid>
                                </Border>
                            </ad:LayoutAnchorable>
                        </ad:LayoutAnchorablePane>
                        <ad:LayoutAnchorablePane x:Name="llmChatPane" DockHeight="*">
                            <ad:LayoutAnchorable x:Name="llmChatAnchor"
                                                 ContentId="llmchat" Title="LLM Chat"
                                                 CanClose="False" CanHide="True"
                                                 CanFloat="True" CanAutoHide="True"
                                                 IsVisible="False">
                                <ContentControl Content="{Binding LlmChatVm}"/>
                            </ad:LayoutAnchorable>
                        </ad:LayoutAnchorablePane>
                    </ad:LayoutPanel>

                </ad:LayoutPanel>
            </ad:LayoutRoot>
        </ad:DockingManager>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- v7 — overlay 형제 배치. BusyOverlay 가 IsHitTestVisible=True 로 floating window 포함 모든 입력 차단.
             FileDragOverlay 는 IsHitTestVisible=False (순수 visual feedback, drop 은 Window-level 핸들러). -->
        <Grid x:Name="BusyOverlay" Grid.RowSpan="3" Panel.ZIndex="200"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
              Background="#80000000" IsHitTestVisible="True">
            <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="40,28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.4" BlurRadius="20" ShadowDepth="4"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Width="36" Height="36" Margin="0,0,16,0">
                        <Ellipse Stroke="{DynamicResource BorderBrush}" StrokeThickness="3"/>
                        <Ellipse Stroke="{DynamicResource AccentBrush}" StrokeThickness="3"
                                 StrokeDashArray="4 6" StrokeDashCap="Round"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform x:Name="BusySpinnerRotate" Angle="0"/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Ellipse.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="BusySpinnerRotate"
                                                             Storyboard.TargetProperty="Angle"
                                                             From="0" To="360" Duration="0:0:1.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="로딩 중..."
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="{Binding BusyMessage}"
                                   FontSize="12" Margin="0,4,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextTrimming="CharacterEllipsis" MaxWidth="420"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="FileDragOverlay" Grid.RowSpan="3" Visibility="Collapsed" IsHitTestVisible="False" Panel.ZIndex="100">
            <Rectangle x:Name="DragDropBackground" Fill="{DynamicResource AccentBrush}" Opacity="0.15"/>

            <Rectangle x:Name="DragDropBorder" Stroke="{DynamicResource AccentBrush}"
                       StrokeThickness="4"
                       StrokeDashArray="10,5"
                       Margin="20"/>

            <Border Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="60,50"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.4" BlurRadius="20" ShadowDepth="5"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <Image x:Name="DragDropSdfIcon" Source="Assets/SdfFile.ico"
                           Width="100" Height="100" Margin="0,0,0,20"
                           HorizontalAlignment="Center" Stretch="Uniform" Visibility="Collapsed"/>

                    <Grid x:Name="DragDropJsonIcon" Width="100" Height="100" Margin="0,0,0,20"
                          HorizontalAlignment="Center" Visibility="Collapsed">
                        <Rectangle Fill="#FF2196F3" RadiusX="12" RadiusY="12"/>
                        <TextBlock Text="JSON" FontSize="24" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <Image x:Name="DragDropAasxIcon" Source="Resources/Icons/aas.png"
                           Width="100" Height="100" Margin="0,0,0,20"
                           HorizontalAlignment="Center" Stretch="Uniform" Visibility="Collapsed"/>

                    <iconPacks:PackIconMaterial x:Name="DragDropMermaidIcon" Kind="FileChart"
                             Width="100" Height="100" Margin="0,0,0,20"
                             HorizontalAlignment="Center" Visibility="Collapsed"
                             Foreground="{DynamicResource AccentBrush}"/>

                    <!-- YAML Icon (shown for .yaml/.yml files) - lossy 공유 포맷 -->
                    <Grid x:Name="DragDropYamlIcon" Width="100" Height="100" Margin="0,0,0,20"
                          HorizontalAlignment="Center" Visibility="Collapsed">
                        <Rectangle Fill="#FFCB171E" RadiusX="12" RadiusY="12"/>
                        <TextBlock Text="YAML" FontSize="22" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock x:Name="DragDropMessage" Text="프로젝트 파일을 여기에 놓으세요"
                               FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock x:Name="DragDropSubMessage" Text="지원 형식: SDF, AASX, Mermaid, YAML"
                               FontSize="12" Margin="0,10,0,0" HorizontalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
