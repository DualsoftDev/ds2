}

@if (_showBatchEdit)
{
    var filteredRecords = GetFilteredBatchRecords();
    var applyTargets = GetBatchApplyTargets();
    var entityTypes = GetBatchEntityTypes();
    var vtCategories = GetBatchValueTypeCategories();
    var highlightCount = _batchHighlightedIds.Count;

    <div class="modal-overlay">
        <div class="modal-dialog" style="width:720px;max-height:85vh;display:flex;flex-direction:column">
            <div class="modal-title">일괄 편집 — 검색 결과 @(_searchResults.Count)건 중 @(applyTargets.Count)건 선택됨</div>
            <div class="modal-body" style="display:flex;flex-direction:column;overflow:hidden;flex:1;min-height:0">

                @* Row 1: 편집 방식 (Bit은 덮어쓰기만 가능) *@
                @if (_batchValueTypeFilter != "bit")
                {
                    <div style="margin-bottom:8px;flex-shrink:0">
                        <label class="modal-input-label">편집 방식</label>
                        <select class="modal-input" @bind="_batchEditMode">
                            @foreach (var (mode, label) in BatchEditModes)
                            {
                                <option value="@mode">@label</option>
                            }
                        </select>
                    </div>
                }

                @* Row 2: 필터 *@
                <div style="display:flex;gap:6px;margin-bottom:6px;flex-shrink:0;align-items:center">
                    <select class="modal-input" style="font-size:12px;padding:4px 6px;flex:0 0 120px"
                            @bind="_batchTypeFilter">
                        <option value="">전체 타입</option>
                        @foreach (var t in entityTypes)
                        {
                            var cnt = _searchResults.Count(r => r.EntityType == t);
                            <option value="@t">@t (@cnt)</option>
                        }
                    </select>
                    @if (vtCategories.Count > 0)
                    {
                        <select class="modal-input" style="font-size:12px;padding:4px 6px;flex:0 0 120px"
                                value="@_batchValueTypeFilter"
                                @onchange="(e) => OnBatchValueTypeFilterChanged(e.Value?.ToString() ?? string.Empty)">
                            <option value="">전체 값타입</option>
                            @foreach (var (cat, catLabel, cnt) in vtCategories)
                            {
                                <option value="@cat">@catLabel (@cnt)</option>
                            }
                        </select>
                    }
                    <input class="modal-input" type="text" style="font-size:12px;padding:4px 6px;flex:1"
                           placeholder="IdShort 필터..."
                           @bind="_batchIdFilter" @bind:event="oninput" />
                    <button class="btn btn-outline-info" style="font-size:11px;padding:3px 8px;white-space:nowrap" @onclick="OnBatchSelectAllVisible">
                        전체선택
                    </button>
                    <button class="btn btn-outline-secondary" style="font-size:11px;padding:3px 8px;white-space:nowrap" @onclick="OnBatchDeselectAllVisible">
                        전체해제
                    </button>
                </div>

                @* Row 2.5: 하이라이트 액션 바 (행 클릭 선택 시 표시) *@
                @if (highlightCount > 0)
                {
                    <div class="batch-highlight-bar">
                        <span class="batch-highlight-count">@highlightCount 건 선택됨</span>
                        <button class="btn btn-outline-info" style="font-size:11px;padding:2px 8px" @onclick="OnBatchCheckHighlighted">
                            체크
                        </button>
                        <button class="btn btn-outline-secondary" style="font-size:11px;padding:2px 8px" @onclick="OnBatchUncheckHighlighted">
                            체크해제
                        </button>
                        <button class="btn btn-outline-secondary" style="font-size:11px;padding:2px 6px" @onclick="() => _batchHighlightedIds.Clear()">
                            취소
                        </button>
                        <span class="batch-highlight-hint">Ctrl+클릭: 추가, Shift+클릭: 범위</span>
                    </div>
                }

                @* Row 3: 스크롤 가능한 항목 목록 *@
                <div class="batch-table-wrap">
                    <table class="batch-table">
                        <thead>
                            <tr>
                                <td style="width:28px;padding:4px;text-align:center"></td>
                                <td style="width:65px;padding:4px;cursor:pointer" @onclick='() => OnBatchSortToggle("EntityType")'>
                                    타입@(_batchSortColumn == "EntityType" ? (_batchSortAsc ? " \u25B2" : " \u25BC") : "")
                                </td>
                                <td style="padding:4px;cursor:pointer" @onclick='() => OnBatchSortToggle("IdShort")'>
                                    IdShort@(_batchSortColumn == "IdShort" ? (_batchSortAsc ? " \u25B2" : " \u25BC") : "")
                                </td>
                                <td style="width:70px;padding:4px;cursor:pointer" @onclick='() => OnBatchSortToggle("ValueType")'>
                                    값타입@(_batchSortColumn == "ValueType" ? (_batchSortAsc ? " \u25B2" : " \u25BC") : "")
                                </td>
                                <td style="padding:4px;min-width:80px;cursor:pointer" @onclick='() => OnBatchSortToggle("Value")'>
                                    현재 값@(_batchSortColumn == "Value" ? (_batchSortAsc ? " \u25B2" : " \u25BC") : "")
                                </td>
                                @if (CanApply() && _batchEditMode != "overwrite")
                                {
                                    <td style="padding:4px;min-width:80px">변경 후</td>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in filteredRecords)
                            {
                                var rec = r;
                                var isEditable = IsEditableType(rec.EntityType);
                                var isChecked = _batchSelectedIds.Contains(rec.Id);
                                var isHighlighted = _batchHighlightedIds.Contains(rec.Id);
                                var curVal = rec.Value ?? "";
                                var showPreview = CanApply() && _batchEditMode != "overwrite" && isChecked;

                                var opacity = !isEditable ? "0.35" : isChecked ? "1" : "0.55";

                                <tr class="@(isHighlighted ? "highlighted" : "")"
                                    style="opacity:@opacity;cursor:@(isEditable ? "pointer" : "default")"
                                    @onclick="(e) => OnBatchRowClick(rec.Id, e)"
                                    @onclick:stopPropagation="true">
                                    <td style="padding:3px 4px;text-align:center" @onclick:stopPropagation="true">
                                        <input type="checkbox" checked="@isChecked" disabled="@(!isEditable)"
                                               @onchange="(e) => OnBatchToggleItem(rec.Id, (bool)e.Value!)" />
                                    </td>
                                    <td style="padding:3px 4px">
                                        <span class="modal-chip-type" style="font-size:10px">@rec.EntityType</span>
                                    </td>
                                    <td class="batch-id-cell">@rec.IdShort</td>
                                    <td class="batch-vt-cell">@(rec.ValueType ?? "")</td>
                                    <td class="batch-value-cell">
                                        @if (!string.IsNullOrEmpty(curVal))
                                        {
                                            <span style="@(showPreview ? "text-decoration:line-through;opacity:0.5" : "")">@TruncateValue(curVal, 18)</span>
                                        }
                                    </td>
                                    @if (CanApply() && _batchEditMode != "overwrite")
                                    {
                                        <td class="batch-preview-cell">
                                            @if (showPreview)
                                            {
                                                @TruncateValue(PreviewNewValue(rec), 18)
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* Row 4: 입력 필드 — 값타입 카테고리별 UI *@
                <div style="flex-shrink:0">
                    @if (_batchValueTypeFilter == "bit")
                    {
                        @* Bit: true/false 토글 버튼 *@
                        <label class="modal-input-label">새 값</label>
                        <div style="display:flex;gap:8px">
                            <button class="btn @(_batchNewValue == "true" ? "btn-info" : "btn-outline-secondary")"
                                    style="flex:1;padding:6px" @onclick='() => _batchNewValue = "true"'>
                                true
                            </button>
                            <button class="btn @(_batchNewValue == "false" ? "btn-info" : "btn-outline-secondary")"
                                    style="flex:1;padding:6px" @onclick='() => _batchNewValue = "false"'>
                                false
                            </button>
                        </div>
                    }
                    else if (_batchValueTypeFilter == "number" && _batchEditMode == "overwrite")
                    {
                        @* Number + 덮어쓰기: 숫자 입력 *@
                        <label class="modal-input-label">새 값</label>
                        <input class="modal-input" type="number" step="any" placeholder="숫자 입력..."
                               @bind="_batchNewValue" @bind:event="oninput" />
                    }
                    else if (_batchEditMode == "findReplace")
                    {
                        <div style="display:flex;gap:8px">
                            <div style="flex:1">
                                <label class="modal-input-label">찾을 텍스트</label>
                                <input class="modal-input" type="text" placeholder="기존 값에서 찾을 텍스트..."
                                       @bind="_batchFindText" @bind:event="oninput" />
                            </div>
                            <div style="flex:1">
                                <label class="modal-input-label">바꿀 텍스트</label>
                                <input class="modal-input" type="text" placeholder="바꿀 텍스트..."
                                       @bind="_batchNewValue" @bind:event="oninput" />
                            </div>
                        </div>
                    }
                    else if (_batchEditMode == "prepend")
                    {
                        <label class="modal-input-label">앞에 추가할 텍스트</label>
                        <input class="modal-input" type="text" placeholder="기존 값 앞에 붙일 텍스트..."
                               @bind="_batchNewValue" @bind:event="oninput" />
                    }
                    else if (_batchEditMode == "append")
                    {
                        <label class="modal-input-label">뒤에 추가할 텍스트</label>
                        <input class="modal-input" type="text" placeholder="기존 값 뒤에 붙일 텍스트..."
                               @bind="_batchNewValue" @bind:event="oninput" />
                    }
                    else
                    {
                        <label class="modal-input-label">새 값</label>
                        <input class="modal-input" type="text" placeholder="변경할 값 입력..."
                               @bind="_batchNewValue" @bind:event="oninput" />
                    }
                </div>
            </div>
            <div class="modal-actions">
                <button class="btn btn-primary btn-sm" @onclick="OnBatchApply"
                        disabled="@(applyTargets.Count == 0 || !CanApply())">
                    적용 (@(applyTargets.Count)건)
                </button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="CloseBatchEdit">취소</button>
            </div>
        </div>
    </div>
}

@if (_showErrorDefEditor)
{
    <div class="modal-overlay">
        <div class="modal-dialog" style="width:420px">
            <div class="modal-title">@(_editingErrorDefIndex >= 0 ? "에러 정의 수정" : "에러 정의 추가")</div>
            <div class="modal-body">
                <div class="form-field">
                    <label class="form-label">에러 이름</label>
                    <input class="form-input" type="text" @bind="_errorDefName" placeholder="Motor_Overload" />
                </div>
                <div class="form-field">
                    <label class="form-label">태그 주소</label>
                    <input class="form-input" type="text" @bind="_errorDefTag" placeholder="M901" />
                </div>
                <div class="form-field">
                    <label class="form-label">값 타입</label>
                    <select class="form-input" @bind="_errorDefValueType">
                        @foreach (var vt in ErrorValueTypes)
                        {
                            <option value="@vt">@vt</option>
                        }
                    </select>
                </div>
            </div>
            <div class="modal-actions">
                <button class="btn btn-primary btn-sm" @onclick="OnSaveErrorDef">저장</button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="() => _showErrorDefEditor = false">취소</button>
            </div>
        </div>
    </div>
}

@if (_showCsvReplaceConfirm)
{
    <div class="modal-overlay">
        <div class="modal-dialog" style="width:400px">
            <div class="modal-title">CSV 교체 확인</div>
            <div class="modal-body">
                <p class="dialog-danger">기존에 추가한 에러 정의를 모두 삭제하고 CSV 파일의 내용으로 덮어씁니다.</p>
                <p class="dialog-subtext">현재 @(_csvReplaceTargetNode?.Children.Count ?? 0)건의 정의가 삭제됩니다. 계속하시겠습니까?</p>
            </div>
            <div class="modal-actions">
                <label class="btn btn-warning btn-sm btn-file" style="margin:0;cursor:pointer">
                    CSV 선택 후 교체
                    <InputFile OnChange="OnCsvReplaceFileSelected" accept=".csv" style="display:none" />
                </label>
                <button class="btn btn-outline-secondary btn-sm" @onclick="() => _showCsvReplaceConfirm = false">취소</button>
            </div>
        </div>
    </div>
}

@code {
    // RenderTreeNode은 마크업 내에서 __builder를 사용하므로 .razor에 있어야 함
    private RenderFragment RenderTreeNode(AasTreeNode node, int depth) => __builder =>
    {
        var isSelected = _selectedNode == node;
        var hasChildren = node.Children.Count > 0;
        var css = IconClass(node);

        <div class="tree-item @(isSelected ? "selected" : "")"
             style="padding-left: @(12 + depth * 16)px"
             @onclick="() => SelectNode(node)"
             @onclick:stopPropagation="true"
             @ondblclick="() => OnNodeDblClick(node)"
             @ondblclick:stopPropagation="true">

            @if (hasChildren)
            {
                <span class="tree-toggle @(node.IsExpanded ? "expanded" : "")"
                      @onclick="() => ToggleNode(node)"
                      @onclick:stopPropagation="true">
                </span>
            }
            else
            {
                <span class="tree-toggle-placeholder"></span>
            }

            <span class="node-icon icon-@css">@node.Icon</span>
            <span class="tree-label">@node.Label</span>

            @if (node.NodeType is "Property" or "MLP" or "Range")
            {
                var val = node.Properties.GetValueOrDefault("value");
                if (val is not null)
                {
                    <span class="tree-value">= @TruncateValue(val, 20)</span>
                }
            }
        </div>

        @if (hasChildren && node.IsExpanded)
        {
            @foreach (var child in node.Children)
            {
                @RenderTreeNode(child, depth + 1)
            }
        }
    };
}
