            onload="window.__MONACO_VS='_content/AasxEditor.Core/lib/monaco-editor/min/vs';"
            onerror="this.remove(); var s=document.createElement('script'); s.src='https://cdn.jsdelivr.net/npm/monaco-editor@0.45.0/min/vs/loader.js'; s.onload=function(){ window.__MONACO_VS='https://cdn.jsdelivr.net/npm/monaco-editor@0.45.0/min/vs'; }; document.head.appendChild(s);"></script>
    <script src="_content/AasxEditor.Core/js/monaco-interop.js"></script>
