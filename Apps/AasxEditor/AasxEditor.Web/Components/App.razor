<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="_content/AasxEditor.Core/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="_content/AasxEditor.Core/app.css" />
    <link rel="stylesheet" href="AasxEditor.Core.styles.css" />
    <link rel="icon" type="image/png" href="_content/AasxEditor.Core/favicon.png" />
