<?xml version="1.0" encoding="utf-8"?>
<!--
  Self-contained publish profile for AasxEditor.Desktop (win-x64).
  Produces a folder containing all .NET runtime dependencies so no
  separate runtime install is needed on the target machine.

  Invoke via:
    dotnet publish AasxEditor.Desktop\AasxEditor.Desktop.csproj ^
        -c Release -p:PublishProfile=win-x64

  Output: AasxEditor.Desktop\bin\Release\net9.0-windows\win-x64\publish\
-->
<Project>
  <PropertyGroup>
    <PublishDir>bin\Release\net9.0-windows\win-x64\publish\</PublishDir>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
  </PropertyGroup>
</Project>
